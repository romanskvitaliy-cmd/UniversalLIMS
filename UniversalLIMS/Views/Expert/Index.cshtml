@model ExpertIndexViewModel
@using UniversalLIMS.Application.Expert
@using UniversalLIMS.Domain.Laboratory

@{
    Layout = "_LayoutWorkspace";
    ViewData["Title"] = "Черга експерта";
}

<div class="d-flex justify-content-between align-items-start gap-3 mb-3">
    <div>
        <h1 class="h3 mb-1">Черга експерта</h1>
        <p class="text-muted mb-0">
            Проби, у яких усі відправлені в лабораторію документи мають статус «Результати внесено».
            Висновок оформлюється в PDF Workspace (поля Conclusion), без окремої таблиці «Показники».
        </p>
    </div>
    <partial name="_WorkspaceCabinetLink" />
</div>

@if (TempData["ExpertSuccess"] is string success)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @success
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Закрити"></button>
    </div>
}

@if (TempData["ExpertWarning"] is string warning)
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        @warning
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Закрити"></button>
    </div>
}

<form method="get" asp-action="Index" class="card mb-3">
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label small text-muted" for="sampleNumber">Номер проби</label>
                <input type="text" class="form-control form-control-sm" id="sampleNumber" name="sampleNumber"
                       value="@Model.Filter.SampleNumber" />
            </div>
            <div class="col-md-3">
                <label class="form-label small text-muted" for="notesContainsUk">Пошук у примітках</label>
                <input type="text" class="form-control form-control-sm" id="notesContainsUk" name="notesContainsUk"
                       value="@Model.Filter.NotesContainsUk" placeholder="Фрагмент тексту примітки" />
            </div>
            <div class="col-md-2">
                <label class="form-label small text-muted" for="dateFrom">Дата від</label>
                <input type="date" class="form-control form-control-sm" id="dateFrom" name="dateFrom"
                       value="@(Model.Filter.DateFrom?.ToString("yyyy-MM-dd"))" />
            </div>
            <div class="col-md-2">
                <label class="form-label small text-muted" for="dateTo">Дата до</label>
                <input type="date" class="form-control form-control-sm" id="dateTo" name="dateTo"
                       value="@(Model.Filter.DateTo?.ToString("yyyy-MM-dd"))" />
            </div>
            <div class="col-md-3">
                <label class="form-label small text-muted" for="reviewStatus">Статус розгляду</label>
                <select class="form-select form-select-sm" id="reviewStatus" name="reviewStatus">
                    @foreach (var option in Model.ReviewStatusOptions)
                    {
                        if (Model.Filter.ReviewStatus == option.Value)
                        {
                            <option value="@(option.Value is null ? "" : ((int)option.Value).ToString())" selected="selected">@option.Label</option>
                        }
                        else
                        {
                            <option value="@(option.Value is null ? "" : ((int)option.Value).ToString())">@option.Label</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-12 col-lg-auto d-flex gap-2">
                <button type="submit" class="btn btn-sm btn-primary">Застосувати</button>
                <a class="btn btn-sm btn-outline-secondary" asp-action="Index">Скинути</a>
            </div>
        </div>
    </div>
</form>

@if (!Model.Result.Items.Any())
{
    <div class="alert alert-info mb-0">Проб за обраними критеріями не знайдено.</div>
}
else
{
    var isFlatView = string.Equals(Context.Request.Query["view"], "flat", StringComparison.OrdinalIgnoreCase);
    var groupedSamples = Model.Result.Items
        .GroupBy(sample => new
        {
            sample.OrderId,
            sample.CustomerFullName,
            sample.ReferralNumber
        })
        .Select(group => new
        {
            OrderId = group.Key.OrderId,
            CustomerFullName = group.Key.CustomerFullName,
            ReferralNumber = group.Key.ReferralNumber,
            Samples = group
                .OrderByDescending(sample => sample.RegisteredAt)
                .ToList()
        })
        .OrderByDescending(group => group.Samples.Max(sample => sample.RegisteredAt))
        .ToList();

    var viewQuery = new Dictionary<string, string?>();
    if (!string.IsNullOrWhiteSpace(Model.Filter.SampleNumber))
    {
        viewQuery["sampleNumber"] = Model.Filter.SampleNumber;
    }

    if (!string.IsNullOrWhiteSpace(Model.Filter.NotesContainsUk))
    {
        viewQuery["notesContainsUk"] = Model.Filter.NotesContainsUk;
    }

    if (Model.Filter.DateFrom.HasValue)
    {
        viewQuery["dateFrom"] = Model.Filter.DateFrom.Value.ToString("yyyy-MM-dd");
    }

    if (Model.Filter.DateTo.HasValue)
    {
        viewQuery["dateTo"] = Model.Filter.DateTo.Value.ToString("yyyy-MM-dd");
    }

    if (Model.Filter.ReviewStatus.HasValue)
    {
        viewQuery["reviewStatus"] = ((int)Model.Filter.ReviewStatus.Value).ToString();
    }

    viewQuery["page"] = Model.Result.Page.ToString();
    viewQuery["pageSize"] = Model.Result.PageSize.ToString();

    <div class="d-flex justify-content-between align-items-end gap-2 flex-wrap mb-2">
        @if (!isFlatView)
        {
            <div>
                <label class="form-label small text-muted mb-1" for="expertGroupSearchInput">Пошук по замовнику або номеру справи</label>
                <input id="expertGroupSearchInput"
                       type="text"
                       class="form-control form-control-sm"
                       placeholder="ПІБ або номер справи (REF-…)" />
            </div>
        }
        @if (isFlatView)
        {
            viewQuery["view"] = "grouped";
            <a class="btn btn-sm btn-outline-primary"
               asp-action="Index"
               asp-all-route-data="viewQuery">Групований вигляд</a>
        }
        else
        {
            viewQuery["view"] = "flat";
            <a class="btn btn-sm btn-outline-secondary"
               asp-action="Index"
               asp-all-route-data="viewQuery">Плоский список</a>
        }
    </div>

    <div class="table-responsive">
        <table class="table table-sm table-hover align-middle lims-workspace-table">
            <thead>
                <tr>
                    <th>Номер проби</th>
                    @if (isFlatView)
                    {
                        <th>Номер справи</th>
                        <th>Замовник</th>
                    }
                    <th>Тип дослідження</th>
                    <th>Лабораторія</th>
                    <th>Док.</th>
                    <th>Дата реєстрації</th>
                    <th>Розгляд</th>
                    <th>Примітка експерта</th>
                    <th></th>
                </tr>
            </thead>
            @if (isFlatView)
            {
                <tbody>
                    @foreach (var sample in Model.Result.Items)
                    {
                        var reviewStatus = sample.ReviewStatus ?? ExpertConclusionStatus.PendingReview;
                        <tr>
                            <td class="fw-semibold">@sample.SampleNumber</td>
                            <td>@(string.IsNullOrWhiteSpace(sample.ReferralNumber) ? "—" : sample.ReferralNumber)</td>
                            <td>@sample.CustomerFullName</td>
                            <td>@sample.InvestigationTypeName</td>
                            <td>@sample.TargetBranchName</td>
                            <td class="text-center">@sample.DocumentCount</td>
                            <td class="text-nowrap">@sample.RegisteredAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                            <td>
                                <span class="badge lims-status-badge @ExpertConclusionStatusDisplay.BadgeClass(reviewStatus)">
                                    @ExpertConclusionStatusDisplay.ToUk(reviewStatus)
                                </span>
                                @if (sample.ReviewStartedAtUtc.HasValue && reviewStatus == ExpertConclusionStatus.InProgress)
                                {
                                    <div class="small text-muted mt-1">
                                        з @sample.ReviewStartedAtUtc.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                                    </div>
                                }
                                @if (sample.ApprovedAtUtc.HasValue)
                                {
                                    <div class="small text-muted mt-1">
                                        @sample.ApprovedAtUtc.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                                    </div>
                                }
                            </td>
                            <td style="max-width: 320px;">
                                @if (string.IsNullOrWhiteSpace(sample.NotesUk))
                                {
                                    <span class="text-muted">—</span>
                                }
                                else
                                {
                                    var normalizedNotes = sample.NotesUk.Trim();
                                    var canExpandNotes = normalizedNotes.Length > 120;
                                    var notesPreview = canExpandNotes ? $"{normalizedNotes[..120]}..." : normalizedNotes;
                                    var notesCollapseId = $"notes-{sample.SampleId:N}";
                                    <div title="@normalizedNotes">
                                        <div class="small text-muted mb-1">Є примітка</div>
                                        <span>@notesPreview</span>
                                    </div>
                                    @if (canExpandNotes)
                                    {
                                        <button class="btn btn-link btn-sm p-0 mt-1"
                                                type="button"
                                                data-bs-toggle="collapse"
                                                data-bs-target="#@notesCollapseId"
                                                aria-expanded="false"
                                                aria-controls="@notesCollapseId">
                                            Розгорнути
                                        </button>
                                        <div class="collapse mt-1" id="@notesCollapseId">
                                            <div class="small text-break">@normalizedNotes</div>
                                        </div>
                                    }
                                }
                            </td>
                            <td class="text-end text-nowrap">
                                <partial name="_ExpertSampleActions" model="sample" />
                            </td>
                        </tr>
                    }
                </tbody>
            }
            else
            {
                @foreach (var group in groupedSamples)
                {
                    var collapseId = $"expert-order-group-{group.OrderId:N}";
                    <tbody class="expert-group-header-row"
                           data-group-id="@group.OrderId"
                           data-group-search="@(string.Concat(group.CustomerFullName, " ", group.ReferralNumber).ToLowerInvariant())">
                        <tr class="table-light">
                            <td colspan="8">
                                <div class="d-flex justify-content-between align-items-center gap-2 flex-wrap">
                                    <div>
                                        <span class="fw-semibold">@group.CustomerFullName</span>
                                        <span class="text-muted ms-2">
                                            Справа: @(string.IsNullOrWhiteSpace(group.ReferralNumber) ? "—" : group.ReferralNumber)
                                        </span>
                                        <span class="badge text-bg-secondary ms-2">Проб: @group.Samples.Count</span>
                                    </div>
                                    <button type="button"
                                            class="btn btn-sm btn-outline-primary"
                                            data-bs-toggle="collapse"
                                            data-bs-target="#@collapseId"
                                            aria-expanded="false"
                                            aria-controls="@collapseId">
                                        Показати/сховати
                                    </button>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                    <tbody id="@collapseId" class="collapse expert-group-detail-row" data-group-id="@group.OrderId">
                        @foreach (var sample in group.Samples)
                        {
                            var reviewStatus = sample.ReviewStatus ?? ExpertConclusionStatus.PendingReview;
                            <tr>
                                <td class="fw-semibold">@sample.SampleNumber</td>
                                <td>@sample.InvestigationTypeName</td>
                                <td>@sample.TargetBranchName</td>
                                <td class="text-center">@sample.DocumentCount</td>
                                <td class="text-nowrap">@sample.RegisteredAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                                <td>
                                    <span class="badge lims-status-badge @ExpertConclusionStatusDisplay.BadgeClass(reviewStatus)">
                                        @ExpertConclusionStatusDisplay.ToUk(reviewStatus)
                                    </span>
                                </td>
                                <td style="max-width: 320px;">
                                    @if (string.IsNullOrWhiteSpace(sample.NotesUk))
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                    else
                                    {
                                        var normalizedNotes = sample.NotesUk.Trim();
                                        var canExpandNotes = normalizedNotes.Length > 120;
                                        var notesPreview = canExpandNotes ? $"{normalizedNotes[..120]}..." : normalizedNotes;
                                        var notesCollapseId = $"notes-{sample.SampleId:N}";
                                        <div title="@normalizedNotes">
                                            <div class="small text-muted mb-1">Є примітка</div>
                                            <span>@notesPreview</span>
                                        </div>
                                        @if (canExpandNotes)
                                        {
                                            <button class="btn btn-link btn-sm p-0 mt-1"
                                                    type="button"
                                                    data-bs-toggle="collapse"
                                                    data-bs-target="#@notesCollapseId"
                                                    aria-expanded="false"
                                                    aria-controls="@notesCollapseId">
                                                Розгорнути
                                            </button>
                                            <div class="collapse mt-1" id="@notesCollapseId">
                                                <div class="small text-break">@normalizedNotes</div>
                                            </div>
                                        }
                                    }
                                </td>
                                <td class="text-end text-nowrap">
                                    <partial name="_ExpertSampleActions" model="sample" />
                                </td>
                            </tr>
                        }
                    </tbody>
                }
            }
        </table>
    </div>

    @if (Model.Result.TotalPages > 1)
    {
        <nav aria-label="Сторінки черги" class="mt-3">
            <ul class="pagination pagination-sm mb-0">
                @{
                    var currentPage = Model.Result.Page;
                    var query = new Dictionary<string, string?>();
                    if (!string.IsNullOrWhiteSpace(Model.Filter.SampleNumber))
                    {
                        query["sampleNumber"] = Model.Filter.SampleNumber;
                    }

                    if (!string.IsNullOrWhiteSpace(Model.Filter.NotesContainsUk))
                    {
                        query["notesContainsUk"] = Model.Filter.NotesContainsUk;
                    }

                    if (Model.Filter.DateFrom.HasValue)
                    {
                        query["dateFrom"] = Model.Filter.DateFrom.Value.ToString("yyyy-MM-dd");
                    }

                    if (Model.Filter.DateTo.HasValue)
                    {
                        query["dateTo"] = Model.Filter.DateTo.Value.ToString("yyyy-MM-dd");
                    }

                    if (Model.Filter.ReviewStatus.HasValue)
                    {
                        query["reviewStatus"] = ((int)Model.Filter.ReviewStatus.Value).ToString();
                    }

                    query["view"] = isFlatView ? "flat" : "grouped";
                }
                @for (var pageNumber = 1; pageNumber <= Model.Result.TotalPages; pageNumber++)
                {
                    query["page"] = pageNumber.ToString();
                    query["pageSize"] = Model.Result.PageSize.ToString();
                    var isActive = pageNumber == currentPage;
                    <li class="page-item @(isActive ? "active" : null)">
                        <a class="page-link"
                           asp-action="Index"
                           asp-all-route-data="query">@pageNumber</a>
                    </li>
                }
            </ul>
        </nav>
    }

    <p class="text-muted small mt-2 mb-0">
        Показано @Model.Result.Items.Count з @Model.Result.TotalCount
        (сторінка @Model.Result.Page з @(Model.Result.TotalPages == 0 ? 1 : Model.Result.TotalPages)).
    </p>
}

<div class="modal fade" id="expertReworkModal" tabindex="-1" aria-labelledby="expertReworkModalTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="ReturnForRework" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h2 class="modal-title fs-6" id="expertReworkModalTitle">Повернення в лабораторію</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Закрити"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="expertReworkSampleId" name="sampleId" value="" />
                    <p class="mb-2">Проба: <strong id="expertReworkSampleNumber">—</strong></p>
                    <label class="form-label small text-muted" for="expertReworkReasonUk">Причина доопрацювання</label>
                    <textarea id="expertReworkReasonUk"
                              name="reworkReasonUk"
                              class="form-control"
                              rows="4"
                              maxlength="2000"
                              required
                              placeholder="Що потрібно виправити лаборанту..."></textarea>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Скасувати</button>
                    <button type="submit" class="btn btn-danger">Повернути в лабораторію</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="expertApproveModal" tabindex="-1" aria-labelledby="expertApproveModalTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="Approve" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h2 class="modal-title fs-6" id="expertApproveModalTitle">Затвердити висновок</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Закрити"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="expertApproveSampleId" name="sampleId" value="" />
                    <p class="mb-2">
                        Проба: <strong id="expertApproveSampleNumber">—</strong>
                    </p>
                    <label class="form-label small text-muted" for="expertApproveNotesUk">Примітка експерта (необов'язково)</label>
                    <textarea id="expertApproveNotesUk"
                              name="notesUk"
                              class="form-control"
                              rows="4"
                              maxlength="2000"
                              placeholder="Наприклад: уточнити формулювання висновку, перевірити показник..."></textarea>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Скасувати</button>
                    <button type="submit" class="btn btn-success">Підтвердити затвердження</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts
{
    <script>
        (() => {
            const sampleIdInput = document.getElementById("expertApproveSampleId");
            const sampleNumberEl = document.getElementById("expertApproveSampleNumber");
            const notesEl = document.getElementById("expertApproveNotesUk");
            document.querySelectorAll(".expert-approve-open").forEach((button) => {
                button.addEventListener("click", () => {
                    const sampleId = button.getAttribute("data-sample-id") || "";
                    const sampleNumber = button.getAttribute("data-sample-number") || "—";
                    if (sampleIdInput) {
                        sampleIdInput.value = sampleId;
                    }
                    if (sampleNumberEl) {
                        sampleNumberEl.textContent = sampleNumber;
                    }
                    if (notesEl) {
                        notesEl.value = "";
                    }
                });
            });

            const reworkSampleIdInput = document.getElementById("expertReworkSampleId");
            const reworkSampleNumberEl = document.getElementById("expertReworkSampleNumber");
            const reworkReasonEl = document.getElementById("expertReworkReasonUk");
            document.querySelectorAll(".expert-rework-open").forEach((button) => {
                button.addEventListener("click", () => {
                    const sampleId = button.getAttribute("data-sample-id") || "";
                    const sampleNumber = button.getAttribute("data-sample-number") || "—";
                    if (reworkSampleIdInput) {
                        reworkSampleIdInput.value = sampleId;
                    }
                    if (reworkSampleNumberEl) {
                        reworkSampleNumberEl.textContent = sampleNumber;
                    }
                    if (reworkReasonEl) {
                        reworkReasonEl.value = "";
                    }
                });
            });

            const storageKey = "expert-journal-expanded-groups-v1";
            const headerRows = Array.from(document.querySelectorAll(".expert-group-header-row"));
            const detailRows = Array.from(document.querySelectorAll(".expert-group-detail-row"));

            if (!headerRows.length || !detailRows.length) {
                return;
            }

            let expandedGroupIds = [];
            try {
                const savedValue = localStorage.getItem(storageKey);
                expandedGroupIds = savedValue ? JSON.parse(savedValue) : [];
                if (!Array.isArray(expandedGroupIds)) {
                    expandedGroupIds = [];
                }
            } catch {
                expandedGroupIds = [];
            }

            const setExpandedState = (groupId, expanded) => {
                const detailRow = document.querySelector(`.expert-group-detail-row[data-group-id="${groupId}"]`);
                const button = document.querySelector(`.expert-group-header-row[data-group-id="${groupId}"] [data-bs-target]`);
                if (!detailRow || !button) {
                    return;
                }

                if (expanded) {
                    detailRow.classList.add("show");
                    button.setAttribute("aria-expanded", "true");
                } else {
                    detailRow.classList.remove("show");
                    button.setAttribute("aria-expanded", "false");
                }
            };

            headerRows.forEach((headerRow) => {
                const groupId = headerRow.getAttribute("data-group-id");
                if (!groupId) {
                    return;
                }

                const isExpanded = expandedGroupIds.includes(groupId);
                setExpandedState(groupId, isExpanded);
            });

            detailRows.forEach((detailRow) => {
                detailRow.addEventListener("shown.bs.collapse", () => {
                    const groupId = detailRow.getAttribute("data-group-id");
                    if (!groupId || expandedGroupIds.includes(groupId)) {
                        return;
                    }

                    expandedGroupIds.push(groupId);
                    localStorage.setItem(storageKey, JSON.stringify(expandedGroupIds));
                });

                detailRow.addEventListener("hidden.bs.collapse", () => {
                    const groupId = detailRow.getAttribute("data-group-id");
                    if (!groupId) {
                        return;
                    }

                    expandedGroupIds = expandedGroupIds.filter((id) => id !== groupId);
                    localStorage.setItem(storageKey, JSON.stringify(expandedGroupIds));
                });
            });

            const searchInput = document.getElementById("expertGroupSearchInput");
            if (!searchInput) {
                return;
            }

            searchInput.addEventListener("input", () => {
                const normalizedQuery = searchInput.value.trim().toLowerCase();
                headerRows.forEach((headerRow) => {
                    const searchValue = headerRow.getAttribute("data-group-search") ?? "";
                    const groupId = headerRow.getAttribute("data-group-id");
                    const detailRow = groupId
                        ? document.querySelector(`.expert-group-detail-row[data-group-id="${groupId}"]`)
                        : null;

                    const matches = normalizedQuery.length === 0 || searchValue.includes(normalizedQuery);
                    headerRow.style.display = matches ? "" : "none";
                    if (detailRow) {
                        detailRow.style.display = matches ? "" : "none";
                    }
                });
            });
        })();
    </script>
}
