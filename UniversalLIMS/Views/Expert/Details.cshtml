@model ExpertSampleDetailsViewModel
@using UniversalLIMS.Application.Expert
@using UniversalLIMS.Application.Registration
@using UniversalLIMS.Domain.Laboratory

@{
    Layout = "_LayoutWorkspace";
    ViewData["Title"] = $"Деталі проби {Model.SampleNumber}";
    var reviewStatus = Model.ReviewStatus ?? ExpertConclusionStatus.PendingReview;
}

<div class="d-flex justify-content-between align-items-start gap-3 mb-3">
    <div>
        <h1 class="h3 mb-1">Деталі проби</h1>
        <p class="text-muted mb-0">
            Проба <strong>@Model.SampleNumber</strong> · @Model.InvestigationTypeName
        </p>
    </div>
    <div class="d-flex flex-wrap gap-2 align-items-start">
        <partial name="_WorkspaceCabinetLink" />
        <a class="btn btn-outline-secondary btn-sm" asp-action="Index">← Черга експерта</a>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-lg-7">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h6 text-muted mb-3">Загальна інформація</h2>
                <dl class="row mb-0">
                    <dt class="col-sm-4">Замовник</dt>
                    <dd class="col-sm-8">@Model.CustomerFullName</dd>

                    <dt class="col-sm-4">Направлення</dt>
                    <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.ReferralNumber) ? "—" : Model.ReferralNumber)</dd>

                    <dt class="col-sm-4">Дата реєстрації</dt>
                    <dd class="col-sm-8">@Model.RegisteredAtUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h6 text-muted mb-3">Розгляд експертом</h2>
                <p class="mb-2">
                    <span class="badge lims-status-badge @ExpertConclusionStatusDisplay.BadgeClass(reviewStatus)">
                        @ExpertConclusionStatusDisplay.ToUk(reviewStatus)
                    </span>
                </p>
                @if (Model.ReviewStartedAtUtc.HasValue)
                {
                    <p class="small text-muted mb-1">
                        Початок розгляду: @Model.ReviewStartedAtUtc.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                    </p>
                }
                @if (Model.ApprovedAtUtc.HasValue)
                {
                    <p class="small text-muted mb-1">
                        Затверджено: @Model.ApprovedAtUtc.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                    </p>
                }
                <div class="mt-3">
                    <div class="small text-muted mb-1">Примітка експерта</div>
                    @if (string.IsNullOrWhiteSpace(Model.NotesUk))
                    {
                        <div class="text-muted">—</div>
                    }
                    else
                    {
                        <div class="text-break">@Model.NotesUk</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <h2 class="h6 text-muted mb-3">Документи проби</h2>
        @if (Model.Documents.Count == 0)
        {
            <div class="alert alert-info mb-0">Документів для цієї проби не знайдено.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Документ</th>
                            <th>Лабораторія</th>
                            <th>Статус</th>
                            <th>Відправлено</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var document in Model.Documents)
                    {
                        <tr>
                            <td>
                                <div class="fw-semibold">@document.TemplateName</div>
                                <div class="small text-muted">v@document.VersionNumber</div>
                            </td>
                            <td>@document.TargetBranchName</td>
                            <td>
                                <span class="badge lims-status-badge @OrderDocumentStatusDisplay.BadgeClass(document.Status)">
                                    @OrderDocumentStatusDisplay.ToUk(document.Status)
                                </span>
                            </td>
                            <td>@(document.SentToLabAtUtc.HasValue ? document.SentToLabAtUtc.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm") : "—")</td>
                            <td class="text-end text-nowrap">
                                <a class="btn btn-sm btn-outline-success"
                                   asp-controller="PdfWorkspace"
                                   asp-action="FinalPdf"
                                   asp-route-templateVersionId="@document.TemplateVersionId"
                                   asp-route-orderId="@Model.OrderId"
                                   asp-route-orderDocumentId="@document.OrderDocumentId"
                                   target="_blank"
                                   rel="noopener"
                                   title="Переглянути фінальний PDF">
                                    Фінал
                                </a>
                                <a class="btn btn-sm btn-outline-secondary"
                                   asp-controller="PdfWorkspace"
                                   asp-action="FinalPdf"
                                   asp-route-templateVersionId="@document.TemplateVersionId"
                                   asp-route-orderId="@Model.OrderId"
                                   asp-route-orderDocumentId="@document.OrderDocumentId"
                                   asp-route-download="true"
                                   title="Завантажити PDF">
                                    ↓ PDF
                                </a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
