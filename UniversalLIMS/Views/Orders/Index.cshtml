@model IReadOnlyList<OrderListItemViewModel>
@{
    ViewData["Title"] = "Замовлення";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Замовлення</h1>
    <a class="btn btn-primary" asp-action="Register">Реєстрація проби</a>
</div>

@if (Model.Count == 0)
{
    <div class="alert alert-secondary">Замовлень ще немає.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Направлення</th>
                    <th>Замовник</th>
                    <th>Філія</th>
                    <th>Статус</th>
                    <th>Дата</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var order in Model)
            {
                <tr>
                    <td>@(order.ReferralNumber ?? "—")</td>
                    <td>@order.CustomerFullName</td>
                    <td>@order.RegistrationBranchName</td>
                    <td>@order.Status</td>
                    <td>@(order.RegisteredAtUtc?.ToLocalTime().ToString("dd.MM.yyyy HH:mm") ?? "—")</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@order.OrderId">Деталі</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
