@model OrderCreateViewModel
@using System.Text.Json

@{
    Layout = "_LayoutWorkspace";
    ViewData["Title"] = "Прийом справи";
    var orderCreateJsonOptions = new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase };
    var templateOptionsJson = JsonSerializer.Serialize(Model.Form.TemplateOptions, orderCreateJsonOptions);
    var investigationTypesJson = JsonSerializer.Serialize(Model.Form.InvestigationTypes, orderCreateJsonOptions);
    var branchesJson = JsonSerializer.Serialize(Model.Form.Branches, orderCreateJsonOptions);
    var initialSamplesJson = JsonSerializer.Serialize(Model.Input.Samples, orderCreateJsonOptions);
    var defaultBranchId = Model.Form.DefaultBranchId?.ToString("D") ?? "";
}

<div class="order-create-page">
<div class="order-create-page__head d-flex justify-content-between align-items-center gap-2 mb-2">
    <div class="min-w-0">
        <h1 class="h5 mb-0">Прийом справи</h1>
        <p class="small text-muted mb-0 d-none d-md-block">Замовник, проби, бланки PDF. Номер справи REF — автоматично.</p>
    </div>
    <div class="d-flex flex-wrap gap-1 align-items-center flex-shrink-0">
        <partial name="_WorkspaceCabinetLink" />
        <a class="btn btn-sm btn-outline-secondary py-0 px-2" asp-action="Index">← До реєстру</a>
    </div>
</div>

<ol class="order-create-steps list-unstyled d-flex flex-wrap align-items-center gap-1 gap-md-0 mb-2" aria-label="Кроки прийому справи">
    <li class="order-create-steps__item">
        <span class="order-create-steps__n" aria-hidden="true">1</span>
        <span class="order-create-steps__label"><strong>Замовник</strong> <span class="text-muted">· існуючий/новий</span></span>
    </li>
    <li class="order-create-steps__sep" aria-hidden="true">›</li>
    <li class="order-create-steps__item">
        <span class="order-create-steps__n" aria-hidden="true">2</span>
        <span class="order-create-steps__label"><strong>Проби та бланки</strong> <span class="text-muted">· PDF, філія</span></span>
    </li>
    <li class="order-create-steps__sep" aria-hidden="true">›</li>
    <li class="order-create-steps__item">
        <span class="order-create-steps__n" aria-hidden="true">3</span>
        <span class="order-create-steps__label"><strong>Мапінг</strong> <span class="text-muted">· якщо кілька бланків</span></span>
    </li>
    <li class="order-create-steps__sep" aria-hidden="true">›</li>
    <li class="order-create-steps__item">
        <span class="order-create-steps__n" aria-hidden="true">4</span>
        <span class="order-create-steps__label"><strong>Заповнення</strong> <span class="text-muted">· PDF, лабораторія</span></span>
    </li>
</ol>

<form asp-action="Create" method="post" class="card order-create-page__form" id="orderCreateForm" data-lims-soft-validate>
    <div class="card-body py-3">
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

        <h2 class="h6 text-muted text-uppercase mb-2">Замовник</h2>
        <div class="btn-group btn-group-sm mb-2" role="group" aria-label="Режим замовника">
            <input type="radio" class="btn-check" asp-for="Input.CustomerMode" id="customerModeExisting" value="existing" />
            <label class="btn btn-outline-primary" for="customerModeExisting">Існуючий</label>
            <input type="radio" class="btn-check" asp-for="Input.CustomerMode" id="customerModeNew" value="new" />
            <label class="btn btn-outline-primary" for="customerModeNew">Новий</label>
        </div>

        <div id="existingCustomerPanel" class="mb-3">
            <label class="form-label small text-muted" for="customerSearch">Пошук (ПІБ, телефон, ЄДРПОУ)</label>
            <input type="search" class="form-control form-control-sm" id="customerSearch"
                   value="@Model.Input.CustomerSearchQuery" autocomplete="off" />
            <input type="hidden" asp-for="Input.SelectedCustomerId" id="selectedCustomerId" />
            <input type="hidden" asp-for="Input.SelectedCustomerLabel" id="selectedCustomerLabel" />
            <div id="customerSearchResults" class="list-group list-group-flush mt-1 d-none"></div>
            <p id="selectedCustomerSummary" class="small text-success mt-2 mb-0"></p>
        </div>

        <div id="newCustomerPanel" class="mb-3 d-none">
            <div class="row g-2">
                <div class="col-md-4">
                    <label class="form-label small text-muted" asp-for="Input.NewCustomerKind">Тип</label>
                    <select asp-for="Input.NewCustomerKind" class="form-select form-select-sm"
                            asp-items="@(new SelectList(
                                Enum.GetValues<CustomerKind>().Select(kind => new { Value = (int)kind, Text = CustomerKindDisplay.ToUk(kind) }),
                                "Value",
                                "Text"))"></select>
                </div>
                <div class="col-md-8">
                    <label class="form-label small text-muted" asp-for="Input.NewCustomerFullName"></label>
                    <input asp-for="Input.NewCustomerFullName" class="form-control form-control-sm" />
                    <span asp-validation-for="Input.NewCustomerFullName" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label small text-muted" asp-for="Input.NewCustomerOrganizationName"></label>
                    <input asp-for="Input.NewCustomerOrganizationName" class="form-control form-control-sm" />
                </div>
                <div class="col-md-6">
                    <label class="form-label small text-muted" asp-for="Input.NewCustomerContactPhone"></label>
                    <input asp-for="Input.NewCustomerContactPhone"
                           class="form-control form-control-sm"
                           data-lims-soft-format="phone"
                           maxlength="50"
                           autocomplete="tel" />
                </div>
                <div class="col-md-6">
                    <label class="form-label small text-muted" asp-for="Input.NewCustomerAddress"></label>
                    <input asp-for="Input.NewCustomerAddress" class="form-control form-control-sm" />
                </div>
                <div class="col-md-6">
                    <label class="form-label small text-muted" asp-for="Input.NewCustomerEdrpou"></label>
                    <input asp-for="Input.NewCustomerEdrpou"
                           class="form-control form-control-sm"
                           data-lims-soft-format="edrpou"
                           maxlength="10"
                           inputmode="numeric"
                           autocomplete="off" />
                </div>
            </div>
        </div>

        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-2">
            <div>
                <h2 class="h6 text-muted text-uppercase mb-1">Проби та бланки</h2>
                <p class="small text-muted mb-0">
                    Один рядок — <strong>одна проба</strong> і <strong>бланк PDF</strong> для неї (на папері це часто «протокол» Ф327, 205…).
                    Номер справи REF — на всю справу. Бланк направлення REF-* — окремо, не в цьому списку.
                </p>
            </div>
            <button type="button" class="btn btn-sm btn-outline-primary" id="btnAddOrderSample">
                + Додати пробу
            </button>
        </div>

        <div id="orderSamplesPanel" class="border rounded-3 p-2 mb-2 bg-light">
            <div class="row g-2 px-1 pb-2 small text-muted fw-semibold d-none d-md-flex">
                <div class="col-md-6">Бланк для проби</div>
                <div class="col-md-5">Лабораторія-виконавець</div>
                <div class="col-md-1 text-end">Дія</div>
            </div>
            <div id="orderSamplesList"></div>
            <p class="small text-muted mb-0 d-none" id="orderSamplesPlaceholder">
                Немає рядків. Натисніть «Додати пробу».
            </p>
        </div>
        <div class="form-check mb-2">
            <input asp-for="Input.OpenPdfAfterCreate" class="form-check-input" />
            <label class="form-check-label small" asp-for="Input.OpenPdfAfterCreate">
                Відкрити PDF Workspace після створення (якщо одна проба з одним бланком)
            </label>
        </div>

        <div class="d-flex flex-wrap gap-2">
            <button type="submit" class="btn btn-primary" id="btnCreateOrder">Створити справу</button>
            <button type="submit"
                    class="btn btn-outline-primary d-none"
                    id="btnPrepareFieldMapping"
                    formaction="@Url.Action("PrepareFieldMapping")">
                Далі: мапінг спільних полів
            </button>
        </div>
        <p class="small text-muted mt-2 mb-0 d-none" id="fieldMappingHint">
            Кілька проб або бланків — об’єднайте спільні поля (ПІБ, дата відбору…) перед створенням справи.
        </p>
    </div>
</form>

<div class="modal fade"
     id="orderTemplatePreviewModal"
     tabindex="-1"
     aria-labelledby="orderTemplatePreviewTitle"
     aria-hidden="true"
     data-bs-focus="false"
     data-bs-keyboard="true">
    <div class="modal-dialog modal-xl order-template-preview-modal__dialog">
        <div class="modal-content order-template-preview-modal__content">
            <div class="modal-header py-2 flex-shrink-0">
                <h2 class="modal-title h6 mb-0" id="orderTemplatePreviewTitle">Оригінал PDF</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Закрити"></button>
            </div>
            <div class="modal-body p-0 order-template-preview-modal__body">
                <iframe id="orderTemplatePreviewFrame"
                        class="order-template-preview-modal__frame"
                        title="Перегляд оригінального PDF"
                        src="about:blank"></iframe>
            </div>
            <div class="modal-footer py-2 flex-shrink-0">
                <a id="orderTemplatePreviewOpenTab"
                   class="btn btn-outline-secondary btn-sm"
                   href="#"
                   target="_blank"
                   rel="noopener noreferrer">У новій вкладці</a>
                <button type="button" class="btn btn-secondary btn-sm" id="orderTemplatePreviewClose" data-bs-dismiss="modal">Закрити</button>
            </div>
        </div>
    </div>
</div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        window.__orderCreateTemplateOptions = @Html.Raw(templateOptionsJson);
        window.__orderCreateInvestigationTypes = @Html.Raw(investigationTypesJson);
        window.__orderCreateBranches = @Html.Raw(branchesJson);
        window.__orderCreateInitialSamples = @Html.Raw(initialSamplesJson);
        window.__orderCreateDefaultBranchId = @Html.Raw(JsonSerializer.Serialize(defaultBranchId));
    </script>
    <script src="~/js/customer-format-hints.js" asp-append-version="true"></script>
    <script src="~/js/order-template-field.js" asp-append-version="true"></script>
    <script src="~/js/order-create.js" asp-append-version="true"></script>
}
