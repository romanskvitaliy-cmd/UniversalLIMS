@model OrderCreateViewModel
@using System.Text.Json

@{
    Layout = "_LayoutWorkspace";
    ViewData["Title"] = "Прийом нової проби";
    var orderCreateJsonOptions = new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase };
    var templateOptionsJson = JsonSerializer.Serialize(Model.Form.TemplateOptions, orderCreateJsonOptions);
    var branchesJson = JsonSerializer.Serialize(Model.Form.Branches, orderCreateJsonOptions);
    var defaultBranchId = Model.Form.DefaultBranchId?.ToString("D") ?? "";
}

<div class="d-flex justify-content-between align-items-start gap-3 mb-3">
    <div>
        <h1 class="h3 mb-1">Прийом нової проби</h1>
        <p class="text-muted mb-0">Замовник, зразок, тип дослідження, PDF-бланки та маршрут по філіях.</p>
    </div>
    <a class="btn btn-sm btn-outline-secondary" asp-action="Index">← До реєстру</a>
</div>

<div class="row g-2 mb-3">
    <div class="col-md-3">
        <div class="border rounded-3 bg-light p-3 h-100">
            <div class="small text-muted fw-semibold text-uppercase mb-1">Крок 1</div>
            <div class="fw-semibold">Замовник</div>
            <div class="small text-muted">Існуючий або новий клієнт.</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded-3 bg-light p-3 h-100">
            <div class="small text-muted fw-semibold text-uppercase mb-1">Крок 2</div>
            <div class="fw-semibold">Проба і бланки</div>
            <div class="small text-muted">Тип дослідження, PDF-шаблони, філії.</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded-3 bg-light p-3 h-100">
            <div class="small text-muted fw-semibold text-uppercase mb-1">Крок 3</div>
            <div class="fw-semibold">Мапінг</div>
            <div class="small text-muted">Для кількох бланків об’єднайте спільні поля.</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded-3 bg-light p-3 h-100">
            <div class="small text-muted fw-semibold text-uppercase mb-1">Крок 4</div>
            <div class="fw-semibold">PDF і лабораторія</div>
            <div class="small text-muted">Перевірка направлень та передача в роботу.</div>
        </div>
    </div>
</div>

<form asp-action="Create" method="post" class="card" id="orderCreateForm">
    <div class="card-body">
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

        <h2 class="h6 text-muted text-uppercase mb-3">Замовник</h2>
        <div class="btn-group btn-group-sm mb-3" role="group" aria-label="Режим замовника">
            <input type="radio" class="btn-check" asp-for="Input.CustomerMode" id="customerModeExisting" value="existing" />
            <label class="btn btn-outline-primary" for="customerModeExisting">Існуючий</label>
            <input type="radio" class="btn-check" asp-for="Input.CustomerMode" id="customerModeNew" value="new" />
            <label class="btn btn-outline-primary" for="customerModeNew">Новий</label>
        </div>

        <div id="existingCustomerPanel" class="mb-4">
            <label class="form-label small text-muted" for="customerSearch">Пошук (ПІБ, телефон, ЄДРПОУ)</label>
            <input type="search" class="form-control form-control-sm" id="customerSearch"
                   value="@Model.Input.CustomerSearchQuery" autocomplete="off" />
            <input type="hidden" asp-for="Input.SelectedCustomerId" id="selectedCustomerId" />
            <input type="hidden" asp-for="Input.SelectedCustomerLabel" id="selectedCustomerLabel" />
            <div id="customerSearchResults" class="list-group list-group-flush mt-1 d-none"></div>
            <p id="selectedCustomerSummary" class="small text-success mt-2 mb-0"></p>
        </div>

        <div id="newCustomerPanel" class="mb-4 d-none">
            <div class="row g-2">
                <div class="col-md-4">
                    <label class="form-label small text-muted" asp-for="Input.NewCustomerKind">Тип</label>
                    <select asp-for="Input.NewCustomerKind" class="form-select form-select-sm"
                            asp-items="@(new SelectList(
                                Enum.GetValues<CustomerKind>().Select(kind => new { Value = (int)kind, Text = CustomerKindDisplay.ToUk(kind) }),
                                "Value",
                                "Text"))"></select>
                </div>
                <div class="col-md-8">
                    <label class="form-label small text-muted" asp-for="Input.NewCustomerFullName"></label>
                    <input asp-for="Input.NewCustomerFullName" class="form-control form-control-sm" />
                    <span asp-validation-for="Input.NewCustomerFullName" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label small text-muted" asp-for="Input.NewCustomerOrganizationName"></label>
                    <input asp-for="Input.NewCustomerOrganizationName" class="form-control form-control-sm" />
                </div>
                <div class="col-md-6">
                    <label class="form-label small text-muted" asp-for="Input.NewCustomerContactPhone"></label>
                    <input asp-for="Input.NewCustomerContactPhone" class="form-control form-control-sm" />
                </div>
                <div class="col-md-6">
                    <label class="form-label small text-muted" asp-for="Input.NewCustomerAddress"></label>
                    <input asp-for="Input.NewCustomerAddress" class="form-control form-control-sm" />
                </div>
                <div class="col-md-6">
                    <label class="form-label small text-muted" asp-for="Input.NewCustomerEdrpou"></label>
                    <input asp-for="Input.NewCustomerEdrpou" class="form-control form-control-sm" />
                </div>
            </div>
        </div>

        <h2 class="h6 text-muted text-uppercase mb-3">Дослідження та бланки</h2>
        <div class="row g-2 mb-3">
            <div class="col-md-6">
                <label class="form-label small text-muted" asp-for="Input.InvestigationTypeId">Тип дослідження</label>
                <select asp-for="Input.InvestigationTypeId" class="form-select form-select-sm" id="investigationTypeId">
                    <option value="">— оберіть —</option>
                    @foreach (var option in Model.Form.InvestigationTypes)
                    {
                        var selected = Model.Input.TemplateVersionId == option.TemplateVersionId
                            || (!Model.Input.TemplateVersionId.HasValue && Model.Input.InvestigationTypeId == option.Id);
                        if (selected)
                        {
                            <option value="@option.Id" data-template-version-id="@option.TemplateVersionId" selected>@option.NameUk</option>
                        }
                        else
                        {
                            <option value="@option.Id" data-template-version-id="@option.TemplateVersionId">@option.NameUk</option>
                        }
                    }
                </select>
                <input type="hidden" asp-for="Input.TemplateVersionId" id="selectedTemplateVersionId" />
                <span asp-validation-for="Input.InvestigationTypeId" class="text-danger small"></span>
            </div>
        </div>

        <p class="small text-muted mb-2">Оберіть один або кілька PDF-шаблонів і для кожного вкажіть філію лабораторії.</p>
        <div id="templateDocumentsPanel" class="border rounded p-2 mb-3 bg-light">
            <p class="small text-muted mb-0" id="templateDocumentsPlaceholder">Спочатку оберіть тип дослідження.</p>
            <div id="templateDocumentsList" class="d-none"></div>
        </div>
        <span asp-validation-for="Input.SelectedTemplateVersionIds" class="text-danger small d-block mb-2"></span>

        <div class="form-check mb-3">
            <input asp-for="Input.OpenPdfAfterCreate" class="form-check-input" />
            <label class="form-check-label small" asp-for="Input.OpenPdfAfterCreate">
                Відкрити PDF Workspace після створення (якщо обрано один бланк)
            </label>
        </div>

        <div class="d-flex flex-wrap gap-2">
            <button type="submit" class="btn btn-primary" id="btnCreateOrder">Зареєструвати пробу</button>
            <button type="submit"
                    class="btn btn-outline-primary d-none"
                    id="btnPrepareFieldMapping"
                    formaction="@Url.Action("PrepareFieldMapping")">
                Далі: мапінг спільних полів
            </button>
        </div>
        <p class="small text-muted mt-2 mb-0 d-none" id="fieldMappingHint">
            Обрано кілька бланків — можна об’єднати однакові поля перед створенням справи.
        </p>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        window.__orderCreateTemplateOptions = @Html.Raw(templateOptionsJson);
        window.__orderCreateBranches = @Html.Raw(branchesJson);
        window.__orderCreateDefaultBranchId = @Html.Raw(JsonSerializer.Serialize(defaultBranchId));
    </script>
    <script src="~/js/order-create.js" asp-append-version="true"></script>
}
