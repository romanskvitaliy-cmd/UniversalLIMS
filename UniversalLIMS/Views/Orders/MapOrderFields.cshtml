@model OrderMapFieldsViewModel
@using System.Text.Json

@{
    Layout = "_LayoutWorkspace";
    ViewData["Title"] = "Мапінг спільних полів";
    var mappingJson = JsonSerializer.Serialize(
        Model.Mapping,
        new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase });
}

<div class="d-flex justify-content-between align-items-start gap-3 mb-3">
    <div>
        <h1 class="h3 mb-1">Мапінг спільних полів</h1>
        <p class="text-muted mb-0">
            У справі кілька проб або бланків PDF — об’єднайте поля з різних форм (ПІБ, дата відбору…), щоб заповнити один раз.
        </p>
    </div>
    <button type="submit"
            form="orderFieldMappingForm"
            formaction="@Url.Action("BackToCreateFromMapping", "Orders")"
            class="btn btn-sm btn-outline-secondary">
        ← Назад
    </button>
</div>

<form asp-action="CreateWithFieldMapping" method="post" id="orderFieldMappingForm">
    @Html.AntiForgeryToken()
    <input type="hidden" name="CustomerMode" value="@Model.CreateInput.CustomerMode" />
    <input type="hidden" name="SelectedCustomerId" value="@Model.CreateInput.SelectedCustomerId" />
    <input type="hidden" name="SelectedCustomerLabel" value="@Model.CreateInput.SelectedCustomerLabel" />
    <input type="hidden" name="NewCustomerKind" value="@Model.CreateInput.NewCustomerKind" />
    <input type="hidden" name="NewCustomerFullName" value="@Model.CreateInput.NewCustomerFullName" />
    <input type="hidden" name="NewCustomerOrganizationName" value="@Model.CreateInput.NewCustomerOrganizationName" />
    <input type="hidden" name="NewCustomerContactPhone" value="@Model.CreateInput.NewCustomerContactPhone" />
    <input type="hidden" name="NewCustomerAddress" value="@Model.CreateInput.NewCustomerAddress" />
    <input type="hidden" name="NewCustomerEdrpou" value="@Model.CreateInput.NewCustomerEdrpou" />
    <input type="hidden" name="OpenPdfAfterCreate" value="@Model.CreateInput.OpenPdfAfterCreate" />
    @for (var sampleIndex = 0; sampleIndex < Model.CreateInput.Samples.Count; sampleIndex++)
    {
        <input type="hidden" name="Samples[@sampleIndex].InvestigationTypeId" value="@Model.CreateInput.Samples[sampleIndex].InvestigationTypeId" />
        <input type="hidden" name="Samples[@sampleIndex].TemplateVersionId" value="@Model.CreateInput.Samples[sampleIndex].TemplateVersionId" />
        @for (var documentIndex = 0; documentIndex < Model.CreateInput.Samples[sampleIndex].SelectedTemplateVersionIds.Count; documentIndex++)
        {
            <input type="hidden" name="Samples[@sampleIndex].SelectedTemplateVersionIds[@documentIndex]" value="@Model.CreateInput.Samples[sampleIndex].SelectedTemplateVersionIds[documentIndex]" />
        }
        @for (var branchIndex = 0; branchIndex < Model.CreateInput.Samples[sampleIndex].DocumentTargetBranchIds.Count; branchIndex++)
        {
            <input type="hidden" name="Samples[@sampleIndex].DocumentTargetBranchIds[@branchIndex]" value="@Model.CreateInput.Samples[sampleIndex].DocumentTargetBranchIds[branchIndex]" />
        }
    }
    <input type="hidden" name="fieldMappingJson" id="fieldMappingJson" />

    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

    <div class="row g-3">
        <div class="col-lg-7">
            <div class="card">
                <div class="card-body">
                    <h2 class="h6 text-muted text-uppercase mb-2">Поля шаблонів</h2>
                    <p class="small text-muted">
                        Позначте чекбоксами поля з однаковим змістом і натисніть «Об’єднати вибрані».
                        Для локальних тегів можна використати автооб’єднання лише за точним збігом тегу.
                    </p>
                    <div id="fieldMappingTemplates"></div>
                </div>
            </div>
        </div>
        <div class="col-lg-5">
            @if (Model.CopySourceOrders.Count > 0)
            {
                <div class="card mb-3">
                    <div class="card-body">
                        <h2 class="h6 text-muted text-uppercase mb-2">Скопіювати мапінг</h2>
                        <p class="small text-muted mb-2">
                            З попереднього замовлення (за збігом тегів полів, не за текстом підпису).
                        </p>
                        <div class="d-flex flex-wrap gap-2 align-items-end">
                            <div class="flex-grow-1">
                                <label class="form-label small mb-0" for="copyMappingSourceOrderId">Замовлення-джерело</label>
                                <select class="form-select form-select-sm" id="copyMappingSourceOrderId">
                                    <option value="">— оберіть —</option>
                                    @foreach (var source in Model.CopySourceOrders)
                                    {
                                        var label = source.ReferralNumber ?? source.OrderId.ToString("N")[..8];
                                        <option value="@source.OrderId">
                                            @label · @source.OrderDateUtc.ToLocalTime().ToString("dd.MM.yyyy") · @source.GroupCount груп
                                        </option>
                                    }
                                </select>
                            </div>
                            <button type="button" class="btn btn-sm btn-outline-primary" id="btnCopyFieldMapping">
                                Застосувати
                            </button>
                        </div>
                        <p class="small text-muted mb-0 mt-2 d-none" id="copyMappingStatus"></p>
                    </div>
                </div>
            }
            <div class="card mb-3">
                <div class="card-body">
                    <h2 class="h6 text-muted text-uppercase mb-2">Групи об’єднаних полів</h2>
                    <div id="fieldMappingSummary" class="small mb-2"></div>
                    <div id="fieldMappingGroups" class="small"></div>
                    <button type="button" class="btn btn-sm btn-outline-primary mt-2" id="btnMergeSelected">
                        Об’єднати вибрані
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-secondary mt-2" id="btnClearSelection">
                        Зняти виділення
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-success mt-2" id="btnAutoMergePreview">
                        Перевірити автооб’єднання
                    </button>
                    <button type="button" class="btn btn-sm btn-success mt-2 d-none" id="btnAutoMergeConfirm">
                        Підтвердити автооб’єднання
                    </button>
                    <p class="small mt-2 mb-0 text-muted d-none" id="autoMergeStatus"></p>
                </div>
            </div>
            <div class="card">
                <div class="card-body">
                    <h2 class="h6 text-muted text-uppercase mb-2">Спільні значення</h2>
                    <p class="small text-muted mb-2">Заповніть один раз для кожної групи (необов’язково зараз).</p>
                    <div id="fieldMappingSharedValues"></div>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-3 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Зареєструвати пробу з мапінгом</button>
        <a class="btn btn-outline-secondary" asp-action="Create">Скасувати</a>
    </div>
</form>

@section Scripts {
    <script>
        window.__orderFieldMapping = @Html.Raw(mappingJson);
        window.__orderFieldMappingAdaptUrl = @Html.Raw(JsonSerializer.Serialize(Url.Action("AdaptFieldMapping")));
    </script>
    <script src="~/js/order-field-mapping.js" asp-append-version="true"></script>
}
