@model OrderDetailViewModel
@using System.Text.Json
@using UniversalLIMS.Application.Registration

@{
    Layout = "_LayoutWorkspace";
    ViewData["Title"] = $"Справу {Model.Detail.ReferralNumber ?? Model.Detail.OrderId.ToString("N")[..8]}";
    var detail = Model.Detail;
    var appendPanelOpen = TempData["OrderDetailAppendOpen"] is true || !ViewData.ModelState.IsValid;
    var firstSampleRegisteredAt = detail.Samples.Min(sample => sample.RegisteredAt);
    var orderCreateJsonOptions = new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase };
    var templateOptionsJson = JsonSerializer.Serialize(Model.AppendForm.TemplateOptions, orderCreateJsonOptions);
    var investigationTypesJson = JsonSerializer.Serialize(Model.AppendForm.InvestigationTypes, orderCreateJsonOptions);
    var branchesJson = JsonSerializer.Serialize(Model.AppendForm.Branches, orderCreateJsonOptions);
    var initialAppendSamplesJson = JsonSerializer.Serialize(Model.AppendSamples.Samples, orderCreateJsonOptions);
    var defaultBranchId = Model.AppendForm.DefaultBranchId?.ToString("D") ?? "";
    var appendSeeds = detail.Samples
        .Select(sample =>
        {
            var doc = detail.Documents.FirstOrDefault(document => document.SampleId == sample.SampleId);
            return new
            {
                sampleNumber = sample.SampleNumber,
                investigationTypeNameUk = sample.InvestigationTypeNameUk,
                investigationTypeId = doc is null
                    ? Guid.Empty
                    : Model.AppendForm.TemplateOptions
                        .FirstOrDefault(option => option.TemplateVersionId == doc.TemplateVersionId)?.InvestigationTypeId ?? Guid.Empty,
                templateVersionId = doc?.TemplateVersionId ?? Guid.Empty,
                branchId = doc?.TargetBranchId ?? Model.AppendForm.DefaultBranchId ?? Guid.Empty
            };
        })
        .Where(seed => seed.templateVersionId != Guid.Empty)
        .ToList();
    var appendSeedsJson = JsonSerializer.Serialize(appendSeeds, orderCreateJsonOptions);
}

<div class="d-flex justify-content-between align-items-start gap-3 mb-3">
    <div>
        <h1 class="h3 mb-1">Справу замовлення</h1>
        <p class="text-muted mb-0">
            @(detail.ReferralNumber ?? "—") · @detail.CustomerFullName
        </p>
        <p class="small text-muted mb-0">
            Проб: @detail.Samples.Count · документів: @detail.Documents.Count ·
            <span class="badge lims-status-badge @OrderStatusDisplay.BadgeClass(detail.Status)">@OrderStatusDisplay.ToUk(detail.Status)</span>
            · <strong>@detail.WorkflowSummaryUk</strong>
        </p>
    </div>
    <div class="d-flex flex-wrap gap-2 align-items-start">
        <partial name="_WorkspaceCabinetLink" />
        <a class="btn btn-sm btn-outline-secondary" asp-action="Index">← До реєстру</a>
    </div>
</div>

@if (TempData["OrderDetailError"] is string errorMessage)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @errorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Закрити"></button>
    </div>
}

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger" role="alert">
        @foreach (var entry in ViewData.ModelState.Values.SelectMany(value => value.Errors))
        {
            <div>@entry.ErrorMessage</div>
        }
    </div>
}

<div class="card mb-3">
    <div class="card-header py-2 d-flex justify-content-between align-items-center">
        <span class="fw-semibold">Дані замовника</span>
        <span class="small text-muted">@CustomerKindDisplay.ToUk(Model.CustomerEdit.Kind)</span>
    </div>
    <div class="card-body">
        <form asp-action="UpdateCustomer" method="post" class="row g-2" id="orderCustomerForm" novalidate data-lims-soft-validate>
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="CustomerEdit.OrderId" />
            <input type="hidden" asp-for="CustomerEdit.CustomerId" />
            <div class="col-md-3">
                <label class="form-label small text-muted" asp-for="CustomerEdit.Kind">Тип</label>
                <select asp-for="CustomerEdit.Kind" class="form-select form-select-sm"
                        asp-items='@(new SelectList(
                            Enum.GetValues<CustomerKind>().Select(kind => new { Value = (int)kind, Text = CustomerKindDisplay.ToUk(kind) }),
                            "Value",
                            "Text"))'></select>
            </div>
            <div class="col-md-5">
                <label class="form-label small text-muted" asp-for="CustomerEdit.FullName">
                    ПІБ / назва <span class="text-danger">*</span>
                </label>
                <input asp-for="CustomerEdit.FullName"
                       class="form-control form-control-sm"
                       required
                       maxlength="250"
                       data-required-message="ПІБ або назва замовника є обов'язковими." />
                <div class="invalid-feedback" id="customerFullNameError">
                    ПІБ або назва замовника є обов'язковими.
                </div>
            </div>
            <div class="col-md-4">
                <label class="form-label small text-muted" asp-for="CustomerEdit.OrganizationName">Організація</label>
                <input asp-for="CustomerEdit.OrganizationName" class="form-control form-control-sm" />
            </div>
            <div class="col-md-3">
                <label class="form-label small text-muted" asp-for="CustomerEdit.ContactPhone">Телефон</label>
                <input asp-for="CustomerEdit.ContactPhone"
                       class="form-control form-control-sm"
                       data-lims-soft-format="phone"
                       maxlength="50"
                       autocomplete="tel" />
            </div>
            <div class="col-md-3">
                <label class="form-label small text-muted" asp-for="CustomerEdit.Email">Email</label>
                <input asp-for="CustomerEdit.Email"
                       class="form-control form-control-sm"
                       data-lims-soft-format="email"
                       maxlength="256"
                       autocomplete="email" />
            </div>
            <div class="col-md-3">
                <label class="form-label small text-muted" asp-for="CustomerEdit.Edrpou">ЄДРПОУ</label>
                <input asp-for="CustomerEdit.Edrpou"
                       class="form-control form-control-sm"
                       data-lims-soft-format="edrpou"
                       maxlength="10"
                       inputmode="numeric"
                       autocomplete="off" />
            </div>
            <div class="col-md-3">
                <label class="form-label small text-muted" asp-for="CustomerEdit.Rnokpp">РНОКПП</label>
                <input asp-for="CustomerEdit.Rnokpp"
                       class="form-control form-control-sm"
                       data-lims-soft-format="rnokpp"
                       maxlength="12"
                       inputmode="numeric"
                       autocomplete="off" />
            </div>
            <div class="col-12">
                <label class="form-label small text-muted" asp-for="CustomerEdit.Address">Адреса</label>
                <input asp-for="CustomerEdit.Address" class="form-control form-control-sm" />
            </div>
            <div class="col-12">
                <label class="form-label small text-muted" asp-for="CustomerEdit.Notes">Примітки</label>
                <textarea asp-for="CustomerEdit.Notes" class="form-control form-control-sm" rows="2"></textarea>
            </div>
            <div class="col-12">
                <button type="submit" class="btn btn-sm btn-outline-primary">Зберегти дані замовника</button>
            </div>
        </form>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header py-2 d-flex justify-content-between align-items-center gap-2">
        <span class="fw-semibold">Проби та документи</span>
        <span class="badge text-bg-light border">@detail.Samples.Count проб · @detail.Documents.Count док.</span>
    </div>
    <div class="card-body p-0">
        @if (!detail.Documents.Any())
        {
            <p class="p-3 mb-0 text-muted">Документів немає.</p>
        }
        else
        {
            <form id="orderDocumentsForm" asp-action="SendDocuments" method="post" class="d-none">
                @Html.AntiForgeryToken()
                <input type="hidden" name="OrderId" value="@detail.OrderId" />
            </form>

            <div class="order-detail-samples">
                @foreach (var sample in detail.Samples)
                {
                    var sampleDocuments = detail.Documents
                        .Where(document => document.SampleId == sample.SampleId)
                        .ToList();
                    var isAppended = sample.RegisteredAt > firstSampleRegisteredAt.AddMinutes(1);
                    var sampleStatusSummary = OrderDocumentStatusDisplay.SummarizeWorkflow(
                        sampleDocuments.Select(document => document.Status).ToList());

                    <section class="order-detail-sample" data-sample-id="@sample.SampleId">
                        <header class="order-detail-sample__head">
                            <div class="order-detail-sample__title">
                                <span class="order-detail-sample__number">@sample.SampleNumber</span>
                                <span class="order-detail-sample__type">@sample.InvestigationTypeNameUk</span>
                            </div>
                            <div class="order-detail-sample__meta">
                                @if (isAppended)
                                {
                                    <span class="badge order-detail-sample__added-badge border"
                                          title="Додано пізніше до цієї справи">
                                        + @sample.RegisteredAt.ToLocalTime().ToString("dd.MM HH:mm")
                                    </span>
                                }
                                <span class="badge lims-status-badge text-bg-light border">@sampleStatusSummary</span>
                                <span class="small text-muted">@sampleDocuments.Count док.</span>
                                @if (sampleDocuments.FirstOrDefault()?.TemplateVersionId is Guid seedVersionId)
                                {
                                    var seedBranchId = sampleDocuments[0].TargetBranchId;
                                    var seedInvestigationId = Model.AppendForm.TemplateOptions
                                        .FirstOrDefault(option => option.TemplateVersionId == seedVersionId)?.InvestigationTypeId ?? Guid.Empty;
                                    <button type="button"
                                            class="btn btn-sm btn-link order-detail-sample__clone px-1"
                                            data-investigation-type-id="@seedInvestigationId"
                                            data-template-version-id="@seedVersionId"
                                            data-branch-id="@seedBranchId"
                                            title="Додати пробу з таким самим бланком">
                                        Як ця
                                    </button>
                                }
                            </div>
                        </header>

                        @if (sampleDocuments.Count == 0)
                        {
                            <p class="order-detail-sample__empty">Для цієї проби документів немає.</p>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-sm table-hover align-middle lims-workspace-table order-detail-sample__table mb-0">
                                    <thead>
                                        <tr>
                                            <th class="ps-3" style="width:2.5rem"></th>
                                            <th>Шаблон</th>
                                            <th>Філія</th>
                                            <th>Статус</th>
                                            <th class="text-end pe-3">Дії</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var document in sampleDocuments)
                                        {
                                            <tr data-document-id="@document.OrderDocumentId">
                                                <td class="ps-3">
                                                    @if (document.CanSendToLab)
                                                    {
                                                        <input type="checkbox" class="form-check-input document-send-checkbox"
                                                               form="orderDocumentsForm"
                                                               name="OrderDocumentIds" value="@document.OrderDocumentId" />
                                                    }
                                                </td>
                                                <td>
                                                    <div class="order-detail-doc__name" title="@document.TemplateNameUk">
                                                        @document.TemplateNameUk
                                                    </div>
                                                    <div class="small text-muted">v@(document.VersionNumber)</div>
                                                </td>
                                                <td>
                                                    @if (document.CanSendToLab)
                                                    {
                                                        <form asp-action="UpdateRouting" method="post" class="d-flex gap-1 align-items-center routing-form">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="OrderId" value="@detail.OrderId" />
                                                            <input type="hidden" name="OrderDocumentId" value="@document.OrderDocumentId" />
                                                            <select name="TargetBranchId" class="form-select form-select-sm" style="min-width:10rem">
                                                                @foreach (var branch in Model.Branches)
                                                                {
                                                                    if (branch.Id == document.TargetBranchId)
                                                                    {
                                                                        <option value="@branch.Id" selected="selected">@branch.Name</option>
                                                                    }
                                                                    else
                                                                    {
                                                                        <option value="@branch.Id">@branch.Name</option>
                                                                    }
                                                                }
                                                            </select>
                                                            <button type="submit" class="btn btn-sm btn-outline-secondary" title="Зберегти філію">OK</button>
                                                        </form>
                                                    }
                                                    else
                                                    {
                                                        <span class="small">@document.TargetBranchName</span>
                                                    }
                                                </td>
                                                <td>
                                                    <span class="badge lims-status-badge @OrderDocumentStatusDisplay.BadgeClass(document.Status)">
                                                        @OrderDocumentStatusDisplay.ToUk(document.Status)
                                                    </span>
                                                </td>
                                                <td class="text-end pe-3 text-nowrap">
                                                    @if (document.CanFill)
                                                    {
                                                        <a class="btn btn-sm btn-outline-primary"
                                                           asp-controller="PdfWorkspace"
                                                           asp-action="Fill"
                                                           asp-route-templateVersionId="@document.TemplateVersionId"
                                                           asp-route-orderId="@detail.OrderId"
                                                           asp-route-orderDocumentId="@document.OrderDocumentId">
                                                            Заповнити
                                                        </a>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted small">—</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </section>
                }
            </div>

            @if (detail.Documents.Any(document => document.CanSendToLab))
            {
                <div class="p-3 border-top d-flex flex-wrap gap-2 align-items-center order-detail-send-bar">
                    <label class="d-inline-flex align-items-center gap-1 small mb-0 me-1">
                        <input type="checkbox" class="form-check-input" id="selectAllDocuments"
                               title="Обрати всі, що можна відправити" />
                        Усі
                    </label>
                    <button type="submit" form="orderDocumentsForm" class="btn btn-sm btn-primary" id="sendDocumentsButton">
                        Відправити обрані в лабораторію
                    </button>
                    <span class="small text-muted">Після відправки статус зміниться на «У лабораторії».</span>
                </div>
            }
        }
    </div>

    <div class="order-detail-append @(appendPanelOpen ? "order-detail-append--open" : "")" id="orderDetailAppend">
        <button type="button"
                class="order-detail-append__toggle"
                id="orderDetailAppendToggle"
                aria-expanded="@(appendPanelOpen ? "true" : "false")"
                aria-controls="orderDetailAppendBody">
            <span class="order-detail-append__toggle-icon" aria-hidden="true">+</span>
            <span class="order-detail-append__toggle-text">Додати пробу до цієї справи</span>
            <span class="order-detail-append__toggle-hint">новий рядок: проба + бланк PDF</span>
        </button>

        <div class="order-detail-append__body" id="orderDetailAppendBody" @(appendPanelOpen ? "" : "hidden")>
            <form asp-action="AppendSamples" method="post" id="appendSamplesForm">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="AppendSamples.OrderId" />

                <p class="order-detail-append__lead">
                    Замовник уже в справі — додайте лише нові проби. Кожна отримає свій номер і статус «Очікує».
                </p>

                <div id="orderAppendSamplesPanel" class="order-detail-append__panel">
                    <div class="row g-2 px-1 pb-2 small text-muted fw-semibold d-none d-md-flex order-detail-append__headings">
                        <div class="col-md-6">Бланк для проби</div>
                        <div class="col-md-5">Філія</div>
                        <div class="col-md-1 text-end"> </div>
                    </div>
                    <div id="orderAppendSamplesList"></div>
                    <p class="small text-muted mb-0 d-none" id="orderAppendSamplesPlaceholder">
                        Натисніть «+ рядок» або «Як ця» біля існуючої проби.
                    </p>
                </div>

                <div class="d-flex flex-wrap gap-2 align-items-center mt-2">
                    <button type="button" class="btn btn-sm btn-outline-secondary" id="btnAddAppendSample">
                        + рядок
                    </button>
                    <button type="submit" class="btn btn-sm btn-primary" id="btnSubmitAppendSamples">
                        Зберегти нові проби
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@if (Model.FieldLinkGroups.Groups.Count > 0)
{
    <div class="card mb-3">
        <div class="card-header py-2 d-flex justify-content-between align-items-center">
            <span class="fw-semibold">Мапінг спільних полів</span>
            <span class="small text-muted">@Model.FieldLinkGroups.Groups.Count груп</span>
        </div>
        <div class="card-body p-0">
            <div class="list-group list-group-flush">
                @foreach (var (group, index) in Model.FieldLinkGroups.Groups.Select((group, index) => (group, index)))
                {
                    var groupTitle = !string.IsNullOrWhiteSpace(group.Label)
                        ? group.Label
                        : $"Група {index + 1}";
                    <div class="list-group-item">
                        <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                            <div class="fw-semibold">@groupTitle</div>
                            @if (!string.IsNullOrWhiteSpace(group.SharedValue))
                            {
                                <span class="badge text-bg-light border text-wrap text-start" style="max-width: 50%;">
                                    @group.SharedValue
                                </span>
                            }
                        </div>
                        <ul class="small mb-0 ps-3">
                            @foreach (var member in group.Members)
                            {
                                <li>
                                    <span class="text-muted">@member.TemplateNameUk (v@(member.VersionNumber)):</span>
                                    <code class="user-select-all">@member.Tag</code>
                                    @if (!string.IsNullOrWhiteSpace(member.Title))
                                    {
                                        <span class="text-muted">— @member.Title</span>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(member.DataFieldKey))
                                    {
                                        <span class="text-muted"> → @member.DataFieldKey</span>
                                    }
                                </li>
                            }
                        </ul>
                    </div>
                }
            </div>
        </div>
    </div>
}

<p class="small text-muted mb-0">
    Дата реєстрації: @detail.OrderDate.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
</p>

@section Scripts {
    <script>
        window.__orderAppendTemplateOptions = @Html.Raw(templateOptionsJson);
        window.__orderAppendInvestigationTypes = @Html.Raw(investigationTypesJson);
        window.__orderAppendBranches = @Html.Raw(branchesJson);
        window.__orderAppendInitialSamples = @Html.Raw(initialAppendSamplesJson);
        window.__orderAppendDefaultBranchId = @Html.Raw(JsonSerializer.Serialize(defaultBranchId));
        window.__orderAppendSeeds = @Html.Raw(appendSeedsJson);
        window.__orderAppendPanelOpen = @Html.Raw(appendPanelOpen ? "true" : "false");
    </script>
    <script src="~/js/customer-format-hints.js" asp-append-version="true"></script>
    <script src="~/js/order-template-field.js" asp-append-version="true"></script>
    <script src="~/js/order-detail.js" asp-append-version="true"></script>
    <script src="~/js/order-detail-append.js" asp-append-version="true"></script>
}
