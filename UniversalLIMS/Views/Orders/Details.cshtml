@model OrderDetailViewModel
@using UniversalLIMS.Application.Registration

@{
    Layout = "_LayoutWorkspace";
    ViewData["Title"] = $"Справу {Model.Detail.ReferralNumber ?? Model.Detail.OrderId.ToString("N")[..8]}";
    var detail = Model.Detail;
}

<div class="d-flex justify-content-between align-items-start gap-3 mb-3">
    <div>
        <h1 class="h3 mb-1">Справу замовлення</h1>
        <p class="text-muted mb-0">
            @(detail.ReferralNumber ?? "—") · @detail.CustomerFullName
        </p>
        <p class="small text-muted mb-0">
            Проб: @detail.Samples.Count · документів: @detail.Documents.Count ·
            <span class="badge lims-status-badge @OrderStatusDisplay.BadgeClass(detail.Status)">@OrderStatusDisplay.ToUk(detail.Status)</span>
            · <strong>@detail.WorkflowSummaryUk</strong>
        </p>
    </div>
    <a class="btn btn-sm btn-outline-secondary" asp-action="Index">← До реєстру</a>
</div>

@if (TempData["OrderDetailSuccess"] is string successMessage)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @successMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Закрити"></button>
    </div>
}

@if (TempData["OrderDetailError"] is string errorMessage)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @errorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Закрити"></button>
    </div>
}

<div class="card mb-3">
    <div class="card-header py-2 d-flex justify-content-between align-items-center">
        <span class="fw-semibold">Дані замовника</span>
        <span class="small text-muted">@CustomerKindDisplay.ToUk(Model.CustomerEdit.Kind)</span>
    </div>
    <div class="card-body">
        <form asp-action="UpdateCustomer" method="post" class="row g-2">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="CustomerEdit.OrderId" />
            <input type="hidden" asp-for="CustomerEdit.CustomerId" />
            <div class="col-md-3">
                <label class="form-label small text-muted" asp-for="CustomerEdit.Kind">Тип</label>
                <select asp-for="CustomerEdit.Kind" class="form-select form-select-sm"
                        asp-items='@(new SelectList(
                            Enum.GetValues<CustomerKind>().Select(kind => new { Value = (int)kind, Text = CustomerKindDisplay.ToUk(kind) }),
                            "Value",
                            "Text"))'></select>
            </div>
            <div class="col-md-5">
                <label class="form-label small text-muted" asp-for="CustomerEdit.FullName">ПІБ / назва</label>
                <input asp-for="CustomerEdit.FullName" class="form-control form-control-sm" />
            </div>
            <div class="col-md-4">
                <label class="form-label small text-muted" asp-for="CustomerEdit.OrganizationName">Організація</label>
                <input asp-for="CustomerEdit.OrganizationName" class="form-control form-control-sm" />
            </div>
            <div class="col-md-3">
                <label class="form-label small text-muted" asp-for="CustomerEdit.ContactPhone">Телефон</label>
                <input asp-for="CustomerEdit.ContactPhone" class="form-control form-control-sm" />
            </div>
            <div class="col-md-3">
                <label class="form-label small text-muted" asp-for="CustomerEdit.Email">Email</label>
                <input asp-for="CustomerEdit.Email" class="form-control form-control-sm" />
            </div>
            <div class="col-md-3">
                <label class="form-label small text-muted" asp-for="CustomerEdit.Edrpou">ЄДРПОУ</label>
                <input asp-for="CustomerEdit.Edrpou" class="form-control form-control-sm" />
            </div>
            <div class="col-md-3">
                <label class="form-label small text-muted" asp-for="CustomerEdit.Rnokpp">РНОКПП</label>
                <input asp-for="CustomerEdit.Rnokpp" class="form-control form-control-sm" />
            </div>
            <div class="col-12">
                <label class="form-label small text-muted" asp-for="CustomerEdit.Address">Адреса</label>
                <input asp-for="CustomerEdit.Address" class="form-control form-control-sm" />
            </div>
            <div class="col-12">
                <label class="form-label small text-muted" asp-for="CustomerEdit.Notes">Примітки</label>
                <textarea asp-for="CustomerEdit.Notes" class="form-control form-control-sm" rows="2"></textarea>
            </div>
            <div class="col-12">
                <button type="submit" class="btn btn-sm btn-outline-primary">Зберегти дані замовника</button>
            </div>
        </form>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header py-2 d-flex justify-content-between align-items-center">
        <span class="fw-semibold">Документи шаблонів</span>
        <span class="small text-muted">@detail.Documents.Count шт.</span>
    </div>
    <div class="card-body p-0">
        @if (!detail.Documents.Any())
        {
            <p class="p-3 mb-0 text-muted">Документів немає.</p>
        }
        else
        {
            <form id="orderDocumentsForm" asp-action="SendDocuments" method="post" class="d-none">
                @Html.AntiForgeryToken()
                <input type="hidden" name="OrderId" value="@detail.OrderId" />
            </form>
            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle lims-workspace-table mb-0">
                    <thead>
                        <tr>
                            <th class="ps-3" style="width:2.5rem">
                                <input type="checkbox" class="form-check-input" id="selectAllDocuments"
                                       title="Обрати всі, що можна відправити" />
                            </th>
                            <th>Шаблон</th>
                            <th>Філія призначення</th>
                            <th>Статус</th>
                            <th class="text-end pe-3">Дії</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var sample in detail.Samples)
                        {
                            var sampleDocuments = detail.Documents
                                .Where(document => document.SampleId == sample.SampleId)
                                .ToList();
                            <tr class="table-light">
                                <td colspan="5" class="ps-3">
                                    <div class="d-flex flex-wrap justify-content-between gap-2">
                                        <span class="fw-semibold">Проба @sample.SampleNumber</span>
                                        <span class="small text-muted">
                                            @sample.InvestigationTypeNameUk · документів: @sampleDocuments.Count
                                        </span>
                                    </div>
                                </td>
                            </tr>
                            @if (sampleDocuments.Count == 0)
                            {
                                <tr>
                                    <td colspan="5" class="ps-3 text-muted small">Для цієї проби документів немає.</td>
                                </tr>
                            }
                            @foreach (var document in sampleDocuments)
                            {
                                <tr data-document-id="@document.OrderDocumentId">
                                    <td class="ps-3">
                                        @if (document.CanSendToLab)
                                        {
                                            <input type="checkbox" class="form-check-input document-send-checkbox"
                                                   form="orderDocumentsForm"
                                                   name="OrderDocumentIds" value="@document.OrderDocumentId" />
                                        }
                                    </td>
                                    <td>
                                        <div class="fw-semibold">@document.TemplateNameUk</div>
                                        <div class="small text-muted">v@(document.VersionNumber)</div>
                                    </td>
                                    <td>
                                        @if (document.CanSendToLab)
                                        {
                                            <form asp-action="UpdateRouting" method="post" class="d-flex gap-1 align-items-center routing-form">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="OrderId" value="@detail.OrderId" />
                                                <input type="hidden" name="OrderDocumentId" value="@document.OrderDocumentId" />
                                                <select name="TargetBranchId" class="form-select form-select-sm" style="min-width:10rem">
                                                    @foreach (var branch in Model.Branches)
                                                    {
                                                        if (branch.Id == document.TargetBranchId)
                                                        {
                                                            <option value="@branch.Id" selected="selected">@branch.Name</option>
                                                        }
                                                        else
                                                        {
                                                            <option value="@branch.Id">@branch.Name</option>
                                                        }
                                                    }
                                                </select>
                                                <button type="submit" class="btn btn-sm btn-outline-secondary" title="Зберегти філію">OK</button>
                                            </form>
                                        }
                                        else
                                        {
                                            @document.TargetBranchName
                                        }
                                    </td>
                                    <td>
                                        <span class="badge lims-status-badge @OrderDocumentStatusDisplay.BadgeClass(document.Status)">
                                            @OrderDocumentStatusDisplay.ToUk(document.Status)
                                        </span>
                                    </td>
                                    <td class="text-end pe-3 text-nowrap">
                                        @if (document.CanFill)
                                        {
                                            <a class="btn btn-sm btn-outline-primary"
                                               asp-controller="PdfWorkspace"
                                               asp-action="Fill"
                                               asp-route-templateVersionId="@document.TemplateVersionId"
                                               asp-route-orderId="@detail.OrderId"
                                               asp-route-orderDocumentId="@document.OrderDocumentId">
                                                Заповнити
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">—</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
            @if (detail.Documents.Any(document => document.CanSendToLab))
            {
                <div class="p-3 border-top d-flex flex-wrap gap-2 align-items-center">
                    <button type="submit" form="orderDocumentsForm" class="btn btn-sm btn-primary" id="sendDocumentsButton">
                        Відправити обрані в лабораторію
                    </button>
                    <span class="small text-muted">Після відправки статус документа зміниться на «У лабораторії».</span>
                </div>
            }
        }
    </div>
</div>

@if (Model.FieldLinkGroups.Groups.Count > 0)
{
    <div class="card mb-3">
        <div class="card-header py-2 d-flex justify-content-between align-items-center">
            <span class="fw-semibold">Мапінг спільних полів</span>
            <span class="small text-muted">@Model.FieldLinkGroups.Groups.Count груп</span>
        </div>
        <div class="card-body p-0">
            <div class="list-group list-group-flush">
                @foreach (var (group, index) in Model.FieldLinkGroups.Groups.Select((group, index) => (group, index)))
                {
                    var groupTitle = !string.IsNullOrWhiteSpace(group.Label)
                        ? group.Label
                        : $"Група {index + 1}";
                    <div class="list-group-item">
                        <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                            <div class="fw-semibold">@groupTitle</div>
                            @if (!string.IsNullOrWhiteSpace(group.SharedValue))
                            {
                                <span class="badge text-bg-light border text-wrap text-start" style="max-width: 50%;">
                                    @group.SharedValue
                                </span>
                            }
                        </div>
                        <ul class="small mb-0 ps-3">
                            @foreach (var member in group.Members)
                            {
                                <li>
                                    <span class="text-muted">@member.TemplateNameUk (v@(member.VersionNumber)):</span>
                                    <code class="user-select-all">@member.Tag</code>
                                    @if (!string.IsNullOrWhiteSpace(member.Title))
                                    {
                                        <span class="text-muted">— @member.Title</span>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(member.DataFieldKey))
                                    {
                                        <span class="text-muted"> → @member.DataFieldKey</span>
                                    }
                                </li>
                            }
                        </ul>
                    </div>
                }
            </div>
        </div>
    </div>
}

<p class="small text-muted mb-0">
    Дата реєстрації: @detail.OrderDate.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
</p>

@section Scripts {
    <script src="~/js/order-detail.js" asp-append-version="true"></script>
}
