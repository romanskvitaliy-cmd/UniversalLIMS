@model IReadOnlyList<PortalThemeOptionVm>
@{
    var returnUrl = Context.Request.Path + Context.Request.QueryString;
}

<div class="dropdown lims-portal-theme-dropdown"
     data-bs-popper-config='{"strategy":"fixed","modifiers":[{"name":"offset","options":{"offset":[0,8]}}]}'>
    <button type="button"
            class="btn lims-portal-theme-trigger"
            data-bs-toggle="dropdown"
            aria-expanded="false"
            aria-label="Змінити фон порталу"
            title="Фон порталу">
        <i class="bi bi-palette2" aria-hidden="true"></i>
    </button>
    <div class="dropdown-menu dropdown-menu-end lims-portal-theme-menu">
        <h6 class="dropdown-header">Фон порталу</h6>
        @foreach (var option in Model)
        {
            <a class="dropdown-item lims-portal-theme-option @(option.IsSelected ? "active" : "")"
               asp-controller="Home"
               asp-action="SetPortalTheme"
               asp-route-theme="@option.Id"
               asp-route-returnUrl="@returnUrl">
                <span class="lims-portal-theme-swatch" style="background: @option.SwatchGradient"></span>
                <span class="lims-portal-theme-label">@option.DisplayName</span>
                @if (option.IsSelected)
                {
                    <i class="bi bi-check-lg lims-portal-theme-check" aria-hidden="true"></i>
                }
            </a>
        }
    </div>
</div>
