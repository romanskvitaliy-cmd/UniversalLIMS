@using UniversalLIMS.Application.Security

<div class="dropdown lims-route-notify-dropdown"
     data-bs-popper-config='{"strategy":"fixed","modifiers":[{"name":"offset","options":{"offset":[0,8]}}]}'>
    <button type="button"
            class="btn lims-route-notify-trigger"
            data-bs-toggle="dropdown"
            data-lims-route-notify-trigger
            aria-expanded="false"
            aria-label="Сповіщення про проби"
            title="Сповіщення про проби">
        <i class="bi bi-bell" aria-hidden="true"></i>
    </button>
    <div class="dropdown-menu dropdown-menu-end lims-route-notify-menu">
        <h6 class="dropdown-header">Сповіщення</h6>
        <div class="lims-route-notify-option">
            <div class="form-check form-switch m-0">
                <input class="form-check-input"
                       type="checkbox"
                       role="switch"
                       id="limsRouteNotifyVisual"
                       checked />
                <label class="form-check-label" for="limsRouteNotifyVisual">Візуальні</label>
            </div>
        </div>
        <div class="lims-route-notify-option">
            <div class="form-check form-switch m-0">
                <input class="form-check-input"
                       type="checkbox"
                       role="switch"
                       id="limsRouteNotifyVoice" />
                <label class="form-check-label" for="limsRouteNotifyVoice">Голосові</label>
            </div>
        </div>
        @if (ViewData["RouteNotifyPollHint"] is string pollHint)
        {
            <div class="dropdown-item-text small text-muted lims-route-notify-hint">
                @pollHint
            </div>
        }
    </div>
</div>
