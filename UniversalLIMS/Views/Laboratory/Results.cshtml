@model LaboratoryResultsViewModel
@using UniversalLIMS.Application.Laboratory

@{
    Layout = "_LayoutWorkspace";
    ViewData["Title"] = $"Результати — {Model.Form.SampleNumber}";
    var fields = Model.Form.Fields;
    var writableCount = fields.Count(field => field.CanWrite);
    var documentTargets = Model.PdfFillTargets
        .Where(target => target.OrderDocumentId.HasValue)
        .ToList();
}

<div class="d-flex justify-content-between align-items-start gap-3 mb-3">
    <div>
        <h1 class="h3 mb-1">Внесення результатів</h1>
        <p class="text-muted mb-0">
            Проба <strong>@Model.Form.SampleNumber</strong> · @Model.Form.InvestigationTypeName ·
            <span class="badge lims-status-badge @SampleStatusDisplay.BadgeClass(Model.Form.Status)">@SampleStatusDisplay.ToUk(Model.Form.Status)</span>
        </p>
        <p class="small text-muted mb-0">
            Замовник: @Model.Form.CustomerFullName
            @if (!string.IsNullOrWhiteSpace(Model.Form.ReferralNumber))
            {
                <span>· Направлення @Model.Form.ReferralNumber</span>
            }
        </p>
    </div>
    <div class="d-flex flex-wrap gap-2">
        @if (Model.HasPdfFillTargets)
        {
            <a class="btn btn-outline-primary btn-sm"
               asp-action="Results"
               asp-route-sampleId="@Model.Form.SampleId">Заповнити PDF</a>
        }
        <a class="btn btn-outline-secondary btn-sm" asp-action="Index">← Журнал проб</a>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-@(Model.StatusType ?? "info")">@Model.StatusMessage</div>
}

@if (fields.Count == 0)
{
    <div class="alert alert-warning mb-0">
        Для цього типу дослідження немає активних полів результатів (`DataFieldScope.Result`).
    </div>
}
else
{
    @if (writableCount == 0)
    {
        <div class="alert alert-warning">
            Для поточної ролі немає прав <strong>Write</strong> на показники цієї проби.
            Перевірте права полів у шаблоні або оберіть роль лаборанта для демо.
        </div>
    }

    <form method="post" asp-action="ResultEntry" asp-route-sampleId="@Model.Form.SampleId">
        <div class="card">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm table-striped align-middle mb-0">
                        <thead>
                            <tr>
                                <th style="min-width: 220px;">Показник</th>
                                <th style="min-width: 180px;">Значення</th>
                                <th style="min-width: 130px;">Невизначеність</th>
                                <th style="min-width: 220px;">Обладнання</th>
                                <th style="min-width: 120px;">Доступ</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (var i = 0; i < fields.Count; i++)
                            {
                                var field = fields[i];
                                <tr>
                                    <td>
                                        <div class="fw-semibold">@field.DisplayNameUk</div>
                                        <div class="small text-muted">
                                            @field.Key
                                            @if (!string.IsNullOrWhiteSpace(field.Unit))
                                            {
                                                <span>· @field.Unit</span>
                                            }
                                        </div>
                                    </td>
                                    <td>
                                        <input type="hidden" name="Input.Values[@i].DataFieldId" value="@field.DataFieldId" />
                                        @if (field.FieldType == UniversalLIMS.Domain.Templates.DataFieldType.Boolean)
                                        {
                                            var isTrueSelected = string.Equals(field.CurrentValue, "true", StringComparison.OrdinalIgnoreCase);
                                            var isFalseSelected = string.Equals(field.CurrentValue, "false", StringComparison.OrdinalIgnoreCase);
                                            <select class="form-select form-select-sm"
                                                    name="Input.Values[@i].Value"
                                                    disabled="@(!field.CanWrite)">
                                                @if (!isTrueSelected && !isFalseSelected)
                                                {
                                                    <option value="" selected="selected">—</option>
                                                }
                                                else
                                                {
                                                    <option value="">—</option>
                                                }
                                                @if (isTrueSelected)
                                                {
                                                    <option value="true" selected="selected">Так</option>
                                                }
                                                else
                                                {
                                                    <option value="true">Так</option>
                                                }
                                                @if (isFalseSelected)
                                                {
                                                    <option value="false" selected="selected">Ні</option>
                                                }
                                                else
                                                {
                                                    <option value="false">Ні</option>
                                                }
                                            </select>
                                        }
                                        else
                                        {
                                            var inputType = field.FieldType == UniversalLIMS.Domain.Templates.DataFieldType.Number ? "number"
                                                : field.FieldType == UniversalLIMS.Domain.Templates.DataFieldType.Date ? "date"
                                                : "text";
                                            <input type="@inputType"
                                                   class="form-control form-control-sm"
                                                   name="Input.Values[@i].Value"
                                                   value="@field.CurrentValue"
                                                   step="any"
                                                   readonly="@(!field.CanWrite)" />
                                        }
                                    </td>
                                    <td>
                                        <input type="number"
                                               class="form-control form-control-sm"
                                               name="Input.Values[@i].Uncertainty"
                                               value="@field.CurrentUncertainty"
                                               step="0.0001"
                                               readonly="@(!field.CanWrite)" />
                                    </td>
                                    <td>
                                        <select class="form-select form-select-sm"
                                                name="Input.Values[@i].EquipmentId"
                                                disabled="@(!field.CanWrite)">
                                            <option value="">—</option>
                                            @foreach (var equipment in Model.Form.EquipmentOptions)
                                            {
                                                if (field.CurrentEquipmentId == equipment.Id)
                                                {
                                                    <option value="@equipment.Id" selected="selected">@equipment.Code — @equipment.NameUk</option>
                                                }
                                                else
                                                {
                                                    <option value="@equipment.Id">@equipment.Code — @equipment.NameUk</option>
                                                }
                                            }
                                        </select>
                                    </td>
                                    <td>
                                        @if (field.CanWrite)
                                        {
                                            <span class="badge text-bg-success">Write</span>
                                        }
                                        else
                                        {
                                            <span class="badge text-bg-secondary">Read</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="card-footer d-flex flex-wrap gap-3 align-items-center justify-content-between">
                <div class="d-flex flex-column gap-2">
                    <div class="form-check mb-0">
                        @if (Model.Form.Status == UniversalLIMS.Domain.Registration.SampleStatus.ResultsEntered)
                        {
                            <input class="form-check-input" type="checkbox" id="markResultsComplete" name="Input.MarkResultsComplete" value="true" checked="checked" />
                        }
                        else
                        {
                            <input class="form-check-input" type="checkbox" id="markResultsComplete" name="Input.MarkResultsComplete" value="true" />
                        }
                        <label class="form-check-label" for="markResultsComplete">
                            Позначити документ як «Результати внесено»
                        </label>
                    </div>
                    @if (documentTargets.Count == 1)
                    {
                        <input type="hidden" name="Input.OrderDocumentId" value="@documentTargets[0].OrderDocumentId" />
                        <div class="small text-muted">
                            Документ: @documentTargets[0].TemplateNameUk · v@(documentTargets[0].VersionNumber)
                        </div>
                    }
                    else if (documentTargets.Count > 1)
                    {
                        <div>
                            <label class="form-label small text-muted mb-1" for="orderDocumentId">Документ для завершення</label>
                            <select class="form-select form-select-sm" id="orderDocumentId" name="Input.OrderDocumentId">
                                <option value="">Оберіть документ</option>
                                @foreach (var target in documentTargets)
                                {
                                    if (Model.Input.OrderDocumentId == target.OrderDocumentId)
                                    {
                                        <option value="@target.OrderDocumentId" selected="selected">@target.TemplateNameUk · v@(target.VersionNumber)</option>
                                    }
                                    else
                                    {
                                        <option value="@target.OrderDocumentId">@target.TemplateNameUk · v@(target.VersionNumber)</option>
                                    }
                                }
                            </select>
                            <div class="form-text">Для проби з кількома PDF завершення фіксується по конкретному документу.</div>
                        </div>
                    }
                </div>
                <button type="submit" class="btn btn-primary btn-sm" disabled="@(writableCount == 0)">Зберегти результати</button>
            </div>
        </div>
    </form>
}
