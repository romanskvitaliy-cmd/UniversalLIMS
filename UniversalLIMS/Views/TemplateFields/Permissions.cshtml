@model TemplateFieldPermissionMatrixViewModel

@{
    ViewData["Title"] = "Права доступу до полів";
    var accessLevels = Enum.GetValues<FieldAccessLevel>();
}

<h1 class="h3">Права доступу до полів шаблону</h1>
<p class="text-muted">@Model.TemplateNameUk · v@(Model.VersionNumber)</p>

@if (TempData["TemplateSuccess"] is string successMessage)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @successMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Закрити"></button>
    </div>
}

@if (!ViewData.ModelState.IsValid)
{
    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
}

@if (Model.IsPublishedVersion && Model.IsEditable)
{
    <div class="alert alert-warning">
        Версія <strong>опублікована</strong>. Тут можна змінювати лише <strong>права доступу до полів</strong>
        (розміщення полів на PDF — у <a asp-action="Map" asp-route-templateVersionId="@Model.TemplateVersionId">Map</a> — для чернетки).
    </div>
}
else if (!Model.IsEditable)
{
    <div class="alert alert-info">Замінену або анульовану версію змінювати заборонено.</div>
}

<form asp-action="Permissions" method="post">
    <input asp-for="TemplateVersionId" type="hidden" />
    <input asp-for="TemplateId" type="hidden" />
    <input asp-for="TemplateNameUk" type="hidden" />
    <input asp-for="VersionNumber" type="hidden" />
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Tag</th>
                <th>Title</th>
                @foreach (var role in UniversalLIMS.Application.Security.LimsRoles.All)
                {
                    <th>@role</th>
                }
            </tr>
        </thead>
        <tbody>
            @for (var i = 0; i < Model.Fields.Count; i++)
            {
                <tr>
                    <td>
                        <input asp-for="Fields[i].FieldId" type="hidden" />
                        <input asp-for="Fields[i].Tag" type="hidden" />
                        <input asp-for="Fields[i].Title" type="hidden" />
                        <code>@Model.Fields[i].Tag</code>
                    </td>
                    <td>@(Model.Fields[i].Title ?? "—")</td>
                    @for (var j = 0; j < Model.Fields[i].RolePermissions.Count; j++)
                    {
                        <td>
                            <input asp-for="Fields[i].RolePermissions[j].RoleName" type="hidden" />
                            <select asp-for="Fields[i].RolePermissions[j].AccessLevel" class="form-select" disabled="@(!Model.IsEditable)">
                                @foreach (var accessLevel in accessLevels)
                                {
                                    <option value="@accessLevel">@accessLevel</option>
                                }
                            </select>
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>

    @if (Model.IsEditable)
    {
        <button type="submit" class="btn btn-primary">Зберегти права</button>
    }
    <a class="btn btn-link" asp-controller="TemplateVersions" asp-action="Details" asp-route-id="@Model.TemplateVersionId">До версії</a>
</form>
