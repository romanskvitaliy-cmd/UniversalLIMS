            </div>
            <div class="cal-pane" data-cal-pane="actions" role="tabpanel">
                <button type="button" id="calResetField" class="btn btn-sm btn-outline-warning w-100 mb-1" data-cal-control>Скинути налаштування поля</button>
                <button type="button" id="calApplyAllFields" class="btn btn-sm btn-outline-secondary w-100 mb-1" data-cal-control>Застосувати до всіх полів</button>
                <button type="button" id="calResetAllOffsets" class="btn btn-sm btn-outline-danger w-100" data-cal-control>Скинути всі offset на шаблоні</button>
            </div>
        </div>
        <div class="cal-panel__footer">
            <span id="calSaveStatus" class="text-muted"></span>
            <button type="button" id="calSaveBtn" class="btn btn-sm btn-primary" disabled>💾 Зберегти</button>
            <button type="button" id="calPreviewPdf" class="btn btn-sm btn-success" disabled>Preview PDF</button>
        </div>
    </div>
    </div>
    <div id="overlayNudgePadFooter" class="nudge-pad-footer">
        <div class="d-flex justify-content-between align-items-center mb-1">
            <div class="small fw-semibold">Розміщення тегів</div>
            <button id="toggleNudgeTagList" type="button" class="btn btn-sm btn-outline-secondary py-0 px-2" aria-expanded="true">▾</button>
        </div>
        <div id="nudgeTagListSection">
            <input id="nudgeTagSearch" class="form-control form-control-sm mb-1" type="text" placeholder="Пошук тегу..." />
            <div id="nudgePlacedFields" class="small nudge-tag-list"></div>
        </div>
    </div>
</div>
<div id="nudgeHoverCard" class="nudge-hover-card"></div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    @if (Model.DocumentFormat == TemplateDocumentFormat.Pdf)
    {
        <script>
            (() => {
                const root = document.getElementById("pdfOverlayDesignerRoot");
                const zoomContainer = document.getElementById("pdfZoomContainer");
                const pagesHost = document.getElementById("pdfPagesHost");
                const previewError = document.getElementById("pdfPreviewError");
