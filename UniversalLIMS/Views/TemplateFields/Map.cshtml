                const overlayPlacedFields = document.getElementById("nudgePlacedFields");
                const overlayDebugStats = document.getElementById("overlayDebugStats");
                const deletedFieldIdsHost = document.getElementById("deletedFieldIdsHost");
                const overlayToast = document.getElementById("overlayToast");
                const nudgePad = document.getElementById("overlayNudgePad");
                const nudgePadHeader = document.getElementById("overlayNudgePadHeader");
                const nudgePadBody = document.getElementById("overlayNudgePadBody");
                const nudgePadDefaultTools = document.getElementById("nudgePadDefaultTools");
                const nudgePadTitleEl = document.getElementById("nudgePadTitle");
                const toggleNudgeInspectModeBtn = document.getElementById("toggleNudgeInspectMode");
                const toggleNudgeDetachModeBtn = document.getElementById("toggleNudgeDetachMode");
                const toggleNudgePadVisibilityBtn = document.getElementById("toggleNudgePadVisibility");
                const toggleNudgePadBodyBtn = document.getElementById("toggleNudgePadBody");
                const nudgeZoomSlider = document.getElementById("overlayNudgeZoomSlider");
                const nudgeZoomValue = document.getElementById("nudgeZoomValue");
                const updateNudgeZoomLabel = () => {
                    if (!nudgeZoomValue || !nudgeZoomSlider) return;
