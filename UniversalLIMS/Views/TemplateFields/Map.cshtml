                <th>Y</th>
                <th>Width</th>
                <th>Height</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @for (var i = 0; i < Model.Fields.Count; i++)
            {
                <tr>
                    <td>
                        <input asp-for="Fields[i].FieldId" type="hidden" />
                        <input asp-for="Fields[i].Tag" type="hidden" />
                        <input asp-for="Fields[i].Title" type="hidden" />
                        <input asp-for="Fields[i].WordControlType" type="hidden" />
                        <input asp-for="Fields[i].IsRequired" type="hidden" />
                        <input asp-for="Fields[i].TextOffsetX" type="hidden" class="js-field-text-offset-x" data-field-id="@Model.Fields[i].FieldId" />
                        <input asp-for="Fields[i].TextOffsetY" type="hidden" class="js-field-text-offset-y" data-field-id="@Model.Fields[i].FieldId" />
                        <code>@Model.Fields[i].Tag</code>
                    </td>
                    <td>@(Model.Fields[i].Title ?? "—")</td>
                    <td>@Model.Fields[i].WordControlType</td>
                    <td>
                        <select asp-for="Fields[i].DataFieldId" class="form-select" disabled="@(Model.IsEditable ? null : "disabled")">
                            <option value="">-- не прив'язано --</option>
                            @foreach (var dataField in Model.DataFields)
                            {
                                <option value="@dataField.Id">@dataField.Label</option>
                            }
                        </select>
                    </td>
                    <td>
                        <input asp-for="Fields[i].EstimatedCapacityChars" class="form-control" type="number" min="1" disabled="@(Model.IsEditable ? null : "disabled")" />
                    </td>
                    <td>
                        <input asp-for="Fields[i].MaxLines" class="form-control" type="number" min="1" disabled="@(Model.IsEditable ? null : "disabled")" />
                    </td>
                    <td class="text-center">
                        <input asp-for="Fields[i].AllowMultiline" class="form-check-input" disabled="@(Model.IsEditable ? null : "disabled")" />
                    </td>
                    <td>
                        <select asp-for="Fields[i].OverflowPolicy" class="form-select" disabled="@(Model.IsEditable ? null : "disabled")">
                            @foreach (var policy in overflowPolicies)
                            {
                                <option value="@policy">@policy</option>
                            }
                        </select>
                    </td>
                    <td>
                        <input asp-for="Fields[i].PageNumber" class="form-control" type="number" min="1" disabled="@(Model.IsEditable ? null : "disabled")" />
                    </td>
                    <td>
                        <input asp-for="Fields[i].PositionX" class="form-control" type="number" min="0" step="1" disabled="@(Model.IsEditable ? null : "disabled")" />
                    </td>
                    <td>
                        <input asp-for="Fields[i].PositionY" class="form-control" type="number" min="0" step="1" disabled="@(Model.IsEditable ? null : "disabled")" />
                    </td>
                    <td>
                        <input asp-for="Fields[i].Width" class="form-control" type="number" min="0" step="1" disabled="@(Model.IsEditable ? null : "disabled")" />
                    </td>
                    <td>
                        <input asp-for="Fields[i].Height" class="form-control" type="number" min="0" step="1" disabled="@(Model.IsEditable ? null : "disabled")" />
                    </td>
                    <td>
                        @if (Model.Fields[i].DataFieldId is null && Model.IsEditable)
                        {
                            <a class="btn btn-sm btn-outline-primary" asp-action="CreateDataField" asp-route-templateFieldId="@Model.Fields[i].FieldId">
                                Створити тег
                            </a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (Model.IsEditable)
    {
        <button type="submit" class="btn btn-primary">Зберегти поля</button>
    }
    <a class="btn btn-link" asp-controller="TemplateVersions" asp-action="Details" asp-route-id="@Model.TemplateVersionId">До версії</a>
</form>

