                     style="max-width: 100%;">
                    <div id="pdfZoomContainer" class="p-2">
                        <div id="pdfPagesHost"></div>
                    </div>
                    <div id="pdfPreviewError"
                         class="alert alert-warning m-2"
                         style="display:none;"></div>
                </div>
            </div>
            <div id="pdfTopControlsPanel" class="pdf-designer-sidebar">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <div class="fw-semibold">Пульт керування overlay</div>
                    <button id="closeTopControlsPanel" type="button" class="btn btn-sm btn-outline-secondary">Сховати</button>
                </div>
                <div class="row g-2">
                    <div class="col-lg-4">
                    <div class="mb-2">
                        <label class="form-label mb-1" for="overlayFieldSelector">Активний тег для постановки</label>
                        <select id="overlayFieldSelector" class="form-select form-select-sm">
                            <option value="">-- оберіть тег --</option>
                            @for (var i = 0; i < Model.Fields.Count; i++)
                            {
                                var optionTitle = string.IsNullOrWhiteSpace(Model.Fields[i].Title) ? "без опису" : Model.Fields[i].Title;
                                <option value="@i">@Model.Fields[i].Tag — @optionTitle</option>
                            }
                        </select>
                        <div id="activeSegmentSummary" class="small text-muted mt-1">Оберіть сегмент на PDF.</div>
                    </div>
                    <div class="mb-2">
                        <label class="form-label mb-1">DataField (словник)</label>
                        <div id="overlayDataFieldCombo"></div>
                    </div>
                    <div class="mb-2">
                        <label class="form-label mb-1" for="overlayZoomSlider">Масштаб preview: <span id="overlayZoomValue">100%</span></label>
                        <input id="overlayZoomSlider" class="form-range" type="range" min="75" max="300" step="5" value="100" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label mb-1" for="overlayFieldWidth">Ширина (px)</label>
                        <input id="overlayFieldWidth" class="form-control form-control-sm" type="number" min="20" step="1" />
                        <input id="overlayFieldWidthSlider" class="form-range mt-1" type="range" min="20" max="800" step="1" value="220" />
                        <div class="d-flex justify-content-between small text-muted">
                            <span>20</span><span id="overlayFieldWidthValue">220 px</span><span>800</span>
                        </div>
                    </div>
                    <div class="mb-2">
                        <label class="form-label mb-1" for="overlayFieldHeight">Висота (px)</label>
                        <input id="overlayFieldHeight" class="form-control form-control-sm" type="number" min="14" step="1" />
                        <input id="overlayFieldHeightSlider" class="form-range mt-1" type="range" min="14" max="240" step="1" value="28" />
                        <div class="d-flex justify-content-between small text-muted">
                            <span>14</span><span id="overlayFieldHeightValue">28 px</span><span>240</span>
                        </div>
                    </div>
                    <div class="mb-2">
                        <button id="applySelectedFieldSize" type="button" class="btn btn-sm btn-outline-secondary w-100">
                            Застосувати розмір
                        </button>
                    </div>
                    <div class="mb-2">
                        <button id="addSegmentLineButton" type="button" class="btn btn-sm btn-outline-primary w-100" style="display: none;">
                            Додати лінію
                        </button>
                    </div>
                    <div class="mb-2">
                        <button id="deleteActiveField" type="button" class="btn btn-sm btn-outline-danger w-100" style="display: none;">
                            🗑 Видалити тег
                        </button>
                    </div>
                    <div class="mb-2">
                        <button id="undoOverlayAction" type="button" class="btn btn-sm btn-outline-warning w-100">
                            Скасувати останню дію
                        </button>
                    </div>
                    <div class="mb-2">
                        <button id="arrangeAllFields" type="button" class="btn btn-sm btn-outline-primary w-100">
                            Вирівняти всі теги
                        </button>
                    </div>
                    <div class="mb-3">
                        <label class="form-label mb-1">Режим роботи</label>
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="editModeToggle" style="width: 52px; height: 26px;">
                            <label class="form-check-label fw-semibold" for="editModeToggle" id="editModeLabel">
                                🔒 Захищено
                            </label>
                        </div>
                        <small class="text-muted" id="editModeHint">Тільки перегляд</small>
                    </div>
                    <div id="editControls" style="display: none;">
                        <div class="d-flex gap-2 mb-2">
                            <button id="btnSingleMode" type="button" class="btn btn-sm btn-outline-primary flex-fill active">
                                ✏️ Тільки активний
                            </button>
                            <button id="btnAllMode" type="button" class="btn btn-sm btn-outline-warning flex-fill">
                                🖱️ Рухати всі
                            </button>
                        </div>
                        <div class="alert alert-warning py-2 small" id="editWarning" style="display: none;">
                            ⚠️ Увімкнено вільне розміщення всіх тегів
                        </div>
                    </div>
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" value="" id="overlaySnapToGrid" checked />
                        <label class="form-check-label" for="overlaySnapToGrid">Прив'язка до сітки (5 px)</label>
                    </div>
                    <div class="small text-muted">
                        Новий тег автоматично стає активним для редагування.
                    </div>
                    </div>
                    <div class="col-lg-4">
                    <hr class="my-2" />
                    <div class="small text-muted">
                        Нижня таблиця (Tag/Title/Page/X/Y/Width/Height) — це точні збережені параметри в БД.
                        Права панель — швидке керування для зручної постановки.
                    </div>
                    </div>
                    <div class="col-lg-4">
                    <hr class="my-2" />
                    <div id="overlayDebugStats" class="small text-muted mt-2"></div>
                    </div>
                </div>
                </div>
        </div>
        <div class="template-map-pdf-footer">
            @if (string.IsNullOrWhiteSpace(Model.PdfPreviewUrl))
            {
                <span class="pdf-overlay-card__hint">Preview URL не згенеровано.</span>
            }
            else
            {
                <span class="pdf-overlay-card__hint">Drag + resize · координати в пікселях preview</span>
                <a class="btn btn-sm btn-outline-secondary text-nowrap" href="@Model.PdfPreviewUrl" target="_blank" rel="noopener">Показати оригінал PDF</a>
            }
        </div>
    </div>
}

@if (Model.DocumentFormat == TemplateDocumentFormat.Pdf && string.IsNullOrWhiteSpace(Model.PdfPreviewUrl))
{
    <div class="alert alert-warning">
        Не вдалося побудувати URL для preview PDF.
    </div>
}
else if (Model.DocumentFormat == TemplateDocumentFormat.Pdf)
{
    <script src="~/js/searchable-combo.js" asp-append-version="true"></script>
    <script src="~/js/pdf-overlay-text-layout.js" asp-append-version="true"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js" referrerpolicy="no-referrer"></script>
    <script>
        window.__pdfPreviewUrl = "@Model.PdfPreviewUrl";
        window.__templateVersionId = "@Model.TemplateVersionId";
        window.__dataFieldCatalog = @Html.Raw(JsonSerializer.Serialize(
            Model.DataFields.Select(df => new
            {
                id = df.Id,
                key = df.Key,
                displayName = df.DisplayNameUk,
                groupName = df.GroupName
            })));
        window.__overlaySeedFields = @Html.Raw(JsonSerializer.Serialize(
            Model.Fields.Select((field, index) => new
            {
                index,
                tag = field.Tag,
                title = field.Title,
                page = field.PageNumber,
                x = field.PositionX,
                y = field.PositionY,
                width = field.Width,
                height = field.Height
            })));
    </script>
}

