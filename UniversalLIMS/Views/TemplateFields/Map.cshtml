                };
                const nudgeModeSingle = document.getElementById("nudgeModeSingle");
                const nudgeModeAll = document.getElementById("nudgeModeAll");
                const toggleNudgeTagListBtn = document.getElementById("toggleNudgeTagList");
                const nudgeTagListSection = document.getElementById("nudgeTagListSection");
                const nudgeTagSearch = document.getElementById("nudgeTagSearch");
                const smartSnapToggle = document.getElementById("overlaySmartSnapToggle");
                const autoInspectAfterOkToggle = document.getElementById("overlayAutoInspectAfterOkToggle");
                const openTopControlsPanel = document.getElementById("openTopControlsPanel");
                const closeTopControlsPanel = document.getElementById("closeTopControlsPanel");
                const topControlsPanel = document.getElementById("pdfTopControlsPanel");
                const designerFocusChrome = document.getElementById("designerFocusChrome");
                const toggleDesignerFocusModeBtn = document.getElementById("toggleDesignerFocusMode");
                const designerFocusToggleButtons = document.querySelectorAll(".js-toggle-designer-focus");
                const nudgeHoverCard = document.getElementById("nudgeHoverCard");
                const fieldMapForm = document.getElementById("fieldMapForm");
                const nudgePersistToDbBtn = document.getElementById("nudgePersistToDb");
                const nudgeSaveHint = document.getElementById("nudgeSaveHint");
                const nudgeAddSegmentLineButton = document.getElementById("nudgeAddSegmentLine");
                const segmentFontSizeInput = document.getElementById("segmentFontSize");
                const calibrationPanel = document.getElementById("calibrationPanel");
                const calibrationPanelHint = document.getElementById("calibrationPanelHint");
                const calEditingFieldEl = document.getElementById("calEditingField");
                const calExitCalibrationBtn = document.getElementById("calExitCalibration");
                const calExitCalibrationFullBtn = document.getElementById("calExitCalibrationFull");
                const calOffsetXInput = document.getElementById("calOffsetX");
                const calOffsetYInput = document.getElementById("calOffsetY");
                const calFontFamilySelect = document.getElementById("calFontFamily");
                const calFontSizeInput = document.getElementById("calFontSize");
                const calBoldBtn = document.getElementById("calBold");
                const calItalicBtn = document.getElementById("calItalic");
                const calUnderlineBtn = document.getElementById("calUnderline");
                const calTextColorInput = document.getElementById("calTextColor");
                const calTextColorHexInput = document.getElementById("calTextColorHex");
                const calLineHeightInput = document.getElementById("calLineHeight");
                const calLetterSpacingInput = document.getElementById("calLetterSpacing");
                const calLetterSpacingMinusBtn = document.getElementById("calLetterSpacingMinus");
                const calLetterSpacingPlusBtn = document.getElementById("calLetterSpacingPlus");
                const calResetFieldBtn = document.getElementById("calResetField");
                const calApplyAllFieldsBtn = document.getElementById("calApplyAllFields");
                const calResetAllOffsetsBtn = document.getElementById("calResetAllOffsets");
                const calSaveBtn = document.getElementById("calSaveBtn");
                const calSaveStatusEl = document.getElementById("calSaveStatus");
                const calPreviewPdfBtn = document.getElementById("calPreviewPdf");
                const calibrationToggleButtons = document.querySelectorAll(".js-toggle-calibration");
                const CAL_TEXT_STYLE_PREFIX = "ULIMS_TEXT_STYLE:";
                const CAL_AUTOSAVE_MS = 800;
                const CAL_OFFSET_MIN = -50;
                const CAL_OFFSET_MAX = 50;
                if (!root || !pagesHost) return;

                const showPreviewError = (message) => {
                    if (!previewError) return;
                    previewError.textContent = message;
                    previewError.style.display = "block";
                };

                const setInputValue = (index, key, value, round = true) => {
                    const input = document.getElementById(`Fields_${index}__${key}`);
                    if (!input) return;
                    if (!Number.isFinite(value)) {
                        input.value = "";
                        return;
                    }

                    input.value = round ? String(Math.round(value)) : String(value);
                };

                const showOverlayToast = (message, isError = false) => {
                    if (!overlayToast) return;
                    overlayToast.textContent = message;
                    overlayToast.classList.remove("alert-success", "alert-danger");
                    overlayToast.classList.add(isError ? "alert-danger" : "alert-success");
                    overlayToast.style.display = "block";
                    window.clearTimeout(showOverlayToast._timer);
                    showOverlayToast._timer = window.setTimeout(() => {
                        overlayToast.style.display = "none";
                    }, isError ? 3200 : 1700);
                };

                const parseServerErrorMessageFromResponse = async (response, fallback) => {
                    const contentType = response.headers.get("content-type") || "";
                    if (contentType.includes("application/json")) {
                        try {
                            const body = await response.json();
                            if (body?.message) {
                                return String(body.message);
                            }

                            if (body?.title) {
                                return String(body.title);
                            }

                            if (body?.errors && typeof body.errors === "object") {
                                const parts = [];
                                Object.values(body.errors).forEach((value) => {
                                    if (Array.isArray(value)) {
                                        value.forEach((item) => parts.push(String(item)));
                                    } else if (value) {
                                        parts.push(String(value));
                                    }
                                });
                                if (parts.length > 0) {
                                    return parts.join(" ");
                                }
                            }
                        } catch {
                            // fall through to plain text
                        }
                    }

                    try {
                        const text = (await response.text()).trim();
                        if (!text) {
                            return fallback;
                        }

                        try {
                            const body = JSON.parse(text);
                            if (body?.message) {
                                return String(body.message);
                            }
                        } catch {
                            // not JSON
                        }

                        return text.length <= 500 ? text : fallback;
                    } catch {
                        return fallback;
                    }
                };

                class FieldEngine {
                    static PREVIEW_SCALE = 1.35;

                    constructor() {
                        this.previewScale = FieldEngine.PREVIEW_SCALE;
                        this.zoomPercent = 100;
                        this.zoomDebounceId = null;
                        this.pdf = null;
                        this.pageLayers = new Map();
                        this.pageCanvases = new Map();
                        this.pageViewports = new Map();
                        this.boxesByIndex = new Map();
                        this.fieldByIndex = new Map();
                        this.fieldsByPage = new Map();
                        this.activeIndex = null;
                        this.activeFieldId = null;
                        this.activeSegmentId = null;
                        this.lastActiveSegmentByFieldId = new Map();
                        this.dragState = null;
                        this.resizeState = null;
                        this.lastApiFieldCount = 0;
                        this.lastApiSample = null;
                        this.lastRenderedSample = null;
                        this.debug = true;
                        this.editMode = "locked";
                        this.allEditable = false;
                        this.initialModeApplied = false;
                        this.nudgeStep = 1;
                        this.editSnapshot = null;
                        this.undoStack = [];
                        this.padDragState = null;
                        this.isNudgeBodyCollapsed = false;
                        this.isTagListCollapsed = false;
                        this.isNudgePadHidden = false;
                        this.isInspectMode = false;
                        this.storageKey = "universal-lims.overlay.nudge-state.v1";
                        this.layoutStorageKey = `universal-lims.overlay.layout.${window.__templateVersionId || "default"}`;
                        this.overlayInteractionConfig = {
                            smartSnapDistancePx: 7,
                            smartGuideDistancePx: 7,
                            holdStartDelayMs: 260,
                            holdRepeatMs: 65
                        };
                        this.smartSnapDistance = this.overlayInteractionConfig.smartSnapDistancePx;
                        this.smartGuideDistance = this.overlayInteractionConfig.smartGuideDistancePx;
                        this.smartSnapEnabled = true;
                        this.autoInspectAfterOk = true;
                        this.isNudgeDetached = false;
                        this.isFocusMode = false;
                        this.focusModeStorageKey = "universal-lims.template-map.focus-mode";
                        this.sizeHoldTimeoutId = null;
                        this.sizeHoldIntervalId = null;
                        this.moveHoldTimeoutId = null;
                        this.moveHoldIntervalId = null;
                        this.layoutSaveTimerId = null;
                        this.hasPendingDbSave = false;
                        this.isApplyingSavedDraft = false;
                        this.lastSavedSegmentFields = [];
                        this.calibrationMode = false;
                        this.calibrationByIndex = new Map();
                        this.calibrationEditingIndex = null;
                        this.calibrationAutosaveTimerId = null;
                        this.calibrationPanelSyncing = false;
                        this.calibrationDirty = false;
                        this.calibrationActiveTab = "text";
                    }

                    debugLog(...args) {
                        if (!this.debug) return;
                        console.log("[FieldEngine]", ...args);
                    }

                    getCoordinateScale() {
                        return this.zoomPercent / 100;
                    }

                    getViewportScale() {
                        return FieldEngine.PREVIEW_SCALE * this.getCoordinateScale();
                    }

                    getOutputScale() {
                        return Math.min(window.devicePixelRatio || 1, 3);
                    }

                    exportFieldsToBaseCoordinates() {
                        const coordScale = this.getCoordinateScale();
                        const baseFields = [];
                        this.fieldByIndex.forEach((field, index) => {
                            const box = this.boxesByIndex.get(index);
                            if (box) {
                                const page = Number.parseInt(box.dataset.page || "1", 10);
                                const previewField = this.getFieldInPreviewSpace(box, page);
                                baseFields.push({
                                    ...field,
                                    index,
                                    page: previewField.page,
                                    x: previewField.x,
                                    y: previewField.y,
                                    width: previewField.width,
                                    height: previewField.height
                                });
                                return;
                            }

                            baseFields.push({
                                ...field,
                                index,
                                x: (field.x ?? 0) / coordScale,
                                y: (field.y ?? 0) / coordScale,
                                width: (field.width ?? 220) / coordScale,
                                height: (field.height ?? 28) / coordScale
                            });
                        });

                        return baseFields.sort((left, right) => left.index - right.index);
                    }

                    schedulePdfZoomRefresh(newZoomPercent) {
                        window.clearTimeout(this.zoomDebounceId);
                        this.zoomDebounceId = window.setTimeout(() => {
                            this.refreshPdfZoom(newZoomPercent).catch((error) => {
                                console.error("PDF zoom refresh failed", error);
                            });
                        }, 120);
                    }

                    async refreshPdfZoom(newZoomPercent) {
                        if (!this.pdf) {
                            return;
                        }

                        const previousActiveIndex = this.activeIndex;
                        const baseFields = this.exportFieldsToBaseCoordinates();
                        this.zoomPercent = Math.max(75, Math.min(300, newZoomPercent));
                        this.previewScale = this.getViewportScale();
                        if (zoomContainer) {
                            zoomContainer.style.zoom = "";
                        }

                        await this.renderPages();

                        const displayFields = baseFields.map((field, overlayIndex) =>
                            this.normalizeField({ ...field, index: overlayIndex }, overlayIndex));
                        this.renderAllFields(displayFields);

                        if (previousActiveIndex !== null && this.boxesByIndex.has(previousActiveIndex)) {
                            this.setActive(previousActiveIndex);
                        }

                        if (this.calibrationMode) {
                            this.fieldByIndex.forEach((_field, index) => this.getCalibrationState(index));
                            this.syncAllCalibrationInlineEditors();
                        }

                        this.updateEditUI();
                        if (typeof syncHorizontalScrollbars === "function") {
                            syncHorizontalScrollbars();
                        }
                    }

                    saveNudgeUiState() {
                        if (!nudgePad) return;
                        const state = {
                            nudgeStep: this.nudgeStep,
                            smartSnapEnabled: this.smartSnapEnabled,
                            autoInspectAfterOk: this.autoInspectAfterOk,
                            isNudgeBodyCollapsed: this.isNudgeBodyCollapsed,
                            isTagListCollapsed: this.isTagListCollapsed,
                            isNudgePadHidden: this.isNudgePadHidden,
                            isNudgeDetached: this.isNudgeDetached,
                            isInspectMode: this.isInspectMode,
                            manualPos: nudgePad.dataset.manualPos === "1",
                            left: this.normalizePixel(nudgePad.style.left, 12),
                            top: this.normalizePixel(nudgePad.style.top, this.getDefaultNudgeTop())
                        };
                        try {
                            window.localStorage.setItem(this.storageKey, JSON.stringify(state));
                        } catch {
                            // ignore storage quota/browser privacy errors
                        }
                    }

                    loadNudgeUiState() {
                        try {
                            const raw = window.localStorage.getItem(this.storageKey);
                            if (!raw) return;
                            const state = JSON.parse(raw);
                            if (!state || typeof state !== "object") return;
                            if (Number.isInteger(state.nudgeStep) && [1, 5, 10].includes(state.nudgeStep)) {
                                this.nudgeStep = state.nudgeStep;
                            }
                            this.smartSnapEnabled = state.smartSnapEnabled !== false;
                            this.autoInspectAfterOk = state.autoInspectAfterOk !== false;
                            this.isNudgeBodyCollapsed = state.isNudgeBodyCollapsed === true;
                            this.isTagListCollapsed = state.isTagListCollapsed === true;
                            this.isNudgePadHidden = false;
                            this.isNudgeDetached = state.isNudgeDetached === true;
                            this.isInspectMode = state.isInspectMode === true;
                            if (nudgePad && state.manualPos === true) {
                                nudgePad.dataset.manualPos = "1";
                                nudgePad.style.left = `${this.normalizePixel(state.left, 12)}px`;
                                nudgePad.style.top = `${this.normalizePixel(state.top, this.getDefaultNudgeTop())}px`;
                            }
                        } catch {
                            // ignore broken JSON or blocked storage
                        }
                    }

                    async init() {
                        if (!window.pdfjsLib || !window.__pdfPreviewUrl) {
                            showPreviewError("Не вдалося ініціалізувати PDF preview.");
                            return;
                        }

                        const pdfjsLib = window.pdfjsLib;
                        pdfjsLib.GlobalWorkerOptions.workerSrc = "https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js";
                        this.pdf = await pdfjsLib.getDocument(window.__pdfPreviewUrl).promise;
                        this.debugLog("PDF loaded", { pages: this.pdf.numPages });
                        this.applyNudgeLayoutMode();
                        await this.renderPages();
                        this.updateEditUI();
                        // Гарантоване перезавантаження даних після повної ініціалізації сторінки
                        setTimeout(() => {
                            this.reloadFromServer();
                        }, 750);
                        await this.reloadFromServer();
                        this.bindUiEvents();
                    }

                    loadFocusModePreference() {
                        try {
                            const raw = window.localStorage.getItem(this.focusModeStorageKey);
                            if (raw === null) {
                                this.isFocusMode = true;
                                return;
                            }
                            this.isFocusMode = raw === "1";
                        } catch {
                            this.isFocusMode = true;
                        }
                    }

                    saveFocusModePreference() {
                        try {
                            window.localStorage.setItem(this.focusModeStorageKey, this.isFocusMode ? "1" : "0");
                        } catch {
                            // ignore storage errors
                        }
                    }

                    applyFocusMode() {
                        document.body.classList.toggle("template-map-focus-mode", this.isFocusMode);
                        if (designerFocusChrome) {
                            designerFocusChrome.hidden = !this.isFocusMode;
                            designerFocusChrome.setAttribute("aria-hidden", this.isFocusMode ? "false" : "true");
                        }
                        if (this.isFocusMode) {
                            this.isNudgeDetached = true;
                        }
                        this.applyNudgeLayoutMode();
                        this.applyNudgeDockedLayout();
                        if (!this.isNudgeDocked()) {
                            this.updateNudgePadPosition();
                        }
                        this.renderFocusModeButtons();
                        if (typeof syncHorizontalScrollbars === "function") {
                            setTimeout(syncHorizontalScrollbars, 0);
                        }
                    }

                    setFocusMode(enabled) {
                        this.isFocusMode = enabled === true;
                        this.saveFocusModePreference();
                        this.applyFocusMode();
                        this.applyNudgeLayoutMode();
                        this.applyNudgeDockedLayout();
                        if (!this.isFocusMode) {
                            this.updateNudgePadPosition();
                        }
                        if (typeof syncHorizontalScrollbars === "function") {
                            setTimeout(syncHorizontalScrollbars, 0);
                        }
                        showOverlayToast(this.isFocusMode ? "Режим конструктора увімкнено" : "Звичайний вигляд");
                    }

                    toggleFocusMode() {
                        this.setFocusMode(!this.isFocusMode);
                    }

                    renderFocusModeButtons() {
                        const isOn = this.isFocusMode === true;
                        if (toggleDesignerFocusModeBtn) {
                            toggleDesignerFocusModeBtn.classList.toggle("btn-primary", isOn);
                            toggleDesignerFocusModeBtn.classList.toggle("btn-outline-primary", !isOn);
                            toggleDesignerFocusModeBtn.title = isOn
                                ? "Вийти з режиму конструктора (Esc)"
                                : "Режим конструктора: лише PDF і пульт (F)";
                        }
                        designerFocusToggleButtons.forEach((button) => {
                            if (button === toggleDesignerFocusModeBtn) return;
                            button.textContent = isOn ? "↩ Звичайний вигляд" : "⛶ Режим конструктора";
                        });
                    }

                    isNudgeDocked() {
                        return document.body.classList.contains("designer-layout-body")
                            && this.isFocusMode === true;
                    }

                    applyNudgeDockedLayout() {
                        if (!nudgePad) return;
                        if (!this.isNudgeDocked()) {
                            nudgePad.classList.remove("nudge-pad-docked");
                            nudgePad.style.height = "";
                            nudgePad.style.maxHeight = "";
                            if (!this.isFocusMode && this.isNudgeDetached) {
                                nudgePad.style.top = `${this.getDefaultNudgeTop()}px`;
                                nudgePad.style.left = `${Math.max(8, window.innerWidth - (nudgePad.offsetWidth || 360) - 12)}px`;
                            }
                            return;
                        }
                        nudgePad.classList.add("nudge-pad-docked");
                        const padWidth = nudgePad.offsetWidth || 360;
                        nudgePad.dataset.manualPos = "1";
                        nudgePad.style.top = "0";
                        nudgePad.style.left = `${Math.max(0, window.innerWidth - padWidth)}px`;
                        nudgePad.style.height = "auto";
                        nudgePad.style.maxHeight = "calc(100vh - 70px)";
                    }

                    getDefaultNudgeTop() {
                        if (this.isNudgeDocked()) {
                            return 0;
                        }
                        const strip = document.querySelector(".template-map-strip");
                        if (strip && strip.offsetParent !== null) {
                            return Math.max(8, Math.round(strip.getBoundingClientRect().bottom) + 6);
                        }
                        return 36;
                    }

                    applyNudgeLayoutMode() {
                        if (!topControlsPanel || !nudgePad) return;
                        const grid = topControlsPanel.closest(".pdf-designer-grid");
                        if (this.isFocusMode || this.isNudgeDetached) {
                            topControlsPanel.style.display = "none";
                            grid?.classList.add("nudge-detached");
                            if (nudgePad.parentElement !== document.body) {
                                document.body.appendChild(nudgePad);
                            }
                            nudgePad.classList.remove("nudge-sidebar-mode");
                            nudgePad.style.display = "block";
                            this.applyNudgeDockedLayout();
                            if (!this.isNudgeDocked()) {
                                if (nudgePad.dataset.manualPos !== "1") {
                                    nudgePad.dataset.manualPos = "1";
                                    nudgePad.style.left = `${Math.max(8, window.innerWidth - (nudgePad.offsetWidth || 360) - 12)}px`;
                                    nudgePad.style.top = `${this.getDefaultNudgeTop()}px`;
                                }
                            }
                        } else {
                            nudgePad.classList.remove("nudge-pad-docked");
                            topControlsPanel.style.display = "block";
                            grid?.classList.remove("nudge-detached");
                            if (nudgePad.parentElement !== topControlsPanel) {
                                topControlsPanel.innerHTML = "";
                                topControlsPanel.appendChild(nudgePad);
                            }
                            nudgePad.classList.add("nudge-sidebar-mode");
                            nudgePad.style.display = "block";
                            delete nudgePad.dataset.manualPos;
                            nudgePad.style.left = "";
                            nudgePad.style.top = "";
                        }
                    }

                    async renderPages() {
                        pagesHost.innerHTML = "";
                        this.pageLayers.clear();
                        this.pageCanvases.clear();
                        this.pageViewports.clear();
                        const viewportScale = this.getViewportScale();
                        const outputScale = this.getOutputScale();
                        this.previewScale = viewportScale;

                        for (let pageNumber = 1; pageNumber <= this.pdf.numPages; pageNumber++) {
                            const page = await this.pdf.getPage(pageNumber);
                            const viewport = page.getViewport({ scale: viewportScale });
                            this.pageViewports.set(pageNumber, viewport);

                            const cssWidth = Math.floor(viewport.width);
                            const cssHeight = Math.floor(viewport.height);

                            const wrapper = document.createElement("div");
                            wrapper.className = "position-relative border bg-white mb-3 mx-auto";
                            wrapper.style.width = `${cssWidth}px`;
                            wrapper.style.height = `${cssHeight}px`;
                            wrapper.dataset.page = String(pageNumber);

                            const canvas = document.createElement("canvas");
                            canvas.width = Math.floor(cssWidth * outputScale);
                            canvas.height = Math.floor(cssHeight * outputScale);
                            canvas.style.width = `${cssWidth}px`;
                            canvas.style.height = `${cssHeight}px`;
                            wrapper.appendChild(canvas);
                            this.pageCanvases.set(pageNumber, canvas);

                            const layer = document.createElement("div");
                            layer.className = "position-absolute top-0 start-0 field-overlay-layer";
                            layer.style.width = `${cssWidth}px`;
                            layer.style.height = `${cssHeight}px`;
                            layer.style.pointerEvents = "all";
                            layer.style.zIndex = "30";
                            layer.dataset.page = String(pageNumber);
                            wrapper.appendChild(layer);
                            this.pageLayers.set(pageNumber, layer);
                            this.debugLog("Page layer created", { pageNumber, width: cssWidth, height: cssHeight });

                            pagesHost.appendChild(wrapper);
                            const ctx = canvas.getContext("2d", { alpha: false });
                            if (ctx) {
                                ctx.imageSmoothingEnabled = true;
                                ctx.imageSmoothingQuality = "high";
                                const transform = outputScale !== 1 ? [outputScale, 0, 0, outputScale, 0, 0] : null;
                                await page.render({
                                    canvasContext: ctx,
                                    viewport,
                                    transform
                                }).promise;
                            }
                        }
                    }

                    async reloadFromServer() {
                        const versionId = window.__templateVersionId;
                        let fields = [];

                        try {
                            const response = await fetch(`/api/template-fields/${versionId}`, { credentials: "same-origin" });
                            if (response.ok) {
                                fields = await response.json();
                                this.debugLog("API fields loaded", { count: Array.isArray(fields) ? fields.length : 0 });
                            }
                        } catch (e) {
                            this.debugLog("API fetch failed", e);
                        }

                        this.lastApiFieldCount = Array.isArray(fields) ? fields.length : 0;

                        // === КРИТИЧНА ЗМІНА ===
                        if (!Array.isArray(fields) || fields.length === 0) {
                            console.warn("[FieldEngine] API returned 0 fields. Possible save race or cache issue.");
                            this.clearOverlays();
                            this.renderPlacedFields();
                            this.renderDebugStats();
                            return;                    // НЕ падаємо на seed автоматично
                        }

                        this.lastApiSample = fields[0];

                        this.clearOverlays();
                        if (!this.hasPendingDbSave) {
                            try {
                                window.localStorage.removeItem(this.layoutStorageKey);
                            } catch {
                                // ignore storage issues
                            }
                        }

                        const prepared = this.expandApiFieldsToOverlayFields(fields);
                        this.renderAllFields(prepared);
                        this.applyInitialModeFromQuery();
                        this.debugLog("Fields rendered", { rendered: this.boxesByIndex.size, pages: this.pageLayers.size });
                        this.renderPlacedFields();
                        this.renderDebugStats();
                    }

                    clearOverlays() {
                        this.boxesByIndex.clear();
                        this.fieldByIndex.clear();
                        this.fieldsByPage.clear();
                        this.pageLayers.forEach(layer => layer.innerHTML = "");
                    }

                    renderAllFields(fields) {
                        this.pageLayers.forEach(layer => layer.innerHTML = "");
                        this.boxesByIndex.clear();
                        this.fieldByIndex.clear();
                        this.fieldsByPage.clear();

                        fields.forEach((field) => {
                            this.fieldByIndex.set(field.index, field);
                            const pageFields = this.fieldsByPage.get(field.page) ?? [];
                            pageFields.push(field);
                            this.fieldsByPage.set(field.page, pageFields);
                        });

                        this.fieldsByPage.forEach((pageFields) => {
                            pageFields.forEach((field) => {
                                this.renderFieldBox(field);
                                const box = this.boxesByIndex.get(field.index);
                                if (box) {
                                    this.syncBoxToInputs(box);
                                }
                            });
                        });

                        if (this.calibrationMode) {
                            this.fieldByIndex.forEach((_field, index) => this.getCalibrationState(index));
                            this.syncAllCalibrationInlineEditors();
                        }
                    }

                    expandApiFieldsToOverlayFields(fields) {
                        const overlayFields = [];
                        (fields ?? []).forEach((field) => {
                            this.resolveApiSegments(field).forEach((segment) => {
                                overlayFields.push(this.normalizeField(
                                    this.coerceSegmentField(field, segment, overlayFields.length),
                                    overlayFields.length));
                            });
                        });
                        return overlayFields;
                    }

                    resolveApiSegments(field) {
                        const source = field ?? {};
                        const rawSegments = Array.isArray(source.segments)
                            ? source.segments
                            : Array.isArray(source.Segments)
                                ? source.Segments
                                : [];
                        if (rawSegments.length > 0) {
                            return [...rawSegments]
                                .sort((left, right) => {
                                    const leftSequence = Number(left?.sequence ?? left?.Sequence ?? 0);
                                    const rightSequence = Number(right?.sequence ?? right?.Sequence ?? 0);
                                    return leftSequence - rightSequence;
                                })
                                .map((segment, index) => ({
                                    ...segment,
                                    sequence: index + 1
                                }));
                        }

                        return [{
                            id: null,
                            sequence: 1,
                            page: source.page ?? source.pageNumber ?? source.PageNumber ?? 1,
                            x: source.x ?? source.positionX ?? source.PositionX ?? 24,
                            y: source.y ?? source.positionY ?? source.PositionY ?? 24,
                            width: source.width ?? source.Width ?? 220,
                            height: source.height ?? source.Height ?? 28,
                            isPrimary: true,
                            textAlignment: "Left"
                        }];
                    }

                    coerceSegmentField(field, segment, overlayIndex) {
                        const source = field ?? {};
                        const segmentSource = segment ?? {};
                        const fieldId = this.normalizeGuidKey(
                            source.id ?? source.fieldId ?? source.templateFieldId ?? this.getFieldIdByIndex(overlayIndex));
                        const segmentSequence = this.readSegmentSequenceFromPayload(segmentSource, overlayIndex + 1);
                        const segmentId = segmentSource.id
                            ?? segmentSource.Id
                            ?? segmentSource.segmentId
                            ?? segmentSource.SegmentId
                            ?? `temp-${fieldId}-${segmentSequence}`;
                        const clientReferenceId = segmentSource.clientReferenceId
                            ?? segmentSource.ClientReferenceId
                            ?? this.createClientReferenceId();
                        return {
                            fieldId,
                            segmentId,
                            clientReferenceId,
                            segmentSequence,
                            segmentRowVersion: this.readRowVersionFromPayload(segmentSource),
                            tag: source.tag ?? source.Tag ?? `field_${overlayIndex + 1}`,
                            title: source.title ?? source.Title ?? "",
                            dataFieldId: source.dataFieldId ?? source.DataFieldId ?? null,
                            page: segmentSource.page ?? segmentSource.pageNumber ?? segmentSource.PageNumber ?? 1,
                            x: segmentSource.x ?? segmentSource.positionX ?? segmentSource.PositionX ?? 24,
                            y: segmentSource.y ?? segmentSource.positionY ?? segmentSource.PositionY ?? 24,
                            width: segmentSource.width ?? segmentSource.Width ?? 220,
                            height: segmentSource.height ?? segmentSource.Height ?? 28,
                            isPrimary: segmentSource.isPrimary ?? segmentSource.IsPrimary ?? segmentSequence === 1,
                            ...this.readTypographyFromSegmentSource(segmentSource),
                            textOffsetX: this.parsePixel(source.textOffsetX ?? source.TextOffsetX ?? 0),
                            textOffsetY: this.parsePixel(source.textOffsetY ?? source.TextOffsetY ?? 0),
                            formIndex: this.getIndexByFieldId(fieldId)
                        };
                    }

                    readTypographyFromSegmentSource(segmentSource) {
                        const source = segmentSource ?? {};
                        const horizontalAlignment = source.horizontalAlignment
                            ?? source.HorizontalAlignment
                            ?? source.textAlignment
                            ?? source.TextAlignment
                            ?? "Left";
                        const verticalAlignment = source.verticalAlignment ?? source.VerticalAlignment ?? null;
                        const fontSizeRaw = source.fontSize ?? source.FontSize;
                        const parsedFontSize = Number.parseFloat(String(fontSizeRaw ?? ""));
                        const lineHeightRaw = source.lineHeight ?? source.LineHeight;
                        const parsedLineHeight = Number.parseFloat(String(lineHeightRaw ?? ""));
                        const extraStyle = this.parseExtraTextStyle(
                            source.svgPathData ?? source.SvgPathData ?? null);
                        return {
                            horizontalAlignment,
                            verticalAlignment,
                            textAlignment: horizontalAlignment,
                            fontSize: Number.isFinite(parsedFontSize) && parsedFontSize > 0
                                ? parsedFontSize
                                : null,
                            fontName: (source.fontName ?? source.FontName ?? "").trim() || null,
                            lineHeight: Number.isFinite(parsedLineHeight) && parsedLineHeight > 0
                                ? parsedLineHeight
                                : null,
                            fontBold: extraStyle.fontBold === true,
                            fontItalic: extraStyle.fontItalic === true,
                            textUnderline: extraStyle.textUnderline === true,
                            textColor: extraStyle.textColor ?? "#111111",
                            letterSpacing: Number.isFinite(extraStyle.letterSpacing)
                                ? extraStyle.letterSpacing
                                : 0,
                            svgPathData: source.svgPathData ?? source.SvgPathData ?? null
                        };
                    }

                    parseExtraTextStyle(svgPathData) {
                        const raw = String(svgPathData ?? "").trim();
                        if (!raw.startsWith(CAL_TEXT_STYLE_PREFIX)) {
                            return {};
                        }

                        try {
                            const parsed = JSON.parse(raw.slice(CAL_TEXT_STYLE_PREFIX.length));
                            return {
                                fontBold: parsed?.b === true || parsed?.bold === true,
                                fontItalic: parsed?.i === true || parsed?.italic === true,
                                textUnderline: parsed?.u === true || parsed?.underline === true,
                                textColor: typeof parsed?.c === "string" ? parsed.c : parsed?.color,
                                letterSpacing: Number.parseFloat(String(parsed?.ls ?? parsed?.letterSpacing ?? ""))
                            };
                        } catch {
                            return {};
                        }
                    }

                    buildExtraTextStylePayload(field) {
                        if (!field) {
                            return null;
                        }

                        const hasExtra = field.fontBold === true
                            || field.fontItalic === true
                            || field.textUnderline === true
                            || (field.textColor && field.textColor !== "#111111")
                            || (Number.isFinite(field.letterSpacing) && field.letterSpacing !== 0);
                        if (!hasExtra) {
                            const legacy = String(field.svgPathData ?? "").trim();
                            return legacy.startsWith(CAL_TEXT_STYLE_PREFIX) ? null : (legacy || null);
                        }

                        return `${CAL_TEXT_STYLE_PREFIX}${JSON.stringify({
                            b: field.fontBold === true,
                            i: field.fontItalic === true,
                            u: field.textUnderline === true,
                            c: field.textColor || "#111111",
                            ls: this.parsePixel(field.letterSpacing ?? 0)
                        })}`;
                    }

                    getDefaultCalibrationTypography() {
                        return {
                            fontName: null,
                            fontSize: null,
                            lineHeight: null,
                            fontBold: false,
                            fontItalic: false,
                            textUnderline: false,
                            textColor: "#111111",
                            letterSpacing: 0,
                            horizontalAlignment: "Left",
                            verticalAlignment: "Bottom"
                        };
                    }

                    normalizeField(field, overlayIndex) {
                        const fallbackPage = 1;
                        const page = this.clampInt(field.page, 1, this.pdf.numPages, fallbackPage);
                        const rect = this.toViewportRect(field, page);
                        return {
                            fieldId: field.fieldId,
                            segmentId: field.segmentId,
                            clientReferenceId: field.clientReferenceId ?? this.createClientReferenceId(),
                            segmentRowVersion: field.segmentRowVersion ?? null,
                            segmentSequence: this.getOverlaySequence(field, overlayIndex),
                            formIndex: field.formIndex,
                            index: overlayIndex,
                            tag: field.tag || `field_${overlayIndex + 1}`,
                            title: (field.title || "").trim(),
                            page,
                            x: Math.max(0, rect.left),
                            y: Math.max(0, rect.top),
                            width: Math.max(20, rect.width),
                            height: Math.max(14, rect.height),
                            isPrimary: field.isPrimary === true,
                            textAlignment: field.textAlignment ?? field.horizontalAlignment ?? "Left",
                            horizontalAlignment: field.horizontalAlignment ?? field.textAlignment ?? "Left",
                            verticalAlignment: field.verticalAlignment ?? null,
                            fontSize: field.fontSize ?? null,
                            fontName: field.fontName ?? null,
                            lineHeight: field.lineHeight ?? null,
                            fontBold: field.fontBold === true,
                            fontItalic: field.fontItalic === true,
                            textUnderline: field.textUnderline === true,
                            textColor: field.textColor ?? "#111111",
                            letterSpacing: this.parsePixel(field.letterSpacing ?? 0),
                            svgPathData: field.svgPathData ?? null,
                            dataFieldId: field.dataFieldId ?? null,
                            textOffsetX: this.parsePixel(field.textOffsetX ?? 0),
                            textOffsetY: this.parsePixel(field.textOffsetY ?? 0)
                        };
                    }

                    toViewportRect(field, page) {
                        const viewport = this.pageViewports.get(page);
                        const coordScale = this.getCoordinateScale();
                        const rawX = Math.max(0, (Number(field.x) || 0) * coordScale);
                        const rawY = Math.max(0, (Number(field.y) || 0) * coordScale);
                        const rawW = Math.max(20, (Number(field.width) || 220) * coordScale);
                        const rawH = Math.max(14, (Number(field.height) || 28) * coordScale);
                        const rawRect = { left: rawX, top: rawY, width: rawW, height: rawH };
                        if (!viewport) {
                            return rawRect;
                        }

                        const layer = this.pageLayers.get(page);
                        const layerWidth = layer?.clientWidth ?? viewport.width;
                        const layerHeight = layer?.clientHeight ?? viewport.height;
                        const fitsLayer = (rect) =>
                            Number.isFinite(rect.left) &&
                            Number.isFinite(rect.top) &&
                            rect.width >= 8 &&
                            rect.height >= 8 &&
                            rect.left >= -4 &&
                            rect.top >= -4 &&
                            rect.left + rect.width <= layerWidth + 4 &&
                            rect.top + rect.height <= layerHeight + 4;

                        if (fitsLayer(rawRect)) {
                            return rawRect;
                        }

                        const [vx1, vy1] = viewport.convertToViewportPoint(rawX, rawY);
                        const [vx2, vy2] = viewport.convertToViewportPoint(rawX + rawW, rawY + rawH);
                        const converted = {
                            left: Math.min(vx1, vx2),
                            top: Math.min(vy1, vy2),
                            width: Math.abs(vx2 - vx1),
                            height: Math.abs(vy2 - vy1)
                        };

                        if (fitsLayer(converted)) {
                            return converted;
                        }

                        return rawRect;
                    }

                    getFieldInPreviewSpace(box, pageNum) {
                        const coordScale = this.getCoordinateScale();
                        return {
                            page: pageNum,
                            x: Math.max(0, Math.round(this.normalizePixel(box.style.left) / coordScale)),
                            y: Math.max(0, Math.round(this.normalizePixel(box.style.top) / coordScale)),
                            width: Math.max(20, Math.round(box.offsetWidth / coordScale)),
                            height: Math.max(14, Math.round(box.offsetHeight / coordScale))
                        };
                    }

                    renderFieldBox(field) {
                        const layer = this.pageLayers.get(field.page) ?? this.pageLayers.get(1);
                        if (!layer) return;
                        const maxLeft = Math.max(0, layer.clientWidth - field.width);
                        const maxTop = Math.max(0, layer.clientHeight - field.height);
                        field.x = Math.min(field.x, maxLeft);
                        field.y = Math.min(field.y, maxTop);

                        const box = document.createElement("div");
                        box.className = "position-absolute rounded field-overlay-box";
                        box.dataset.index = String(field.index);
                        box.dataset.fieldId = String(field.fieldId ?? "");
                        box.dataset.clientRef = String(field.clientReferenceId ?? this.createClientReferenceId());
                        box.dataset.segmentId = String(field.segmentId ?? "");
                        box.dataset.segmentSequence = String(this.getOverlaySequence(field, field.index));
                        box.dataset.rowVersion = String(field.segmentRowVersion ?? "");
                        box.setAttribute("data-row-version", String(field.segmentRowVersion ?? ""));
                        box.dataset.page = String(field.page);
                        box.style.left = `${field.x}px`;
                        box.style.top = `${field.y}px`;
                        box.style.width = `${field.width}px`;
                        box.style.height = `${field.height}px`;
                        box.style.cursor = "default";
                        box.style.border = "2px solid #6c757d";
                        box.style.background = "rgba(108, 117, 125, 0.16)";
                        box.style.zIndex = "20";
                        box.style.userSelect = "none";

                        const label = document.createElement("div");
                        label.className = "small px-1 text-truncate field-overlay-label";
                        label.style.background = "rgba(108, 117, 125, 0.9)";
                        label.style.color = "#fff";
                        label.style.fontWeight = "600";
                        label.textContent = `${field.title || field.tag} #${this.getOverlaySequence(field, field.index)}`;
                        box.appendChild(label);

                        const handlePositions = ["nw", "n", "ne", "e", "se", "s", "sw", "w"];
                        handlePositions.forEach((handle) => {
                            const el = document.createElement("div");
                            el.dataset.handle = handle;
                            el.style.position = "absolute";
                            el.style.width = "8px";
                            el.style.height = "8px";
                            el.style.background = "#0d6efd";
                            el.style.border = "1px solid #fff";
                            el.style.borderRadius = "2px";
                            el.style.display = "none";
                            el.style.zIndex = "40";
                            this.positionResizeHandle(el, handle);
                            box.appendChild(el);
                        });

                        layer.appendChild(box);
                        this.boxesByIndex.set(field.index, box);
                        this.debugLog("Box rendered", {
                            index: field.index,
                            page: field.page,
                            x: field.x,
                            y: field.y,
                            width: field.width,
                            height: field.height
                        });
                        if (!this.lastRenderedSample) {
                            this.lastRenderedSample = {
                                index: field.index,
                                page: field.page,
                                x: field.x,
                                y: field.y,
                                width: field.width,
                                height: field.height,
                                label: field.title || field.tag
                            };
                        }
                        this.bindBoxEvents(box);
                        this.applyBoxVisualState(box, field.index === this.activeIndex);
                        if (this.calibrationMode) {
                            this.ensureCalibrationInlineEditor(box, field);
                        }
                    }

                    normalizePixel(value, fallback = 0) {
                        const raw = Number.parseFloat(String(value));
                        if (!Number.isFinite(raw)) return fallback;
                        return Math.round(raw);
                    }

                    applyGridSnap(value) {
                        const rounded = this.normalizePixel(value);
                        if (snapToGridCheckbox?.checked) {
                            return Math.round(rounded / 5) * 5;
                        }
                        return rounded;
                    }

                    ensureSmartGuideElements(layer) {
                        if (!layer) return null;
                        let vertical = layer.querySelector(".smart-guide-line.vertical");
                        if (!vertical) {
                            vertical = document.createElement("div");
                            vertical.className = "smart-guide-line vertical";
                            layer.appendChild(vertical);
                        }
                        let horizontal = layer.querySelector(".smart-guide-line.horizontal");
                        if (!horizontal) {
                            horizontal = document.createElement("div");
                            horizontal.className = "smart-guide-line horizontal";
                            layer.appendChild(horizontal);
                        }
                        return { vertical, horizontal };
                    }

                    hideSmartGuides(layer) {
                        if (layer) {
                            layer.querySelectorAll(".smart-guide-line").forEach((line) => {
                                line.style.display = "none";
                            });
                            return;
                        }
                        this.pageLayers.forEach((pageLayer) => {
                            pageLayer.querySelectorAll(".smart-guide-line").forEach((line) => {
                                line.style.display = "none";
                            });
                        });
                    }

                    getSmartAlignmentCandidates(layer, activeBox) {
                        const x = [
                            { value: 0, snap: true },
                            { value: layer.clientWidth, snap: true }
                        ];
                        const y = [
                            { value: 0, snap: true },
                            { value: layer.clientHeight, snap: true }
                        ];

                        this.boxesByIndex.forEach((box) => {
                            if (!box || box === activeBox || box.parentElement !== layer) return;
                            const left = this.normalizePixel(box.style.left);
                            const top = this.normalizePixel(box.style.top);
                            const width = Math.max(1, Math.round(box.offsetWidth));
                            const height = Math.max(1, Math.round(box.offsetHeight));
                            const right = left + width;
                            const bottom = top + height;
                            const centerX = left + width / 2;
                            const centerY = top + height / 2;

                            x.push(
                                { value: left, snap: true },
                                { value: right, snap: true },
                                { value: centerX, snap: false }
                            );
                            y.push(
                                { value: top, snap: true },
                                { value: bottom, snap: true },
                                { value: centerY, snap: false }
                            );
                        });

                        return { x, y };
                    }

                    applySmartSnapAndGuides(box, layer, rawLeft, rawTop) {
                        const width = Math.max(1, Math.round(box.offsetWidth));
                        const height = Math.max(1, Math.round(box.offsetHeight));
                        const boundedLeft = Math.min(Math.max(0, rawLeft), Math.max(0, layer.clientWidth - width));
                        const boundedTop = Math.min(Math.max(0, rawTop), Math.max(0, layer.clientHeight - height));
                        const baseLeft = this.applyGridSnap(boundedLeft);
                        const baseTop = this.applyGridSnap(boundedTop);
                        if (!this.smartSnapEnabled) {
                            return {
                                left: this.normalizePixel(baseLeft),
                                top: this.normalizePixel(baseTop),
                                guideX: null,
                                guideY: null
                            };
                        }

                        const xPoints = [
                            { value: baseLeft, offset: 0, snap: true },
                            { value: baseLeft + width, offset: width, snap: true },
                            { value: baseLeft + width / 2, offset: width / 2, snap: false }
                        ];
                        const yPoints = [
                            { value: baseTop, offset: 0, snap: true },
                            { value: baseTop + height, offset: height, snap: true },
                            { value: baseTop + height / 2, offset: height / 2, snap: false }
                        ];

                        const candidates = this.getSmartAlignmentCandidates(layer, box);
                        let bestGuideX = null;
                        let bestGuideY = null;
                        let bestSnapX = null;
                        let bestSnapY = null;

                        candidates.x.forEach((candidate) => {
                            xPoints.forEach((point) => {
                                const dist = Math.abs(candidate.value - point.value);
                                if (dist <= this.smartGuideDistance && (!bestGuideX || dist < bestGuideX.dist)) {
                                    bestGuideX = { dist, value: candidate.value };
                                }
                                if (candidate.snap && point.snap && dist <= this.smartSnapDistance && (!bestSnapX || dist < bestSnapX.dist)) {
                                    bestSnapX = { dist, left: candidate.value - point.offset, guide: candidate.value };
                                }
                            });
                        });

                        candidates.y.forEach((candidate) => {
                            yPoints.forEach((point) => {
                                const dist = Math.abs(candidate.value - point.value);
                                if (dist <= this.smartGuideDistance && (!bestGuideY || dist < bestGuideY.dist)) {
                                    bestGuideY = { dist, value: candidate.value };
                                }
                                if (candidate.snap && point.snap && dist <= this.smartSnapDistance && (!bestSnapY || dist < bestSnapY.dist)) {
                                    bestSnapY = { dist, top: candidate.value - point.offset, guide: candidate.value };
                                }
                            });
                        });

                        let nextLeft = baseLeft;
                        let nextTop = baseTop;
                        if (bestSnapX) {
                            nextLeft = bestSnapX.left;
                            bestGuideX = { dist: bestSnapX.dist, value: bestSnapX.guide };
                        }
                        if (bestSnapY) {
                            nextTop = bestSnapY.top;
                            bestGuideY = { dist: bestSnapY.dist, value: bestSnapY.guide };
                        }

                        nextLeft = Math.min(Math.max(0, nextLeft), Math.max(0, layer.clientWidth - width));
                        nextTop = Math.min(Math.max(0, nextTop), Math.max(0, layer.clientHeight - height));
                        return {
                            left: this.normalizePixel(nextLeft),
                            top: this.normalizePixel(nextTop),
                            guideX: bestGuideX?.value ?? null,
                            guideY: bestGuideY?.value ?? null
                        };
                    }

                    renderSmartGuides(layer, guideX, guideY) {
                        const lines = this.ensureSmartGuideElements(layer);
                        if (!lines) return;
                        if (Number.isFinite(guideX)) {
                            const x = Math.min(Math.max(0, this.normalizePixel(guideX)), layer.clientWidth);
                            lines.vertical.style.left = `${x}px`;
                            lines.vertical.style.display = "block";
                        } else {
                            lines.vertical.style.display = "none";
                        }
                        if (Number.isFinite(guideY)) {
                            const y = Math.min(Math.max(0, this.normalizePixel(guideY)), layer.clientHeight);
                            lines.horizontal.style.top = `${y}px`;
                            lines.horizontal.style.display = "block";
                        } else {
                            lines.horizontal.style.display = "none";
                        }
                    }

                    getSizeLevel(height) {
                        if (height < 12) return "critical";
                        if (height <= 22) return "small";
                        return "normal";
                    }

                    getCompactLabel(text, maxChars, fallback) {
                        const source = (text || "").trim();
                        if (!source) return fallback;
                        if (source.length <= maxChars) return source;
                        return `${source.slice(0, maxChars)}...`;
                    }

                    getTwoThreeWordLabel(text, fallback) {
                        const source = (text || "").trim();
                        if (!source) return fallback;
                        const words = source.split(/\s+/).filter(Boolean).slice(0, 3);
                        if (words.length === 0) return fallback;
                        return words.join(" ");
                    }

                    showNudgeHoverCard(event, details, anchorEl) {
                        if (!nudgeHoverCard) return;
                        nudgeHoverCard.innerHTML = details;
                        nudgeHoverCard.style.display = "block";
                        this.positionNudgeHoverCard(event, anchorEl);
                    }

                    positionNudgeHoverCard(event, anchorEl) {
                        if (!nudgeHoverCard || nudgeHoverCard.style.display === "none") return;
                        const cardWidth = nudgeHoverCard.offsetWidth || 280;
                        const cardHeight = nudgeHoverCard.offsetHeight || 120;
                        const gap = 10;
                        const margin = 8;
                        const anchor = anchorEl || event?.currentTarget;
                        let left;
                        let top;

                        if (anchor instanceof Element) {
                            const itemRect = anchor.getBoundingClientRect();
                            const listRect = overlayPlacedFields?.getBoundingClientRect();
                            const anchorLeft = listRect?.left ?? itemRect.left;
                            left = anchorLeft - cardWidth - gap;
                            top = itemRect.top + Math.max(0, (itemRect.height - cardHeight) / 2);

                            if (left < margin) {
                                left = Math.max(margin, itemRect.right + gap);
                            }
                            if (top + cardHeight > window.innerHeight - margin) {
                                top = window.innerHeight - cardHeight - margin;
                            }
                        } else {
                            left = (event?.clientX ?? 0) + 12;
                            top = (event?.clientY ?? 0) + 12;
                        }

                        left = Math.min(window.innerWidth - cardWidth - margin, Math.max(margin, left));
                        top = Math.min(window.innerHeight - cardHeight - margin, Math.max(margin, top));
                        nudgeHoverCard.style.left = `${Math.round(left)}px`;
                        nudgeHoverCard.style.top = `${Math.round(top)}px`;
                    }

                    hideNudgeHoverCard() {
                        if (!nudgeHoverCard) return;
                        nudgeHoverCard.style.display = "none";
                    }

                    positionResizeHandle(handleEl, handle) {
                        const mappings = {
                            nw: { left: "-4px", top: "-4px", cursor: "nwse-resize" },
                            n: { left: "50%", top: "-4px", transform: "translateX(-50%)", cursor: "ns-resize" },
                            ne: { right: "-4px", top: "-4px", cursor: "nesw-resize" },
                            e: { right: "-4px", top: "50%", transform: "translateY(-50%)", cursor: "ew-resize" },
                            se: { right: "-4px", bottom: "-4px", cursor: "nwse-resize" },
                            s: { left: "50%", bottom: "-4px", transform: "translateX(-50%)", cursor: "ns-resize" },
                            sw: { left: "-4px", bottom: "-4px", cursor: "nesw-resize" },
                            w: { left: "-4px", top: "50%", transform: "translateY(-50%)", cursor: "ew-resize" }
                        };
                        const cfg = mappings[handle];
                        if (!cfg) return;
                        if (cfg.left) handleEl.style.left = cfg.left;
                        if (cfg.right) handleEl.style.right = cfg.right;
                        if (cfg.top) handleEl.style.top = cfg.top;
                        if (cfg.bottom) handleEl.style.bottom = cfg.bottom;
                        if (cfg.transform) handleEl.style.transform = cfg.transform;
                        handleEl.style.cursor = cfg.cursor;
                    }

                    canEditBox(box) {
                        if (!box) return false;
                        if (this.calibrationMode) return false;
                        if (this.isInspectMode) return false;
                        if (this.editMode !== "edit") return false;
                        const boxIndex = Number.parseInt(box.dataset.index || "-1", 10);
                        return this.allEditable || boxIndex === this.activeIndex;
                    }

                    applyBoxVisualState(box, isActive, isLinked = false) {
                        const label = box.firstElementChild;
                        const isEditable = this.canEditBox(box);
                        const index = Number.parseInt(box.dataset.index || "-1", 10);
                        const field = this.fieldByIndex.get(index);
                        const fullLabel = field
                            ? `${field.title || field.tag} #${field.segmentSequence ?? 1}`
                            : "Тег";
                        const level = this.calibrationMode
                            ? "normal"
                            : this.getSizeLevel(Math.round(box.offsetHeight));
                        box.dataset.sizeLevel = level;

                        box.classList.toggle("active", isActive);
                        box.classList.toggle("linked", isLinked);
                        box.classList.toggle("field-segment-active", isActive);
                        box.classList.toggle("field-group-member", isLinked);
                        if (this.calibrationMode) {
                            box.style.cursor = "text";
                            box.style.border = "none";
                            box.style.background = "transparent";
                            box.style.boxShadow = "none";
                            box.style.opacity = "1";
                            box.title = fullLabel;
                            return;
                        } else if (this.editMode === "edit" && this.allEditable) {
                            box.style.border = isActive ? "3.5px solid #fd7e14" : (isLinked ? "2.5px solid #6610f2" : "2px solid #dc3545");
                            box.style.background = isActive ? "rgba(253, 126, 20, 0.24)" : (isLinked ? "rgba(102, 16, 242, 0.18)" : "rgba(220, 53, 69, 0.16)");
                        } else if (isActive) {
                            box.style.border = "3.5px solid #0d6efd";
                            box.style.background = "rgba(13, 110, 253, 0.24)";
                        } else if (isLinked) {
                            box.style.border = "2.5px solid #6610f2";
                            box.style.background = "rgba(102, 16, 242, 0.18)";
                        } else {
                            box.style.border = "2px solid #6c757d";
                            box.style.background = "rgba(108, 117, 125, 0.16)";
                        }

                        box.style.boxShadow = isActive
                            ? "0 0 0 5px rgba(13, 110, 253, 0.35)"
                            : (isLinked ? "0 0 0 3px rgba(102, 16, 242, 0.28)" : "none");
                        box.style.zIndex = isActive ? "48" : (isLinked ? "34" : "20");
                        if (!this.calibrationMode) {
                            box.style.cursor = isEditable ? "move" : "default";
                            box.style.opacity = this.editMode === "locked" ? "0.68" : (isActive ? "1" : "0.82");
                        }
                        box.title = fullLabel;

                        if (label) {
                            label.style.background = isActive
                                ? "#0d6efd"
                                : (isLinked ? "rgba(102, 16, 242, 0.92)" : "rgba(108, 117, 125, 0.9)");
                            label.style.color = "#fff";
                            label.style.fontWeight = isActive ? "700" : "600";
                            label.style.fontSize = isActive ? "0.82rem" : "0.72rem";
                            if (level === "small") {
                                label.style.fontSize = "11px";
                                label.textContent = this.getCompactLabel(fullLabel, 24, field?.tag || "T");
                            } else if (level === "critical") {
                                label.style.fontSize = "9px";
                                label.textContent = (field?.tag || fullLabel || "T").slice(0, 1).toUpperCase();
                            } else {
                                label.textContent = fullLabel;
                            }
                        }

                        box.querySelectorAll("[data-handle]").forEach((handleEl) => {
                            handleEl.style.display = isEditable && isActive ? "block" : "none";
                        });
                    }

                    updateAllBoxVisualStates() {
                        this.boxesByIndex.forEach((box, boxIndex) => {
                            const field = this.fieldByIndex.get(boxIndex);
                            const isActive = boxIndex === this.activeIndex;
                            const isLinked = Boolean(
                                this.activeFieldId &&
                                this.normalizeGuidKey(field?.fieldId) === this.activeFieldId &&
                                boxIndex !== this.activeIndex);
                            this.applyBoxVisualState(box, isActive, isLinked);
                        });
                    }

                    bindBoxEvents(box) {
                        box.addEventListener("click", (event) => {
                            event.stopPropagation();
                            const index = Number.parseInt(box.dataset.index || "-1", 10);
                            this.setActive(index);
                            if (this.calibrationMode && Number.isInteger(index)) {
                                this.focusCalibrationInlineEditor(index);
                            }
                        });

                        box.querySelectorAll("[data-handle]").forEach((handleEl) => {
                            handleEl.addEventListener("mousedown", (event) => {
                                event.stopPropagation();
                                if (event.button !== 0) return;

                                if (!this.canEditBox(box)) {
                                    event.preventDefault();
                                    this.setActive(Number(box.dataset.index));
                                    return;
                                }

                                this.resizeState = {
                                    box,
                                    handle: handleEl.dataset.handle,
                                    startX: event.clientX,
                                    startY: event.clientY,
                                    startLeft: parseFloat(box.style.left || "0"),
                                    startTop: parseFloat(box.style.top || "0"),
                                    startWidth: box.offsetWidth,
                                    startHeight: box.offsetHeight
                                };
                                this.pushUndoState("resize");
                                event.preventDefault();
                            });
                        });

                        box.addEventListener("mousedown", (event) => {
                            if (event.button !== 0) return;
                            const boxIndex = Number.parseInt(box.dataset.index || "-1", 10);
                            if (Number.isInteger(boxIndex) && boxIndex >= 0) {
                                // Ensure dragged box becomes active immediately so nudge pad is visible.
                                this.setActive(boxIndex);
                            }

                            const isMovable = this.canEditBox(box);

                            if (!isMovable) {
                                event.preventDefault();
                                return;
                            }

                            this.dragState = {
                                box,
                                startX: event.clientX,
                                startY: event.clientY,
                                left: parseFloat(box.style.left || "0"),
                                top: parseFloat(box.style.top || "0")
                            };
                            this.pushUndoState("move");
                            event.preventDefault();
                        });
                    }

                    bindUiEvents() {
                        this.loadNudgeUiState();
                        this.loadFocusModePreference();
                        if (this.isFocusMode) {
                            this.isNudgeDetached = true;
                        }
                        this.applyFocusMode();
                        document.addEventListener("mousemove", (event) => {
                            if (this.resizeState) {
                                this.hideSmartGuides(this.resizeState.box?.parentElement ?? null);
                                const { box, handle, startX, startY, startLeft, startTop, startWidth, startHeight } = this.resizeState;
                                const layer = box.parentElement;
                                if (!layer) return;

                                const minWidth = 20;
                                const minHeight = 14;
                                const dx = event.clientX - startX;
                                const dy = event.clientY - startY;

                                let nextLeft = startLeft;
                                let nextTop = startTop;
                                let nextWidth = startWidth;
                                let nextHeight = startHeight;

                                if (handle.includes("e")) nextWidth = startWidth + dx;
                                if (handle.includes("s")) nextHeight = startHeight + dy;
                                if (handle.includes("w")) {
                                    nextWidth = startWidth - dx;
                                    nextLeft = startLeft + dx;
                                }
                                if (handle.includes("n")) {
                                    nextHeight = startHeight - dy;
                                    nextTop = startTop + dy;
                                }

                                if (nextWidth < minWidth) {
                                    if (handle.includes("w")) nextLeft -= (minWidth - nextWidth);
                                    nextWidth = minWidth;
                                }
                                if (nextHeight < minHeight) {
                                    if (handle.includes("n")) nextTop -= (minHeight - nextHeight);
                                    nextHeight = minHeight;
                                }

                                nextLeft = Math.max(0, Math.min(nextLeft, layer.clientWidth - nextWidth));
                                nextTop = Math.max(0, Math.min(nextTop, layer.clientHeight - nextHeight));
                                nextWidth = Math.min(nextWidth, layer.clientWidth - nextLeft);
                                nextHeight = Math.min(nextHeight, layer.clientHeight - nextTop);

                                box.style.left = `${this.applyGridSnap(nextLeft)}px`;
                                box.style.top = `${this.applyGridSnap(nextTop)}px`;
                                box.style.width = `${Math.max(20, this.normalizePixel(nextWidth, 20))}px`;
                                box.style.height = `${Math.max(12, this.normalizePixel(nextHeight, 12))}px`;
                                this.syncBoxToInputs(box);
                                this.setActive(Number(box.dataset.index));
                                this.renderPlacedFields();
                                this.renderDebugStats();
                                this.updateNudgePadPosition();
                                return;
                            }

                            if (!this.dragState) return;
                            const { box, startX, startY, left, top } = this.dragState;
                            const layer = box.parentElement;
                            if (!layer) return;
                            const dx = event.clientX - startX;
                            const dy = event.clientY - startY;
                            const width = box.offsetWidth;
                            const height = box.offsetHeight;
                            const nextLeft = Math.min(Math.max(0, left + dx), Math.max(0, layer.clientWidth - width));
                            const nextTop = Math.min(Math.max(0, top + dy), Math.max(0, layer.clientHeight - height));
                            const smartMove = this.applySmartSnapAndGuides(box, layer, nextLeft, nextTop);
                            box.style.left = `${smartMove.left}px`;
                            box.style.top = `${smartMove.top}px`;
                            this.renderSmartGuides(layer, smartMove.guideX, smartMove.guideY);
                            this.syncBoxToInputs(box);
                            this.renderPlacedFields();
                            this.renderDebugStats();
                            this.updateNudgePadPosition();
                        });
                        document.addEventListener("mouseup", () => {
                            this.dragState = null;
                            this.resizeState = null;
                            this.hideSmartGuides();
                        });

                        this.pageLayers.forEach((layer, pageNumber) => {
                            layer.addEventListener("click", (event) => {
                                if (this.editMode !== "edit") return;
                                if (this.activeIndex === null) return;
                                const box = this.boxesByIndex.get(this.activeIndex);
                                if (!box) return;
                                const rect = layer.getBoundingClientRect();
                                if (box.parentElement !== layer) {
                                    layer.appendChild(box);
                                    box.dataset.page = String(pageNumber);
                                }
                                this.pushUndoState("reposition");
                                const left = event.clientX - rect.left;
                                const top = event.clientY - rect.top;
                                box.style.left = `${this.applyGridSnap(Math.max(0, Math.min(left, layer.clientWidth - box.offsetWidth)))}px`;
                                box.style.top = `${this.applyGridSnap(Math.max(0, Math.min(top, layer.clientHeight - box.offsetHeight)))}px`;
                                this.syncBoxToInputs(box);
                                this.renderPlacedFields();
                                this.renderDebugStats();
                                this.updateNudgePadPosition();
                            });
                        });

                        fieldSelector?.addEventListener("change", () => {
                            const formIndex = Number.parseInt(fieldSelector.value || "-1", 10);
                            const fieldId = this.getFieldIdByIndex(formIndex);
                            const overlayIndex = this.getOverlayIndexForField(fieldId, this.lastActiveSegmentByFieldId.get(fieldId));
                            this.setActive(overlayIndex ?? -1);
                        });
                        addSegmentLineButton?.addEventListener("click", () => this.addSegmentLine());
                        nudgeAddSegmentLineButton?.addEventListener("click", () => this.addSegmentLine());
                        applySizeButton?.addEventListener("click", () => this.applySize());
                        deleteActiveFieldButton?.addEventListener("click", () => this.deleteActiveField());
                        widthInput?.addEventListener("input", () => {
                            if (!widthSlider) return;
                            const value = Math.max(20, Number.parseFloat(widthInput.value || "0") || 220);
                            widthSlider.value = String(Math.round(value));
                            this.updateSizeScaleLabels();
                            this.applySize();
                        });
                        heightInput?.addEventListener("input", () => {
                            if (!heightSlider) return;
                            const value = Math.max(14, Number.parseFloat(heightInput.value || "0") || 28);
                            heightSlider.value = String(Math.round(value));
                            this.updateSizeScaleLabels();
                            this.applySize();
                        });
                        widthSlider?.addEventListener("input", () => {
                            if (!widthInput) return;
                            widthInput.value = widthSlider.value;
                            this.updateSizeScaleLabels();
                            this.applySize();
                        });
                        heightSlider?.addEventListener("input", () => {
                            if (!heightInput) return;
                            heightInput.value = heightSlider.value;
                            this.updateSizeScaleLabels();
                            this.applySize();
                        });
                        const editToggle = document.getElementById("editModeToggle");
                        const allModeBtn = document.getElementById("btnAllMode");
                        const singleModeBtn = document.getElementById("btnSingleMode");

                        editToggle?.addEventListener("change", () => this.toggleEditMode());
                        allModeBtn?.addEventListener("click", () => this.toggleAllEditable());
                        singleModeBtn?.addEventListener("click", () => {
                            if (this.editMode !== "edit") return;
                            this.allEditable = false;
                            this.updateEditUI();
                            this.setActive(this.activeIndex);
                        });
                        nudgePad?.querySelectorAll("[data-nudge-step]").forEach((buttonEl) => {
                            buttonEl.addEventListener("click", () => {
                                const step = Number.parseInt(buttonEl.getAttribute("data-nudge-step") || "1", 10);
                                if (!Number.isInteger(step) || step <= 0) return;
                                this.nudgeStep = step;
                                this.renderNudgeStepButtons();
                                this.saveNudgeUiState();
                            });
                        });
                        smartSnapToggle?.addEventListener("change", () => {
                            this.smartSnapEnabled = smartSnapToggle.checked;
                            if (!this.smartSnapEnabled) {
                                this.hideSmartGuides();
                            }
                            this.saveNudgeUiState();
                        });
                        autoInspectAfterOkToggle?.addEventListener("change", () => {
                            this.autoInspectAfterOk = autoInspectAfterOkToggle.checked;
                            this.saveNudgeUiState();
                        });
                        nudgeZoomSlider?.addEventListener("input", () => {
                            if (!zoomSlider) return;
                            zoomSlider.value = nudgeZoomSlider.value;
                            updateNudgeZoomLabel();
                            zoomSlider.dispatchEvent(new Event("input", { bubbles: true }));
                        });
                        nudgeModeSingle?.addEventListener("click", () => {
                            this.isInspectMode = false;
                            this.editMode = "edit";
                            this.allEditable = false;
                            this.updateEditUI();
                            this.setActive(this.activeIndex);
                            this.saveNudgeUiState();
                        });
                        nudgeModeAll?.addEventListener("click", () => {
                            this.isInspectMode = false;
                            this.editMode = "edit";
                            this.allEditable = true;
                            this.updateEditUI();
                            this.setActive(this.activeIndex);
                            this.saveNudgeUiState();
                        });
                        nudgePad?.querySelectorAll("[data-nudge-move]").forEach((buttonEl) => {
                            buttonEl.addEventListener("mousedown", (event) => {
                                if (event.button !== 0) return;
                                const direction = buttonEl.getAttribute("data-nudge-move");
                                this.startNudgeMoveHold(direction);
                                event.preventDefault();
                            });
                            buttonEl.addEventListener("touchstart", (event) => {
                                const direction = buttonEl.getAttribute("data-nudge-move");
                                this.startNudgeMoveHold(direction);
                                event.preventDefault();
                            }, { passive: false });
                            buttonEl.addEventListener("mouseup", () => this.stopNudgeMoveHold());
                            buttonEl.addEventListener("mouseleave", () => this.stopNudgeMoveHold());
                            buttonEl.addEventListener("touchend", () => this.stopNudgeMoveHold());
                            buttonEl.addEventListener("touchcancel", () => this.stopNudgeMoveHold());
                            buttonEl.addEventListener("keydown", (event) => {
                                if (event.key !== "Enter" && event.key !== " ") return;
                                const direction = buttonEl.getAttribute("data-nudge-move");
                                this.applyNudgeMoveDirection(direction);
                                event.preventDefault();
                            });
                        });
                        nudgePad?.querySelectorAll("[data-nudge-size]").forEach((buttonEl) => {
                            buttonEl.addEventListener("mousedown", (event) => {
                                if (event.button !== 0) return;
                                const mode = buttonEl.getAttribute("data-nudge-size");
                                this.startNudgeSizeHold(mode);
                                event.preventDefault();
                            });
                            buttonEl.addEventListener("touchstart", (event) => {
                                const mode = buttonEl.getAttribute("data-nudge-size");
                                this.startNudgeSizeHold(mode);
                                event.preventDefault();
                            }, { passive: false });
                            buttonEl.addEventListener("mouseup", () => this.stopNudgeSizeHold());
                            buttonEl.addEventListener("mouseleave", () => this.stopNudgeSizeHold());
                            buttonEl.addEventListener("touchend", () => this.stopNudgeSizeHold());
                            buttonEl.addEventListener("touchcancel", () => this.stopNudgeSizeHold());
                            buttonEl.addEventListener("keydown", (event) => {
                                if (event.key !== "Enter" && event.key !== " ") return;
                                const mode = buttonEl.getAttribute("data-nudge-size");
                                this.applyNudgeSizeMode(mode);
                                event.preventDefault();
                            });
                        });
                        document.addEventListener("mouseup", () => {
                            this.stopNudgeSizeHold();
                            this.stopNudgeMoveHold();
                        });
                        document.addEventListener("touchend", () => {
                            this.stopNudgeSizeHold();
                            this.stopNudgeMoveHold();
                        });
                        document.addEventListener("visibilitychange", () => {
                            if (document.hidden) {
                                this.stopNudgeSizeHold();
                                this.stopNudgeMoveHold();
                            }
                        });
                        this.bindSegmentTextSettingsEvents();
                        this.bindCalibrationEvents();
                        document.getElementById("nudgeConfirm")?.addEventListener("click", () => this.commitActiveSnapshot());
                        document.getElementById("nudgeCancel")?.addEventListener("click", () => this.rollbackActiveSnapshot());
                        document.getElementById("nudgeUndo")?.addEventListener("click", () => this.undoLastAction());
                        document.getElementById("nudgeDelete")?.addEventListener("click", () => this.deleteActiveField());
                        nudgePersistToDbBtn?.addEventListener("click", async () => {
                            this.renderSaveHint("Відправляємо зміни в БД...");
                            const saved = await this.persistSegmentsToApi();
                            if (!saved) return;
                            this.hasPendingDbSave = false;
                        });
                        fieldMapForm?.addEventListener("submit", async (event) => {
                            event.preventDefault();
                            this.renderSaveHint("Відправляємо зміни в БД...");
                            if (this.calibrationMode) {
                                this.collectCalibrationOffsetsPayload().forEach((item) => {
                                    this.syncFieldTextOffsetsToForm(
                                        item.fieldId,
                                        item.textOffsetX,
                                        item.textOffsetY);
                                });
                            }
                            if (this.hasPendingDbSave) {
                                const saved = await this.persistSegmentsToApi();
                                if (!saved) return;
                                this.hasPendingDbSave = false;
                            }
                            await this.persistFieldMapFormAsync();
                        });
                        nudgeTagSearch?.addEventListener("input", () => this.filterPlacedFields());
                        overlayPlacedFields?.addEventListener("wheel", (event) => {
                            const list = event.currentTarget;
                            if (!(list instanceof HTMLElement) || list.scrollHeight <= list.clientHeight + 1) {
                                return;
                            }
                            const delta = event.deltaY;
                            const maxScroll = list.scrollHeight - list.clientHeight;
                            if (delta < 0 && list.scrollTop > 0) {
                                event.stopPropagation();
                            } else if (delta > 0 && list.scrollTop < maxScroll - 1) {
                                event.stopPropagation();
                            }
                        }, { passive: false });
                        toggleNudgePadBodyBtn?.addEventListener("click", () => {
                            this.isNudgeBodyCollapsed = !this.isNudgeBodyCollapsed;
                            if (nudgePadBody) nudgePadBody.style.display = this.isNudgeBodyCollapsed ? "none" : "block";
                            toggleNudgePadBodyBtn.textContent = this.isNudgeBodyCollapsed ? "+" : "−";
                            this.saveNudgeUiState();
                        });
                        toggleNudgeInspectModeBtn?.addEventListener("click", () => {
                            this.isInspectMode = !this.isInspectMode;
                            if (this.isInspectMode) {
                                this.setActive(null);
                                this.stopNudgeMoveHold();
                                this.stopNudgeSizeHold();
                                this.hideSmartGuides();
                            } else {
                                this.setActive(this.activeIndex);
                            }
                            this.renderInspectModeButton();
                            this.renderNudgeModeButtons();
                            this.applyInspectModeUi();
                            this.saveNudgeUiState();
                        });
                        designerFocusToggleButtons.forEach((button) => {
                            button.addEventListener("click", () => this.toggleFocusMode());
                        });
                        toggleNudgeDetachModeBtn?.addEventListener("click", () => {
                            this.isNudgeDetached = !this.isNudgeDetached;
                            this.applyNudgeLayoutMode();
                            this.updateNudgePadPosition();
                            this.renderDetachModeButton();
                            this.saveNudgeUiState();
                            showOverlayToast(this.isNudgeDetached ? "Пульт відкріплено" : "Пульт прикріплено праворуч");
                        });
                        toggleNudgePadVisibilityBtn?.addEventListener("click", () => {
                            this.isNudgeBodyCollapsed = true;
                            if (nudgePadBody) nudgePadBody.style.display = "none";
                            if (toggleNudgePadBodyBtn) toggleNudgePadBodyBtn.textContent = "+";
                            this.saveNudgeUiState();
                            showOverlayToast("Пульт згорнуто");
                        });
                        toggleNudgeTagListBtn?.addEventListener("click", () => {
                            this.isTagListCollapsed = !this.isTagListCollapsed;
                            if (nudgeTagListSection) nudgeTagListSection.style.display = this.isTagListCollapsed ? "none" : "block";
                            toggleNudgeTagListBtn.textContent = this.isTagListCollapsed ? "▸" : "▾";
                            this.saveNudgeUiState();
                        });
                        nudgePadHeader?.addEventListener("mousedown", (event) => {
                            if (event.button !== 0 || !nudgePad) return;
                            if (nudgePad.classList.contains("nudge-sidebar-mode")) return;
                            if (event.target instanceof HTMLButtonElement) return;
                            const rect = nudgePad.getBoundingClientRect();
                            this.padDragState = {
                                startX: event.clientX,
                                startY: event.clientY,
                                left: rect.left,
                                top: rect.top
                            };
                            nudgePad.dataset.manualPos = "1";
                            this.isNudgeDetached = true;
                            this.saveNudgeUiState();
                            event.preventDefault();
                        });
                        document.addEventListener("keydown", (event) => {
                            const target = event.target;
                            const isTypingContext =
                                target instanceof HTMLInputElement ||
                                target instanceof HTMLTextAreaElement ||
                                target instanceof HTMLSelectElement ||
                                target?.isContentEditable;
                            if (isTypingContext) return;

                            if (event.key === "Escape" && this.isFocusMode) {
                                event.preventDefault();
                                this.setFocusMode(false);
                                return;
                            }

                            if ((event.key === "f" || event.key === "F") && !event.ctrlKey && !event.metaKey && !event.altKey) {
                                event.preventDefault();
                                this.toggleFocusMode();
                                return;
                            }

                            if (this.editMode !== "edit" || this.activeIndex === null) return;

                            if (event.key === "Delete") {
                                event.preventDefault();
                                this.deleteActiveField();
                                return;
                            }

                            if (event.key === "Escape") {
                                event.preventDefault();
                                this.rollbackActiveSnapshot();
                                return;
                            }

                            if (event.key === "Enter") {
                                event.preventDefault();
                                this.commitActiveSnapshot();
                                return;
                            }

                            if (event.ctrlKey && event.key.toLowerCase() === "z") {
                                event.preventDefault();
                                this.undoLastAction();
                                return;
                            }

                            if (event.ctrlKey && event.shiftKey && event.key.toLowerCase() === "f") {
                                event.preventDefault();
                                this.clearTagSearch();
                                nudgeTagSearch?.focus();
                                return;
                            }

                            if (event.ctrlKey && event.key.toLowerCase() === "f") {
                                event.preventDefault();
                                nudgeTagSearch?.focus();
                                nudgeTagSearch?.select();
                                return;
                            }

                            if (event.ctrlKey && event.key === "0") {
                                event.preventDefault();
                                this.resetNudgePadPosition();
                                return;
                            }

                            if (!["ArrowUp", "ArrowDown", "ArrowLeft", "ArrowRight"].includes(event.key)) return;
                            event.preventDefault();
                            const step = event.shiftKey ? 10 : (event.altKey ? 5 : 1);
                            if (event.key === "ArrowUp") this.nudgeActive(0, -step);
                            if (event.key === "ArrowDown") this.nudgeActive(0, step);
                            if (event.key === "ArrowLeft") this.nudgeActive(-step, 0);
                            if (event.key === "ArrowRight") this.nudgeActive(step, 0);
                        });
                        document.addEventListener("mousemove", (event) => {
                            if (!this.padDragState || !nudgePad) return;
                            const dx = event.clientX - this.padDragState.startX;
                            const dy = event.clientY - this.padDragState.startY;
                            const maxLeft = Math.max(0, window.innerWidth - nudgePad.offsetWidth - 6);
                            const maxTop = Math.max(0, window.innerHeight - nudgePad.offsetHeight - 6);
                            const nextLeft = Math.min(maxLeft, Math.max(0, this.padDragState.left + dx));
                            const nextTop = Math.min(maxTop, Math.max(0, this.padDragState.top + dy));
                            nudgePad.style.left = `${Math.round(nextLeft)}px`;
                            nudgePad.style.top = `${Math.round(nextTop)}px`;
                        });
                        document.addEventListener("mouseup", () => {
                            if (this.padDragState) {
                                this.padDragState = null;
                                this.saveNudgeUiState();
                            }
                        });
                        root.addEventListener("scroll", () => this.updateNudgePadPosition());
                        window.addEventListener("resize", () => this.updateNudgePadPosition());
                        this.updateSizeScaleLabels();
                        this.renderNudgeStepButtons();
                        this.renderNudgeModeButtons();
                        this.renderInspectModeButton();
                        this.renderDetachModeButton();
                        this.renderSmartSnapToggle();
                        this.renderAutoInspectAfterOkToggle();
                        this.renderNudgeSizeButtons();
                        this.renderSaveHint();
                        this.applyInspectModeUi();
                        if (nudgeZoomSlider && zoomSlider) {
                            nudgeZoomSlider.value = zoomSlider.value;
                            updateNudgeZoomLabel();
                        }
                        if (nudgePadBody) nudgePadBody.style.display = this.isNudgeBodyCollapsed ? "none" : "block";
                        if (toggleNudgePadBodyBtn) toggleNudgePadBodyBtn.textContent = this.isNudgeBodyCollapsed ? "+" : "−";
                        if (nudgeTagListSection) nudgeTagListSection.style.display = this.isTagListCollapsed ? "none" : "block";
                        if (toggleNudgeTagListBtn) toggleNudgeTagListBtn.textContent = this.isTagListCollapsed ? "▸" : "▾";
                    }

                    setActive(index) {
                        this.activeIndex = Number.isInteger(index) && this.boxesByIndex.has(index) ? index : null;
                        const activeField = this.activeIndex !== null ? this.fieldByIndex.get(this.activeIndex) : null;
                        this.activeFieldId = activeField?.fieldId ? this.normalizeGuidKey(activeField.fieldId) : null;
                        this.activeSegmentId = activeField?.segmentId ?? null;
                        if (activeField?.fieldId && this.activeIndex !== null) {
                            this.lastActiveSegmentByFieldId.set(activeField.fieldId, this.activeIndex);
                        }
                        if (this.activeIndex !== null && this.isInspectMode) {
                            this.isInspectMode = false;
                            this.saveNudgeUiState();
                        }
                        this.captureActiveSnapshot();
                        this.updateAllBoxVisualStates();
                        if (this.activeIndex !== null) {
                            if (activeField?.formIndex !== null && activeField?.formIndex !== undefined) {
                                fieldSelector.value = String(activeField.formIndex);
                            }
                            this.syncActiveSegmentToPanel();
                        }
                        this.syncSegmentTextSettingsUi();
                        this.syncOverlayDataFieldCombo();
                        this.renderNudgeSizeButtons();
                        this.updateDeleteButtonVisibility();
                        this.updateNudgePadVisibility();
                        this.updateNudgePadPosition();
                        this.renderNudgeModeButtons();
                        this.renderInspectModeButton();
                        this.applyInspectModeUi();
                        this.updateActiveSegmentSummary(activeField);
                        this.syncCalibrationPanel();
                        this.renderPlacedFields();
                        this.renderDebugStats();
                    }

                    bindSegmentTextSettingsEvents() {
                        segmentFontSizeInput?.addEventListener("input", () => this.applySegmentTextSettingsFromPanel());
                        segmentFontSizeInput?.addEventListener("change", () => this.applySegmentTextSettingsFromPanel());
                        nudgePad?.querySelectorAll("[data-segment-h-align]").forEach((buttonEl) => {
                            buttonEl.addEventListener("click", () => {
                                const value = buttonEl.getAttribute("data-segment-h-align");
                                if (!value) return;
                                this.setActiveSegmentHorizontalAlignment(value);
                            });
                        });
                        nudgePad?.querySelectorAll("[data-segment-v-align]").forEach((buttonEl) => {
                            buttonEl.addEventListener("click", () => {
                                const value = buttonEl.getAttribute("data-segment-v-align");
                                if (!value) return;
                                this.setActiveSegmentVerticalAlignment(value);
                            });
                        });
                    }

                    setActiveSegmentHorizontalAlignment(value) {
                        if (this.activeIndex === null) {
                            return;
                        }

                        const field = this.fieldByIndex.get(this.activeIndex);
                        if (!field) {
                            return;
                        }

                        field.horizontalAlignment = value;
                        field.textAlignment = value;
                        this.fieldByIndex.set(this.activeIndex, field);
                        this.syncSegmentTextSettingsUi();
                        this.scheduleLayoutDraftSave();
                        this.hasPendingDbSave = true;
                        this.renderSaveHint();
                    }

                    setActiveSegmentVerticalAlignment(value) {
                        if (this.activeIndex === null) {
                            return;
                        }

                        const field = this.fieldByIndex.get(this.activeIndex);
                        if (!field) {
                            return;
                        }

                        field.verticalAlignment = value;
                        this.fieldByIndex.set(this.activeIndex, field);
                        this.syncSegmentTextSettingsUi();
                        this.scheduleLayoutDraftSave();
                        this.hasPendingDbSave = true;
                        this.renderSaveHint();
                    }

                    applySegmentTextSettingsFromPanel() {
                        if (this.activeIndex === null) {
                            return;
                        }

                        const field = this.fieldByIndex.get(this.activeIndex);
                        if (!field) {
                            return;
                        }

                        const raw = String(segmentFontSizeInput?.value ?? "").trim();
                        const parsed = Number.parseFloat(raw);
                        field.fontSize = raw === "" || !Number.isFinite(parsed) || parsed <= 0 ? null : parsed;
                        this.fieldByIndex.set(this.activeIndex, field);
                        this.scheduleLayoutDraftSave();
                        this.hasPendingDbSave = true;
                        this.renderSaveHint();
                    }

                    syncSegmentTextSettingsUi() {
                        if (!segmentFontSizeInput) {
                            return;
                        }

                        const field = this.activeIndex !== null ? this.fieldByIndex.get(this.activeIndex) : null;
                        const disabled = !field;
                        segmentFontSizeInput.disabled = disabled;
                        nudgePad?.querySelectorAll("[data-segment-h-align], [data-segment-v-align]").forEach((buttonEl) => {
                            buttonEl.disabled = disabled;
                        });

                        if (!field) {
                            segmentFontSizeInput.value = "";
                            this.updateSegmentAlignmentToggleStates(null, null);
                            return;
                        }

                        segmentFontSizeInput.value = field.fontSize != null ? String(field.fontSize) : "";
                        this.updateSegmentAlignmentToggleStates(
                            field.horizontalAlignment ?? field.textAlignment ?? "Left",
                            field.verticalAlignment ?? "Bottom");
                    }

                    updateSegmentAlignmentToggleStates(horizontal, vertical) {
                        nudgePad?.querySelectorAll("[data-segment-h-align]").forEach((buttonEl) => {
                            const value = buttonEl.getAttribute("data-segment-h-align");
                            buttonEl.classList.toggle("active", Boolean(horizontal) && value === horizontal);
                        });
                        nudgePad?.querySelectorAll("[data-segment-v-align]").forEach((buttonEl) => {
                            const value = buttonEl.getAttribute("data-segment-v-align");
                            const effectiveVertical = vertical || "Bottom";
                            buttonEl.classList.toggle("active", value === effectiveVertical);
                        });
                    }

                    syncActiveSegmentToPanel() {
                        if (this.activeIndex === null) {
                            return;
                        }

                        const box = this.boxesByIndex.get(this.activeIndex);
                        const activeField = this.fieldByIndex.get(this.activeIndex);
                        if (!box || !activeField) {
                            return;
                        }

                        const page = Number.parseInt(box.dataset.page || "1", 10);
                        const previewField = this.getFieldInPreviewSpace(box, page);
                        const activeWidth = previewField.width;
                        const activeHeight = previewField.height;
                        if (widthInput) widthInput.value = String(activeWidth);
                        if (heightInput) heightInput.value = String(activeHeight);
                        if (widthSlider) widthSlider.value = String(activeWidth);
                        if (heightSlider) heightSlider.value = String(activeHeight);
                        this.updateSizeScaleLabels();
                        this.syncFieldInputs({
                            ...activeField,
                            index: this.activeIndex,
                            page: previewField.page,
                            x: previewField.x,
                            y: previewField.y,
                            width: activeWidth,
                            height: activeHeight
                        });
                    }

                    updateActiveSegmentSummary(activeField) {
                        if (!activeSegmentSummary) {
                            return;
                        }

                        if (!activeField) {
                            activeSegmentSummary.textContent = "Оберіть сегмент на PDF.";
                            return;
                        }

                        const segmentCount = this.getSegmentIndexesForField(activeField.fieldId).length;
                        const segmentNumber = activeField.segmentSequence ?? 1;
                        const box = this.activeIndex !== null ? this.boxesByIndex.get(this.activeIndex) : null;
                        const page = Number.parseInt(box?.dataset.page || String(activeField.page || 1), 10);
                        const previewField = box
                            ? this.getFieldInPreviewSpace(box, page)
                            : {
                                x: Math.round(activeField.x ?? 0),
                                y: Math.round(activeField.y ?? 0),
                                width: Math.round(activeField.width ?? 0),
                                height: Math.round(activeField.height ?? 0)
                            };
                        activeSegmentSummary.textContent =
                            `${activeField.tag} · сегмент ${segmentNumber}/${segmentCount} · стор. ${page} · x=${previewField.x}, y=${previewField.y}, w=${previewField.width}, h=${previewField.height}`;
                    }

                    getSegmentIndexesForField(fieldId) {
                        if (!fieldId) {
                            return [];
                        }

                        return [...this.fieldByIndex.entries()]
                            .filter(([, field]) => this.normalizeGuidKey(field?.fieldId) === this.normalizeGuidKey(fieldId))
                            .sort(([, left], [, right]) => {
                                const leftSequence = left?.segmentSequence ?? Number.MAX_SAFE_INTEGER;
                                const rightSequence = right?.segmentSequence ?? Number.MAX_SAFE_INTEGER;
                                return leftSequence - rightSequence;
                            })
                            .map(([overlayIndex]) => overlayIndex);
                    }

                    updateEditUI() {
                        const toggle = document.getElementById("editModeToggle");
                        const label = document.getElementById("editModeLabel");
                        const hint = document.getElementById("editModeHint");
                        const controls = document.getElementById("editControls");
                        const allBtn = document.getElementById("btnAllMode");
                        const singleBtn = document.getElementById("btnSingleMode");
                        const warning = document.getElementById("editWarning");

                        if (!toggle || !label || !hint || !controls || !allBtn || !singleBtn || !warning) {
                            return;
                        }

                        if (this.editMode === "edit") {
                            toggle.checked = true;
                            label.textContent = "✏️ Редагування";
                            label.style.color = "#d39e00";
                            hint.textContent = this.allEditable
                                ? "Можна рухати всі теги"
                                : "Можна рухати тільки активний тег";
                            controls.style.display = "block";
                            warning.style.display = this.allEditable ? "block" : "none";
                            allBtn.classList.toggle("active", this.allEditable);
                            singleBtn.classList.toggle("active", !this.allEditable);
                        } else {
                            toggle.checked = false;
                            label.textContent = "🔒 Захищено";
                            label.style.color = "";
                            hint.textContent = "Тільки перегляд";
                            controls.style.display = "none";
                            warning.style.display = "none";
                            allBtn.classList.remove("active");
                            singleBtn.classList.add("active");
                        }
                        this.updateDeleteButtonVisibility();
                        this.updateNudgePadVisibility();
                        this.renderNudgeModeButtons();
                        this.renderInspectModeButton();
                        this.applyInspectModeUi();
                    }

                    toggleEditMode() {
                        this.editMode = this.editMode === "locked" ? "edit" : "locked";
                        this.allEditable = false;
                        this.hideSmartGuides();
                        this.updateEditUI();
                        this.setActive(this.activeIndex);
                    }

                    toggleAllEditable() {
                        if (this.editMode !== "edit") return;
                        this.allEditable = !this.allEditable;
                        this.updateEditUI();
                        this.setActive(this.activeIndex);
                    }

                    applyInitialModeFromQuery() {
                        if (this.initialModeApplied) return;
                        this.initialModeApplied = true;

                        const params = new URLSearchParams(window.location.search);
                        const requestedFieldId = params.get("fieldId");
                        const shouldEnableEdit = params.get("edit") === "true";

                        if (requestedFieldId) {
                            const targetIndex = this.getOverlayIndexForField(requestedFieldId);
                            if (targetIndex !== null) {
                                this.setActive(targetIndex);
                            }
                        } else if (this.activeIndex === null && this.boxesByIndex.size > 0) {
                            this.setActive([...this.boxesByIndex.keys()][0]);
                        }

                        if (shouldEnableEdit) {
                            this.editMode = "edit";
                            this.allEditable = false;
                            this.updateEditUI();
                            this.setActive(this.activeIndex);
                        }
                    }

                    applySize() {
                        if (this.activeIndex === null) return;
                        const box = this.boxesByIndex.get(this.activeIndex);
                        const layer = box?.parentElement;
                        if (!box || !layer) return;
                        if (!this.canEditBox(box)) return;
                        this.pushUndoState("applySize");
                        const width = Math.max(20, Number.parseFloat(widthInput?.value || "0") || box.offsetWidth);
                        const height = Math.max(12, Number.parseFloat(heightInput?.value || "0") || box.offsetHeight);
                        box.style.width = `${Math.min(this.normalizePixel(width, 20), layer.clientWidth)}px`;
                        box.style.height = `${Math.min(this.normalizePixel(height, 12), layer.clientHeight)}px`;
                        const actualWidth = Math.round(box.offsetWidth);
                        const actualHeight = Math.round(box.offsetHeight);
                        if (widthInput) widthInput.value = String(actualWidth);
                        if (heightInput) heightInput.value = String(actualHeight);
                        if (widthSlider) widthSlider.value = String(actualWidth);
                        if (heightSlider) heightSlider.value = String(actualHeight);
                        this.updateSizeScaleLabels();
                        this.syncBoxToInputs(box);
                        this.renderPlacedFields();
                        this.renderDebugStats();
                        this.updateAllBoxVisualStates();
                        this.updateNudgePadPosition();
                    }

                    updateSizeScaleLabels() {
                        if (widthValue && widthSlider) {
                            widthValue.textContent = `${widthSlider.value} px`;
                        }
                        if (heightValue && heightSlider) {
                            heightValue.textContent = `${heightSlider.value} px`;
                        }
                    }

                    syncFieldInputs(field) {
                        const formIndex = field.formIndex ?? field.index;
                        if (!Number.isInteger(formIndex) || formIndex < 0) {
                            return;
                        }

                        if (!field.isPrimary) {
                            return;
                        }

                        setInputValue(formIndex, "PageNumber", field.page);
                        setInputValue(formIndex, "PositionX", field.x);
                        setInputValue(formIndex, "PositionY", field.y);
                        setInputValue(formIndex, "Width", field.width);
                        setInputValue(formIndex, "Height", field.height);
                    }

                    syncBoxToInputs(box) {
                        const index = Number.parseInt(box.dataset.index || "-1", 10);
                        if (index === this.activeIndex) {
                            this.renderNudgeSizeButtons(Math.round(box.offsetWidth), Math.round(box.offsetHeight));
                            this.syncActiveSegmentToPanel();
                            this.updateActiveSegmentSummary(this.fieldByIndex.get(index));
                        }
                        const page = Number.parseInt(box.dataset.page || "1", 10);
                        const previewField = this.getFieldInPreviewSpace(box, page);
                        const fieldMeta = this.fieldByIndex.get(index) ?? {};
                        this.syncFieldInputs({
                            ...fieldMeta,
                            index,
                            page: previewField.page,
                            x: previewField.x,
                            y: previewField.y,
                            width: previewField.width,
                            height: previewField.height
                        });
                        this.debugLog("Box synced to preview-space", {
                            index,
                            page,
                            x: previewField.x,
                            y: previewField.y,
                            width: previewField.width,
                            height: previewField.height
                        });
                        this.scheduleLayoutDraftSave();
                    }

                    renderPlacedFields() {
                        if (!overlayPlacedFields) return;
                        overlayPlacedFields.innerHTML = "";
                        const searchQuery = (nudgeTagSearch?.value || "").trim().toLowerCase();
                        const groupedFields = new Map();
                        this.fieldByIndex.forEach((field, index) => {
                            if (!field?.fieldId || groupedFields.has(field.fieldId)) {
                                return;
                            }
                            groupedFields.set(field.fieldId, { field, index });
                        });
                        const entries = [...groupedFields.values()].sort((a, b) => a.index - b.index);
                        if (entries.length === 0) {
                            overlayPlacedFields.innerHTML = "<div class='text-muted'>Поки немає полів.</div>";
                            return;
                        }

                        entries.forEach(({ field, index }) => {
                            const box = this.boxesByIndex.get(index);
                            if (!field || !box) return;
                            const searchableText = `${field.tag} ${(field.title || "")}`.toLowerCase();
                            if (searchQuery && !searchableText.includes(searchQuery)) return;
                            const segmentCount = [...this.fieldByIndex.values()]
                                .filter((item) => this.normalizeGuidKey(item.fieldId) === this.normalizeGuidKey(field.fieldId)).length;
                            const details = `
                                <div><strong>${field.title || field.tag}</strong></div>
                                <div><strong>Tag:</strong> ${field.tag}</div>
                                <div><strong>Сегментів:</strong> ${segmentCount}</div>
                                <div><strong>Page:</strong> ${box.dataset.page}</div>
                                <div><strong>X:</strong> ${Math.round(parseFloat(box.style.left || "0"))}, <strong>Y:</strong> ${Math.round(parseFloat(box.style.top || "0"))}</div>
                                <div><strong>W:</strong> ${Math.round(box.offsetWidth)}, <strong>H:</strong> ${Math.round(box.offsetHeight)}</div>
                            `;
                            const item = document.createElement("button");
                            item.type = "button";
                            const isActiveGroup = this.activeFieldId && this.normalizeGuidKey(field.fieldId) === this.activeFieldId;
                            item.className = "btn btn-sm w-100 text-start mb-1 nudge-compact-item " + (isActiveGroup ? "btn-primary" : "btn-outline-secondary");
                            const titleLine = document.createElement("span");
                            titleLine.className = "nudge-placed-item__title";
                            titleLine.textContent = field.title || field.tag;
                            const metaLine = document.createElement("span");
                            metaLine.className = "nudge-placed-item__meta";
                            metaLine.textContent = `${field.tag} · ${segmentCount} сегм.`;
                            item.appendChild(titleLine);
                            item.appendChild(metaLine);
                            item.addEventListener("click", () => {
                                const preferredIndex = this.lastActiveSegmentByFieldId.get(field.fieldId);
                                const overlayIndex = this.getOverlayIndexForField(field.fieldId, preferredIndex ?? index);
                                const targetBox = overlayIndex !== null ? this.boxesByIndex.get(overlayIndex) : box;
                                targetBox?.scrollIntoView({ behavior: "smooth", block: "center" });
                                this.setActive(overlayIndex ?? index);
                            });
                            item.addEventListener("mouseenter", (event) => this.showNudgeHoverCard(event, details, item));
                            item.addEventListener("mousemove", (event) => this.positionNudgeHoverCard(event, item));
                            item.addEventListener("mouseleave", () => this.hideNudgeHoverCard());
                            overlayPlacedFields.appendChild(item);
                        });
                    }

                    renderDebugStats() {
                        if (!overlayDebugStats) return;
                        const sample = this.lastRenderedSample
                            ? ` | sample: p${this.lastRenderedSample.page} x=${Math.round(this.lastRenderedSample.x)} y=${Math.round(this.lastRenderedSample.y)} w=${Math.round(this.lastRenderedSample.width)} h=${Math.round(this.lastRenderedSample.height)}`
                            : "";
                        overlayDebugStats.textContent =
                            `Debug: api=${this.lastApiFieldCount}, rendered=${this.boxesByIndex.size}, pages=${this.pageLayers.size}, active=${this.activeIndex ?? "none"}, mode=${this.editMode}, all=${this.allEditable ? "on" : "off"}, snap=${this.smartSnapEnabled ? "on" : "off"}${sample}`;
                    }

                    updateDeleteButtonVisibility() {
                        const canManageSegments = this.editMode === "edit" && this.activeIndex !== null && this.boxesByIndex.has(this.activeIndex);
                        if (nudgeAddSegmentLineButton) {
                            nudgeAddSegmentLineButton.disabled = !canManageSegments;
                        }
                        if (deleteActiveFieldButton) {
                            deleteActiveFieldButton.style.display = canManageSegments ? "block" : "none";
                        }
                        if (addSegmentLineButton) {
                            addSegmentLineButton.style.display = canManageSegments ? "block" : "none";
                        }
                    }

                    addDeletedFieldId(fieldId) {
                        if (!deletedFieldIdsHost || !fieldId) return;
                        const exists = deletedFieldIdsHost.querySelector(`input[name="DeletedFieldIds"][value="${fieldId}"]`);
                        if (exists) return;
                        const hidden = document.createElement("input");
                        hidden.type = "hidden";
                        hidden.name = "DeletedFieldIds";
                        hidden.value = fieldId;
                        deletedFieldIdsHost.appendChild(hidden);
                    }

                    collectDeletedFieldIds() {
                        if (!deletedFieldIdsHost) {
                            return [];
                        }

                        return [...deletedFieldIdsHost.querySelectorAll('input[name="DeletedFieldIds"]')]
                            .map((input) => this.normalizeGuidKey(input.value))
                            .filter((fieldId) => Boolean(fieldId));
                    }

                    clearDeletedFieldIds() {
                        if (!deletedFieldIdsHost) {
                            return;
                        }

                        deletedFieldIdsHost.innerHTML = "";
                    }

                    removeFieldRow(index) {
                        const idInput = document.getElementById(`Fields_${index}__FieldId`);
                        const row = idInput?.closest("tr");
                        if (row) {
                            row.remove();
                        }
                    }

                    removeFieldSelectorOption(index) {
                        if (!fieldSelector) return;
                        const option = fieldSelector.querySelector(`option[value="${index}"]`);
                        if (option) {
                            option.remove();
                        }
                    }

                    deleteActiveField() {
                        if (this.editMode !== "edit" || this.activeIndex === null) return;
                        this.pushUndoState("delete");
                        const activeIndex = this.activeIndex;
                        const activeField = this.fieldByIndex.get(activeIndex);
                        const activeBox = this.boxesByIndex.get(activeIndex);
                        if (!activeField || !activeBox) return;

                        const fieldId = activeField.fieldId;
                        const segmentIndexes = this.getSegmentIndexesForField(fieldId);
                        const isLastSegment = segmentIndexes.length <= 1;
                        const segmentNumber = activeField.segmentSequence ?? 1;
                        const confirmText = isLastSegment
                            ? `Видалити тег «${activeField.tag}»?`
                            : `Видалити сегмент #${segmentNumber} тега «${activeField.tag}»?`;
                        if (!window.confirm(confirmText)) {
                            return;
                        }

                        const page = Number.parseInt(activeBox.dataset.page || "1", 10);
                        activeBox.remove();
                        this.boxesByIndex.delete(activeIndex);
                        this.fieldByIndex.delete(activeIndex);
                        const pageFields = this.fieldsByPage.get(page);
                        if (Array.isArray(pageFields)) {
                            this.fieldsByPage.set(page, pageFields.filter((field) => field.index !== activeIndex));
                        }

                        let nextIndex = null;
                        if (isLastSegment) {
                            if (fieldId) {
                                this.addDeletedFieldId(fieldId);
                                this.lastActiveSegmentByFieldId.delete(fieldId);
                            }

                            if (activeField.formIndex !== null && activeField.formIndex !== undefined) {
                                this.removeFieldRow(activeField.formIndex);
                                this.removeFieldSelectorOption(activeField.formIndex);
                            }

                            const nextIndexes = [...this.boxesByIndex.keys()].sort((a, b) => a - b);
                            nextIndex = nextIndexes.find((idx) => idx > activeIndex) ?? nextIndexes[0] ?? null;
                            showOverlayToast("Тег видалено");
                        } else {
                            const remainingForField = this.getSegmentIndexesForField(fieldId);
                            nextIndex = remainingForField.find((idx) => idx > activeIndex)
                                ?? remainingForField[remainingForField.length - 1]
                                ?? null;
                            if (fieldId && nextIndex !== null) {
                                this.lastActiveSegmentByFieldId.set(fieldId, nextIndex);
                            }

                            showOverlayToast(`Сегмент #${segmentNumber} видалено`);
                        }

                        this.activeIndex = null;
                        this.editSnapshot = null;
                        this.setActive(nextIndex);
                        this.scheduleLayoutDraftSave();
                        this.renderPlacedFields();
                        this.renderDebugStats();
                    }

                    captureActiveSnapshot() {
                        if (this.editMode !== "edit" || this.activeIndex === null) {
                            this.editSnapshot = null;
                            return;
                        }

                        const box = this.boxesByIndex.get(this.activeIndex);
                        if (!box) {
                            this.editSnapshot = null;
                            return;
                        }

                        this.editSnapshot = {
                            index: this.activeIndex,
                            page: Number.parseInt(box.dataset.page || "1", 10),
                            left: this.normalizePixel(box.style.left),
                            top: this.normalizePixel(box.style.top),
                            width: Math.max(20, Math.round(box.offsetWidth)),
                            height: Math.max(12, Math.round(box.offsetHeight))
                        };
                    }

                    commitActiveSnapshot() {
                        if (this.editMode !== "edit" || this.activeIndex === null) return;
                        this.captureActiveSnapshot();
                        this.scheduleLayoutDraftSave();
                        if (this.autoInspectAfterOk) {
                            this.isInspectMode = true;
                            this.setActive(null);
                        }
                        showOverlayToast("Позицію зафіксовано");
                    }

                    rollbackActiveSnapshot() {
                        if (!this.editSnapshot || this.editMode !== "edit") return;
                        const box = this.boxesByIndex.get(this.editSnapshot.index);
                        const targetLayer = this.pageLayers.get(this.editSnapshot.page);
                        if (!box || !targetLayer) return;
                        if (box.parentElement !== targetLayer) {
                            targetLayer.appendChild(box);
                            box.dataset.page = String(this.editSnapshot.page);
                        }

                        box.style.left = `${this.editSnapshot.left}px`;
                        box.style.top = `${this.editSnapshot.top}px`;
                        box.style.width = `${this.editSnapshot.width}px`;
                        box.style.height = `${this.editSnapshot.height}px`;
                        this.syncBoxToInputs(box);
                        this.updateAllBoxVisualStates();
                        this.updateNudgePadPosition();
                        this.renderPlacedFields();
                        this.renderDebugStats();
                        showOverlayToast("Зміни скасовано");
                    }

                    getActiveBox() {
                        if (this.activeIndex === null) return null;
                        return this.boxesByIndex.get(this.activeIndex) ?? null;
                    }

                    nudgeActive(dx, dy) {
                        const box = this.getActiveBox();
                        const layer = box?.parentElement;
                        if (!box || !layer || !this.canEditBox(box)) return;
                        this.pushUndoState("nudge");

                        const nextLeftRaw = this.normalizePixel(box.style.left) + dx;
                        const nextTopRaw = this.normalizePixel(box.style.top) + dy;
                        const boundedLeft = Math.min(Math.max(0, nextLeftRaw), Math.max(0, layer.clientWidth - box.offsetWidth));
                        const boundedTop = Math.min(Math.max(0, nextTopRaw), Math.max(0, layer.clientHeight - box.offsetHeight));
                        // Nudge should stay truly pixel-precise (especially for 1px mode).
                        box.style.left = `${this.normalizePixel(boundedLeft)}px`;
                        box.style.top = `${this.normalizePixel(boundedTop)}px`;
                        this.syncBoxToInputs(box);
                        this.updateAllBoxVisualStates();
                        this.updateNudgePadPosition();
                        this.renderPlacedFields();
                        this.renderDebugStats();
                    }

                    resizeActive(dw, dh) {
                        const box = this.getActiveBox();
                        const layer = box?.parentElement;
                        if (!box || !layer || !this.canEditBox(box)) return;
                        this.pushUndoState("resize");

                        const currentWidth = Math.round(box.offsetWidth);
                        const currentHeight = Math.round(box.offsetHeight);
                        const maxWidth = Math.max(20, layer.clientWidth - this.normalizePixel(box.style.left));
                        const maxHeight = Math.max(12, layer.clientHeight - this.normalizePixel(box.style.top));
                        const nextWidth = Math.min(maxWidth, Math.max(20, currentWidth + dw));
                        const nextHeight = Math.min(maxHeight, Math.max(12, currentHeight + dh));
                        box.style.width = `${this.normalizePixel(nextWidth, 20)}px`;
                        box.style.height = `${this.normalizePixel(nextHeight, 12)}px`;
                        this.syncBoxToInputs(box);
                        this.setActive(Number(box.dataset.index));
                    }

                    captureLayoutState() {
                        const boxes = [...this.boxesByIndex.entries()].map(([index, box]) => ({
                            index,
                            page: Number.parseInt(box.dataset.page || "1", 10),
                            left: this.normalizePixel(box.style.left),
                            top: this.normalizePixel(box.style.top),
                            width: Math.round(box.offsetWidth),
                            height: Math.round(box.offsetHeight)
                        }));
                        return {
                            boxes,
                            activeIndex: this.activeIndex
                        };
                    }

                    restoreLayoutState(state) {
                        if (!state || !Array.isArray(state.boxes)) return;
                        state.boxes.forEach((item) => {
                            const box = this.boxesByIndex.get(item.index);
                            const layer = this.pageLayers.get(item.page);
                            if (!box || !layer) return;
                            if (box.parentElement !== layer) {
                                layer.appendChild(box);
                                box.dataset.page = String(item.page);
                            }
                            box.style.left = `${this.normalizePixel(item.left)}px`;
                            box.style.top = `${this.normalizePixel(item.top)}px`;
                            box.style.width = `${Math.max(20, this.normalizePixel(item.width, 20))}px`;
                            box.style.height = `${Math.max(12, this.normalizePixel(item.height, 12))}px`;
                            this.syncBoxToInputs(box);
                        });
                        this.setActive(state.activeIndex);
                    }

                    pushUndoState(reason) {
                        const snapshot = this.captureLayoutState();
                        snapshot.reason = reason;
                        this.undoStack.push(snapshot);
                        if (this.undoStack.length > 40) {
                            this.undoStack.shift();
                        }
                    }

                    undoLastAction() {
                        if (this.undoStack.length === 0) {
                            showOverlayToast("Немає дій для скасування");
                            return;
                        }
                        const snapshot = this.undoStack.pop();
                        this.restoreLayoutState(snapshot);
                        this.renderPlacedFields();
                        this.renderDebugStats();
                        showOverlayToast("Останню дію скасовано");
                    }

                    filterPlacedFields() {
                        this.renderPlacedFields();
                    }

                    clearTagSearch() {
                        if (!nudgeTagSearch) return;
                        nudgeTagSearch.value = "";
                        this.renderPlacedFields();
                    }

                    resetNudgePadPosition() {
                        if (!nudgePad) return;
                        delete nudgePad.dataset.manualPos;
                        this.updateNudgePadPosition();
                        this.saveNudgeUiState();
                        showOverlayToast("Пульт повернуто в авто-позицію");
                    }

                    updateNudgePadVisibility() {
                        if (!nudgePad) return;
                        if (nudgePad.classList.contains("nudge-sidebar-mode")) {
                            nudgePad.style.display = "block";
                            return;
                        }
                        const show = !this.isNudgePadHidden;
                        nudgePad.style.display = show ? "block" : "none";
                        if (!show) this.hideNudgeHoverCard();
                    }

                    updateNudgePadPosition() {
                        if (!nudgePad || nudgePad.style.display === "none") return;
                        if (nudgePad.classList.contains("nudge-sidebar-mode")) return;
                        if (this.isNudgeDocked()) {
                            this.applyNudgeDockedLayout();
                            return;
                        }
                        const padWidth = nudgePad.offsetWidth || 228;
                        const padHeight = nudgePad.offsetHeight || 200;
                        if (nudgePad.dataset.manualPos === "1") {
                            const currentLeft = this.normalizePixel(nudgePad.style.left, 12);
                            const currentTop = this.normalizePixel(nudgePad.style.top, this.getDefaultNudgeTop());
                            const maxLeft = Math.max(8, window.innerWidth - padWidth - 8);
                            const maxTop = Math.max(8, window.innerHeight - padHeight - 8);
                            const safeLeft = Math.min(maxLeft, Math.max(8, currentLeft));
                            const safeTop = Math.min(maxTop, Math.max(8, currentTop));
                            nudgePad.style.left = `${Math.round(safeLeft)}px`;
                            nudgePad.style.top = `${Math.round(safeTop)}px`;
                            this.saveNudgeUiState();
                            return;
                        }
                        const box = this.getActiveBox();
                        let left = 12;
                        let top = this.getDefaultNudgeTop();
                        if (box) {
                            const rect = box.getBoundingClientRect();
                            const preferredLeft = rect.right + 12;
                            const fallbackLeft = rect.left - padWidth - 12;
                            left = preferredLeft + padWidth < window.innerWidth - 8
                                ? preferredLeft
                                : Math.max(8, fallbackLeft);
                            top = Math.min(
                                Math.max(8, rect.top),
                                Math.max(8, window.innerHeight - padHeight - 8));
                        } else {
                            left = Math.max(8, Math.min(left, window.innerWidth - padWidth - 8));
                            top = Math.max(8, Math.min(top, window.innerHeight - padHeight - 8));
                        }
                        nudgePad.style.left = `${Math.round(left)}px`;
                        nudgePad.style.top = `${Math.round(top)}px`;
                        this.saveNudgeUiState();
                    }

                    renderNudgeStepButtons() {
                        nudgePad?.querySelectorAll("[data-nudge-step]").forEach((buttonEl) => {
                            const step = Number.parseInt(buttonEl.getAttribute("data-nudge-step") || "0", 10);
                            buttonEl.classList.toggle("btn-primary", step === this.nudgeStep);
                            buttonEl.classList.toggle("btn-outline-secondary", step !== this.nudgeStep);
                        });
                    }

                    renderSmartSnapToggle() {
                        if (!smartSnapToggle) return;
                        smartSnapToggle.checked = this.smartSnapEnabled;
                    }

                    renderAutoInspectAfterOkToggle() {
                        if (!autoInspectAfterOkToggle) return;
                        autoInspectAfterOkToggle.checked = this.autoInspectAfterOk;
                    }

                    renderNudgeModeButtons() {
                        if (!nudgeModeSingle || !nudgeModeAll) return;
                        const isSingle = !this.isInspectMode && this.editMode === "edit" && !this.allEditable;
                        const isAll = !this.isInspectMode && this.editMode === "edit" && this.allEditable;
                        nudgeModeSingle.classList.toggle("btn-primary", isSingle);
                        nudgeModeSingle.classList.toggle("btn-outline-primary", !isSingle);
                        nudgeModeAll.classList.toggle("btn-warning", isAll);
                        nudgeModeAll.classList.toggle("btn-outline-warning", !isAll);
                    }

                    renderInspectModeButton() {
                        if (!toggleNudgeInspectModeBtn) return;
                        const isOn = this.isInspectMode;
                        toggleNudgeInspectModeBtn.classList.toggle("btn-secondary", isOn);
                        toggleNudgeInspectModeBtn.classList.toggle("btn-outline-secondary", !isOn);
                        toggleNudgeInspectModeBtn.title = isOn ? "Режим перегляду увімкнено" : "Увімкнути режим перегляду";
                    }

                    renderDetachModeButton() {
                        if (!toggleNudgeDetachModeBtn) return;
                        toggleNudgeDetachModeBtn.classList.toggle("btn-secondary", this.isNudgeDetached);
                        toggleNudgeDetachModeBtn.classList.toggle("btn-outline-secondary", !this.isNudgeDetached);
                        toggleNudgeDetachModeBtn.textContent = this.isNudgeDetached ? "⇲" : "⧉";
                        toggleNudgeDetachModeBtn.title = this.isNudgeDetached
                            ? "Прикріпити меню праворуч"
                            : "Відкріпити меню (можна рухати)";
                    }

                    applyCalibrationModeUi() {
                        if (nudgePadTitleEl) {
                            nudgePadTitleEl.textContent = this.calibrationMode
                                ? "Калібрування тексту"
                                : "Точне позиціонування";
                        }

                        if (nudgePadDefaultTools) {
                            nudgePadDefaultTools.style.display = this.calibrationMode ? "none" : "";
                        }

                        if (calibrationPanel) {
                            calibrationPanel.style.display = this.calibrationMode ? "block" : "none";
                        }

                        if (this.calibrationMode) {
                            this.isNudgePadHidden = false;
                            this.updateNudgePadVisibility();
                            this.updateNudgePadPosition();
                            if (nudgePadBody) {
                                nudgePadBody.style.display = "block";
                            }
                            if (toggleNudgePadBodyBtn) {
                                toggleNudgePadBodyBtn.textContent = "−";
                            }
                            this.isNudgeBodyCollapsed = false;
                        }
                    }

                    applyInspectModeUi() {
                        if (!nudgePadBody) return;
                        const controls = nudgePadBody.querySelectorAll(
                            "#overlaySmartSnapToggle, [data-nudge-step], [data-nudge-move], [data-nudge-size], #nudgeConfirm, #nudgeCancel, #nudgeUndo, #nudgeDelete, #nudgeAddSegmentLine, #nudgeModeSingle, #nudgeModeAll"
                        );
                        controls.forEach((el) => {
                            if ("disabled" in el) {
                                el.disabled = this.isInspectMode;
                            }
                        });
                    }

                    renderNudgeSizeButtons(widthOverride = null, heightOverride = null) {
                        const activeBox = this.getActiveBox();
                        const width = Number.isFinite(widthOverride)
                            ? Math.max(20, Math.round(widthOverride))
                            : Math.max(20, Math.round(activeBox?.offsetWidth || Number.parseFloat(widthInput?.value || "220") || 220));
                        const height = Number.isFinite(heightOverride)
                            ? Math.max(12, Math.round(heightOverride))
                            : Math.max(12, Math.round(activeBox?.offsetHeight || Number.parseFloat(heightInput?.value || "28") || 28));

                        const specs = {
                            "w-plus": { value: width, sign: "+", title: "Збільшити ширину" },
                            "w-minus": { value: width, sign: "-", title: "Зменшити ширину" },
                            "h-plus": { value: height, sign: "+", title: "Збільшити висоту" },
                            "h-minus": { value: height, sign: "-", title: "Зменшити висоту" }
                        };

                        nudgePad?.querySelectorAll("[data-nudge-size]").forEach((buttonEl) => {
                            const mode = buttonEl.getAttribute("data-nudge-size") || "";
                            const spec = specs[mode];
                            if (!spec) return;
                            buttonEl.innerHTML = `<span class="nudge-size-value">${spec.value}</span><span class="nudge-size-badge">${spec.sign}</span>`;
                            buttonEl.title = spec.title;
                        });
                    }

                    applyNudgeSizeMode(mode) {
                        const step = this.nudgeStep;
                        if (mode === "w-minus") this.resizeActive(-step, 0);
                        if (mode === "w-plus") this.resizeActive(step, 0);
                        if (mode === "h-minus") this.resizeActive(0, -step);
                        if (mode === "h-plus") this.resizeActive(0, step);
                    }

                    startNudgeSizeHold(mode) {
                        this.stopNudgeSizeHold();
                        this.applyNudgeSizeMode(mode);
                        this.sizeHoldTimeoutId = window.setTimeout(() => {
                            this.sizeHoldIntervalId = window.setInterval(() => {
                                this.applyNudgeSizeMode(mode);
                            }, this.overlayInteractionConfig.holdRepeatMs);
                        }, this.overlayInteractionConfig.holdStartDelayMs);
                    }

                    stopNudgeSizeHold() {
                        if (this.sizeHoldTimeoutId !== null) {
                            window.clearTimeout(this.sizeHoldTimeoutId);
                            this.sizeHoldTimeoutId = null;
                        }
                        if (this.sizeHoldIntervalId !== null) {
                            window.clearInterval(this.sizeHoldIntervalId);
                            this.sizeHoldIntervalId = null;
                        }
                    }

                    applyNudgeMoveDirection(direction) {
                        const step = this.nudgeStep;
                        if (direction === "up") this.nudgeActive(0, -step);
                        if (direction === "down") this.nudgeActive(0, step);
                        if (direction === "left") this.nudgeActive(-step, 0);
                        if (direction === "right") this.nudgeActive(step, 0);
                    }

                    startNudgeMoveHold(direction) {
                        this.stopNudgeMoveHold();
                        this.applyNudgeMoveDirection(direction);
                        this.moveHoldTimeoutId = window.setTimeout(() => {
                            this.moveHoldIntervalId = window.setInterval(() => {
                                this.applyNudgeMoveDirection(direction);
                            }, this.overlayInteractionConfig.holdRepeatMs);
                        }, this.overlayInteractionConfig.holdStartDelayMs);
                    }

                    stopNudgeMoveHold() {
                        if (this.moveHoldTimeoutId !== null) {
                            window.clearTimeout(this.moveHoldTimeoutId);
                            this.moveHoldTimeoutId = null;
                        }
                        if (this.moveHoldIntervalId !== null) {
                            window.clearInterval(this.moveHoldIntervalId);
                            this.moveHoldIntervalId = null;
                        }
                    }

                    scheduleLayoutDraftSave() {
                        if (this.layoutSaveTimerId !== null) {
                            window.clearTimeout(this.layoutSaveTimerId);
                        }
                        if (!this.isApplyingSavedDraft) {
                            this.hasPendingDbSave = true;
                            this.renderSaveHint();
                        }
                        this.layoutSaveTimerId = window.setTimeout(() => this.saveLayoutDraft(), 160);
                    }

                    saveLayoutDraft() {
                        try {
                            const state = {
                                savedAt: Date.now(),
                                boxes: [...this.boxesByIndex.entries()].map(([index, box]) => ({
                                    index,
                                    page: Number.parseInt(box.dataset.page || "1", 10),
                                    left: this.normalizePixel(box.style.left),
                                    top: this.normalizePixel(box.style.top),
                                    width: Math.round(box.offsetWidth),
                                    height: Math.round(box.offsetHeight)
                                }))
                            };
                            window.localStorage.setItem(this.layoutStorageKey, JSON.stringify(state));
                        } catch {
                            // ignore storage issues
                        }
                    }

                    applySavedLayoutDraft() {
                        try {
                            const raw = window.localStorage.getItem(this.layoutStorageKey);
                            if (!raw) return;
                            const state = JSON.parse(raw);
                            if (!state || !Array.isArray(state.boxes)) return;
                            this.isApplyingSavedDraft = true;
                            state.boxes.forEach((item) => {
                                const box = this.boxesByIndex.get(item.index);
                                const layer = this.pageLayers.get(item.page);
                                if (!box || !layer) return;
                                if (box.parentElement !== layer) {
                                    layer.appendChild(box);
                                    box.dataset.page = String(item.page);
                                }
                                box.style.left = `${this.normalizePixel(item.left)}px`;
                                box.style.top = `${this.normalizePixel(item.top)}px`;
                                box.style.width = `${Math.max(20, this.normalizePixel(item.width, 20))}px`;
                                box.style.height = `${Math.max(12, this.normalizePixel(item.height, 12))}px`;
                                this.syncBoxToInputs(box);
                            });
                            this.hasPendingDbSave = false;
                            this.renderSaveHint();
                        } catch {
                            // ignore invalid persisted state
                        } finally {
                            this.isApplyingSavedDraft = false;
                        }
                    }

                    renderSaveHint(message = "") {
                        if (!nudgeSaveHint) return;
                        if (message) {
                            nudgeSaveHint.classList.remove("text-warning");
                            nudgeSaveHint.classList.add("text-muted");
                            nudgeSaveHint.textContent = message;
                            this.updateSaveDbButtonHighlight();
                            return;
                        }
                        if (this.hasPendingDbSave) {
                            nudgeSaveHint.classList.remove("text-muted");
                            nudgeSaveHint.classList.add("text-warning");
                            nudgeSaveHint.textContent = "Є локальні зміни. Для персисту в БД натисніть «💾 БД» або «Зберегти поля».";
                            this.updateSaveDbButtonHighlight();
                            return;
                        }
                        nudgeSaveHint.classList.remove("text-warning");
                        nudgeSaveHint.classList.add("text-muted");
                        nudgeSaveHint.textContent = "Локальний draft синхронізовано.";
                        this.updateSaveDbButtonHighlight();
                    }

                    updateSaveDbButtonHighlight() {
                        nudgePersistToDbBtn?.classList.toggle("nudge-save-pending", this.hasPendingDbSave === true);
                    }

                    getActiveDataFieldSelect() {
                        const activeField = this.activeIndex !== null ? this.fieldByIndex.get(this.activeIndex) : null;
                        if (!activeField || activeField.formIndex === null || activeField.formIndex === undefined) {
                            return null;
                        }

                        return document.getElementById(`Fields_${activeField.formIndex}__DataFieldId`);
                    }

                    syncOverlayDataFieldCombo() {
                        if (!this.overlayDataFieldCombo) {
                            return;
                        }

                        const select = this.getActiveDataFieldSelect();
                        const value = select?.value || "";
                        this.overlayDataFieldCombo.setValue(value || null);
                        this.overlayDataFieldCombo.setDisabled(!select || select.disabled);
                    }

                    applyDataFieldToActiveField(dataFieldId) {
                        const select = this.getActiveDataFieldSelect();
                        if (!select) {
                            return;
                        }

                        select.value = dataFieldId || "";
                        const fieldKey = this.activeFieldId;
                        if (fieldKey) {
                            this.fieldByIndex.forEach((field, overlayIndex) => {
                                if (this.normalizeGuidKey(field.fieldId) !== fieldKey) {
                                    return;
                                }

                                field.dataFieldId = dataFieldId || null;
                                this.fieldByIndex.set(overlayIndex, field);
                            });
                        }

                        this.hasPendingDbSave = true;
                        this.renderSaveHint();
                    }

                    getNextOverlayIndex() {
                        if (this.boxesByIndex.size === 0) {
                            return 0;
                        }

                        return Math.max(...this.boxesByIndex.keys()) + 1;
                    }

                    addSegmentLine() {
                        if (this.editMode !== "edit" || this.activeIndex === null) {
                            return;
                        }

                        const source = this.fieldByIndex.get(this.activeIndex);
                        const sourceBox = this.boxesByIndex.get(this.activeIndex);
                        if (!source || !sourceBox) {
                            return;
                        }

                        const nextSequence = [...this.fieldByIndex.values()]
                            .filter((field) => this.normalizeGuidKey(field.fieldId) === this.normalizeGuidKey(source.fieldId))
                            .reduce((max, field) => Math.max(max, field.segmentSequence ?? 1), 0) + 1;
                        const overlayIndex = this.getNextOverlayIndex();
                        const sourceLeft = this.normalizePixel(sourceBox.style.left);
                        const sourceTop = this.normalizePixel(sourceBox.style.top);
                        const sourceWidth = Math.max(20, Math.round(sourceBox.offsetWidth));
                        const sourceHeight = Math.max(14, Math.round(sourceBox.offsetHeight));
                        const page = Number.parseInt(sourceBox.dataset.page || "1", 10);
                        const layer = this.pageLayers.get(page);
                        const calculatedY = sourceTop + sourceHeight + 5;
                        const maxTop = layer ? Math.max(0, layer.clientHeight - sourceHeight) : calculatedY;
                        const newField = this.normalizeField({
                            fieldId: source.fieldId,
                            segmentId: null,
                            clientReferenceId: this.createClientReferenceId(),
                            segmentSequence: nextSequence,
                            formIndex: source.formIndex,
                            tag: source.tag,
                            title: source.title,
                            page,
                            x: Math.max(0, sourceLeft),
                            y: Math.min(maxTop, Math.max(0, calculatedY)),
                            width: sourceWidth,
                            height: sourceHeight,
                            isPrimary: false,
                            horizontalAlignment: source.horizontalAlignment ?? source.textAlignment ?? "Left",
                            verticalAlignment: source.verticalAlignment ?? null,
                            textAlignment: source.horizontalAlignment ?? source.textAlignment ?? "Left",
                            fontSize: source.fontSize ?? null
                        }, overlayIndex);

                        this.fieldByIndex.set(overlayIndex, newField);
                        const pageFields = this.fieldsByPage.get(newField.page) ?? [];
                        pageFields.push(newField);
                        this.fieldsByPage.set(newField.page, pageFields);
                        this.renderFieldBox(newField);
                        this.setActive(overlayIndex);
                        this.scheduleLayoutDraftSave();
                        showOverlayToast(`Додано сегмент #${nextSequence}`);
                    }

                    normalizeGuidKey(value) {
                        const raw = String(value ?? "").trim();
                        return raw ? raw.toLowerCase() : "";
                    }

                    createClientReferenceId() {
                        if (typeof crypto !== "undefined" && typeof crypto.randomUUID === "function") {
                            return crypto.randomUUID();
                        }

                        return `client-${Date.now()}-${Math.random().toString(16).slice(2)}`;
                    }

                    readSegmentSequenceFromPayload(segment, fallback = 1) {
                        const raw = segment?.sequence ?? segment?.Sequence;
                        const parsed = Number.parseInt(String(raw ?? ""), 10);
                        return Number.isInteger(parsed) && parsed > 0 ? parsed : fallback;
                    }

                    getOverlaySequence(field, overlayIndex) {
                        const box = this.boxesByIndex.get(overlayIndex) ?? this.boxesByIndex.get(field?.index);
                        const fromBox = box
                            ? this.readSegmentSequenceFromPayload({ sequence: box.dataset.segmentSequence }, 0)
                            : 0;
                        if (fromBox > 0) {
                            return fromBox;
                        }

                        return this.readSegmentSequenceFromPayload(
                            { sequence: field?.segmentSequence },
                            overlayIndex + 1);
                    }

                    sortOverlayEntriesForField(entries) {
                        return [...entries].sort((left, right) => {
                            const leftSequence = this.getOverlaySequence(left[1], left[0]);
                            const rightSequence = this.getOverlaySequence(right[1], right[0]);
                            if (leftSequence !== rightSequence) {
                                return leftSequence - rightSequence;
                            }

                            return left[0] - right[0];
                        });
                    }

                    async reloadSegmentIdsFromServer() {
                        const versionId = window.__templateVersionId;
                        if (!versionId) {
                            return 0;
                        }

                        try {
                            const response = await fetch(`/api/template-fields/${versionId}`, {
                                credentials: "same-origin",
                                headers: { Accept: "application/json" }
                            });
                            if (!response.ok) {
                                throw new Error(`GET /api/template-fields/${versionId} повернув ${response.status}.`);
                            }

                            const rawJson = await response.json();
                            console.log("СИРА ВІДПОВІДЬ GET /api/template-fields:", JSON.stringify(rawJson));
                            const savedFields = this.extractSavedFieldsFromResponse(rawJson);
                            if (!savedFields.length) {
                                throw new Error("GET /api/template-fields: у відповіді бракує fields[].");
                            }

                            return this.syncSegmentIdsFromSavedFields(savedFields);
                        } catch (error) {
                            console.error("[FieldEngine] reloadSegmentIdsFromServer failed", error);
                            throw error;
                        }
                    }

                    readFieldIdFromPayload(field) {
                        return field?.fieldId
                            ?? field?.FieldId
                            ?? field?.id
                            ?? field?.Id
                            ?? null;
                    }

                    readRawSegmentsFromSavedField(savedField) {
                        if (!savedField || typeof savedField !== "object") {
                            return [];
                        }

                        const candidates = [
                            savedField.segments,
                            savedField.Segments,
                            savedField.templateFieldSegments,
                            savedField.TemplateFieldSegments
                        ];

                        for (const candidate of candidates) {
                            if (Array.isArray(candidate)) {
                                return candidate;
                            }
                        }

                        return [];
                    }

                    extractSavedFieldsFromResponse(responseBody) {
                        if (!responseBody) {
                            return [];
                        }

                        const normalizeField = (field) => ({
                            fieldId: this.readFieldIdFromPayload(field),
                            segments: this.readRawSegmentsFromSavedField(field)
                        });

                        if (Array.isArray(responseBody)) {
                            return responseBody.map(normalizeField);
                        }

                        if (typeof responseBody !== "object") {
                            return [];
                        }

                        const fields = responseBody.fields
                            ?? responseBody.Fields
                            ?? responseBody.data?.fields
                            ?? responseBody.Data?.Fields
                            ?? responseBody.result?.fields
                            ?? responseBody.Result?.Fields;

                        if (Array.isArray(fields)) {
                            return fields.map(normalizeField);
                        }

                        if (this.readFieldIdFromPayload(responseBody) && this.readRawSegmentsFromSavedField(responseBody).length > 0) {
                            return [normalizeField(responseBody)];
                        }

                        return [];
                    }

                    resolveSegmentIdForPayload(segmentId) {
                        const raw = String(segmentId ?? "").trim();
                        if (!raw || raw.startsWith("temp-")) {
                            return null;
                        }

                        return /^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$/i.test(raw)
                            ? raw.toLowerCase()
                            : null;
                    }

                    readSegmentIdFromPayload(segment) {
                        const raw = segment?.id
                            ?? segment?.Id
                            ?? segment?.segmentId
                            ?? segment?.SegmentId;
                        if (raw === null || raw === undefined) {
                            return null;
                        }

                        return this.resolveSegmentIdForPayload(String(raw));
                    }

                    encodeRowVersionBytes(bytes) {
                        if (!Array.isArray(bytes) || bytes.length === 0) {
                            return null;
                        }

                        let binary = "";
                        for (let index = 0; index < bytes.length; index += 1) {
                            binary += String.fromCharCode(bytes[index] & 0xff);
                        }

                        return btoa(binary);
                    }

                    readRowVersionFromPayload(segment) {
                        const raw = segment?.rowVersion
                            ?? segment?.RowVersion
                            ?? segment?.rowVersionBase64
                            ?? segment?.RowVersionBase64;
                        if (raw === null || raw === undefined) {
                            return null;
                        }

                        if (Array.isArray(raw)) {
                            return this.encodeRowVersionBytes(raw);
                        }

                        if (raw instanceof Uint8Array) {
                            return this.encodeRowVersionBytes(Array.from(raw));
                        }

                        const value = String(raw).trim();
                        return value ? value : null;
                    }

                    resolveRowVersionForPayload(rowVersion) {
                        const value = String(rowVersion ?? "").trim();
                        return value ? value : null;
                    }

                    resolveDomRowVersion(box, field) {
                        if (!box) {
                            return this.resolveRowVersionForPayload(field?.segmentRowVersion);
                        }

                        const fromDataset = box.dataset.rowVersion ?? "";
                        const fromAttribute = box.getAttribute("data-row-version") ?? "";
                        const fromState = field?.segmentRowVersion ?? "";
                        return this.resolveRowVersionForPayload(fromDataset || fromAttribute || fromState);
                    }

                    normalizeSavedSegments(rawSegments) {
                        if (!Array.isArray(rawSegments) || rawSegments.length === 0) {
                            return [];
                        }

                        return rawSegments
                            .map((segment, index) => {
                                const sequence = this.readSegmentSequenceFromPayload(segment, index + 1);
                                const id = this.readSegmentIdFromPayload(segment);
                                if (!id) {
                                    throw new Error(
                                        `[FieldEngine] У відповіді сервера немає id для сегмента sequence=${sequence}: ${JSON.stringify(segment)}`);
                                }

                                const rowVersion = this.readRowVersionFromPayload(segment);
                                if (!rowVersion) {
                                    console.warn("[FieldEngine] У відповіді сервера немає rowVersion для сегмента", {
                                        id,
                                        sequence,
                                        segment
                                    });
                                }

                                return {
                                    id,
                                    rowVersion,
                                    sequence,
                                    page: segment?.page ?? segment?.Page ?? segment?.pageNumber ?? segment?.PageNumber ?? 1,
                                    x: segment?.x ?? segment?.X ?? segment?.positionX ?? segment?.PositionX ?? 0,
                                    y: segment?.y ?? segment?.Y ?? segment?.positionY ?? segment?.PositionY ?? 0,
                                    width: segment?.width ?? segment?.Width ?? 0,
                                    height: segment?.height ?? segment?.Height ?? 0,
                                    isPrimary: segment?.isPrimary ?? segment?.IsPrimary ?? false,
                                    ...this.readTypographyFromSegmentSource(segment)
                                };
                            })
                            .sort((left, right) => left.sequence - right.sequence)
                            .map((segment, index) => ({
                                ...segment,
                                sequence: index + 1
                            }));
                    }

                    findOverlayBoxForSegment(fieldId, serverSegment, overlayIndex, previousSegmentId) {
                        const fieldKey = this.normalizeGuidKey(fieldId);
                        const boxByIndex = Number.isInteger(overlayIndex)
                            ? this.boxesByIndex.get(overlayIndex)
                            : null;
                        if (boxByIndex && this.normalizeGuidKey(boxByIndex.dataset.fieldId) === fieldKey) {
                            return boxByIndex;
                        }

                        const candidates = [...this.boxesByIndex.values()]
                            .filter((box) => this.normalizeGuidKey(box.dataset.fieldId) === fieldKey);

                        const previousKey = this.normalizeGuidKey(previousSegmentId);
                        if (previousKey) {
                            const byPreviousId = candidates.find((box) =>
                                this.normalizeGuidKey(box.dataset.segmentId) === previousKey);
                            if (byPreviousId) {
                                return byPreviousId;
                            }
                        }

                        const bySequence = candidates.find((box) =>
                            this.readSegmentSequenceFromPayload({ sequence: box.dataset.segmentSequence }, 0) === serverSegment.sequence);
                        if (bySequence) {
                            return bySequence;
                        }

                        return candidates[serverSegment.sequence - 1] ?? null;
                    }

                    applySegmentIdentityToOverlay(overlayIndex, field, serverSegment, serverSegments) {
                        if (!serverSegment?.id) {
                            throw new Error(
                                `[FieldEngine] Сервер не повернув id для сегмента sequence=${serverSegment?.sequence ?? "?"}.`);
                        }

                        const previousSegmentId = field?.segmentId ?? null;
                        const nextSegmentId = serverSegment.id;
                        const nextSequence = serverSegment.sequence;
                        const nextRowVersion = this.resolveRowVersionForPayload(serverSegment.rowVersion);
                        const nextClientReferenceId = serverSegment.clientReferenceId
                            ?? field?.clientReferenceId
                            ?? this.createClientReferenceId();
                        const nextField = {
                            ...field,
                            segmentId: nextSegmentId,
                            clientReferenceId: nextClientReferenceId,
                            segmentSequence: nextSequence,
                            segmentRowVersion: nextRowVersion,
                            rowVersion: nextRowVersion,
                            segments: serverSegments.map((segment) => ({
                                id: segment.id,
                                sequence: segment.sequence,
                                rowVersion: segment.rowVersion
                            }))
                        };

                        this.fieldByIndex.set(overlayIndex, nextField);

                        const box = this.boxesByIndex.get(overlayIndex) ?? this.boxesByIndex.get(field?.index);
                        if (!box) {
                            throw new Error(
                                `[FieldEngine] Не знайдено DOM-елемент для сегмента sequence=${nextSequence}, overlayIndex=${overlayIndex}, fieldId=${field?.fieldId ?? "?"}.`);
                        }

                        box.dataset.segmentId = String(nextSegmentId);
                        box.dataset.clientRef = String(nextClientReferenceId);
                        box.dataset.segmentSequence = String(nextSequence);
                        box.dataset.rowVersion = String(nextRowVersion ?? "");
                        box.setAttribute("data-row-version", String(nextRowVersion ?? ""));
                        const label = box.querySelector(".field-overlay-label");
                        if (label) {
                            label.textContent = `${nextField.title || nextField.tag} #${nextSequence}`;
                        }

                        console.log("Оновлено DOM елемент для Sequence:", nextSequence, {
                            fieldId: field.fieldId,
                            overlayIndex,
                            previousSegmentId,
                            nextSegmentId,
                            nextRowVersion,
                            boxIndex: box.dataset.index
                        });
                        return true;
                    }

                    countUnsyncedOverlaySegments() {
                        let count = 0;
                        this.fieldByIndex.forEach((field, overlayIndex) => {
                            const box = this.boxesByIndex.get(overlayIndex) ?? this.boxesByIndex.get(field.index);
                            const segmentId = this.resolveSegmentIdForPayload(box?.dataset.segmentId ?? field.segmentId);
                            if (!segmentId) {
                                count += 1;
                                return;
                            }

                            const rowVersion = this.resolveRowVersionForPayload(box?.dataset.rowVersion ?? field.segmentRowVersion);
                            if (!rowVersion) {
                                count += 1;
                            }
                        });
                        return count;
                    }

                    countPersistedSegments(savedFields) {
                        if (!Array.isArray(savedFields)) {
                            return 0;
                        }

                        return savedFields.reduce((total, savedField) => {
                            const rawSegments = Array.isArray(savedField?.segments)
                                ? savedField.segments
                                : Array.isArray(savedField?.Segments)
                                    ? savedField.Segments
                                    : [];
                            return total + this.normalizeSavedSegments(rawSegments).length;
                        }, 0);
                    }

                    replaceAllSegmentsState(serverSegments) {
                        if (!Array.isArray(serverSegments)) {
                            throw new Error("[StateSync] replaceAllSegmentsState: segments[] відсутній.");
                        }

                        const byClientRef = new Map();
                        const byId = new Map();
                        const byFieldSequence = new Map();

                        serverSegments.forEach((serverSeg) => {
                            const savedId = this.readSegmentIdFromPayload(serverSeg);
                            const clientReferenceId = String(
                                serverSeg?.clientReferenceId ?? serverSeg?.ClientReferenceId ?? "").trim();
                            const fieldId = this.normalizeGuidKey(serverSeg?.fieldId ?? serverSeg?.FieldId);
                            const sequence = this.readSegmentSequenceFromPayload(serverSeg, 0);

                            if (savedId) {
                                byId.set(savedId, serverSeg);
                            }

                            if (clientReferenceId) {
                                byClientRef.set(clientReferenceId, serverSeg);
                            }

                            if (fieldId && sequence > 0) {
                                byFieldSequence.set(`${fieldId}|${sequence}`, serverSeg);
                            }
                        });

                        const resolveServerSegment = (box, field) => {
                            const clientRef = String(box.dataset.clientRef ?? field.clientReferenceId ?? "").trim();
                            const segmentId = this.resolveSegmentIdForPayload(box.dataset.segmentId ?? field.segmentId);
                            const fieldId = this.normalizeGuidKey(field.fieldId ?? box.dataset.fieldId);
                            const sequence = this.readSegmentSequenceFromPayload(
                                { sequence: box.dataset.segmentSequence },
                                this.readSegmentSequenceFromPayload(field, 0));

                            return (clientRef && byClientRef.get(clientRef))
                                || (segmentId && byId.get(segmentId))
                                || (fieldId && sequence > 0 ? byFieldSequence.get(`${fieldId}|${sequence}`) : null);
                        };

                        const overlayIndexesToRemove = [];
                        this.boxesByIndex.forEach((box, overlayIndex) => {
                            const field = this.fieldByIndex.get(overlayIndex)
                                ?? this.fieldByIndex.get(Number.parseInt(box.dataset.index ?? "", 10));
                            if (!field) {
                                overlayIndexesToRemove.push(overlayIndex);
                                return;
                            }

                            if (!resolveServerSegment(box, field)) {
                                overlayIndexesToRemove.push(overlayIndex);
                            }
                        });

                        overlayIndexesToRemove
                            .sort((left, right) => right - left)
                            .forEach((overlayIndex) => {
                                const box = this.boxesByIndex.get(overlayIndex);
                                if (box) {
                                    box.remove();
                                }

                                this.boxesByIndex.delete(overlayIndex);
                                this.fieldByIndex.delete(overlayIndex);
                                this.fieldsByPage.forEach((pageFields, page) => {
                                    this.fieldsByPage.set(
                                        page,
                                        pageFields.filter((item) => item.index !== overlayIndex));
                                });
                            });

                        this.boxesByIndex.forEach((box, overlayIndex) => {
                            const field = this.fieldByIndex.get(overlayIndex)
                                ?? this.fieldByIndex.get(Number.parseInt(box.dataset.index ?? "", 10));
                            if (!field) {
                                return;
                            }

                            const serverSeg = resolveServerSegment(box, field);
                            if (!serverSeg) {
                                return;
                            }

                            const clientRef = String(box.dataset.clientRef ?? field.clientReferenceId ?? "").trim();
                            const fieldId = this.normalizeGuidKey(field.fieldId ?? box.dataset.fieldId);
                            const localSequence = this.readSegmentSequenceFromPayload(
                                { sequence: box.dataset.segmentSequence },
                                this.readSegmentSequenceFromPayload(field, 0));
                            const savedId = this.readSegmentIdFromPayload(serverSeg);
                            const rowVersion = this.resolveRowVersionForPayload(
                                this.readRowVersionFromPayload(serverSeg));
                            const nextSequence = this.readSegmentSequenceFromPayload(
                                serverSeg,
                                localSequence > 0 ? localSequence : overlayIndex + 1);
                            const nextClientRef = String(
                                serverSeg?.clientReferenceId ?? serverSeg?.ClientReferenceId ?? clientRef).trim();

                            if (savedId) {
                                box.dataset.segmentId = String(savedId);
                            }

                            if (nextClientRef) {
                                box.dataset.clientRef = nextClientRef;
                            }

                            const nextFieldId = this.normalizeGuidKey(serverSeg?.fieldId ?? serverSeg?.FieldId) || fieldId;
                            if (nextFieldId) {
                                box.dataset.fieldId = nextFieldId;
                            }

                            box.dataset.rowVersion = String(rowVersion ?? "");
                            box.setAttribute("data-row-version", String(rowVersion ?? ""));
                            box.dataset.segmentSequence = String(nextSequence);
                            box.removeAttribute("data-temp-id");

                            const label = box.querySelector(".field-overlay-label");
                            if (label) {
                                label.textContent = `${field.title || field.tag} #${nextSequence}`;
                            }

                            this.fieldByIndex.set(overlayIndex, {
                                ...field,
                                fieldId: nextFieldId || field.fieldId,
                                segmentId: savedId ? String(savedId) : field.segmentId,
                                clientReferenceId: nextClientRef || field.clientReferenceId,
                                rowVersion: rowVersion ?? null,
                                segmentRowVersion: rowVersion ?? null,
                                segmentSequence: nextSequence,
                                isPrimary: serverSeg?.isPrimary ?? serverSeg?.IsPrimary ?? field.isPrimary,
                                ...this.readTypographyFromSegmentSource(serverSeg ?? field)
                            });
                        });

                        if (this.activeIndex !== null) {
                            const activeField = this.fieldByIndex.get(this.activeIndex);
                            this.activeSegmentId = activeField?.segmentId ?? null;
                            this.syncSegmentTextSettingsUi();
                        }

                        if (this.calibrationMode) {
                            this.refreshAllCalibrationInlineEditorStyles();
                            this.syncCalibrationPanel();
                        }
                    }

                    syncSegmentIdsFromSavedFields(savedFields) {
                        console.log("[SyncEngine] Початок синхронізації...", savedFields);
                        if (!Array.isArray(savedFields) || savedFields.length === 0) {
                            throw new Error("[SyncEngine] syncSegmentIdsFromSavedFields: порожній savedFields payload.");
                        }

                        let updatedCount = 0;
                        savedFields.forEach((fieldData) => {
                            const fieldId = this.readFieldIdFromPayload(fieldData);
                            const rawSegments = this.readRawSegmentsFromSavedField(fieldData);
                            if (!fieldId) {
                                throw new Error(
                                    `[SyncEngine] У відповіді сервера немає fieldId: ${JSON.stringify(fieldData)}`);
                            }

                            const serverSegments = this.normalizeSavedSegments(rawSegments);
                            serverSegments.forEach((saved) => {
                                const selector = `.field-overlay-box[data-field-id="${fieldId}"][data-segment-sequence="${saved.sequence}"]`;
                                const box = document.querySelector(selector);
                                if (!box) {
                                    console.warn(
                                        `[SyncEngine] Не знайдено overlay для поля ${fieldId}, seq: ${saved.sequence}`);
                                    return;
                                }

                                const overlayIndex = Number.parseInt(box.dataset.index ?? "", 10);
                                const stateField = Number.isInteger(overlayIndex)
                                    ? this.fieldByIndex.get(overlayIndex)
                                    : null;

                                box.dataset.segmentId = String(saved.id);
                                box.dataset.rowVersion = String(this.resolveRowVersionForPayload(saved.rowVersion) ?? "");
                                box.removeAttribute("data-temp-id");

                                if (stateField) {
                                    this.applySegmentIdentityToOverlay(
                                        overlayIndex,
                                        stateField,
                                        saved,
                                        serverSegments);
                                    updatedCount += 1;
                                }
                            });
                        });

                        if (this.activeIndex !== null) {
                            const activeField = this.fieldByIndex.get(this.activeIndex);
                            this.activeSegmentId = activeField?.segmentId ?? null;
                        }

                        console.log("%c[SyncEngine] Синхронізація завершена успішно", "color: limegreen; font-weight: bold");
                        return updatedCount;
                    }

                    collectSegmentsPayload() {
                        const grouped = new Map();
                        this.fieldByIndex.forEach((field, overlayIndex) => {
                            const box = this.boxesByIndex.get(overlayIndex) ?? this.boxesByIndex.get(field.index);
                            if (!box || !field.fieldId) {
                                return;
                            }

                            const page = Number.parseInt(box.dataset.page || "1", 10);
                            const previewField = this.getFieldInPreviewSpace(box, page);
                            const fieldKey = this.normalizeGuidKey(field.fieldId);
                            const group = grouped.get(fieldKey) ?? {
                                fieldId: this.normalizeGuidKey(field.fieldId),
                                textOffsetX: this.parsePixel(field.textOffsetX ?? 0),
                                textOffsetY: this.parsePixel(field.textOffsetY ?? 0),
                                segments: []
                            };
                            group.textOffsetX = this.parsePixel(field.textOffsetX ?? group.textOffsetX ?? 0);
                            group.textOffsetY = this.parsePixel(field.textOffsetY ?? group.textOffsetY ?? 0);
                            const clientReferenceId = box.dataset.clientRef
                                || field.clientReferenceId
                                || this.createClientReferenceId();
                            const segmentId = this.resolveSegmentIdForPayload(box.dataset.segmentId ?? field.segmentId);
                            const rowVersion = this.resolveDomRowVersion(box, field);
                            box.dataset.clientRef = clientReferenceId;
                            field.clientReferenceId = clientReferenceId;
                            field.segmentRowVersion = rowVersion;
                            field.rowVersion = rowVersion;
                            this.fieldByIndex.set(overlayIndex, field);

                            const segmentPayload = {
                                clientReferenceId,
                                id: segmentId,
                                sequence: this.getOverlaySequence(field, overlayIndex),
                                page: previewField.page,
                                x: previewField.x,
                                y: previewField.y,
                                width: previewField.width,
                                height: previewField.height,
                                isPrimary: field.isPrimary === true,
                                textAlignment: field.horizontalAlignment ?? field.textAlignment ?? "Left",
                                fontSize: field.fontSize ?? null,
                                fontName: field.fontName ?? null,
                                lineHeight: field.lineHeight ?? null,
                                horizontalAlignment: field.horizontalAlignment ?? field.textAlignment ?? "Left",
                                verticalAlignment: field.verticalAlignment ?? null,
                                svgPathData: this.buildExtraTextStylePayload(field),
                                rowVersionBase64: rowVersion
                            };

                            group.segments.push(segmentPayload);
                            grouped.set(fieldKey, group);
                        });

                        return [...grouped.values()].map((group) => {
                            const orderedSegments = group.segments
                                .sort((left, right) => left.sequence - right.sequence)
                                .map((segment, index) => ({
                                    ...segment,
                                    sequence: index + 1
                                }));

                            if (!orderedSegments.some((segment) => segment.isPrimary)) {
                                orderedSegments[0].isPrimary = true;
                            } else {
                                let primaryAssigned = false;
                                orderedSegments.forEach((segment) => {
                                    if (segment.isPrimary && !primaryAssigned) {
                                        primaryAssigned = true;
                                        return;
                                    }

                                    segment.isPrimary = false;
                                });
                            }

                            return {
                                fieldId: group.fieldId,
                                textOffsetX: group.textOffsetX ?? 0,
                                textOffsetY: group.textOffsetY ?? 0,
                                segments: orderedSegments
                            };
                        });
                    }

                    getAntiForgeryToken() {
                        return fieldMapForm?.querySelector('input[name="__RequestVerificationToken"]')?.value ?? "";
                    }

                    async persistSegmentsToApi(options = {}) {
                        const silent = options.silent === true;
                        const versionId = window.__templateVersionId;
                        const deletedFieldIds = this.collectDeletedFieldIds();
                        const payload = {
                            fields: this.collectSegmentsPayload(),
                            deletedFieldIds
                        };
                        if (!versionId || (payload.fields.length === 0 && deletedFieldIds.length === 0)) {
                            return true;
                        }

                        try {
                            const response = await fetch(`/api/template-fields/${versionId}/segments`, {
                                method: "PUT",
                                credentials: "same-origin",
                                headers: {
                                    "Content-Type": "application/json",
                                    "Accept": "application/json",
                                    "RequestVerificationToken": this.getAntiForgeryToken()
                                },
                                body: JSON.stringify(payload)
                            });

                            if (!response.ok) {
                                const message = await parseServerErrorMessageFromResponse(
                                    response,
                                    "Не вдалося зберегти сегменти.");
                                this.renderSaveHint(message);
                                showOverlayToast(message, true);
                                return false;
                            }

                            const data = await response.json();
                            this.replaceAllSegmentsState(data.segments ?? data.Segments ?? []);
                            this.clearDeletedFieldIds();

                            this.lastSavedSegmentFields = Array.isArray(data?.segments)
                                ? data.segments
                                : Array.isArray(data?.Segments)
                                    ? data.Segments
                                    : [];

                            try {
                                window.localStorage.removeItem(this.layoutStorageKey);
                            } catch {
                                // ignore storage issues
                            }

                            if (!silent) {
                                await this.reloadFromServer();
                                this.renderSaveHint("Сегменти збережено в БД.");
                                showOverlayToast("Сегменти збережено в БД.");
                            }

                            const savedActiveIndex = this.activeIndex;
                            const savedActiveFieldId = this.activeFieldId;
                            if (Number.isInteger(savedActiveIndex)) {
                                this.setActive(savedActiveIndex);
                            } else if (savedActiveFieldId) {
                                const restoredIndex = this.getOverlayIndexForField(
                                    savedActiveFieldId,
                                    this.lastActiveSegmentByFieldId.get(savedActiveFieldId));
                                if (restoredIndex !== null) {
                                    this.setActive(restoredIndex);
                                }
                            }
                            return true;
                        } catch (error) {
                            this.debugLog("Segment save failed", error);
                            const message = error instanceof Error && error.message
                                ? error.message
                                : "Помилка збереження сегментів.";
                            this.renderSaveHint(message);
                            showOverlayToast(message, true);
                            return false;
                        }
                    }

                    async persistFieldMapFormAsync() {
                        if (!fieldMapForm) {
                            return false;
                        }

                        try {
                            const response = await fetch(fieldMapForm.action || window.location.href, {
                                method: "POST",
                                credentials: "same-origin",
                                headers: {
                                    "X-Requested-With": "XMLHttpRequest",
                                    "Accept": "application/json"
                                },
                                body: new FormData(fieldMapForm)
                            });

                            if (response.ok) {
                                const body = await response.json().catch(() => null);
                                const message = body?.message ?? "Поля шаблону збережено.";
                                this.renderSaveHint("Поля шаблону збережено в БД.");
                                showOverlayToast(message);
                                return true;
                            }

                            const message = await parseServerErrorMessageFromResponse(
                                response,
                                "Не вдалося зберегти поля.");
                            this.renderSaveHint(message);
                            showOverlayToast(message, true);
                            return false;
                        } catch (error) {
                            this.debugLog("Field map save failed", error);
                            const message = "Помилка збереження полів.";
                            this.renderSaveHint(message);
                            showOverlayToast(message, true);
                            return false;
                        }
                    }

                    getDebugDump() {
                        return {
                            apiCount: this.lastApiFieldCount,
                            renderedCount: this.boxesByIndex.size,
                            pages: this.pageLayers.size,
                            active: this.activeIndex,
                            apiSample: this.lastApiSample,
                            renderedSample: this.lastRenderedSample
                        };
                    }

                    getFieldIdByIndex(index) {
                        return document.getElementById(`Fields_${index}__FieldId`)?.value ?? null;
                    }

                    getOverlayIndexForField(fieldId, preferredOverlayIndex = null) {
                        const normalizedFieldId = this.normalizeGuidKey(fieldId);
                        if (!normalizedFieldId) {
                            return null;
                        }

                        if (Number.isInteger(preferredOverlayIndex) && this.boxesByIndex.has(preferredOverlayIndex)) {
                            const preferredField = this.fieldByIndex.get(preferredOverlayIndex);
                            if (this.normalizeGuidKey(preferredField?.fieldId) === normalizedFieldId) {
                                return preferredOverlayIndex;
                            }
                        }

                        if (this.activeFieldId === normalizedFieldId && this.activeIndex !== null) {
                            const activeField = this.fieldByIndex.get(this.activeIndex);
                            if (this.normalizeGuidKey(activeField?.fieldId) === normalizedFieldId) {
                                return this.activeIndex;
                            }
                        }

                        const matches = [...this.fieldByIndex.entries()]
                            .filter(([, field]) => this.normalizeGuidKey(field?.fieldId) === normalizedFieldId)
                            .sort(([, left], [, right]) => {
                                const leftSequence = left?.segmentSequence ?? Number.MAX_SAFE_INTEGER;
                                const rightSequence = right?.segmentSequence ?? Number.MAX_SAFE_INTEGER;
                                return leftSequence - rightSequence;
                            });

                        return matches[0]?.[0] ?? null;
                    }

                    getIndexByFieldId(fieldId) {
                        const normalizedFieldId = this.normalizeGuidKey(fieldId);
                        if (!normalizedFieldId) return null;
                        for (let i = 0; ; i++) {
                            const input = document.getElementById(`Fields_${i}__FieldId`);
                            if (!input) break;
                            if (this.normalizeGuidKey(input.value) === normalizedFieldId) return i;
                        }
                        return null;
                    }

                    clampInt(value, min, max, fallback) {
                        const parsed = Number.parseInt(String(value), 10);
                        if (!Number.isInteger(parsed)) return fallback;
                        return Math.min(Math.max(parsed, min), max);
                    }

                    parsePixel(value, fallback = 0) {
                        const raw = Number.parseFloat(String(value));
                        return Number.isFinite(raw) ? raw : fallback;
                    }

                    clampCalibrationOffset(value) {
                        const raw = this.parsePixel(value, 0);
                        return Math.min(CAL_OFFSET_MAX, Math.max(CAL_OFFSET_MIN, raw));
                    }

                    formatCalibrationEditingLabel(field) {
                        if (!field) {
                            return "";
                        }

                        const tag = String(field.tag ?? "").trim();
                        const title = String(field.title ?? "").trim();
                        if (tag && title) {
                            return `${tag} — ${title}`;
                        }

                        return tag || title || "поле";
                    }

                    getCalibrationState(index) {
                        const field = this.fieldByIndex.get(index);
                        if (!field) return null;

                        let state = this.calibrationByIndex.get(index);
                        if (!state) {
                            state = {
                                offsetX: this.parsePixel(field.textOffsetX ?? 0),
                                offsetY: this.parsePixel(field.textOffsetY ?? 0),
                                text: ""
                            };
                            this.calibrationByIndex.set(index, state);
                        }
                        return state;
                    }

                    syncFieldTextOffsetsToForm(fieldId, offsetX, offsetY) {
                        const normalized = this.normalizeGuidKey(fieldId);
                        if (!normalized) return;
                        document.querySelectorAll(`.js-field-text-offset-x[data-field-id="${normalized}"]`)
                            .forEach((input) => { input.value = String(offsetX); });
                        document.querySelectorAll(`.js-field-text-offset-y[data-field-id="${normalized}"]`)
                            .forEach((input) => { input.value = String(offsetY); });
                    }

                    applyFieldTextOffsets(index, offsetX, offsetY) {
                        const field = this.fieldByIndex.get(index);
                        if (!field) return;

                        offsetX = this.clampCalibrationOffset(offsetX);
                        offsetY = this.clampCalibrationOffset(offsetY);
                        field.textOffsetX = offsetX;
                        field.textOffsetY = offsetY;
                        this.fieldByIndex.set(index, field);

                        const state = this.getCalibrationState(index);
                        if (state) {
                            state.offsetX = offsetX;
                            state.offsetY = offsetY;
                        }

                        if (field.fieldId) {
                            this.syncFieldTextOffsetsToForm(field.fieldId, offsetX, offsetY);
                        }

                        const page = field.page ?? Number.parseInt(this.boxesByIndex.get(index)?.dataset.page || "1", 10);
                        const box = this.boxesByIndex.get(index);
                        if (box) {
                            this.layoutCalibrationInlineEditor(box, field, box.querySelector(".calibration-inline-input"));
                        }
                        this.syncCalibrationPanel();
                        if (index === this.activeIndex) {
                            this.markCalibrationDirty();
                        }
                    }

                    toggleCalibrationMode() {
                        if (this.calibrationMode) {
                            this.disableCalibrationMode();
                        } else {
                            this.enableCalibrationMode();
                        }
                    }

                    enableCalibrationMode() {
                        this.calibrationMode = true;
                        this.isInspectMode = false;
                        document.body.classList.add("template-map-calibration-mode");
                        calibrationToggleButtons.forEach((btn) => btn.classList.add("active"));
                        this.applyCalibrationModeUi();
                        this.calibrationByIndex.clear();
                        this.fieldByIndex.forEach((_field, index) => this.getCalibrationState(index));
                        this.syncAllCalibrationInlineEditors();
                        this.updateAllBoxVisualStates();
                        this.setCalibrationTab("text");
                        this.renderCalibrationSaveStatus("");
                        if (this.activeIndex === null && this.boxesByIndex.size > 0) {
                            const firstIndex = [...this.boxesByIndex.keys()].sort((a, b) => a - b)[0];
                            this.setActive(firstIndex);
                        } else {
                            this.syncCalibrationPanel();
                        }
                        showOverlayToast("Калібрування: клік по полю — введення тексту на PDF");
                    }

                    disableCalibrationMode() {
                        if (this.calibrationAutosaveTimerId !== null) {
                            window.clearTimeout(this.calibrationAutosaveTimerId);
                            this.calibrationAutosaveTimerId = null;
                        }
                        this.calibrationMode = false;
                        this.calibrationEditingIndex = null;
                        this.calibrationDirty = false;
                        document.body.classList.remove("template-map-calibration-mode");
                        calibrationToggleButtons.forEach((btn) => btn.classList.remove("active"));
                        this.applyCalibrationModeUi();
                        this.removeAllCalibrationInlineEditors();
                        pagesHost?.querySelectorAll(".calibration-text-layer").forEach((layer) => layer.remove());
                        this.calibrationByIndex.clear();
                        this.updateAllBoxVisualStates();
                        this.syncCalibrationPanel();
                        showOverlayToast("Режим калібрування вимкнено");
                    }

                    /** Текст/offset у базових preview-координатах (як PdfOverlayTextLayout у C#); field.x/y — уже viewport. */
                    getCalibrationTextBounds(field, state) {
                        const layout = window.PdfOverlayTextLayout;
                        if (!layout || !field) {
                            return null;
                        }

                        const coordScale = this.getCoordinateScale();
                        if (!Number.isFinite(coordScale) || coordScale <= 0) {
                            return null;
                        }

                        const calibrationState = state ?? this.getCalibrationState(field.index);
                        return layout.getPreviewBounds(
                            this.parsePixel(field.x ?? 0) / coordScale,
                            this.parsePixel(field.y ?? 0) / coordScale,
                            this.parsePixel(field.width ?? 220, 220) / coordScale,
                            this.parsePixel(field.height ?? 28, 28) / coordScale,
                            field.textOffsetX ?? calibrationState?.offsetX ?? 0,
                            field.textOffsetY ?? calibrationState?.offsetY ?? 0,
                            coordScale);
                    }

                    getCalibrationInputRect(field) {
                        const layout = window.PdfOverlayTextLayout;
                        if (!layout || !field) {
                            return null;
                        }

                        const state = this.getCalibrationState(field.index);
                        const coordScale = this.getCoordinateScale();
                        const boxX = this.parsePixel(field.x ?? 0);
                        const boxY = this.parsePixel(field.y ?? 0);
                        const bounds = this.getCalibrationTextBounds(field, state);
                        if (!bounds) {
                            return null;
                        }

                        return {
                            translateX: bounds.left - boxX,
                            translateY: bounds.top - boxY,
                            width: Math.max(24, bounds.width),
                            height: Math.max(14, bounds.height),
                            fontSize: layout.resolveFontSizePx(field.fontSize, coordScale)
                        };
                    }

                    layoutCalibrationInlineEditor(box, field, input) {
                        const rect = this.getCalibrationInputRect(field);
                        if (!rect || !input) {
                            return;
                        }

                        input.style.left = "0";
                        input.style.top = "0";
                        input.style.width = `${rect.width}px`;
                        input.style.height = `${rect.height}px`;
                        input.style.padding = "0";
                        input.style.transform = `translate(${rect.translateX}px, ${rect.translateY}px)`;
                        input.style.transformOrigin = "0 0";
                        input.style.fontSize = `${rect.fontSize}px`;
                        input.style.boxSizing = "border-box";
                        this.applyCalibrationStylesToInlineEditor(input, field);
                    }

                    applyCalibrationStylesToInlineEditor(input, field) {
                        if (!input || !field) {
                            return;
                        }

                        const fontStack = field.fontName
                            ? `${field.fontName}, Arial, Helvetica, sans-serif`
                            : "Arial, Helvetica, sans-serif";
                        const lineHeightValue = field.lineHeight != null
                            ? Number.parseFloat(String(field.lineHeight))
                            : 1.2;
                        const lineHeight = Number.isFinite(lineHeightValue) && lineHeightValue > 0
                            ? lineHeightValue
                            : 1.2;
                        const letterSpacing = this.parsePixel(field.letterSpacing ?? 0);
                        const fontSizePx = Number.parseFloat(input.style.fontSize);
                        const boxHeightPx = Number.parseFloat(input.style.height);
                        const contentHeight = Number.isFinite(fontSizePx) && fontSizePx > 0
                            ? fontSizePx * lineHeight
                            : 0;

                        input.classList.toggle("cal-text-bold", field.fontBold === true);
                        input.classList.toggle("cal-text-italic", field.fontItalic === true);
                        input.classList.toggle("cal-text-underline", field.textUnderline === true);
                        input.style.display = "block";
                        input.style.alignItems = "";
                        input.style.fontFamily = fontStack;
                        input.style.fontWeight = field.fontBold ? "700" : "400";
                        input.style.fontStyle = field.fontItalic ? "italic" : "normal";
                        input.style.textDecoration = field.textUnderline ? "underline" : "none";
                        input.style.color = field.textColor || "#111111";
                        input.style.lineHeight = String(lineHeight);
                        input.style.letterSpacing = letterSpacing !== 0 ? `${letterSpacing}px` : "normal";

                        const hAlign = String(field.horizontalAlignment ?? field.textAlignment ?? "Left");
                        input.style.textAlign = hAlign.toLowerCase() === "center"
                            ? "center"
                            : hAlign.toLowerCase() === "right"
                                ? "right"
                                : "left";

                        const vAlign = String(field.verticalAlignment ?? "Top").toLowerCase();
                        let paddingTop = 0;
                        if (Number.isFinite(boxHeightPx) && boxHeightPx > 0 && contentHeight > 0) {
                            if (vAlign === "middle") {
                                paddingTop = Math.max(0, (boxHeightPx - contentHeight) / 2);
                            } else if (vAlign === "bottom") {
                                paddingTop = Math.max(0, boxHeightPx - contentHeight);
                            }
                        }

                        input.style.paddingTop = `${paddingTop}px`;
                        input.style.paddingRight = "0";
                        input.style.paddingBottom = "0";
                        input.style.paddingLeft = "0";
                    }

                    refreshActiveCalibrationPreview() {
                        if (!this.calibrationMode || this.activeIndex === null) {
                            return;
                        }

                        const field = this.fieldByIndex.get(this.activeIndex);
                        const box = this.boxesByIndex.get(this.activeIndex);
                        if (!field || !box) {
                            return;
                        }

                        const input = box.querySelector(".calibration-inline-input");
                        if (input) {
                            this.layoutCalibrationInlineEditor(box, field, input);
                        }
                    }

                    refreshAllCalibrationInlineEditorStyles() {
                        if (!this.calibrationMode) {
                            return;
                        }

                        this.boxesByIndex.forEach((box, index) => {
                            const field = this.fieldByIndex.get(index);
                            const input = box?.querySelector(".calibration-inline-input");
                            if (!field || !input) {
                                return;
                            }

                            this.layoutCalibrationInlineEditor(box, field, input);
                        });
                    }

                    setCalibrationStyleToggleState(buttonEl, isActive) {
                        if (!buttonEl) {
                            return;
                        }

                        buttonEl.classList.toggle("active", isActive === true);
                        buttonEl.setAttribute("aria-pressed", isActive === true ? "true" : "false");
                    }

                    canEditCalibrationPanel() {
                        return this.calibrationMode
                            && this.activeIndex !== null
                            && this.fieldByIndex.has(this.activeIndex);
                    }

                    readCalibrationFontSizeFromPanel() {
                        const raw = String(calFontSizeInput?.value ?? "").trim();
                        const parsed = Number.parseFloat(raw);
                        if (raw === "" || !Number.isFinite(parsed) || parsed <= 0) {
                            return null;
                        }

                        return Math.min(72, Math.max(6, Math.round(parsed * 2) / 2));
                    }

                    syncCalibrationFontPresetButtons(fontSize) {
                        calibrationPanel?.querySelectorAll("[data-cal-font-preset]").forEach((buttonEl) => {
                            const preset = Number.parseFloat(buttonEl.getAttribute("data-cal-font-preset") || "");
                            buttonEl.classList.toggle(
                                "active",
                                Number.isFinite(fontSize) && fontSize === preset);
                        });
                    }

                    commitCalibrationTypographyChanges() {
                        if (!this.canEditCalibrationPanel()) {
                            return;
                        }

                        const field = this.fieldByIndex.get(this.activeIndex);
                        if (!field) {
                            return;
                        }

                        field.svgPathData = this.buildExtraTextStylePayload(field);
                        this.fieldByIndex.set(this.activeIndex, field);
                        this.refreshActiveCalibrationPreview();
                        this.markCalibrationDirty();
                    }

                    setCalibrationFontSize(size) {
                        if (!this.canEditCalibrationPanel() || !calFontSizeInput) {
                            return;
                        }

                        const normalized = Math.min(72, Math.max(6, Math.round(size * 2) / 2));
                        const field = this.fieldByIndex.get(this.activeIndex);
                        if (!field) {
                            return;
                        }

                        field.fontSize = normalized;
                        calFontSizeInput.value = String(normalized);
                        this.fieldByIndex.set(this.activeIndex, field);
                        this.syncCalibrationFontPresetButtons(normalized);
                        this.commitCalibrationTypographyChanges();
                    }

                    adjustCalibrationFontSize(delta) {
                        const step = Number.parseFloat(String(delta)) >= 0 ? 0.5 : -0.5;
                        const current = this.readCalibrationFontSizeFromPanel() ?? 10;
                        this.setCalibrationFontSize(current + step);
                    }

                    toggleCalibrationStyle(styleKey) {
                        if (!this.canEditCalibrationPanel()) {
                            return;
                        }

                        const field = this.fieldByIndex.get(this.activeIndex);
                        if (!field) {
                            return;
                        }

                        if (styleKey === "bold") {
                            field.fontBold = field.fontBold !== true;
                        } else if (styleKey === "italic") {
                            field.fontItalic = field.fontItalic !== true;
                        } else if (styleKey === "underline") {
                            field.textUnderline = field.textUnderline !== true;
                        } else {
                            return;
                        }

                        this.fieldByIndex.set(this.activeIndex, field);
                        this.setCalibrationStyleToggleState(calBoldBtn, field.fontBold === true);
                        this.setCalibrationStyleToggleState(calItalicBtn, field.fontItalic === true);
                        this.setCalibrationStyleToggleState(calUnderlineBtn, field.textUnderline === true);
                        this.commitCalibrationTypographyChanges();
                    }

                    handleCalibrationPanelClick(event) {
                        if (!this.canEditCalibrationPanel()) {
                            return;
                        }

                        const presetButton = event.target.closest("[data-cal-font-preset]");
                        if (presetButton && calibrationPanel?.contains(presetButton)) {
                            event.preventDefault();
                            event.stopPropagation();
                            const preset = Number.parseFloat(presetButton.getAttribute("data-cal-font-preset") || "");
                            if (Number.isFinite(preset)) {
                                this.setCalibrationFontSize(preset);
                            }
                            return;
                        }

                        const deltaButton = event.target.closest("[data-cal-font-delta]");
                        if (deltaButton && calibrationPanel?.contains(deltaButton)) {
                            event.preventDefault();
                            event.stopPropagation();
                            const delta = Number.parseFloat(deltaButton.getAttribute("data-cal-font-delta") || "0");
                            if (Number.isFinite(delta)) {
                                this.adjustCalibrationFontSize(delta);
                            }
                            return;
                        }

                        const styleButton = event.target.closest("[data-cal-style]");
                        if (styleButton && calibrationPanel?.contains(styleButton)) {
                            event.preventDefault();
                            event.stopPropagation();
                            const styleKey = styleButton.getAttribute("data-cal-style");
                            if (styleKey) {
                                this.toggleCalibrationStyle(styleKey);
                            }
                        }
                    }

                    applyCalibrationPanelToActiveField() {
                        if (this.calibrationPanelSyncing || this.activeIndex === null) {
                            return;
                        }

                        const field = this.fieldByIndex.get(this.activeIndex);
                        if (!field) {
                            return;
                        }

                        const fontSizeRaw = String(calFontSizeInput?.value ?? "").trim();
                        const parsedFontSize = Number.parseFloat(fontSizeRaw);
                        field.fontSize = fontSizeRaw === "" || !Number.isFinite(parsedFontSize) || parsedFontSize <= 0
                            ? null
                            : parsedFontSize;

                        const fontNameRaw = String(calFontFamilySelect?.value ?? "").trim();
                        field.fontName = fontNameRaw || null;

                        const lineHeightRaw = String(calLineHeightInput?.value ?? "").trim();
                        const parsedLineHeight = Number.parseFloat(lineHeightRaw);
                        field.lineHeight = lineHeightRaw === "" || !Number.isFinite(parsedLineHeight) || parsedLineHeight <= 0
                            ? null
                            : parsedLineHeight;

                        field.fontBold = calBoldBtn?.getAttribute("aria-pressed") === "true";
                        field.fontItalic = calItalicBtn?.getAttribute("aria-pressed") === "true";
                        field.textUnderline = calUnderlineBtn?.getAttribute("aria-pressed") === "true";

                        const colorRaw = String(calTextColorHexInput?.value ?? calTextColorInput?.value ?? "").trim();
                        field.textColor = /^#[0-9A-Fa-f]{6}$/.test(colorRaw) ? colorRaw : "#111111";

                        field.letterSpacing = this.parsePixel(calLetterSpacingInput?.value ?? 0);
                        field.svgPathData = this.buildExtraTextStylePayload(field);

                        const offsetX = this.clampCalibrationOffset(calOffsetXInput?.value ?? "0");
                        const offsetY = this.clampCalibrationOffset(calOffsetYInput?.value ?? "0");
                        if (calOffsetXInput) calOffsetXInput.value = String(offsetX);
                        if (calOffsetYInput) calOffsetYInput.value = String(offsetY);
                        if (Number.isFinite(offsetX) && Number.isFinite(offsetY)) {
                            field.textOffsetX = offsetX;
                            field.textOffsetY = offsetY;
                            const state = this.getCalibrationState(this.activeIndex);
                            if (state) {
                                state.offsetX = offsetX;
                                state.offsetY = offsetY;
                            }
                            if (field.fieldId) {
                                this.syncFieldTextOffsetsToForm(field.fieldId, offsetX, offsetY);
                            }
                        }

                        this.fieldByIndex.set(this.activeIndex, field);
                        this.refreshActiveCalibrationPreview();
                        this.markCalibrationDirty();
                    }

                    markCalibrationDirty() {
                        this.calibrationDirty = true;
                        this.hasPendingDbSave = true;
                        this.renderCalibrationSaveStatus("Незбережені зміни…");
                        this.scheduleCalibrationAutosave();
                    }

                    renderCalibrationSaveStatus(message = "") {
                        if (!calSaveStatusEl) {
                            return;
                        }

                        calSaveStatusEl.textContent = message;
                        calSaveStatusEl.classList.toggle("text-warning", message.includes("Незбережені"));
                        calSaveStatusEl.classList.toggle("text-success", message.includes("Збережено"));
                        calSaveStatusEl.classList.toggle("text-danger", message.includes("Помилка"));
                    }

                    scheduleCalibrationAutosave() {
                        if (!this.calibrationMode) {
                            return;
                        }

                        if (this.calibrationAutosaveTimerId !== null) {
                            window.clearTimeout(this.calibrationAutosaveTimerId);
                        }

                        this.calibrationAutosaveTimerId = window.setTimeout(async () => {
                            this.calibrationAutosaveTimerId = null;
                            if (!this.calibrationDirty) {
                                return;
                            }

                            this.renderCalibrationSaveStatus("Автозбереження…");
                            const saved = await this.persistCalibrationToApi({ silent: true });
                            if (saved) {
                                this.calibrationDirty = false;
                                this.renderCalibrationSaveStatus("Збережено автоматично");
                            }
                        }, CAL_AUTOSAVE_MS);
                    }

                    getCalibrationEditableElement(box) {
                        if (!box) {
                            return null;
                        }

                        return box.querySelector(
                            ".calibration-inline-input, input.pdf-field-input, input.pdf-field, textarea.pdf-field-input, textarea.pdf-field");
                    }

                    readEditableElementText(element) {
                        if (!element) {
                            return "";
                        }

                        if (element instanceof HTMLInputElement || element instanceof HTMLTextAreaElement) {
                            return String(element.value ?? "").replace(/\r/g, "").trim();
                        }

                        const raw = element.innerText || element.textContent || "";
                        return String(raw).replace(/\r/g, "").trim();
                    }

                    syncAllCalibrationTextFromDom() {
                        this.gatherContentFromEditableFields();
                    }

                    writeCalibrationTextToState(index, text) {
                        const normalized = String(text ?? "").replace(/\r/g, "").trim();
                        const state = this.getCalibrationState(index);
                        if (state) {
                            state.text = normalized;
                        }

                        const field = this.fieldByIndex.get(index);
                        if (field) {
                            field.calibrationPreviewText = normalized;
                            this.fieldByIndex.set(index, field);
                        }

                        return normalized;
                    }

                    resolveCalibrationTextForIndex(index, box = null) {
                        const resolvedBox = box ?? this.boxesByIndex.get(index);
                        const field = this.fieldByIndex.get(index);
                        if (this.calibrationMode && resolvedBox && field) {
                            this.ensureCalibrationInlineEditor(resolvedBox, field);
                        }

                        const editor = this.getCalibrationEditableElement(resolvedBox);
                        const domText = this.readEditableElementText(editor);
                        if (domText) {
                            return this.writeCalibrationTextToState(index, domText);
                        }

                        const state = this.getCalibrationState(index);
                        return String(
                            state?.text
                            ?? field?.calibrationPreviewText
                            ?? "").trim();
                    }

                    /**
                     * Збирає текст з усіх overlay-сегментів перед Preview PDF (патерн Gather and Send).
                     */
                    gatherContentFromEditableFields() {
                        if (this.calibrationMode) {
                            this.syncAllCalibrationInlineEditors();
                        }

                        let withText = 0;
                        this.boxesByIndex.forEach((box, index) => {
                            if (!box) {
                                return;
                            }

                            const text = this.resolveCalibrationTextForIndex(index, box);
                            if (text) {
                                withText++;
                            }
                        });

                        const root = document.getElementById("pdfOverlayDesignerRoot");
                        const editables = (root ?? document).querySelectorAll('[contenteditable="true"]');
                        editables.forEach((element) => {
                            const box = element.closest(".field-overlay-box");
                            if (!box) {
                                return;
                            }

                            const index = Number.parseInt(box.dataset.index ?? "-1", 10);
                            if (!Number.isInteger(index) || index < 0) {
                                return;
                            }

                            this.writeCalibrationTextToState(
                                index,
                                this.readEditableElementText(element));
                        });

                        withText = [...this.boxesByIndex.keys()]
                            .filter((idx) => String(this.getCalibrationState(idx)?.text ?? "").trim()).length;

                        console.info(
                            `[Calibration] gatherContentFromEditableFields: boxes=${this.boxesByIndex.size}, editors=${editables.length}, withText=${withText}`);
                        return withText;
                    }

                    /** Збір тексту з overlay-input'ів (для Preview PDF). */
                    collectCalibrationFieldsFromDom() {
                        const valuesByIndex = new Map();
                        let scannedBoxes = 0;

                        this.boxesByIndex.forEach((box, index) => {
                            if (!box) {
                                return;
                            }

                            scannedBoxes++;
                            const text = this.resolveCalibrationTextForIndex(index, box);
                            if (text) {
                                valuesByIndex.set(index, text);
                            }
                        });

                        const rows = [...valuesByIndex.entries()].map(([index, text]) => {
                            const field = this.fieldByIndex.get(index);
                            return {
                                index,
                                segmentSequence: field?.segmentSequence ?? null,
                                templateFieldId: field?.fieldId ?? null,
                                text: text.slice(0, 80)
                            };
                        });

                        console.info(
                            `[Calibration] UI fields collected: boxesScanned=${scannedBoxes}, withText=${valuesByIndex.size}`);
                        if (rows.length > 0) {
                            console.table(rows);
                        }

                        return valuesByIndex;
                    }

                    readCalibrationTextForPreview(index) {
                        return this.resolveCalibrationTextForIndex(index);
                    }

                    readCalibrationTextForIndex(index) {
                        return this.resolveCalibrationTextForIndex(index);
                    }

                    async persistCalibrationToApi(options = {}) {
                        const silent = options.silent === true;
                        this.applyCalibrationPanelToActiveField();
                        this.syncAllCalibrationTextFromDom();
                        const offsetsSaved = await this.persistCalibrationOffsetsToApi({ silent });
                        const segmentsSaved = await this.persistSegmentsToApi({ silent });
                        const saved = offsetsSaved && segmentsSaved;
                        if (saved) {
                            this.calibrationDirty = false;
                            if (!silent) {
                                this.renderCalibrationSaveStatus("Збережено");
                            }
                        } else if (!silent) {
                            this.renderCalibrationSaveStatus("Помилка збереження");
                        }
                        return saved;
                    }

                    setCalibrationTab(tabId) {
                        this.calibrationActiveTab = tabId || "text";
                        calibrationPanel?.querySelectorAll("[data-cal-tab]").forEach((buttonEl) => {
                            const isActive = buttonEl.getAttribute("data-cal-tab") === this.calibrationActiveTab;
                            buttonEl.classList.toggle("active", isActive);
                        });
                        calibrationPanel?.querySelectorAll("[data-cal-pane]").forEach((paneEl) => {
                            paneEl.classList.toggle(
                                "active",
                                paneEl.getAttribute("data-cal-pane") === this.calibrationActiveTab);
                        });
                    }

                    updateCalibrationToggleStates(horizontal, vertical) {
                        calibrationPanel?.querySelectorAll("[data-cal-h-align]").forEach((buttonEl) => {
                            const value = buttonEl.getAttribute("data-cal-h-align");
                            buttonEl.classList.toggle("active", Boolean(horizontal) && value === horizontal);
                        });
                        calibrationPanel?.querySelectorAll("[data-cal-v-align]").forEach((buttonEl) => {
                            const value = buttonEl.getAttribute("data-cal-v-align");
                            const effectiveVertical = vertical || "Top";
                            buttonEl.classList.toggle("active", value === effectiveVertical);
                        });
                    }

                    setActiveFieldHorizontalAlignment(value) {
                        if (this.activeIndex === null) {
                            return;
                        }

                        const field = this.fieldByIndex.get(this.activeIndex);
                        if (!field) {
                            return;
                        }

                        field.horizontalAlignment = value;
                        field.textAlignment = value;
                        this.fieldByIndex.set(this.activeIndex, field);
                        this.updateCalibrationToggleStates(value, field.verticalAlignment);
                        this.refreshActiveCalibrationPreview();
                        this.markCalibrationDirty();
                    }

                    setActiveFieldVerticalAlignment(value) {
                        if (this.activeIndex === null) {
                            return;
                        }

                        const field = this.fieldByIndex.get(this.activeIndex);
                        if (!field) {
                            return;
                        }

                        field.verticalAlignment = value;
                        this.fieldByIndex.set(this.activeIndex, field);
                        this.updateCalibrationToggleStates(
                            field.horizontalAlignment ?? field.textAlignment ?? "Left",
                            value);
                        this.refreshActiveCalibrationPreview();
                        this.markCalibrationDirty();
                    }

                    resetActiveCalibrationField() {
                        if (this.activeIndex === null) {
                            return;
                        }

                        const defaults = this.getDefaultCalibrationTypography();
                        const field = this.fieldByIndex.get(this.activeIndex);
                        if (!field) {
                            return;
                        }

                        Object.assign(field, defaults);
                        field.textOffsetX = 0;
                        field.textOffsetY = 0;
                        field.svgPathData = null;
                        this.fieldByIndex.set(this.activeIndex, field);
                        this.applyFieldTextOffsets(this.activeIndex, 0, 0);
                        this.syncCalibrationPanel();
                        this.markCalibrationDirty();
                    }

                    applyCalibrationTypographyToAllFields() {
                        if (this.activeIndex === null) {
                            return;
                        }

                        const source = this.fieldByIndex.get(this.activeIndex);
                        if (!source) {
                            return;
                        }

                        const styleSnapshot = {
                            fontName: source.fontName,
                            fontSize: source.fontSize,
                            lineHeight: source.lineHeight,
                            fontBold: source.fontBold,
                            fontItalic: source.fontItalic,
                            textUnderline: source.textUnderline,
                            textColor: source.textColor,
                            letterSpacing: source.letterSpacing,
                            horizontalAlignment: source.horizontalAlignment,
                            verticalAlignment: source.verticalAlignment,
                            textAlignment: source.textAlignment
                        };

                        this.fieldByIndex.forEach((field, index) => {
                            Object.assign(field, styleSnapshot);
                            field.svgPathData = this.buildExtraTextStylePayload(field);
                            this.fieldByIndex.set(index, field);
                        });

                        this.refreshAllCalibrationInlineEditorStyles();
                        this.syncCalibrationPanel();
                        this.markCalibrationDirty();
                        showOverlayToast("Стиль застосовано до всіх полів");
                    }

                    resetAllTemplateOffsets() {
                        this.fieldByIndex.forEach((field, index) => {
                            field.textOffsetX = 0;
                            field.textOffsetY = 0;
                            this.fieldByIndex.set(index, field);
                            const state = this.getCalibrationState(index);
                            if (state) {
                                state.offsetX = 0;
                                state.offsetY = 0;
                            }
                            if (field.fieldId) {
                                this.syncFieldTextOffsetsToForm(field.fieldId, 0, 0);
                            }
                            const box = this.boxesByIndex.get(index);
                            if (box) {
                                const input = box.querySelector(".calibration-inline-input");
                                if (input) {
                                    this.layoutCalibrationInlineEditor(box, field, input);
                                }
                            }
                        });

                        this.syncCalibrationPanel();
                        this.markCalibrationDirty();
                        showOverlayToast("Усі offset скинуто");
                    }

                    setCalibrationPanelEnabled(enabled) {
                        calibrationPanel?.querySelectorAll("[data-cal-control]").forEach((controlEl) => {
                            if (enabled) {
                                controlEl.removeAttribute("disabled");
                                controlEl.classList.remove("cal-control--locked");
                            } else {
                                controlEl.setAttribute("disabled", "disabled");
                                controlEl.classList.add("cal-control--locked");
                            }
                        });
                        calibrationPanel?.querySelectorAll("[data-cal-tab]").forEach((tabEl) => {
                            tabEl.disabled = !this.calibrationMode;
                        });
                    }

                    ensureCalibrationInlineEditor(box, field) {
                        if (!box || !field || !this.calibrationMode) {
                            return null;
                        }

                        let input = box.querySelector(".calibration-inline-input");
                        if (!input) {
                            const useMultiline = (field.height ?? 28) > 36;
                            input = document.createElement("div");
                            input.className = useMultiline
                                ? "calibration-inline-input pdf-field pdf-field-input calibration-inline-input--multiline pdf-field--multiline"
                                : "calibration-inline-input pdf-field pdf-field-input";
                            input.contentEditable = "true";
                            input.spellcheck = false;
                            input.setAttribute("role", "textbox");

                            const readCalibrationText = () => this.readEditableElementText(input);

                            input.addEventListener("mousedown", (event) => event.stopPropagation());
                            input.addEventListener("click", (event) => event.stopPropagation());
                            input.addEventListener("paste", (event) => {
                                event.preventDefault();
                                const plain = event.clipboardData?.getData("text/plain") ?? "";
                                if (document.queryCommandSupported("insertText")) {
                                    document.execCommand("insertText", false, plain);
                                } else {
                                    input.textContent = `${readCalibrationText()}${plain}`;
                                }
                            });
                            input.addEventListener("focus", () => {
                                const index = Number.parseInt(box.dataset.index || "-1", 10);
                                if (!Number.isInteger(index)) {
                                    return;
                                }

                                this.calibrationEditingIndex = index;
                                this.setActive(index);
                            });
                            input.addEventListener("input", () => {
                                const index = Number.parseInt(box.dataset.index || "-1", 10);
                                const state = this.getCalibrationState(index);
                                if (!state) {
                                    return;
                                }

                                state.text = readCalibrationText();
                            });
                            input.addEventListener("blur", () => {
                                const index = Number.parseInt(box.dataset.index || "-1", 10);
                                const state = this.getCalibrationState(index);
                                if (state) {
                                    state.text = readCalibrationText();
                                }

                                if (this.calibrationEditingIndex === index) {
                                    this.calibrationEditingIndex = null;
                                }
                            });
                            input.addEventListener("keydown", (event) => {
                                if (!useMultiline && event.key === "Enter") {
                                    event.preventDefault();
                                    input.blur();
                                }
                            });

                            box.addEventListener("mousedown", (event) => {
                                if (event.target !== input) {
                                    event.preventDefault();
                                    input.focus();
                                }
                            });

                            box.appendChild(input);
                        }

                        const state = this.getCalibrationState(field.index);
                        const domText = this.readEditableElementText(input);
                        if (domText) {
                            if (state) {
                                state.text = domText;
                            }
                        } else if (state?.text) {
                            input.textContent = state.text;
                        } else {
                            input.textContent = "";
                        }

                        this.layoutCalibrationInlineEditor(box, field, input);
                        return input;
                    }

                    syncAllCalibrationInlineEditors() {
                        if (!this.calibrationMode) {
                            return;
                        }

                        this.boxesByIndex.forEach((box, index) => {
                            const field = this.fieldByIndex.get(index);
                            if (field) {
                                this.ensureCalibrationInlineEditor(box, field);
                            }
                        });
                    }

                    removeAllCalibrationInlineEditors() {
                        this.boxesByIndex.forEach((box) => {
                            box.querySelectorAll(".calibration-inline-input").forEach((input) => input.remove());
                        });
                    }

                    focusCalibrationInlineEditor(index) {
                        const field = this.fieldByIndex.get(index);
                        const box = this.boxesByIndex.get(index);
                        if (!field || !box) {
                            return;
                        }

                        this.setActive(index);
                        const input = this.ensureCalibrationInlineEditor(box, field);
                        if (!input) {
                            return;
                        }

                        window.setTimeout(() => {
                            input.focus();
                            const selection = window.getSelection();
                            if (!selection) {
                                return;
                            }
                            const range = document.createRange();
                            range.selectNodeContents(input);
                            selection.removeAllRanges();
                            selection.addRange(range);
                        }, 0);
                    }

                    setCalibrationOffset(index, offsetX, offsetY) {
                        this.applyFieldTextOffsets(index, offsetX, offsetY);
                    }

                    shiftCalibrationOffset(axis, delta) {
                        if (this.activeIndex === null) return;
                        const state = this.getCalibrationState(this.activeIndex);
                        if (!state) return;

                        if (axis === "x") {
                            this.setCalibrationOffset(this.activeIndex, state.offsetX + delta, state.offsetY);
                        } else {
                            this.setCalibrationOffset(this.activeIndex, state.offsetX, state.offsetY + delta);
                        }
                    }

                    syncCalibrationPanel() {
                        const panelEnabled = this.calibrationMode && this.activeIndex !== null;
                        const state = panelEnabled ? this.getCalibrationState(this.activeIndex) : null;
                        const field = panelEnabled ? this.fieldByIndex.get(this.activeIndex) : null;

                        this.setCalibrationPanelEnabled(panelEnabled);
                        if (calSaveBtn) calSaveBtn.disabled = !this.calibrationMode;
                        if (calPreviewPdfBtn) calPreviewPdfBtn.disabled = !this.calibrationMode;
                        if (calResetAllOffsetsBtn) calResetAllOffsetsBtn.disabled = !this.calibrationMode;

                        this.calibrationPanelSyncing = true;
                        try {
                            if (calEditingFieldEl) {
                                calEditingFieldEl.textContent = panelEnabled
                                    ? `Редагується: ${this.formatCalibrationEditingLabel(field)}`
                                    : "";
                            }

                            if (calOffsetXInput) {
                                calOffsetXInput.value = panelEnabled
                                    ? String(this.clampCalibrationOffset(field?.textOffsetX ?? state?.offsetX ?? 0))
                                    : "0";
                            }
                            if (calOffsetYInput) {
                                calOffsetYInput.value = panelEnabled
                                    ? String(this.clampCalibrationOffset(field?.textOffsetY ?? state?.offsetY ?? 0))
                                    : "0";
                            }

                            if (calFontFamilySelect) {
                                calFontFamilySelect.value = field?.fontName ?? "";
                            }
                            if (calFontSizeInput) {
                                calFontSizeInput.value = field?.fontSize != null ? String(field.fontSize) : "";
                            }
                            this.syncCalibrationFontPresetButtons(field?.fontSize ?? null);
                            if (calLineHeightInput) {
                                calLineHeightInput.value = field?.lineHeight != null ? String(field.lineHeight) : "";
                            }
                            if (calLetterSpacingInput) {
                                calLetterSpacingInput.value = panelEnabled
                                    ? String(this.parsePixel(field?.letterSpacing ?? 0))
                                    : "0";
                            }

                            const color = field?.textColor ?? "#111111";
                            if (calTextColorInput) calTextColorInput.value = color;
                            if (calTextColorHexInput) calTextColorHexInput.value = color;

                            this.setCalibrationStyleToggleState(calBoldBtn, field?.fontBold === true);
                            this.setCalibrationStyleToggleState(calItalicBtn, field?.fontItalic === true);
                            this.setCalibrationStyleToggleState(calUnderlineBtn, field?.textUnderline === true);

                            this.updateCalibrationToggleStates(
                                field?.horizontalAlignment ?? field?.textAlignment ?? "Left",
                                field?.verticalAlignment ?? "Bottom");
                        } finally {
                            this.calibrationPanelSyncing = false;
                        }

                        if (calibrationPanelHint) {
                            calibrationPanelHint.textContent = !this.calibrationMode
                                ? "Увімкніть режим калібрування."
                                : (panelEnabled
                                    ? "Зміни offset — миттєвий preview на PDF."
                                    : "Клікніть поле на PDF.");
                            calibrationPanelHint.classList.toggle("is-hidden", this.calibrationMode && panelEnabled);
                        }

                        if (calExitCalibrationFullBtn) {
                            calExitCalibrationFullBtn.style.display = this.calibrationMode ? "" : "none";
                        }

                        this.setCalibrationTab(this.calibrationActiveTab);
                    }

                    collectCalibrationOffsetsPayload() {
                        const fields = [];
                        const seen = new Set();
                        this.fieldByIndex.forEach((field) => {
                            const fieldId = this.normalizeGuidKey(field.fieldId);
                            if (!fieldId || seen.has(fieldId)) return;
                            seen.add(fieldId);
                            fields.push({
                                fieldId,
                                textOffsetX: this.parsePixel(field.textOffsetX ?? 0),
                                textOffsetY: this.parsePixel(field.textOffsetY ?? 0)
                            });
                        });
                        return fields;
                    }

                    getCalibrationPreviewLayout(index, field) {
                        const coordScale = this.getCoordinateScale();
                        const box = this.boxesByIndex.get(index);
                        const page = Number.parseInt(
                            box?.dataset.page || String(field?.page ?? 1),
                            10);

                        if (box) {
                            const preview = this.getFieldInPreviewSpace(box, page);
                            return {
                                page: preview.page,
                                x: preview.x,
                                y: preview.y,
                                width: preview.width,
                                height: preview.height
                            };
                        }

                        return {
                            page: this.clampInt(page, 1, this.pdf?.numPages ?? 1, 1),
                            x: Math.max(0, Math.round((field?.x ?? 0) / coordScale)),
                            y: Math.max(0, Math.round((field?.y ?? 0) / coordScale)),
                            width: Math.max(20, Math.round((field?.width ?? 220) / coordScale)),
                            height: Math.max(14, Math.round((field?.height ?? 28) / coordScale))
                        };
                    }

                    buildPreviewCalibrationData() {
                        this.gatherContentFromEditableFields();
                        this.applyCalibrationPanelToActiveField();
                        const uiTextByIndex = this.collectCalibrationFieldsFromDom();

                        const versionId = String(window.__templateVersionId ?? "").trim();
                        const fields = [];

                        this.fieldByIndex.forEach((field, index) => {
                            const text = uiTextByIndex.get(index)
                                ?? this.resolveCalibrationTextForIndex(index);
                            if (!text) {
                                return;
                            }

                            const layout = this.getCalibrationPreviewLayout(index, field);
                            const fieldIdRaw = String(field.fieldId ?? "").trim();
                            const templateFieldId = /^[0-9a-f-]{36}$/i.test(fieldIdRaw) ? fieldIdRaw : null;
                            const state = this.getCalibrationState(index);
                            const offsetX = Number(this.parsePixel(field.textOffsetX ?? state?.offsetX ?? 0));
                            const offsetY = Number(this.parsePixel(field.textOffsetY ?? state?.offsetY ?? 0));
                            const fontSizeRaw = Number.parseFloat(String(field.fontSize ?? ""));
                            const fontSize = Number.isFinite(fontSizeRaw) && fontSizeRaw > 0 ? fontSizeRaw : null;
                            const segmentSequence = this.getOverlaySequence(field, index);

                            fields.push({
                                overlayIndex: index,
                                segmentSequence,
                                templateFieldId,
                                text,
                                textToDraw: text,
                                offsetX,
                                offsetY,
                                page: Number.parseInt(String(layout.page ?? 1), 10) || 1,
                                x: Number(layout.x),
                                y: Number(layout.y),
                                width: Number(layout.width),
                                height: Number(layout.height),
                                fontSize,
                                fontName: field.fontName || null,
                                alignment: field.horizontalAlignment ?? field.textAlignment ?? "Left",
                                verticalAlignment: field.verticalAlignment ?? "Top"
                            });
                        });

                        return {
                            templateVersionId: versionId,
                            isCalibrationPreview: true,
                            fields
                        };
                    }

                    async persistCalibrationOffsetsToApi(options = {}) {
                        const silent = options.silent === true;
                        const versionId = window.__templateVersionId;
                        const fields = this.collectCalibrationOffsetsPayload();
                        if (!versionId || fields.length === 0) {
                            return true;
                        }

                        try {
                            const response = await fetch(`/api/template-fields/${versionId}/text-offsets`, {
                                method: "PUT",
                                credentials: "same-origin",
                                headers: {
                                    "Content-Type": "application/json",
                                    "Accept": "application/json",
                                    "RequestVerificationToken": this.getAntiForgeryToken()
                                },
                                body: JSON.stringify({ fields })
                            });
                            if (!response.ok) {
                                const message = await parseServerErrorMessageFromResponse(
                                    response,
                                    "Не вдалося зберегти offset.");
                                if (!silent) {
                                    showOverlayToast(message, true);
                                }
                                return false;
                            }
                            if (!silent) {
                                showOverlayToast("Text offset збережено в БД.");
                            }
                            return true;
                        } catch {
                            if (!silent) {
                                showOverlayToast("Помилка збереження offset.", true);
                            }
                            return false;
                        }
                    }

                    async openCalibrationPreviewPdf() {
                        this.gatherContentFromEditableFields();
                        const previewData = this.buildPreviewCalibrationData();
                        const versionId = previewData.templateVersionId;
                        if (!versionId) {
                            return;
                        }

                        if (!previewData.fields.length) {
                            showOverlayToast("Введіть текст хоча в одному полі (клік на PDF).", true);
                            return;
                        }

                        console.info("[Calibration] Preview PDF payload:", previewData);
                        console.table(previewData.fields.map((field) => ({
                            overlayIndex: field.overlayIndex,
                            segmentSequence: field.segmentSequence,
                            templateFieldId: field.templateFieldId,
                            text: field.text.slice(0, 40),
                            page: field.page,
                            x: field.x,
                            y: field.y,
                            offsetX: field.offsetX,
                            offsetY: field.offsetY
                        })));
                        showOverlayToast(
                            `Генеруємо PDF: ${previewData.fields.length} пол(я/ів) з текстом. Якщо в PDF порожньо — перевірте цей лог у F12.`);

                        const prevLabel = calPreviewPdfBtn?.textContent ?? "";
                        if (calPreviewPdfBtn) {
                            calPreviewPdfBtn.disabled = true;
                            calPreviewPdfBtn.textContent = "Генеруємо…";
                        }

                        try {
                            const response = await fetch(`/api/template/preview-calibration/${versionId}`, {
                                method: "POST",
                                credentials: "same-origin",
                                headers: {
                                    "Content-Type": "application/json",
                                    "Accept": "application/pdf",
                                    "RequestVerificationToken": this.getAntiForgeryToken()
                                },
                                body: JSON.stringify(previewData)
                            });
                            if (!response.ok) {
                                const message = await parseServerErrorMessageFromResponse(
                                    response,
                                    "Не вдалося згенерувати PDF.");
                                showOverlayToast(message, true);
                                return;
                            }

                            const contentType = response.headers.get("content-type") ?? "";
                            if (!contentType.includes("application/pdf")) {
                                showOverlayToast("Сервер повернув не PDF. Перевірте авторизацію або оновіть сторінку.", true);
                                return;
                            }

                            const blob = await response.blob();
                            if (!blob.size) {
                                showOverlayToast("Отримано порожній PDF.", true);
                                return;
                            }

                            const sentCount = previewData.fields.length;
                            const drawnCountRaw = response.headers.get("X-Calibration-Segments-Drawn");
                            const drawnCount = drawnCountRaw !== null ? Number.parseInt(drawnCountRaw, 10) : null;
                            const skippedEmpty = response.headers.get("X-Calibration-Segments-Skipped-Empty");
                            const skippedPage = response.headers.get("X-Calibration-Segments-Skipped-Page");
                            const pdfPages = response.headers.get("X-Calibration-Pdf-Pages");
                            let toastMsg = `PDF готово: з UI ${sentCount}`;
                            if (drawnCount !== null && Number.isFinite(drawnCount)) {
                                toastMsg += `, намалювано ${drawnCount}`;
                            }
                            if (skippedEmpty && Number(skippedEmpty) > 0) {
                                toastMsg += `, без тексту (сервер): ${skippedEmpty}`;
                            }
                            if (skippedPage && Number(skippedPage) > 0) {
                                toastMsg += `, пропущено (сторінка): ${skippedPage}`;
                            }
                            if (pdfPages) {
                                toastMsg += `, сторінок у PDF: ${pdfPages}`;
                            }
                            showOverlayToast(`${toastMsg}.`);
                            if (drawnCount === 0) {
                                console.warn("[Calibration] Preview PDF: сервер не намалював жодного сегмента.", previewData);
                                showOverlayToast(
                                    "PDF без тексту: перевірте F12 (payload) і лог сервера (координати/сторінка).",
                                    true);
                            }

                            const url = URL.createObjectURL(blob);
                            window.open(url, "_blank", "noopener");
                            window.setTimeout(() => URL.revokeObjectURL(url), 60_000);
                        } catch {
                            showOverlayToast("Помилка генерації preview PDF.", true);
                        } finally {
                            if (calPreviewPdfBtn) {
                                calPreviewPdfBtn.disabled = false;
                                calPreviewPdfBtn.textContent = prevLabel || "Preview PDF";
                            }
                        }
                    }

                    bindCalibrationEvents() {
                        calibrationToggleButtons.forEach((buttonEl) => {
                            buttonEl.addEventListener("click", () => this.toggleCalibrationMode());
                        });

                        calibrationPanel?.querySelectorAll("[data-cal-tab]").forEach((buttonEl) => {
                            buttonEl.addEventListener("click", () => {
                                const tabId = buttonEl.getAttribute("data-cal-tab");
                                if (!tabId) return;
                                this.setCalibrationTab(tabId);
                            });
                        });

                        const onPanelChange = () => this.applyCalibrationPanelToActiveField();
                        [
                            calFontFamilySelect,
                            calFontSizeInput,
                            calLineHeightInput,
                            calLetterSpacingInput,
                            calOffsetXInput,
                            calOffsetYInput
                        ].forEach((controlEl) => {
                            controlEl?.addEventListener("input", onPanelChange);
                            controlEl?.addEventListener("change", onPanelChange);
                        });

                        calibrationPanel?.addEventListener("click", (event) => this.handleCalibrationPanelClick(event));

                        calLetterSpacingMinusBtn?.addEventListener("click", () => {
                            if (!calLetterSpacingInput || this.activeIndex === null) return;
                            const current = this.parsePixel(calLetterSpacingInput.value);
                            calLetterSpacingInput.value = String(Math.round((current - 0.1) * 10) / 10);
                            onPanelChange();
                        });

                        calLetterSpacingPlusBtn?.addEventListener("click", () => {
                            if (!calLetterSpacingInput || this.activeIndex === null) return;
                            const current = this.parsePixel(calLetterSpacingInput.value);
                            calLetterSpacingInput.value = String(Math.round((current + 0.1) * 10) / 10);
                            onPanelChange();
                        });

                        const syncColorFromPicker = () => {
                            if (!calTextColorInput || !calTextColorHexInput) return;
                            calTextColorHexInput.value = calTextColorInput.value;
                            onPanelChange();
                        };
                        const syncColorFromHex = () => {
                            if (!calTextColorInput || !calTextColorHexInput) return;
                            const raw = calTextColorHexInput.value.trim();
                            if (/^#[0-9A-Fa-f]{6}$/.test(raw)) {
                                calTextColorInput.value = raw;
                                onPanelChange();
                            }
                        };
                        calTextColorInput?.addEventListener("input", syncColorFromPicker);
                        calTextColorHexInput?.addEventListener("input", syncColorFromHex);
                        calTextColorHexInput?.addEventListener("change", syncColorFromHex);

                        calibrationPanel?.querySelectorAll("[data-cal-shift]").forEach((buttonEl) => {
                            buttonEl.addEventListener("click", () => {
                                const axis = buttonEl.getAttribute("data-cal-shift");
                                const delta = Number.parseFloat(buttonEl.getAttribute("data-cal-delta") || "0");
                                if (!axis || !Number.isFinite(delta)) return;
                                this.shiftCalibrationOffset(axis, delta);
                            });
                        });

                        calibrationPanel?.querySelectorAll("[data-cal-offset-step]").forEach((buttonEl) => {
                            buttonEl.addEventListener("click", () => {
                                const axis = buttonEl.getAttribute("data-cal-offset-step");
                                const step = Number.parseFloat(buttonEl.getAttribute("data-cal-step") || "0");
                                if (!axis || !Number.isFinite(step) || this.activeIndex === null) return;
                                const state = this.getCalibrationState(this.activeIndex);
                                if (!state) return;
                                if (axis === "x") {
                                    this.setCalibrationOffset(
                                        this.activeIndex,
                                        this.clampCalibrationOffset(state.offsetX + step),
                                        state.offsetY);
                                } else {
                                    this.setCalibrationOffset(
                                        this.activeIndex,
                                        state.offsetX,
                                        this.clampCalibrationOffset(state.offsetY + step));
                                }
                            });
                        });

                        const exitCalibration = () => this.disableCalibrationMode();
                        calExitCalibrationBtn?.addEventListener("click", exitCalibration);
                        calExitCalibrationFullBtn?.addEventListener("click", exitCalibration);

                        calibrationPanel?.querySelectorAll("[data-cal-h-align]").forEach((buttonEl) => {
                            buttonEl.addEventListener("click", () => {
                                const value = buttonEl.getAttribute("data-cal-h-align");
                                if (!value) return;
                                this.setActiveFieldHorizontalAlignment(value);
                            });
                        });

                        calibrationPanel?.querySelectorAll("[data-cal-v-align]").forEach((buttonEl) => {
                            buttonEl.addEventListener("click", () => {
                                const value = buttonEl.getAttribute("data-cal-v-align");
                                if (!value) return;
                                this.setActiveFieldVerticalAlignment(value);
                            });
                        });

                        calResetFieldBtn?.addEventListener("click", () => this.resetActiveCalibrationField());
                        calApplyAllFieldsBtn?.addEventListener("click", () => this.applyCalibrationTypographyToAllFields());
                        calResetAllOffsetsBtn?.addEventListener("click", () => this.resetAllTemplateOffsets());

                        calSaveBtn?.addEventListener("click", () => this.persistCalibrationToApi());
                        calPreviewPdfBtn?.addEventListener("mousedown", (event) => {
                            event.preventDefault();
                            this.gatherContentFromEditableFields();
                        });
                        calPreviewPdfBtn?.addEventListener("click", () => this.openCalibrationPreviewPdf());

                        this.setCalibrationPanelEnabled(false);
                    }
                }

                const engine = new FieldEngine();
                window.__fieldEngine = engine;
                Object.defineProperty(window, "__pdfSegments", {
                    configurable: true,
                    get() {
                        if (!window.__fieldEngine) {
                            return [];
                        }

                        const items = [];
                        window.__fieldEngine.fieldByIndex.forEach((field, overlayIndex) => {
                            const state = window.__fieldEngine.getCalibrationState(overlayIndex);
                            const text = String(
                                state?.text
                                ?? field.calibrationPreviewText
                                ?? "").trim();
                            items.push({ overlayIndex, Text: text, ...field });
                        });
                        return items;
                    }
                });

                window.gatherContentFromEditableFields = () => {
                    if (!window.__fieldEngine?.gatherContentFromEditableFields) {
                        return 0;
                    }

                    return window.__fieldEngine.gatherContentFromEditableFields();
                };

                const overlayDataFieldComboRoot = document.getElementById("overlayDataFieldCombo");
                if (overlayDataFieldComboRoot && typeof initSearchableCombo === "function" && Array.isArray(window.__dataFieldCatalog)) {
                    engine.overlayDataFieldCombo = initSearchableCombo(overlayDataFieldComboRoot, {
                        items: window.__dataFieldCatalog,
                        placeholder: "Оберіть тег з словника...",
                        onChange: (value) => engine.applyDataFieldToActiveField(value)
                    });
                }

                if (pdfTagLibrary && newPdfFieldTag && newPdfFieldTitle) {
                    const addPdfFieldForm = document.getElementById("addPdfFieldForm");
                    const nudgeDraftTitle = document.getElementById("nudgeDraftTitle");
                    const nudgeSubmitNewTag = document.getElementById("nudgeSubmitNewTag");
                    const nudgeTagPreview = document.getElementById("nudgeTagLivePreview");
                    const nudgeTagPreviewPlaceholder = nudgeTagPreview?.querySelector(".nudge-tag-live-preview__placeholder");
                    const nudgeTagPreviewContent = nudgeTagPreview?.querySelector(".nudge-tag-live-preview__content");
                    const nudgeTagPreviewGroup = nudgeTagPreview?.querySelector(".nudge-tag-live-preview__group");
                    const nudgeTagPreviewKey = nudgeTagPreview?.querySelector(".nudge-tag-live-preview__key");
                    const nudgeTagPreviewTitle = nudgeTagPreview?.querySelector(".nudge-tag-live-preview__title");
                    const toggleNudgeTagComposerBtn = document.getElementById("toggleNudgeTagComposer");
                    const nudgeTagComposerBody = document.getElementById("nudgeTagComposerBody");

                    let draftTagKey = (newPdfFieldTag.value || "").trim();
                    let draftItem = null;

                    const buildTagLibraryItems = () => {
                        const items = [];
                        pdfTagLibrary.querySelectorAll("optgroup").forEach((group) => {
                            const groupName = (group.label || "").trim();
                            group.querySelectorAll("option").forEach((option) => {
                                if (!option.value) return;
                                items.push({
                                    id: option.value,
                                    key: option.value,
                                    displayName: option.getAttribute("data-title") || option.value,
                                    groupName
                                });
                            });
                        });
                        return items;
                    };

                    const setSubmitEnabled = () => {
                        if (!nudgeSubmitNewTag) return;
                        const title = (nudgeDraftTitle?.value || "").trim();
                        nudgeSubmitNewTag.disabled = !draftTagKey || !title;
                    };

                    const updateNudgeTagPreview = (item, titleOverride) => {
                        if (!nudgeTagPreview) return;
                        const key = (item?.key ?? item?.id ?? draftTagKey ?? "").trim();
                        const title = String(titleOverride ?? item?.displayName ?? "").trim();
                        const group = (item?.groupName ?? "").trim();
                        const hasContent = Boolean(key);
                        nudgeTagPreview.classList.toggle("is-ready", hasContent);
                        nudgeTagPreviewPlaceholder?.classList.toggle("d-none", hasContent);
                        nudgeTagPreviewContent?.classList.toggle("d-none", !hasContent);
                        if (!hasContent) {
                            setSubmitEnabled();
                            return;
                        }
                        if (nudgeTagPreviewGroup) {
                            if (group) {
                                nudgeTagPreviewGroup.textContent = group;
                                nudgeTagPreviewGroup.style.display = "";
                            } else {
                                nudgeTagPreviewGroup.textContent = "";
                                nudgeTagPreviewGroup.style.display = "none";
                            }
                        }
                        if (nudgeTagPreviewKey) nudgeTagPreviewKey.textContent = key;
                        if (nudgeTagPreviewTitle) nudgeTagPreviewTitle.textContent = title || key;
                        setSubmitEnabled();
                    };

                    const applyTagDraft = (item) => {
                        draftItem = item ?? null;
                        draftTagKey = String(item?.key ?? item?.id ?? "").trim();
                        if (draftTagKey) {
                            pdfTagLibrary.value = draftTagKey;
                            newPdfFieldTag.value = draftTagKey;
                        }
                        const defaultTitle = String(item?.displayName ?? "").trim();
                        if (nudgeDraftTitle && defaultTitle) {
                            nudgeDraftTitle.value = defaultTitle;
                        }
                        updateNudgeTagPreview(item, nudgeDraftTitle?.value ?? defaultTitle);
                    };

                    nudgeDraftTitle?.addEventListener("input", () => {
                        updateNudgeTagPreview(draftItem, nudgeDraftTitle.value);
                    });

                    nudgeSubmitNewTag?.addEventListener("click", () => {
                        submitAddPdfField();
                    });

                    toggleNudgeTagComposerBtn?.addEventListener("click", () => {
                        if (!nudgeTagComposerBody) return;
                        const collapsed = nudgeTagComposerBody.style.display === "none";
                        nudgeTagComposerBody.style.display = collapsed ? "" : "none";
                        toggleNudgeTagComposerBtn.setAttribute("aria-expanded", collapsed ? "true" : "false");
                        toggleNudgeTagComposerBtn.textContent = collapsed ? "▾" : "▸";
                    });

                    let nudgeTagComboApi = null;

                    const resetTagComposer = () => {
                        draftTagKey = "";
                        draftItem = null;
                        if (nudgeDraftTitle) nudgeDraftTitle.value = "";
                        newPdfFieldTag.value = "";
                        newPdfFieldTitle.value = "";
                        if (pdfTagLibrary) pdfTagLibrary.value = "";
                        nudgeTagComboApi?.setValue(null);
                        updateNudgeTagPreview(null);
                    };

                    const submitAddPdfField = async () => {
                        if (!draftTagKey || !addPdfFieldForm) return;
                        const title = (nudgeDraftTitle?.value || "").trim();
                        if (!title) return;

                        const token = addPdfFieldForm.querySelector('input[name="__RequestVerificationToken"]')?.value
                            ?? fieldMapForm?.querySelector('input[name="__RequestVerificationToken"]')?.value
                            ?? "";
                        const formData = new FormData(addPdfFieldForm);
                        formData.set("Tag", draftTagKey);
                        formData.set("Title", title);

                        const prevLabel = nudgeSubmitNewTag?.textContent ?? "";
                        if (nudgeSubmitNewTag) {
                            nudgeSubmitNewTag.disabled = true;
                            nudgeSubmitNewTag.textContent = "Додаємо…";
                        }

                        try {
                            const response = await fetch(addPdfFieldForm.action, {
                                method: "POST",
                                credentials: "same-origin",
                                headers: {
                                    Accept: "application/json",
                                    RequestVerificationToken: token
                                },
                                body: formData
                            });

                            if (!response.ok) {
                                const message = await parseServerErrorMessageFromResponse(
                                    response,
                                    "Не вдалося додати тег.");
                                showOverlayToast(message, true);
                                return;
                            }

                            const data = await response.json();
                            const createdFieldId = data?.fieldId ?? data?.FieldId ?? null;
                            showOverlayToast(data?.message ?? "Поле додано.");

                            const engine = window.__fieldEngine;
                            if (engine) {
                                await engine.reloadFromServer();
                                if (createdFieldId) {
                                    engine.editMode = "edit";
                                    engine.allEditable = false;
                                    engine.updateEditUI();
                                    const overlayIndex = engine.getOverlayIndexForField(createdFieldId);
                                    if (overlayIndex !== null) {
                                        engine.setActive(overlayIndex);
                                        engine.boxesByIndex.get(overlayIndex)?.scrollIntoView({
                                            behavior: "smooth",
                                            block: "center"
                                        });
                                    }
                                }
                            }

                            resetTagComposer();
                        } catch {
                            showOverlayToast("Не вдалося додати тег. Перевірте зʼєднання.", true);
                        } finally {
                            if (nudgeSubmitNewTag) {
                                nudgeSubmitNewTag.textContent = prevLabel || "➕ Додати на шаблон";
                                setSubmitEnabled();
                            }
                        }
                    };

                    addPdfFieldForm?.addEventListener("submit", (event) => {
                        event.preventDefault();
                    });

                    const libraryItems = buildTagLibraryItems();
                    const nudgeTagComboRoot = document.getElementById("nudgeTagLibraryCombo");
                    if (nudgeTagComboRoot && typeof initSearchableCombo === "function") {
                        nudgeTagComboApi = initSearchableCombo(nudgeTagComboRoot, {
                            items: libraryItems,
                            placeholder: "Оберіть тег зі словника...",
                            value: draftTagKey || null,
                            onPreview: (item) => {
                                if (!item) return;
                                draftItem = item;
                                updateNudgeTagPreview(item, nudgeDraftTitle?.value ?? item.displayName);
                            },
                            onChange: (_value, item) => applyTagDraft(item)
                        });
                    }

                    if (draftTagKey) {
                        const match = libraryItems.find((item) => item.id === draftTagKey);
                        if (match) {
                            applyTagDraft(match);
                        } else {
                            updateNudgeTagPreview(
                                { key: draftTagKey, displayName: newPdfFieldTitle.value },
                                newPdfFieldTitle.value);
                        }
                    } else {
                        updateNudgeTagPreview(null);
                    }
                }

                let syncingHorizontalScroll = false;
                const syncHorizontalScrollbars = (source = root) => {
                    if (!root || !zoomContainer || !topScroller || !topScrollerTrack) return;

                    topScrollerTrack.style.width = `${Math.max(root.scrollWidth, zoomContainer.scrollWidth)}px`;

                    if (syncingHorizontalScroll) return;
                    syncingHorizontalScroll = true;
                    const left = source?.scrollLeft ?? root.scrollLeft;
                    if (source !== topScroller) topScroller.scrollLeft = left;
                    if (source !== root) root.scrollLeft = left;
                    syncingHorizontalScroll = false;
                };

                topScroller?.addEventListener("scroll", () => syncHorizontalScrollbars(topScroller));
                root?.addEventListener("scroll", () => syncHorizontalScrollbars(root));

                if (typeof ResizeObserver !== "undefined" && zoomContainer) {
                    const horizontalScrollObserver = new ResizeObserver(() => syncHorizontalScrollbars());
                    horizontalScrollObserver.observe(zoomContainer);
                    if (pagesHost) horizontalScrollObserver.observe(pagesHost);
                }

                if (zoomSlider && zoomContainer) {
                    const applyZoom = () => {
                        const zoomPercent = Number.parseInt(zoomSlider.value, 10);
                        if (!Number.isInteger(zoomPercent)) return;
                        const clamped = Math.max(75, Math.min(300, zoomPercent));
                        zoomValue.textContent = `${clamped}%`;
                        if (nudgeZoomSlider) nudgeZoomSlider.value = String(clamped);
                        if (typeof updateNudgeZoomLabel === "function") updateNudgeZoomLabel();
                        engine.schedulePdfZoomRefresh(clamped);
                    };
                    zoomSlider.addEventListener("input", applyZoom);
                }

                engine.init().then(() => {
                    if (previewError) previewError.style.display = "none";
                    setTimeout(syncHorizontalScrollbars, 0);
                }).catch((error) => {
                    console.error("PDF preview load failed", error);
                    showPreviewError("Не вдалося відрендерити PDF у конструкторі. Перевірте доступність PDF файлу та перезавантажте сторінку.");
                });
            })();
        </script>
    }
}
