</style>

@if (Model.DocumentFormat == TemplateDocumentFormat.Pdf)
{
    <div id="designerFocusChrome" class="designer-focus-chrome" hidden aria-hidden="true">
        <div class="designer-focus-chrome__actions">
            <button type="button" class="btn btn-sm btn-outline-secondary js-toggle-designer-focus" title="Показати таблицю полів (Esc)">↩ Звичайний вигляд</button>
            <a class="btn btn-sm btn-link py-0 text-nowrap" asp-controller="TemplateVersions" asp-action="Details" asp-route-id="@Model.TemplateVersionId">До версії</a>
            @if (Model.IsEditable)
            {
                <button type="button" class="btn btn-sm btn-outline-secondary js-toggle-calibration" title="Live калібрування тексту та позиції">⚙️ Калібрування</button>
            }
        </div>
        <span class="designer-focus-chrome__title" title="@Model.TemplateNameUk">@Model.TemplateNameUk · v@(Model.VersionNumber)</span>
    </div>
    <div class="template-map-strip">
        <div class="template-map-strip__actions">
            <button type="button" class="btn btn-sm btn-outline-primary js-toggle-designer-focus" title="Тільки PDF і пульт (F)">⛶ Режим конструктора</button>
            <a class="btn btn-link btn-sm py-0 px-1 text-nowrap" asp-controller="TemplateVersions" asp-action="Details" asp-route-id="@Model.TemplateVersionId">До версії</a>
            @if (Model.IsEditable)
            {
                <button type="button" class="btn btn-sm btn-outline-secondary js-toggle-calibration" title="Live калібрування тексту та позиції">⚙️ Калібрування</button>
            }
        </div>
        <span class="template-map-strip__title" title="@Model.TemplateNameUk">@Model.TemplateNameUk · v@(Model.VersionNumber)</span>
    </div>
}
else
{
    <div class="template-map-hero">
        <div>
            <h1 class="h4 template-map-title mb-1">Поля шаблону</h1>
            <p class="template-map-subtitle small mb-0">@Model.TemplateNameUk · v@(Model.VersionNumber)</p>
        </div>
        <div class="template-map-actions">
            @if (!string.IsNullOrEmpty(Model.OpenInWordUri))
            {
                <a class="btn btn-sm btn-primary" href="@Model.OpenInWordUri">Відкрити в Word</a>
            }
            <a class="btn btn-sm btn-outline-secondary" asp-controller="TemplateVersions" asp-action="DownloadOriginal" asp-route-id="@Model.TemplateVersionId">
                Завантажити файл
            </a>
        </div>
    </div>
}

<div class="template-map-page-alerts">
@if (TempData["TemplateWarning"] is string warning)
{
    <div class="alert alert-warning">@warning</div>
}
@if (TempData["TemplateSuccess"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}

@if (!Model.IsEditable)
{
    <div class="alert alert-info">Опубліковану або замінену версію змінювати заборонено.</div>
}
