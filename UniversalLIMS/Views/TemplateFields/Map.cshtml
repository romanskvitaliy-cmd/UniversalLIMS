    body.template-map-focus-mode .designer-focus-chrome {
        display: flex;
    }

    body.template-map-focus-mode .template-map-strip,
    body.template-map-focus-mode .template-map-pdf-footer,
    body.template-map-focus-mode #pdfTopControlsPanel,
