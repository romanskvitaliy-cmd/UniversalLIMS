@model TemplateFieldMappingViewModel
@using System.Text.Json

@{
    ViewData["Title"] = "Поля шаблону";
    var overflowPolicies = Enum.GetValues<FieldOverflowPolicy>();
    var isLegacyDocx = Model.DocumentFormat == TemplateDocumentFormat.DocxLegacy;
    if (Model.DocumentFormat == TemplateDocumentFormat.Pdf)
    {
        Layout = "_LayoutDesigner";
    }
}

<style>
    .pdf-designer-grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr) var(--designer-nudge-width, 360px);
        gap: 12px;
    }

    .pdf-designer-grid.nudge-detached {
        grid-template-columns: minmax(0, 1fr);
    }

    .pdf-designer-sidebar {
        position: sticky;
        top: 12px;
        align-self: start;
    }

    .pdf-designer-canvas {
        min-width: 0;
        --pdf-scroll-thumb: rgba(15, 23, 42, 0.22);
        --pdf-scroll-thumb-hover: rgba(15, 23, 42, 0.38);
        --pdf-scroll-track: transparent;
    }

    .template-map-strip {
        display: flex;
        align-items: center;
        justify-content: flex-start;
        gap: 10px;
        margin-bottom: 4px;
        padding: 4px 8px 2px;
        font-size: 0.82rem;
        color: #64748b;
    }

    .template-map-strip__actions {
        display: flex;
        align-items: center;
        gap: 6px;
        flex-shrink: 0;
    }

    .template-map-strip__title {
        font-weight: 600;
        color: #334155;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        min-width: 0;
        margin-left: auto;
    }

    .template-map-pdf-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        margin-top: 8px;
        padding-top: 8px;
        border-top: 1px solid #e8edf4;
    }

    .template-map-hero {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 12px;
        padding: 12px 14px;
        margin-bottom: 10px;
        border: 1px solid #e5eaf1;
        border-radius: 12px;
        background: linear-gradient(180deg, #fafcff 0%, #ffffff 100%);
    }

    .template-map-title {
        margin: 0;
        font-weight: 700;
        letter-spacing: 0.1px;
    }

    .template-map-subtitle {
        margin: 2px 0 0;
        color: #6c7a89;
    }

    .template-map-actions {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        justify-content: flex-end;
    }

    .pdf-overlay-card {
        border: 1px solid #e5eaf1;
        border-radius: 10px;
        padding: 8px 10px 10px;
        margin-bottom: 8px;
        background: #fff;
    }

    .pdf-overlay-card__hint {
        font-size: 0.72rem;
        color: #94a3b8;
    }

    .pdf-library-search {
        border-color: #d8e1ed;
        background: #fff;
    }

    .pdf-tag-panel {
        border: 1px solid #d8e2ef;
        border-radius: 12px;
        background: linear-gradient(180deg, #fbfdff 0%, #ffffff 100%);
        box-shadow: 0 8px 22px rgba(15, 23, 42, 0.06);
        padding: 0.9rem 1rem;
    }

    .pdf-tag-panel-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 10px;
        margin-bottom: 10px;
        padding-bottom: 8px;
        border-bottom: 1px solid #e6edf7;
    }

    .pdf-tag-panel-title {
        font-weight: 700;
        margin: 0;
    }

    .pdf-tag-panel-note {
        font-size: 0.78rem;
        color: #6c7a89;
    }

    .pdf-tag-panel.floating {
        position: fixed;
        top: 74px;
        left: 12px;
        z-index: 1700;
        width: min(380px, calc(100vw - 24px));
        max-height: 78vh;
        overflow: auto;
        box-shadow: 0 16px 36px rgba(15, 23, 42, 0.2);
    }

    .pdf-tag-panel.floating .pdf-tag-panel-head {
        cursor: move;
    }

    .pdf-tag-panel.pdf-tag-panel-collapsed .pdf-tag-panel-body {
        display: none;
    }

    #pdfTagLibrary.pdf-tag-library-select-hidden {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
    }

    .searchable-combo {
        position: relative;
        width: 100%;
    }

    .searchable-combo-trigger {
        display: flex;
        align-items: center;
        gap: 0.35rem;
        width: 100%;
        text-align: left;
        background: #fff;
        border-color: #d8e1ed;
    }

    .searchable-combo-trigger:focus {
        border-color: #86b7fe;
        box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.15);
    }

    .searchable-combo-icon {
        flex: 0 0 auto;
        opacity: 0.55;
        font-size: 0.8rem;
    }

    .searchable-combo-label {
        flex: 1 1 auto;
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        font-size: 0.8rem;
    }

    .searchable-combo-caret {
        flex: 0 0 auto;
        opacity: 0.45;
        font-size: 0.65rem;
    }

    .searchable-combo-menu {
        position: relative !important;
        margin-top: 0.2rem;
        margin-bottom: 10px;
        width: 100%;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        background: #fff;
        box-shadow: 0 12px 28px rgba(15, 23, 42, 0.14);
        padding: 0.35rem;
    }

    .searchable-combo-search {
        margin-bottom: 0.35rem;
        border-color: #e2e8f0;
    }

    .searchable-combo-list {
        list-style: none;
        margin: 0;
        padding: 0;
        max-height: 280px;
        overflow-y: auto;
    }

    /* Список знайдених тегів у полі "Тег з бібліотеки" */
    #nudgeTagLibraryCombo .searchable-combo-list {
        max-height: 30vh !important;
        width: 100%;
        overflow-y: auto !important;
    }

    .searchable-combo-option {
        display: flex;
        flex-direction: column;
        gap: 0.1rem;
        padding: 0.4rem 0.45rem;
        border-radius: 8px;
        cursor: pointer;
    }

    .searchable-combo-option:hover,
    .searchable-combo-option.is-active {
        background: #f1f5f9;
    }

    .searchable-combo-option.is-selected {
        background: #eff6ff;
        box-shadow: inset 0 0 0 1px rgba(37, 99, 235, 0.25);
    }

    .searchable-combo-option-group {
        font-size: 0.65rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.03em;
        color: #6366f1;
    }

    .searchable-combo-option-title {
        font-size: 0.8rem;
        font-weight: 600;
        color: #0f172a;
        line-height: 1.25;
    }

    .searchable-combo-option-key {
        font-family: ui-monospace, Consolas, monospace;
        font-size: 0.72rem;
        color: #64748b;
    }

    .searchable-combo-empty {
        padding: 0.75rem 0.5rem;
        text-align: center;
        color: #64748b;
        font-size: 0.8rem;
    }

    #nudgePersistToDb.nudge-save-pending {
        animation: nudge-save-pulse 1.4s ease-in-out infinite;
        box-shadow: 0 0 0 0.2rem rgba(255, 193, 7, 0.45);
    }

    @@keyframes nudge-save-pulse {
        0%, 100% { filter: brightness(1); }
        50% { filter: brightness(1.08); }
    }

    .pdf-designer-scroll,
    .pdf-h-scrollbar {
        scrollbar-width: thin;
        scrollbar-color: var(--pdf-scroll-thumb) var(--pdf-scroll-track);
    }

    .pdf-designer-scroll::-webkit-scrollbar,
    .pdf-h-scrollbar::-webkit-scrollbar {
        width: 6px;
        height: 6px;
    }

    .pdf-designer-scroll::-webkit-scrollbar-track,
    .pdf-h-scrollbar::-webkit-scrollbar-track {
        background: transparent;
    }

    .pdf-designer-scroll::-webkit-scrollbar-thumb,
    .pdf-h-scrollbar::-webkit-scrollbar-thumb {
        background-color: var(--pdf-scroll-thumb);
        border-radius: 999px;
        border: 2px solid transparent;
        background-clip: padding-box;
    }

    .pdf-designer-scroll::-webkit-scrollbar-thumb:hover,
    .pdf-h-scrollbar::-webkit-scrollbar-thumb:hover {
        background-color: var(--pdf-scroll-thumb-hover);
    }

    .pdf-designer-scroll::-webkit-scrollbar-button,
    .pdf-h-scrollbar::-webkit-scrollbar-button {
        display: none;
        width: 0;
        height: 0;
    }

    .pdf-h-scrollbar {
        overflow-x: auto;
        overflow-y: hidden;
        height: 10px;
        margin-bottom: 6px;
    }

    .pdf-h-scrollbar > div {
        height: 1px;
    }

    #pdfOverlayDesignerRoot {
        overflow: auto;
    }

    #pdfPagesHost canvas {
        display: block;
    }

    .field-overlay-box {
        transition: transform 0.12s ease, box-shadow 0.12s ease, outline-color 0.12s ease;
        transform-origin: center;
    }

    .field-overlay-box.field-group-member {
        z-index: 34;
    }

    .field-overlay-box.field-segment-active {
        z-index: 48;
    }

    /* Калібрування — той самий overlay-підхід, що PdfWorkspace Fill */
    body.template-map-calibration-mode .field-overlay-box {
        border: none !important;
        background: transparent !important;
        box-shadow: none !important;
        opacity: 1 !important;
        pointer-events: auto;
        overflow: visible;
    }

    body.template-map-calibration-mode .field-overlay-box.field-segment-active {
        border: none !important;
        box-shadow: none !important;
        background: transparent !important;
        z-index: 60;
        overflow: visible;
    }

    body.template-map-calibration-mode .field-overlay-label {
        display: none !important;
    }

    body.template-map-calibration-mode .calibration-inline-input,
    body.template-map-calibration-mode .field-overlay-box .pdf-field,
    body.template-map-calibration-mode .field-overlay-box .pdf-field-input {
        position: absolute;
        left: 0;
        top: 0;
        display: block;
        box-sizing: border-box;
        width: 100%;
        height: 100%;
        margin: 0;
        padding: 0;
        border: none;
        outline: none;
        resize: none;
        overflow: visible;
        background: transparent;
        color: #111;
        font-family: Arial, Helvetica, sans-serif;
        font-size: 12px;
        line-height: 1.2;
        letter-spacing: normal;
        text-align: left;
        vertical-align: top;
        white-space: nowrap;
        word-break: normal;
        z-index: 50;
        pointer-events: auto;
        cursor: text;
        -webkit-user-select: text;
        user-select: text;
    }

    body.template-map-calibration-mode .calibration-inline-input--multiline,
    body.template-map-calibration-mode .pdf-field--multiline {
        white-space: pre-wrap;
        word-break: break-word;
    }

    body.template-map-calibration-mode .calibration-inline-input:focus,
    body.template-map-calibration-mode .field-overlay-box .pdf-field:focus,
    body.template-map-calibration-mode .field-overlay-box .pdf-field-input:focus {
        outline: 2px solid #007bff;
        outline-offset: 0;
        border: none;
        background: transparent;
    }

    body.template-map-calibration-mode .calibration-inline-input.cal-text-bold {
        font-weight: 700 !important;
    }

    body.template-map-calibration-mode .calibration-inline-input.cal-text-italic {
        font-style: italic !important;
    }

    body.template-map-calibration-mode .calibration-inline-input.cal-text-underline {
        text-decoration: underline !important;
        text-decoration-thickness: from-font;
    }

    .js-toggle-calibration.active {
        color: #fff;
        background-color: #198754;
        border-color: #198754;
    }

    body.template-map-calibration-mode .field-overlay-box [data-handle] {
        display: none !important;
    }

    body.template-map-calibration-mode .field-overlay-layer {
        overflow: visible;
    }

    #calibrationPanel.cal-panel {
        --cal-gap: 0.28rem;
        padding: 0.35rem 0.4rem 0.4rem;
        border: 1px solid #dbe4f0;
        border-radius: 10px;
        background: linear-gradient(165deg, #f8fbff 0%, #fff 55%);
        font-size: 0.74rem;
    }

    #calibrationPanel .cal-panel__head {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 0.25rem;
        margin-bottom: 0.15rem;
    }

    #calibrationPanel .cal-panel__head-main {
        flex: 1;
        min-width: 0;
    }

    #calibrationPanel .cal-panel__title {
        font-weight: 700;
        font-size: 0.72rem;
        color: #1e293b;
        line-height: 1.2;
    }

    #calibrationPanel .cal-panel__editing {
        margin: 0.1rem 0 0;
        font-size: 0.7rem;
        font-weight: 600;
        color: #0f766e;
        line-height: 1.25;
        word-break: break-word;
    }

    #calibrationPanel .cal-panel__editing:empty {
        display: none;
    }

    #calibrationPanel .cal-panel__exit {
        flex: 0 0 auto;
        padding: 0.15rem 0.45rem;
        font-size: 0.68rem;
        font-weight: 600;
        line-height: 1.2;
        white-space: nowrap;
    }

    #calibrationPanel .cal-panel__exit-icon {
        width: 1.65rem;
        height: 1.65rem;
        padding: 0;
        line-height: 1;
        font-size: 1rem;
        font-weight: 700;
    }

    #calibrationPanel .cal-panel__hint {
        margin: 0 0 0.28rem;
        font-size: 0.66rem;
        color: #64748b;
        line-height: 1.2;
    }

    #calibrationPanel .cal-panel__hint.is-hidden {
        display: none;
    }

    #calibrationPanel .cal-panel__tabs {
        display: flex;
        gap: 2px;
        margin-bottom: 0.35rem;
        border-bottom: 1px solid #e2e8f0;
    }

    #calibrationPanel .cal-panel__tab {
        flex: 1;
        border: none;
        border-bottom: 2px solid transparent;
        margin-bottom: -1px;
        padding: 0.2rem 0.15rem;
        background: transparent;
        color: #64748b;
        font-size: 0.7rem;
        font-weight: 600;
        cursor: pointer;
    }

    #calibrationPanel .cal-panel__tab.active {
        color: #0d6efd;
        border-bottom-color: #0d6efd;
    }

    #calibrationPanel .cal-panel__tab:disabled {
        opacity: 0.45;
        cursor: not-allowed;
    }

    #calibrationPanel .cal-pane {
        display: none;
    }

    #calibrationPanel .cal-pane.active {
        display: block;
    }

    #calibrationPanel .cal-row {
        display: flex;
        align-items: center;
        gap: var(--cal-gap);
        margin-bottom: var(--cal-gap);
    }

    #calibrationPanel .cal-row label {
        flex: 0 0 4.5rem;
        margin: 0;
        font-size: 0.68rem;
        color: #475569;
    }

    #calibrationPanel .cal-row__control {
        flex: 1;
        min-width: 0;
        display: flex;
        align-items: center;
        gap: 0.2rem;
    }

    #calibrationPanel .form-control-sm,
    #calibrationPanel .form-select-sm {
        padding: 0.12rem 0.3rem;
        font-size: 0.72rem;
        min-height: 1.55rem;
    }

    #calibrationPanel .cal-stepper {
        display: flex;
        align-items: stretch;
        gap: 0;
        flex: 1;
    }

    #calibrationPanel .cal-stepper .form-control {
        border-radius: 0;
        text-align: center;
        flex: 1;
        min-width: 0;
    }

    #calibrationPanel .cal-stepper .btn {
        padding: 0 0.35rem;
        font-size: 0.8rem;
        line-height: 1.2;
        min-width: 1.6rem;
    }

    #calibrationPanel [data-cal-control]:not(:disabled) {
        pointer-events: auto;
    }

    #calibrationPanel [data-cal-control].cal-control--locked,
    #calibrationPanel [data-cal-control]:disabled {
        opacity: 0.45;
        pointer-events: none;
        cursor: not-allowed;
    }

    #calibrationPanel .cal-font-toolbar {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
        flex: 1;
        min-width: 0;
    }

    #calibrationPanel .cal-font-stepper {
        display: grid;
        grid-template-columns: 2.1rem 1fr 2.1rem;
        gap: 0;
        border: 1px solid #cbd5e1;
        border-radius: 8px;
        overflow: hidden;
        background: #fff;
    }

    #calibrationPanel .cal-font-stepper__btn {
        border: none;
        border-radius: 0;
        background: #f8fafc;
        color: #0f172a;
        font-size: 1.05rem;
        font-weight: 700;
        line-height: 1;
        min-height: 2.1rem;
        padding: 0;
    }

    #calibrationPanel .cal-font-stepper__btn:not(:disabled):hover {
        background: #e2e8f0;
    }

    #calibrationPanel .cal-font-stepper__btn:not(:disabled):active {
        background: #cbd5e1;
    }

    #calibrationPanel .cal-font-stepper__input {
        border: none;
        border-left: 1px solid #e2e8f0;
        border-right: 1px solid #e2e8f0;
        border-radius: 0;
        text-align: center;
        font-size: 0.95rem;
        font-weight: 700;
        color: #0f172a;
        min-height: 2.1rem;
        padding: 0 0.25rem;
        box-shadow: none;
    }

    #calibrationPanel .cal-font-stepper__input:focus {
        box-shadow: inset 0 0 0 2px rgba(13, 110, 253, 0.25);
    }

    #calibrationPanel .cal-font-presets {
        display: grid;
        grid-template-columns: repeat(6, minmax(0, 1fr));
        gap: 3px;
    }

    #calibrationPanel .cal-font-preset {
        border: 1px solid #cbd5e1;
        border-radius: 6px;
        background: #fff;
        color: #334155;
        font-size: 0.72rem;
        font-weight: 700;
        line-height: 1.1;
        min-height: 1.75rem;
        padding: 0.15rem 0;
    }

    #calibrationPanel .cal-font-preset:not(:disabled):hover {
        border-color: #64748b;
        background: #f8fafc;
    }

    #calibrationPanel .cal-font-preset.active {
        background: #0d6efd;
        border-color: #0d6efd;
        color: #fff;
        box-shadow: 0 1px 2px rgba(13, 110, 253, 0.35);
    }

    #calibrationPanel .cal-style-segment {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 0;
        flex: 1;
        border: 1px solid #cbd5e1;
        border-radius: 8px;
        overflow: hidden;
        background: #fff;
    }

    #calibrationPanel .cal-style-segment__btn {
        border: none;
        border-radius: 0;
        background: #fff;
        color: #334155;
        min-height: 2.15rem;
        padding: 0.2rem 0;
        position: relative;
    }

    #calibrationPanel .cal-style-segment__btn + .cal-style-segment__btn {
        border-left: 1px solid #e2e8f0;
    }

    #calibrationPanel .cal-style-segment__btn:not(:disabled):hover {
        background: #f1f5f9;
    }

    #calibrationPanel .cal-style-segment__glyph {
        display: inline-block;
        font-size: 1rem;
        line-height: 1;
        color: inherit;
    }

    #calibrationPanel .cal-style-segment__glyph--bold {
        font-weight: 800;
    }

    #calibrationPanel .cal-style-segment__glyph--italic {
        font-style: italic;
        font-weight: 600;
    }

    #calibrationPanel .cal-style-segment__glyph--underline {
        text-decoration: underline;
        text-underline-offset: 2px;
        font-weight: 600;
    }

    #calibrationPanel .cal-style-segment__btn.active {
        background: #0d6efd !important;
        color: #fff !important;
        box-shadow: inset 0 1px 2px rgba(0, 0, 0, 0.15);
    }

    #calibrationPanel .cal-style-segment__btn.active .cal-style-segment__glyph {
        color: #fff;
    }

    #calibrationPanel .cal-stepper .btn:first-child {
        border-top-right-radius: 0;
        border-bottom-right-radius: 0;
    }

    #calibrationPanel .cal-stepper .btn:last-child {
        border-top-left-radius: 0;
        border-bottom-left-radius: 0;
    }

    #calibrationPanel .cal-toggle-group {
        display: flex;
        flex: 1;
        gap: 2px;
    }

    #calibrationPanel .cal-toggle-group .btn {
        flex: 1;
        padding: 0.1rem 0.2rem;
        font-size: 0.72rem;
        line-height: 1.15;
        min-width: 0;
    }

    #calibrationPanel .cal-shift-row {
        margin-bottom: 0.25rem;
    }

    #calibrationPanel .cal-shift-row__label {
        font-size: 0.65rem;
        color: #64748b;
        margin-bottom: 0.15rem;
    }

    #calibrationPanel .cal-shift-btns {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 3px;
    }

    #calibrationPanel .cal-shift-btns .btn {
        padding: 0.28rem 0.15rem;
        font-size: 0.78rem;
        font-weight: 600;
        line-height: 1.1;
        min-height: 1.85rem;
        min-width: 0;
    }

    #calibrationPanel #calTextColor {
        width: 2.2rem;
        height: 1.55rem;
        padding: 0.1rem;
        flex: 0 0 auto;
    }

    #calibrationPanel .cal-panel__footer {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.25rem;
        margin-top: 0.35rem;
        padding-top: 0.35rem;
        border-top: 1px solid #e8edf4;
    }

    #calibrationPanel #calSaveStatus {
        flex: 1 1 100%;
        font-size: 0.65rem;
        min-height: 0.9rem;
    }

    #calibrationPanel .cal-panel__footer .btn {
        flex: 1;
        font-size: 0.72rem;
        padding: 0.15rem 0.35rem;
    }

    .nudge-pad #calibrationPanel.cal-panel {
        margin: 0;
        border: none;
        border-radius: 0;
        background: transparent;
        box-shadow: none;
    }

    body.template-map-calibration-mode #nudgePadDefaultTools {
        display: none !important;
    }

    body.template-map-calibration-mode .nudge-pad #calibrationPanel.cal-panel {
        display: block !important;
    }

    body.template-map-calibration-mode #overlayNudgePad .nudge-pad-header .small.fw-semibold,
    body.template-map-calibration-mode #nudgePadTitle {
        color: #198754;
    }

    .field-overlay-label {
        line-height: 1.1;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

