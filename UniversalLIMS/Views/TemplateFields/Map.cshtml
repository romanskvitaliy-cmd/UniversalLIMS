@if (Model.DocumentFormat == TemplateDocumentFormat.Pdf)
{
    <div class="pdf-overlay-card">
        <div class="pdf-designer-grid">
            <div class="pdf-designer-canvas">
                <div id="pdfTopScroller" class="pdf-h-scrollbar pdf-designer-scroll">
                    <div id="pdfTopScrollerTrack"></div>
                </div>
