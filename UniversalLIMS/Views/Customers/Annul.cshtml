@model CustomerAnnulViewModel
@{
    ViewData["Title"] = "Анулювання замовника";
}

<h1 class="h3">Анулювання замовника</h1>
<p class="text-muted">@Model.FullName</p>

<form asp-action="Annul" asp-route-id="@Model.Id" method="post" class="mt-3">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="FullName" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3">
        <label asp-for="Reason" class="form-label"></label>
        <textarea asp-for="Reason" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Reason" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-danger">Підтвердити анулювання</button>
    <a class="btn btn-link" asp-action="Details" asp-route-id="@Model.Id">Скасувати</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
