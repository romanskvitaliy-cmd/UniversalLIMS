@model WorkspaceViewModel
@using UniversalLIMS.Application.Security
@{
    Layout = "_LayoutWorkspace";
    ViewData["Title"] = $"Кабінет — {Model.RoleDisplayName}";
    ViewData["BodyClass"] = "lims-workspace--dashboard";
    var isRegistrar = Model.RoleCode == LimsRoles.Registrar;
    var isAdministrator = Model.RoleCode == LimsRoles.SystemAdministrator;
}

<div class="lims-workspace-dashboard">

@if (User.IsInRole(LimsRoles.SystemAdministrator) && Model.RoleCode != LimsRoles.SystemAdministrator)
{
    <div class="lims-workspace-notice" role="status">
        <i class="bi bi-shield-check lims-workspace-notice__icon" aria-hidden="true"></i>
        <p class="lims-workspace-notice__text">
            Активна роль <strong>@Model.RoleDisplayName</strong> — у вас також є права адміністратора.
            <a asp-controller="Home" asp-action="ClearRole">Перейти як Адміністратор</a>
        </p>
    </div>
}

<div class="lims-workspace-hero" style="--workspace-accent: @Model.AccentColor">
    <div class="lims-workspace-hero__glow" aria-hidden="true"></div>
    <div class="lims-workspace-hero__main">
        <div class="lims-workspace-hero__avatar" aria-hidden="true">
            <i class="bi @Model.IconClass"></i>
        </div>
        <div class="lims-workspace-hero__text">
            <h1 class="lims-workspace-hero__title">
                <span class="lims-workspace-hero__greeting">Вітаємо,</span>
                <span class="lims-workspace-hero__name">@Model.UserDisplayName</span>
            </h1>
            <p class="lims-workspace-hero__meta">
                <span class="lims-workspace-hero__role-pill">
                    <span class="lims-workspace-hero__role-dot" aria-hidden="true"></span>
                    @Model.RoleDisplayName
                </span>
                <span class="lims-workspace-hero__hint">Ви на головній · оберіть дію нижче або пункт меню зліва</span>
            </p>
        </div>
    </div>
    <div class="lims-workspace-hero__calendar-toggle-wrap">
        <button type="button"
                class="lims-workspace-calendar-toggle"
                data-calendar-toggle
                aria-pressed="false"
                title="Увімкнути календар-фон">
            <i class="bi bi-calendar3-week" aria-hidden="true"></i>
            <span>Календар-фон</span>
        </button>
    </div>
</div>

<section class="lims-workspace-calendar-overlay" data-calendar-overlay hidden aria-hidden="true">
    <div class="lims-workspace-calendar-overlay__head">
        <span class="lims-workspace-calendar-overlay__month" data-calendar-month>—</span>
        <span class="lims-workspace-calendar-overlay__year" data-calendar-year>—</span>
    </div>
    <div class="lims-workspace-calendar-overlay__weekdays" aria-hidden="true">
        <span>Пн</span><span>Вт</span><span>Ср</span><span>Чт</span><span>Пт</span><span>Сб</span><span>Нд</span>
    </div>
    <div class="lims-workspace-calendar-overlay__grid" data-calendar-grid></div>
</section>

@if (isRegistrar)
{
    <a class="lims-workspace-primary-action" href="/Orders/Create" style="--workspace-accent: @Model.AccentColor">
        <span class="lims-workspace-primary-action__icon" aria-hidden="true">
            <i class="bi bi-clipboard2-plus"></i>
        </span>
        <span class="lims-workspace-primary-action__body">
            <span class="lims-workspace-primary-action__eyebrow">Головна дія реєстратора</span>
            <span class="lims-workspace-primary-action__title">Прийняти справу</span>
            <span class="lims-workspace-primary-action__desc">
                Замовник, проби та бланки PDF. Номер справи REF — автоматично.
            </span>
        </span>
        <span class="lims-workspace-primary-action__cta">
            Почати
            <i class="bi bi-arrow-right-short"></i>
        </span>
    </a>
}

@if (isAdministrator)
{
    <a class="lims-workspace-primary-action" href="/Laboratories" style="--workspace-accent: @Model.AccentColor">
        <span class="lims-workspace-primary-action__icon" aria-hidden="true">
            <i class="bi bi-building"></i>
        </span>
        <span class="lims-workspace-primary-action__body">
            <span class="lims-workspace-primary-action__eyebrow">Головна дія адміністратора</span>
            <span class="lims-workspace-primary-action__title">Переглянути лабораторії</span>
            <span class="lims-workspace-primary-action__desc">
                Огляд усіх філій, показники workflow і вхід у журнал проб будь-якої лабораторії.
            </span>
        </span>
        <span class="lims-workspace-primary-action__cta">
            Відкрити
            <i class="bi bi-arrow-right-short"></i>
        </span>
    </a>
}

@if (Model.Metrics.Count > 0)
{
    <div class="lims-workspace-metrics" aria-label="Показники кабінету">
        @foreach (var metric in Model.Metrics)
        {
            <div class="lims-workspace-metric" style="--workspace-accent: @Model.AccentColor">
                <div class="lims-workspace-metric__icon" aria-hidden="true">
                    <i class="bi @metric.IconClass"></i>
                </div>
                <div>
                    <div class="lims-workspace-metric__label">@metric.Label</div>
                    <div class="lims-workspace-metric__value">@metric.Value</div>
                    <div class="lims-workspace-metric__desc">@metric.Description</div>
                </div>
            </div>
        }
    </div>
}

<h2 class="lims-section-title">Швидкий доступ</h2>

<div class="lims-workspace-quicklinks">
    @foreach (var link in Model.QuickLinks)
    {
        if (link.IsAvailable && !string.IsNullOrEmpty(link.Url))
        {
            <a class="lims-workspace-quicklink" href="@link.Url" style="--workspace-accent: @Model.AccentColor">
                <div class="lims-workspace-quicklink__icon" aria-hidden="true">
                    <i class="bi @link.IconClass"></i>
                </div>
                <p class="lims-workspace-quicklink__title">@link.Title</p>
                <p class="lims-workspace-quicklink__desc">@link.Description</p>
            </a>
        }
        else
        {
            <div class="lims-workspace-quicklink lims-workspace-quicklink--disabled"
                 style="--workspace-accent: @Model.AccentColor">
                <div class="lims-workspace-quicklink__icon" aria-hidden="true">
                    <i class="bi @link.IconClass"></i>
                </div>
                <p class="lims-workspace-quicklink__title">@link.Title</p>
                <p class="lims-workspace-quicklink__desc">@link.Description</p>
                <span class="lims-workspace-quicklink__soon">Незабаром</span>
            </div>
        }
    }
</div>

</div>
