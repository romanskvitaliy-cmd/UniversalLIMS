@model WorkspaceViewModel
@using UniversalLIMS.Application.Security
@{
    Layout = "_LayoutWorkspace";
    ViewData["Title"] = $"Кабінет — {Model.RoleDisplayName}";
    var isRegistrar = Model.RoleCode == LimsRoles.Registrar;
}

<div class="lims-workspace-welcome" style="--workspace-accent: @Model.AccentColor">
    <div class="lims-workspace-welcome__icon" aria-hidden="true">
        <i class="bi @Model.IconClass"></i>
    </div>
    <h1>Вітаємо, @Model.UserDisplayName</h1>
    <p>
        Ви працюєте як <strong>@Model.RoleDisplayName</strong>.
        Оберіть розділ нижче або скористайтеся меню зверху.
    </p>
</div>

@if (isRegistrar)
{
    <a class="lims-workspace-primary-action" href="/Orders/Create" style="--workspace-accent: @Model.AccentColor">
        <span class="lims-workspace-primary-action__icon" aria-hidden="true">
            <i class="bi bi-clipboard2-plus"></i>
        </span>
        <span class="lims-workspace-primary-action__body">
            <span class="lims-workspace-primary-action__eyebrow">Головна дія реєстратора</span>
            <span class="lims-workspace-primary-action__title">Прийняти нову пробу</span>
            <span class="lims-workspace-primary-action__desc">
                Зареєструвати замовника, пробу, дослідження, бланки та направлення.
            </span>
        </span>
        <span class="lims-workspace-primary-action__cta">
            Почати
            <i class="bi bi-arrow-right-short"></i>
        </span>
    </a>
}

<h2 class="lims-section-title">Швидкий доступ</h2>

<div class="lims-workspace-quicklinks">
    @foreach (var link in Model.QuickLinks)
    {
        if (link.IsAvailable && !string.IsNullOrEmpty(link.Url))
        {
            <a class="lims-workspace-quicklink" href="@link.Url" style="--workspace-accent: @Model.AccentColor">
                <div class="lims-workspace-quicklink__icon" aria-hidden="true">
                    <i class="bi @link.IconClass"></i>
                </div>
                <p class="lims-workspace-quicklink__title">@link.Title</p>
                <p class="lims-workspace-quicklink__desc">@link.Description</p>
            </a>
        }
        else
        {
            <div class="lims-workspace-quicklink lims-workspace-quicklink--disabled"
                 style="--workspace-accent: @Model.AccentColor">
                <div class="lims-workspace-quicklink__icon" aria-hidden="true">
                    <i class="bi @link.IconClass"></i>
                </div>
                <p class="lims-workspace-quicklink__title">@link.Title</p>
                <p class="lims-workspace-quicklink__desc">@link.Description</p>
                <span class="lims-workspace-quicklink__soon">Незабаром</span>
            </div>
        }
    }
</div>
