@model LaboratoryOverviewViewModel
@using UniversalLIMS.Application.Organization
@{
    Layout = "_LayoutWorkspace";
    ViewData["Title"] = "Лабораторії";
    var overview = Model.Overview;
    var expertOverview = Model.ExpertOverview;
}

<div class="d-flex justify-content-between align-items-start gap-3 mb-3">
    <div>
        <h1 class="h3 mb-1">Лабораторії</h1>
        <p class="text-muted mb-0">
            Огляд усіх лабораторних філій. Оберіть лабораторію, щоб відкрити її журнал проб,
            або перегляньте зведення по всій мережі.
        </p>
    </div>
    <partial name="_WorkspaceCabinetLink" />
</div>

@if (overview.ActiveBranchId is Guid activeBranchId)
{
    <div class="alert alert-info py-2">
        Поточний контекст журналу:
        <strong>@(overview.ActiveBranchName ?? "Обрана лабораторія")</strong>.
        <a class="alert-link" asp-controller="Laboratory" asp-action="Index">Відкрити журнал</a>
    </div>
}
else
{
    <div class="alert alert-secondary py-2 mb-3">
        Поточний контекст журналу: <strong>Усі лабораторії</strong>.
        <a class="alert-link" asp-controller="Laboratory" asp-action="Index">Відкрити журнал</a>
    </div>
}

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card h-100 border-primary-subtle">
            <div class="card-body">
                <div class="text-muted small mb-1">Усі лабораторії</div>
                <div class="display-6 fw-semibold mb-2">@overview.TotalActiveSampleCount</div>
                <p class="small text-muted mb-3">
                    проб у лабораторному workflow
                    <span class="d-block mt-1">Лише після відправки зі справи реєстратора. Документи «Очікує» тут не рахуються.</span>
                </p>
                <div class="d-flex flex-wrap gap-2 small mb-3">
                    <span class="badge text-bg-light border">В роботі: @overview.TotalInProgressSampleCount</span>
                    <span class="badge text-bg-light border">Результати внесено: @overview.TotalResultsEnteredSampleCount</span>
                    @if (overview.TotalAwaitingSendSampleCount > 0)
                    {
                        <span class="badge text-bg-warning-subtle border text-dark">
                            Очікує відправки: @overview.TotalAwaitingSendSampleCount
                        </span>
                    }
                </div>
                <form asp-action="EnterJournal" method="post" class="m-0">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-primary btn-sm w-100">
                        Відкрити журнал усіх лабораторій
                    </button>
                </form>
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h6 mb-2">Як працює огляд</h2>
                <ul class="small text-muted mb-0 ps-3">
                    <li>Рахуються <strong>проби</strong>, не PDF-документи. Одна проба з кількома шаблонами — один рядок у журналі.</li>
                    <li>У лічильник потрапляють лише проби з документами, відправленими в лабораторію (статус «У лабораторії» і далі).</li>
                    <li>Нові замовлення з реєстратури з’являться тут після «Відправити в лабораторію» на сторінці справи.</li>
                    <li>Кожна картка нижче — лабораторія-виконавець (<code>TargetBranch</code> документа).</li>
                    <li>Адміністратор бачить проби всіх філій; лаборант — лише своєї філії користувача.</li>
                </ul>
            </div>
        </div>
    </div>
</div>

<h2 class="h5 mb-3">Експертиза</h2>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card h-100 border-warning-subtle">
            <div class="card-body">
                <div class="text-muted small mb-1">Черга експерта (усі філії)</div>
                <div class="display-6 fw-semibold mb-2">@expertOverview.TotalQueueSampleCount</div>
                <p class="small text-muted mb-3">
                    проб готові до розгляду
                    <span class="d-block mt-1">Усі відправлені документи мають «Результати внесено»; без затвердження та rework.</span>
                </p>
                <div class="d-flex flex-wrap gap-2 small mb-3">
                    <span class="badge text-bg-light border">В роботі: @expertOverview.TotalInProgressSampleCount</span>
                </div>
                <a class="btn btn-outline-warning btn-sm w-100" asp-controller="Expert" asp-action="Index">
                    Відкрити чергу експерта
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-8">
        @if (!expertOverview.Branches.Any())
        {
            <div class="alert alert-secondary mb-0 h-100 d-flex align-items-center">
                Немає активних експертних філій (тип «Експертиза» або «Lab + Expert»). Додайте у «Філії».
            </div>
        }
        else
        {
            <div class="row g-3">
                @foreach (var branch in expertOverview.Branches)
                {
                    <div class="col-md-6">
                        <div class="card h-100">
                            <div class="card-body d-flex flex-column">
                                <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                                    <div>
                                        <div class="fw-semibold">@branch.Name</div>
                                        <div class="small text-muted">@branch.Code · @branch.City</div>
                                    </div>
                                    <span class="lims-branch-kind @BranchKindCatalog.GetBadgeClass(branch.Kind)">
                                        @BranchKindCatalog.GetDisplayNameUk(branch.Kind)
                                    </span>
                                </div>
                                <div class="row g-2 small mb-3">
                                    <div class="col-6">
                                        <div class="text-muted">У черзі</div>
                                        <div class="fw-semibold fs-5">@branch.QueueSampleCount</div>
                                    </div>
                                    <div class="col-6">
                                        <div class="text-muted">В роботі</div>
                                        <div class="fw-semibold fs-5">@branch.InProgressSampleCount</div>
                                    </div>
                                </div>
                                <div class="d-flex flex-wrap gap-2 mt-auto">
                                    <a class="btn btn-outline-warning btn-sm"
                                       asp-controller="Expert"
                                       asp-action="Index">
                                        Черга
                                    </a>
                                    <a class="btn btn-outline-secondary btn-sm"
                                       asp-controller="Users"
                                       asp-action="Index"
                                       asp-route-branchId="@branch.BranchId">
                                        Користувачі
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<h2 class="h5 mb-3">Філії (@overview.Branches.Count)</h2>

@if (!overview.Branches.Any())
{
    <div class="alert alert-warning mb-0">Активних лабораторних філій не знайдено.</div>
}
else
{
    <div class="row g-3">
        @foreach (var branch in overview.Branches)
        {
            var isActive = overview.ActiveBranchId == branch.BranchId;
            <div class="col-md-6 col-xl-4">
                <div class="card h-100 @(isActive ? "border-primary" : null)">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                            <div>
                                <div class="fw-semibold">@branch.Name</div>
                                <div class="small text-muted">@branch.Code · @branch.City</div>
                            </div>
                            <div class="d-flex flex-column align-items-end gap-1">
                                @if (isActive)
                                {
                                    <span class="badge text-bg-primary">Поточний контекст</span>
                                }
                                <span class="lims-branch-kind @BranchKindCatalog.GetBadgeClass(branch.Kind)">
                                    @BranchKindCatalog.GetDisplayNameUk(branch.Kind)
                                </span>
                            </div>
                        </div>

                        <div class="row g-2 small mb-3">
                            <div class="col-4">
                                <div class="text-muted">У workflow</div>
                                <div class="fw-semibold fs-5">@branch.ActiveSampleCount</div>
                            </div>
                            <div class="col-4">
                                <div class="text-muted">В роботі</div>
                                <div class="fw-semibold fs-5">@branch.InProgressSampleCount</div>
                            </div>
                            <div class="col-4">
                                <div class="text-muted">Готово</div>
                                <div class="fw-semibold fs-5">@branch.ResultsEnteredSampleCount</div>
                            </div>
                            @if (branch.AwaitingSendSampleCount > 0)
                            {
                                <div class="col-12">
                                    <span class="badge text-bg-warning-subtle border text-dark">
                                        Очікує відправки: @branch.AwaitingSendSampleCount
                                    </span>
                                </div>
                            }
                        </div>

                        <form asp-action="EnterJournal" method="post" class="mt-auto mb-2">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="branchId" value="@branch.BranchId" />
                            <button type="submit" class="btn btn-outline-primary btn-sm w-100">
                                Відкрити журнал цієї лабораторії
                            </button>
                        </form>
                        <a class="btn btn-outline-secondary btn-sm w-100"
                           asp-controller="Users"
                           asp-action="Index"
                           asp-route-branchId="@branch.BranchId">
                            Користувачі філії
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}
