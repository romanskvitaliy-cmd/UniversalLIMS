@model AnnulTemplateViewModel

@{
    ViewData["Title"] = "Анулювання шаблону";
}

<h1 class="h3">Анулювання шаблону</h1>
<p>Ви анулюєте шаблон <strong>@Model.NameUk</strong>. Фізичне видалення не виконується.</p>

<form asp-action="Annul" asp-route-id="@Model.Id" method="post">
    <input asp-for="Id" type="hidden" />
    <input asp-for="NameUk" type="hidden" />
    <div class="mb-3">
        <label asp-for="AnnulmentReason" class="form-label"></label>
        <textarea asp-for="AnnulmentReason" class="form-control" rows="4"></textarea>
        <span asp-validation-for="AnnulmentReason" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-danger">Анулювати</button>
    <a class="btn btn-link" asp-action="Details" asp-route-id="@Model.Id">Назад</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
