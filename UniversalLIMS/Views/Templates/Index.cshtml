@model IReadOnlyCollection<TemplateListItemViewModel>
@using UniversalLIMS.Application.Templates

@{
    Layout = "_LayoutWorkspace";
    ViewData["Title"] = "Конструктор шаблонів";
}

<section class="lims-page">
    <header class="lims-page-header">
        <div class="lims-page-header__text">
            <h1 class="lims-page-header__title">Конструктор шаблонів</h1>
            <p class="lims-page-header__subtitle">
                Керування PDF overlay шаблонами, версіями та правами полів (legacy .docx підтримується).
            </p>
        </div>
        <a class="lims-btn lims-btn--primary" asp-action="Create">
            <i class="bi bi-plus-lg" aria-hidden="true"></i>
            Створити шаблон
        </a>
    </header>

    <div class="lims-panel">
        <div class="lims-data-table-wrap">
            <table class="lims-data-table">
                <thead>
                    <tr>
                        <th>Код</th>
                        <th>Назва</th>
                        <th>Призначення</th>
                        <th>Статус</th>
                        <th class="text-center">Версії</th>
                        <th>Чинна версія</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var template in Model)
                    {
                        <tr>
                            <td><code class="lims-code">@template.Code</code></td>
                            <td class="lims-data-table__name">@template.NameUk</td>
                            <td>
                                <span class="lims-badge lims-badge--draft">
                                    @TemplatePurposeCatalog.GetDisplayNameUk(template.Purpose)
                                </span>
                            </td>
                            <td>
                                <span class="lims-badge lims-badge--draft">@template.Status</span>
                            </td>
                            <td class="text-center">@template.VersionCount</td>
                            <td class="lims-data-table__muted">
                                @(template.CurrentPublishedVersionNumber?.ToString() ?? "немає")
                            </td>
                            <td class="text-end">
                                <a class="lims-btn lims-btn--outline lims-btn--sm" asp-action="Details" asp-route-id="@template.Id">
                                    Відкрити
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
