@model TemplateDetailsViewModel

@{
    ViewData["Title"] = Model.NameUk;
}

<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1 class="h3 mb-1">@Model.NameUk</h1>
        <div class="text-muted"><code>@Model.Code</code> · @Model.Status</div>
        @if (!string.IsNullOrWhiteSpace(Model.DescriptionUk))
        {
            <p class="mt-2 mb-0">@Model.DescriptionUk</p>
        }
    </div>
    <div class="btn-group">
        <a class="btn btn-outline-secondary" asp-action="Edit" asp-route-id="@Model.Id">Редагувати</a>
        <a class="btn btn-primary" asp-controller="TemplateVersions" asp-action="Upload" asp-route-templateId="@Model.Id">Нова версія</a>
    </div>
</div>

<h2 class="h5">Версії</h2>
<table class="table table-striped align-middle">
    <thead>
        <tr>
            <th>Версія</th>
            <th>Файл</th>
            <th>Статус</th>
            <th>Поля</th>
            <th>Завантажено UTC</th>
            <th>Опубліковано UTC</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var version in Model.Versions)
        {
            <tr>
                <td>v@(version.VersionNumber)</td>
                <td>@version.OriginalFileName</td>
                <td>@version.Status</td>
                <td>@version.FieldCount</td>
                <td>@version.UploadedAtUtc</td>
                <td>@(version.PublishedAtUtc?.ToString() ?? "—")</td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-primary" asp-controller="TemplateVersions" asp-action="Details" asp-route-id="@version.Id">Відкрити</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<div class="alert alert-light border small">
  <strong>Нова версія</strong> — завантаження оновленого PDF/DOCX і, за потреби, копіювання тегів з попередньої версії з тими самими координатами overlay.
  Legacy `.docx` підтримується для раніше створених шаблонів.
</div>

<div class="mt-3">
    <a class="btn btn-link" asp-action="Index">До списку шаблонів</a>
    <a class="btn btn-link text-danger" asp-action="Annul" asp-route-id="@Model.Id">Анулювати шаблон</a>
</div>
