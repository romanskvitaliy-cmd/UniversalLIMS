@model TemplateEditViewModel
@using UniversalLIMS.Application.Templates

@{
    ViewData["Title"] = "Новий шаблон";
}

<h1 class="h3">Новий шаблон</h1>

<div class="alert alert-secondary">
    Після збереження відкрийте картку шаблону та натисніть <strong>Завантажити версію</strong>.
    Для нових шаблонів використовуйте PDF + overlay. Legacy `.docx` підтримується лише для сумісності.
</div>

<form asp-action="Create" method="post" class="mt-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3">
        <label asp-for="Code" class="form-label"></label>
        <input asp-for="Code" class="form-control" />
        <span asp-validation-for="Code" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="NameUk" class="form-label"></label>
        <input asp-for="NameUk" class="form-control" />
        <span asp-validation-for="NameUk" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Purpose" class="form-label"></label>
        <select asp-for="Purpose" asp-items="Model.PurposeOptions" class="form-select"></select>
        <div class="form-text">Коди <code>REF-*</code> — направлення; <code>f327_</code>, <code>Food_</code> тощо — протоколи.</div>
        <span asp-validation-for="Purpose" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="DescriptionUk" class="form-label"></label>
        <textarea asp-for="DescriptionUk" class="form-control" rows="4"></textarea>
        <span asp-validation-for="DescriptionUk" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Зберегти</button>
    <a class="btn btn-link" asp-action="Index">Назад</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
