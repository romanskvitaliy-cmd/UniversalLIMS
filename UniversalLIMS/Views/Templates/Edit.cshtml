@model TemplateEditViewModel

@{
    ViewData["Title"] = "Редагування шаблону";
}

<h1 class="h3">Редагування шаблону</h1>

<form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="mt-3">
    <input asp-for="Id" type="hidden" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3">
        <label asp-for="Code" class="form-label"></label>
        <input asp-for="Code" class="form-control" />
        <span asp-validation-for="Code" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="NameUk" class="form-label"></label>
        <input asp-for="NameUk" class="form-control" />
        <span asp-validation-for="NameUk" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Purpose" class="form-label"></label>
        <select asp-for="Purpose" asp-items="Model.PurposeOptions" class="form-select"></select>
        <span asp-validation-for="Purpose" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="DescriptionUk" class="form-label"></label>
        <textarea asp-for="DescriptionUk" class="form-control" rows="4"></textarea>
        <span asp-validation-for="DescriptionUk" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Зберегти</button>
    <a class="btn btn-link" asp-action="Details" asp-route-id="@Model.Id">Назад</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
