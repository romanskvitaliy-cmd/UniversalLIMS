@model PdfWorkspaceVersionListViewModel
@using UniversalLIMS.Application.Templates

@{
    Layout = "_LayoutWorkspace";
    ViewData["Title"] = "PDF Workspace — версії";
}

<div class="d-flex justify-content-between align-items-start gap-3 mb-3">
    <div>
        <h1 class="h3 mb-1">PDF Workspace</h1>
        <p class="text-muted mb-0">
            @if (Model.IsRegistrarMode)
            {
                <text>Допоміжний режим для перевірки та ручного заповнення опублікованих PDF-бланків.</text>
            }
            else
            {
                <text>Режим заповнення — оберіть версію PDF-шаблону.</text>
            }
        </p>
    </div>
    <div class="d-flex flex-wrap gap-2 align-items-start">
        <partial name="_WorkspaceCabinetLink" />
        @if (Model.IsRegistrarMode)
        {
            <a class="btn btn-sm btn-primary" asp-controller="Orders" asp-action="Create">
                <i class="bi bi-clipboard2-plus me-1"></i>
                Прийняти нову пробу
            </a>
        }
    </div>
</div>

@if (!Model.Versions.Any())
{
    <div class="alert alert-warning">
        @if (Model.IsRegistrarMode)
        {
            <text>Опубліковані PDF-бланки для реєстратора не знайдено. Опублікуйте шаблон або почніть прийом проби через реєстр.</text>
        }
        else
        {
            <text>PDF-версії шаблонів не знайдено.</text>
        }
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-sm table-hover align-middle lims-workspace-table">
            <thead>
                <tr>
                    <th>Шаблон</th>
                    <th>Версія</th>
                    <th>Статус</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var version in Model.Versions)
                {
                    <tr>
                        <td class="fw-semibold">@version.TemplateNameUk</td>
                        <td>
                            <span class="badge lims-version-badge">v@(version.VersionNumber)</span>
                        </td>
                        <td>
                            <span class="badge lims-status-badge @TemplateVersionStatusDisplay.BadgeClass(version.Status)">
                                @TemplateVersionStatusDisplay.ToUk(version.Status)
                            </span>
                        </td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-primary"
                               asp-action="Fill"
                               asp-route-templateVersionId="@version.TemplateVersionId">
                                Заповнити
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
