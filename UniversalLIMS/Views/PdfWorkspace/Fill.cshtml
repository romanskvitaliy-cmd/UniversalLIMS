@model PdfWorkspaceFillViewModel
@using System.Text.Json

@{
    Layout = "_LayoutWorkspace";
    ViewData["Title"] = $"Заповнення PDF — v{Model.VersionNumber}";
    ViewData["BodyClass"] = "lims-page--pdf-fill";
}

<style>
    .pdf-fill-layout__main #pdfFillWorkspaceRoot {
        overflow: auto;
        max-width: 100%;
        height: 100%;
        min-height: 0;
        border: 1px solid #dee2e6;
        border-radius: 8px;
        background: #f8f9fa;
    }

    #pdfFillZoomContainer {
        transform-origin: top center;
    }

    .pdf-fill-overlay-layer {
        position: absolute;
        top: 0;
        left: 0;
        z-index: 10;
        pointer-events: none;
    }

    /* Кліки лише по полях; порожній шар не перехоплює події */
    .pdf-fill-overlay-layer .pdf-fill-field-box {
        pointer-events: auto;
    }

    .pdf-fill-field-box {
        position: absolute;
        box-sizing: border-box;
        display: block;
        margin: 0;
        padding: 0;
        border: 1px dashed rgba(0, 123, 255, 0.65);
        overflow: hidden;
        pointer-events: auto;
        background: rgba(255, 255, 255, 0.55);
        cursor: text;
        z-index: 20;
    }

    .pdf-fill-field-box:hover {
        border-color: rgba(0, 123, 255, 0.85);
        background: rgba(0, 123, 255, 0.08);
    }

    .pdf-fill-field-box.is-focused {
        border-color: rgba(0, 123, 255, 0.95);
        background: rgba(0, 123, 255, 0.12);
        box-shadow: 0 0 0 2px rgba(0, 123, 255, 0.2);
    }

    /* Один елемент для перегляду й редагування — без стрибків при фокусі */
    .pdf-fill-field-box .pdf-field,
    .pdf-fill-field-box .pdf-field-input {
        display: block;
        box-sizing: border-box;
        width: 100%;
        height: 100%;
        margin: 0;
        padding: 0;
        border: none;
        outline: none;
        resize: none;
        overflow: hidden;
        background: transparent;
        color: #111827;
        font-family: "Times New Roman", Times, serif;
        font-size: 12px;
        line-height: 1.2;
        letter-spacing: normal;
        text-align: left;
        vertical-align: top;
        white-space: nowrap;
        word-break: normal;
        -webkit-user-select: text;
        user-select: text;
        cursor: text;
        pointer-events: auto;
    }

    .pdf-fill-field-box textarea.pdf-field-input {
        white-space: pre-wrap;
        word-break: break-word;
    }

    .pdf-fill-field-box .pdf-field--multiline {
        white-space: pre-wrap;
        word-break: break-word;
    }

    .pdf-fill-field-box .pdf-field:focus,
    .pdf-fill-field-box .pdf-field-input:focus {
        outline: none;
        border: none;
        background: transparent;
        box-shadow: none;
    }

    .pdf-fill-field-box.is-readonly {
        border-style: solid;
        border-color: rgba(108, 117, 125, 0.45);
        background: rgba(248, 249, 250, 0.75);
        cursor: default;
    }

    .pdf-fill-field-box.is-readonly:hover {
        border-color: rgba(108, 117, 125, 0.55);
        background: rgba(248, 249, 250, 0.85);
    }

    .pdf-fill-field-box.is-readonly .pdf-field-input {
        cursor: default;
        color: #495057;
    }

    .pdf-fill-field-box .pdf-field-input.is-empty:not(:focus) {
        min-height: 1em;
    }

    .pdf-fill-page-canvas {
        display: block;
        pointer-events: none;
    }

    .pdf-fill-page {
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
    }
</style>

<div id="pdfFillStatus" class="alert d-none mb-1 py-1 px-2 small" role="status"></div>

<form id="pdfFillAntiforgeryForm" class="d-none">
    @Html.AntiForgeryToken()
</form>

@if (TempData["TemplateWarning"] is string warning)
{
    <div class="alert alert-warning">@warning</div>
}

@if (string.IsNullOrWhiteSpace(Model.PdfPreviewUrl))
{
    <div class="alert alert-warning">Preview URL для PDF не згенеровано.</div>
}
else
{
    <div class="pdf-fill-shell">
    <header class="pdf-fill-toolbar" aria-label="Панель заповнення PDF">
        <div class="pdf-fill-toolbar__meta" title="@Model.TemplateNameUk · v@(Model.VersionNumber)">
            <span class="pdf-fill-toolbar__title">Заповнення</span>
            <span class="pdf-fill-toolbar__detail text-truncate">@Model.TemplateNameUk · v@(Model.VersionNumber)</span>
            @if (!string.IsNullOrWhiteSpace(Model.ActiveRoleCode))
            {
                <span class="pdf-fill-toolbar__role">@(Model.ActiveRoleDisplayName ?? Model.ActiveRoleCode)</span>
            }
        </div>
        @if (Model.Segments.Any())
        {
            <div class="pdf-fill-toolbar__zoom">
                <label class="pdf-fill-toolbar__zoom-label" for="pdfFillZoomSlider">Масштаб</label>
                <input id="pdfFillZoomSlider" class="form-range pdf-fill-toolbar__zoom-range" type="range" min="75" max="300" step="5" value="100" />
                <span id="pdfFillZoomValue" class="pdf-fill-toolbar__zoom-value">100%</span>
                <span class="pdf-fill-toolbar__stats" title="Кількість полів на бланку">
                    @Model.Segments.Count пол.
                    @if (Model.ReadOnlyFieldCount > 0)
                    {
                        <span>· @Model.WritableFieldCount/@Model.Segments.Count</span>
                    }
                </span>
            </div>
        }
        <div class="pdf-fill-toolbar__actions">
            <a class="btn btn-outline-secondary btn-sm pdf-fill-toolbar__btn" asp-action="Index" title="Список версій шаблону">Версії</a>
            @if (!string.IsNullOrWhiteSpace(Model.PdfPreviewUrl))
            {
                <a class="btn btn-outline-secondary btn-sm pdf-fill-toolbar__btn" href="@Model.PdfPreviewUrl" target="_blank" rel="noopener" title="Відкрити оригінал PDF">PDF</a>
            }
            <button id="pdfFillSaveButton" type="button" class="btn btn-primary btn-sm pdf-fill-toolbar__btn"
                    title="Зберегти значення для замовлення"
                    @(Model.Segments.Any(segment => segment.CanWrite) ? "" : "disabled")>Зберегти</button>
            <a id="pdfFillPreviewFinalButton"
               class="btn btn-success btn-sm pdf-fill-toolbar__btn @(Model.OrderId.HasValue ? "" : "d-none")"
               href="@(Model.OrderId.HasValue ? Url.Action("FinalPdf", "PdfWorkspace", new { templateVersionId = Model.TemplateVersionId, orderId = Model.OrderId }) : "#")"
               target="_blank"
               rel="noopener"
               title="Переглянути фінальний PDF">Фінал</a>
            <a id="pdfFillDownloadFinalButton"
               class="btn btn-outline-success btn-sm pdf-fill-toolbar__btn @(Model.OrderId.HasValue ? "" : "d-none")"
               href="@(Model.OrderId.HasValue ? Url.Action("FinalPdf", "PdfWorkspace", new { templateVersionId = Model.TemplateVersionId, orderId = Model.OrderId, download = true }) : "#")"
               title="Зберегти як PDF">↓ PDF</a>
        </div>
    </header>

    @if (Model.IsBlockedByPermissions)
    {
        <div class="alert alert-warning mb-1 py-1 px-2 small">
            У шаблоні розміщено <strong>@Model.LayoutSegmentCount</strong> полів на PDF, але для ролі
            <strong>@(Model.ActiveRoleDisplayName ?? Model.ActiveRoleCode ?? "поточна")</strong>
            не налаштовано доступу (Read або Write) жодного поля.
            <span class="d-block small mt-1">
                Налаштуйте матрицю «Права доступу до полів» для цієї версії
                @if (!string.IsNullOrWhiteSpace(Model.FieldPermissionsUrl))
                {
                    <a href="@Model.FieldPermissionsUrl">у конструкторі шаблону</a>
                }
                — колонка <code>LaboratoryTechnician</code> для лаборанта, <code>Registrar</code> для реєстратора.
            </span>
        </div>
    }
    else if (Model.HasNoLayout)
    {
        <div class="alert alert-info mb-1 py-1 px-2 small">
            У цій версії ще немає розміщених полів (сегментів). Відкрийте
            <a asp-controller="TemplateFields" asp-action="Map" asp-route-templateVersionId="@Model.TemplateVersionId">карту полів (Map)</a>
            і розмістіть поля на PDF.
        </div>
    }

    @if (Model.Segments.Any() && Model.WritableFieldCount == 0)
    {
        <div class="alert alert-warning mb-1 py-1 px-2 small">
            Поля видимі лише для перегляду: для ролі
            <strong>@(Model.ActiveRoleDisplayName ?? Model.ActiveRoleCode ?? "поточна")</strong>
            не налаштовано права <strong>Write</strong>.
            @if (!string.IsNullOrWhiteSpace(Model.FieldPermissionsUrl))
            {
                <span class="d-block small mt-1">
                    Увімкніть <code>Write</code> для колонки <code>Registrar</code> (або вашої ролі) у
                    <a href="@Model.FieldPermissionsUrl">матриці прав полів</a>.
                </span>
            }
        </div>
    }

    <div class="pdf-fill-layout" id="pdfFillLayout">
        <div class="pdf-fill-layout__main">
            <div id="pdfFillWorkspaceRoot" class="p-2" data-pdf-preview-url="@Model.PdfPreviewUrl">
                <div id="pdfFillZoomContainer">
                    <div id="pdfFillPagesHost"></div>
                </div>
                <div id="pdfFillPreviewError" class="alert alert-warning m-2" style="display:none;"></div>
            </div>
        </div>
        @if (Model.Segments.Any())
        {
            <aside id="pdfFillSidePanel" class="pdf-fill-panel" aria-label="Панель заповнення полів">
                <div class="pdf-fill-panel__head">
                    <div class="pdf-fill-panel__head-row">
                        <p id="pdfFillPanelEditing" class="pdf-fill-panel__editing" aria-live="polite"></p>
                        <span id="pdfFillSaveBadge" class="pdf-fill-panel__save-badge pdf-fill-panel__save-badge--saved">Збережено</span>
                    </div>
                </div>
                <p id="pdfFillPanelHint" class="pdf-fill-panel__hint">Клікніть поле на PDF або в «Поля».</p>
                <section id="pdfFillValueZone" class="pdf-fill-panel__value-zone" aria-label="Значення поля для замовлення">
                    <label for="pdfFillPanelValue" class="form-label small mb-0">Значення</label>
                    <textarea id="pdfFillPanelValue" class="form-control pdf-fill-panel__value-input" rows="3"
                              placeholder="Оберіть поле…" disabled spellcheck="false"></textarea>
                    <p id="pdfFillPanelReadonlyNote" class="pdf-fill-panel__meta d-none mb-0">
                        Це поле лише для перегляду (немає права Write).
                    </p>
                    <p id="pdfFillValueZoneNotice" class="pdf-fill-panel__value-notice d-none mb-0" role="status" aria-live="polite"></p>
                    <p id="pdfFillPanelCharCount" class="pdf-fill-panel__meta mb-0"></p>
                </section>
                <div id="pdfFillPanelScroll" class="pdf-fill-panel__scroll">
                <section id="pdfFillLibraryBrowser" class="pdf-fill-library-browser is-collapsed d-none" aria-label="Бібліотека текстів">
                    <div class="pdf-fill-library-browser__toolbar">
                        <button type="button" id="pdfFillLibraryCollapseToggle" class="pdf-fill-library-browser__collapse-btn"
                                aria-expanded="false" aria-controls="pdfFillLibraryBody" disabled
                                title="Розгорнути / згорнути бібліотеку">
                            <span class="pdf-fill-library-browser__chevron" aria-hidden="true">▸</span>
                            <span class="pdf-fill-library-browser__heading">
                                <span class="pdf-fill-library-browser__title">Бібліотека</span>
                                <span id="pdfFillLibraryTag" class="pdf-fill-library-browser__tag d-none" hidden></span>
                            </span>
                        </button>
                        <div class="pdf-fill-library-browser__toolbar-actions">
                            <span id="pdfFillLibraryCount" class="pdf-fill-library-browser__count badge text-bg-secondary d-none">0</span>
                            <button type="button" id="pdfFillLibraryExpand" class="btn btn-outline-secondary btn-sm"
                                    title="Повний список (екран)" disabled aria-haspopup="dialog">⛶</button>
                            <button type="button" id="pdfFillLibraryAddNow" class="btn btn-outline-primary btn-sm" disabled
                                    title="Додати поточний текст">+</button>
                        </div>
                    </div>
                    <div id="pdfFillLibraryBody" class="pdf-fill-library-browser__body" hidden>
                        <div class="pdf-fill-library-browser__search-wrap">
                            <label class="pdf-fill-library-browser__search-label" for="pdfFillLibrarySearch">Пошук</label>
                            <input id="pdfFillLibrarySearch" type="search"
                                   class="form-control pdf-fill-library-browser__search"
                                   placeholder="Частина тексту або назви…" autocomplete="off" disabled spellcheck="false" />
                            <div class="form-check form-check-sm pdf-fill-library-browser__add-on-save mb-0">
                                <input class="form-check-input" type="checkbox" id="pdfFillLibraryAddOnSave" disabled />
                                <label class="form-check-label small" for="pdfFillLibraryAddOnSave">Додати після збереження</label>
                            </div>
                            <div class="form-check form-check-sm pdf-fill-library-browser__scope-to-version mb-0">
                                <input class="form-check-input" type="checkbox" id="pdfFillLibraryScopeToVersion" disabled />
                                <label class="form-check-label small" for="pdfFillLibraryScopeToVersion">Лише для цієї версії шаблону</label>
                            </div>
                        </div>
                        <p id="pdfFillLibraryEmpty" class="pdf-fill-library-browser__empty small text-muted d-none mb-0"></p>
                        <ul id="pdfFillLibraryList" class="pdf-fill-library-browser__list" role="listbox"
                            aria-label="Записи бібліотеки"></ul>
                    </div>
                </section>
                <div class="pdf-fill-panel__tools">
                <div class="pdf-fill-panel__tabs" role="tablist">
                    <button type="button" class="pdf-fill-panel__tab active" data-fill-tab="text" role="tab">Текст</button>
                    <button type="button" class="pdf-fill-panel__tab" data-fill-tab="position" role="tab">Позиція</button>
                    <button type="button" class="pdf-fill-panel__tab" data-fill-tab="fields" role="tab">Поля</button>
                    <button type="button" class="pdf-fill-panel__tab" data-fill-tab="actions" role="tab">Дії</button>
                </div>
                <div class="pdf-fill-panel__body">
                    <div class="pdf-fill-panel__pane active" data-fill-pane="text" role="tabpanel">
                        <div class="pdf-fill-text-style">
                            <div class="pdf-fill-text-style__grid">
                                <div class="pdf-fill-text-style__cell pdf-fill-text-style__cell--wide">
                                    <label class="pdf-fill-text-style__label" for="pdfFillFontFamily">Шрифт</label>
                                    <select id="pdfFillFontFamily" class="pdf-fill-text-style__control form-select form-select-sm" disabled>
                                        <option value="">Arial</option>
                                        <option value="Arial">Arial</option>
                                        <option value="Times New Roman">Times New Roman</option>
                                        <option value="Georgia">Georgia</option>
                                        <option value="Verdana">Verdana</option>
                                    </select>
                                </div>
                                <div class="pdf-fill-text-style__cell">
                                    <label class="pdf-fill-text-style__label" for="pdfFillFontSize">Розмір</label>
                                    <div class="pdf-fill-text-style__stepper input-group input-group-sm">
                                        <button type="button" class="btn" id="pdfFillFontSizeMinus" disabled aria-label="Зменшити">−</button>
                                        <input id="pdfFillFontSize" type="number" class="form-control" min="6" max="72" step="0.5" disabled />
                                        <button type="button" class="btn" id="pdfFillFontSizePlus" disabled aria-label="Збільшити">+</button>
                                    </div>
                                </div>
                                <div class="pdf-fill-text-style__cell">
                                    <label class="pdf-fill-text-style__label" for="pdfFillLineHeight">Міжряддя</label>
                                    <input id="pdfFillLineHeight" type="number" class="pdf-fill-text-style__control form-control form-control-sm"
                                           min="0.8" max="3" step="0.05" disabled />
                                </div>
                                <div class="pdf-fill-text-style__cell pdf-fill-text-style__cell--wide">
                                    <span class="pdf-fill-text-style__label">Стиль</span>
                                    <div class="pdf-fill-text-style__toggles" role="group" aria-label="Стиль тексту">
                                        <button type="button" class="pdf-fill-text-style__toggle" id="pdfFillBold" disabled aria-pressed="false" title="Жирний">B</button>
                                        <button type="button" class="pdf-fill-text-style__toggle" id="pdfFillItalic" disabled aria-pressed="false" title="Курсив"><em>I</em></button>
                                        <button type="button" class="pdf-fill-text-style__toggle" id="pdfFillUnderline" disabled aria-pressed="false" title="Підкреслення"><u>U</u></button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="pdf-fill-panel__pane" data-fill-pane="position" role="tabpanel">
                        <div class="pdf-fill-cal-group pdf-fill-cal-group--inline">
                            <label class="pdf-fill-cal-label" for="pdfFillOffsetX">Offset X</label>
                            <div class="input-group input-group-sm">
                                <button type="button" class="btn btn-outline-secondary pdf-fill-offset-step" data-axis="x" data-delta="-1" disabled>−</button>
                                <input id="pdfFillOffsetX" type="number" step="0.1" class="form-control" disabled />
                                <button type="button" class="btn btn-outline-secondary pdf-fill-offset-step" data-axis="x" data-delta="1" disabled>+</button>
                            </div>
                        </div>
                        <div class="pdf-fill-shift-btns mb-2">
                            <span class="pdf-fill-cal-label d-block mb-1">Зсув X (px)</span>
                            <div class="d-flex flex-wrap gap-1">
                                @foreach (var dx in new[] { -5, -2, -1, -0.5, 0.5, 1, 2, 5 })
                                {
                                    <button type="button" class="btn btn-sm btn-outline-secondary pdf-fill-shift" data-axis="x" data-delta="@dx" disabled>@($"{(dx > 0 ? "+" : "")}{dx}")</button>
                                }
                            </div>
                        </div>
                        <div class="pdf-fill-cal-group pdf-fill-cal-group--inline">
                            <label class="pdf-fill-cal-label" for="pdfFillOffsetY">Offset Y</label>
                            <div class="input-group input-group-sm">
                                <button type="button" class="btn btn-outline-secondary pdf-fill-offset-step" data-axis="y" data-delta="-1" disabled>−</button>
                                <input id="pdfFillOffsetY" type="number" step="0.1" class="form-control" disabled />
                                <button type="button" class="btn btn-outline-secondary pdf-fill-offset-step" data-axis="y" data-delta="1" disabled>+</button>
                            </div>
                        </div>
                        <div class="pdf-fill-shift-btns mb-2">
                            <span class="pdf-fill-cal-label d-block mb-1">Зсув Y (px)</span>
                            <div class="d-flex flex-wrap gap-1">
                                @foreach (var dy in new[] { -5, -2, -1, -0.5, 0.5, 1, 2, 5 })
                                {
                                    <button type="button" class="btn btn-sm btn-outline-secondary pdf-fill-shift" data-axis="y" data-delta="@dy" disabled>@($"{(dy > 0 ? "+" : "")}{dy}")</button>
                                }
                            </div>
                        </div>
                        <div class="pdf-fill-cal-group">
                            <span class="pdf-fill-cal-label">Гориз.</span>
                            <div class="btn-group btn-group-sm" role="group">
                                <button type="button" class="btn btn-outline-secondary pdf-fill-h-align" data-align="Left" disabled title="Ліворуч">⬅</button>
                                <button type="button" class="btn btn-outline-secondary pdf-fill-h-align" data-align="Center" disabled title="Центр">☰</button>
                                <button type="button" class="btn btn-outline-secondary pdf-fill-h-align" data-align="Right" disabled title="Праворуч">➡</button>
                            </div>
                        </div>
                        <div class="pdf-fill-cal-group">
                            <span class="pdf-fill-cal-label">Верт.</span>
                            <div class="btn-group btn-group-sm" role="group">
                                <button type="button" class="btn btn-outline-secondary pdf-fill-v-align" data-align="Top" disabled title="Верх">⤒</button>
                                <button type="button" class="btn btn-outline-secondary pdf-fill-v-align" data-align="Middle" disabled title="Середина">☰</button>
                                <button type="button" class="btn btn-outline-secondary pdf-fill-v-align" data-align="Bottom" disabled title="Низ">⤓</button>
                            </div>
                        </div>
                    </div>
                    <div class="pdf-fill-panel__pane" data-fill-pane="fields" role="tabpanel">
                        <input id="pdfFillFieldSearch" class="form-control form-control-sm mb-2" type="search"
                               placeholder="Пошук поля…" autocomplete="off" />
                        <div id="pdfFillFieldList" class="pdf-fill-panel__field-list" role="list"></div>
                    </div>
                    <div class="pdf-fill-panel__pane" data-fill-pane="actions" role="tabpanel">
                        <p class="small text-muted mb-2">
                            <strong>Значення</strong> — лише для цього замовлення (автозбереження, Ctrl+S).<br />
                            <strong>Макет</strong> — позиція та шрифт для всіх майбутніх заповнень <strong>цієї версії</strong> шаблону.<br />
                            Після «Зберегти» (зверху або тут) незбережений макет з вкладки «Позиція» також зберігається в шаблон автоматично.
                        </p>
                        <span id="pdfFillLayoutBadge" class="pdf-fill-panel__save-badge pdf-fill-panel__save-badge--saved mb-2">Макет збережено</span>
                        <label class="form-check form-check-sm mb-2">
                            <input class="form-check-input" type="checkbox" id="pdfFillAutoSaveToggle" checked />
                            <span class="form-check-label small">Автозбереження значень</span>
                        </label>
                        <button type="button" id="pdfFillPanelSaveButton" class="btn btn-primary btn-sm w-100 mb-2"
                                @(Model.Segments.Any(segment => segment.CanWrite) ? "" : "disabled")>
                            Зберегти значення (замовлення)
                        </button>
                        <button type="button" id="pdfFillSaveLayoutButton" class="btn btn-outline-primary btn-sm w-100">
                            Зберегти макет у шаблон
                        </button>
                        <p class="pdf-fill-panel__meta mb-0 mt-2">v@(Model.VersionNumber) · застосується до нових замовлень з цим бланком.</p>
                    </div>
                </div>
                </div>
                </div>
                <div class="pdf-fill-panel__footer">
                    <button type="button" id="pdfFillPanelNextField" class="btn btn-outline-secondary btn-sm w-100 pdf-fill-panel__next-btn" disabled>
                        Наступне поле →
                    </button>
                </div>
            </aside>
            <div id="pdfFillLibraryModal" class="pdf-fill-library-modal" hidden>
                <div id="pdfFillLibraryModalBackdrop" class="pdf-fill-library-modal__backdrop" tabindex="-1"></div>
                <div class="pdf-fill-library-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="pdfFillLibraryModalTitle">
                    <div class="pdf-fill-library-modal__head">
                        <h2 id="pdfFillLibraryModalTitle" class="pdf-fill-library-modal__title h6 mb-0">Бібліотека текстів</h2>
                        <button type="button" id="pdfFillLibraryModalClose" class="btn-close btn-close-sm" aria-label="Закрити"></button>
                    </div>
                    <p id="pdfFillLibraryModalField" class="pdf-fill-library-modal__field small text-muted mb-2"></p>
                    <div class="pdf-fill-library-browser__search-wrap pdf-fill-library-browser__search-wrap--modal mb-2">
                        <label class="pdf-fill-library-browser__search-label" for="pdfFillLibraryModalSearch">Пошук</label>
                        <input id="pdfFillLibraryModalSearch" type="search"
                               class="form-control pdf-fill-library-browser__search"
                               placeholder="Частина тексту або назви…" autocomplete="off" spellcheck="false" />
                    </div>
                    <ul id="pdfFillLibraryModalList" class="pdf-fill-library-modal__list" role="listbox"></ul>
                    <p class="pdf-fill-library-modal__hint small text-muted mb-0 mt-2">
                        Клік або Enter — підставити текст у «Значення» зверху панелі.
                    </p>
                </div>
            </div>
        }
    </div>
    </div>
}

@section Scripts {
    @if (!string.IsNullOrWhiteSpace(Model.PdfPreviewUrl))
    {
        var pdfFillClientConfigJson = JsonSerializer.Serialize(
                new
                {
                    pdfJsWorkerSrc = Url.Content("~/lib/pdfjs/pdf.worker.min.js"),
                    pdfPreviewUrl = Model.PdfPreviewUrl,
                    templateVersionId = Model.TemplateVersionId,
                    orderId = Model.OrderId,
                    orderDocumentId = Model.OrderDocumentId,
                    sampleId = Model.SampleId,
                    activeRoleCode = Model.ActiveRoleCode,
                    expertQueueUrl = Model.ExpertQueueUrl,
                    expertDetailsUrl = Model.ExpertDetailsUrl,
                    saveUrl = $"/PdfWorkspace/Fill/{Model.TemplateVersionId}/values",
                    layoutSaveUrl = $"/PdfWorkspace/Fill/{Model.TemplateVersionId}/layout",
                    libraryUrl = $"/PdfWorkspace/Fill/{Model.TemplateVersionId}/library",
                    versionNumber = Model.VersionNumber,
                    finalPdfUrlTemplate = Url.Action(
                        "FinalPdf",
                        "PdfWorkspace",
                        new
                        {
                            templateVersionId = Model.TemplateVersionId,
                            orderId = "__ORDER_ID__",
                            orderDocumentId = Model.OrderDocumentId
                        })!
                        .Replace("__ORDER_ID__", "{orderId}", StringComparison.Ordinal),
                    savedValues = Model.SavedValuesByKey,
                    expectedSegmentCount = Model.Segments.Count,
                    firstFieldPage = Model.Segments.Count > 0
                        ? Model.Segments.Min(segment => segment.PageNumber)
                        : 1,
                    segments = Model.Segments.Select(segment => new
                    {
                        segmentId = segment.SegmentId,
                        templateFieldId = segment.TemplateFieldId,
                        tag = segment.Tag,
                        title = segment.Title,
                        dataFieldId = segment.DataFieldId,
                        dataFieldKey = segment.DataFieldKey,
                        sequence = segment.Sequence,
                        page = segment.PageNumber,
                        x = segment.PositionX,
                        y = segment.PositionY,
                        width = segment.Width,
                        height = segment.Height,
                        allowMultiline = segment.AllowMultiline,
                        textOffsetX = segment.TextOffsetX,
                        textOffsetY = segment.TextOffsetY,
                        fontSize = segment.FontSize,
                        fontName = segment.FontName,
                        horizontalAlignment = segment.HorizontalAlignment,
                        verticalAlignment = segment.VerticalAlignment,
                        textAlignment = segment.TextAlignment,
                        lineHeight = segment.LineHeight,
                        svgPathData = segment.SvgPathData,
                        isPrimary = segment.IsPrimary,
                        rowVersionBase64 = segment.SegmentRowVersionBase64,
                        accessLevel = segment.AccessLevel.ToString(),
                        canWrite = segment.CanWrite
                    })
                },
                new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase });

        <script src="~/lib/pdfjs/pdf.min.js" asp-append-version="true"></script>
        <script src="~/js/pdf-overlay-text-layout.js" asp-append-version="true"></script>
        <script type="application/json" id="pdfFillConfig">@Html.Raw(pdfFillClientConfigJson)</script>
        <script src="~/js/pdf-workspace-fill.js" asp-append-version="true"></script>
    }
}
