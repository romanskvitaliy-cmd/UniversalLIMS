@model PdfWorkspaceFillViewModel
@using System.Text.Json

@{
    ViewData["Title"] = $"Заповнення PDF — v{Model.VersionNumber}";
}

<style>
    .pdf-fill-hero {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 12px;
        padding: 12px 14px;
        margin-bottom: 10px;
        border: 1px solid #e5eaf1;
        border-radius: 12px;
        background: linear-gradient(180deg, #fafcff 0%, #ffffff 100%);
    }

    #pdfFillWorkspaceRoot {
        overflow: auto;
        max-width: 100%;
        height: 80vh;
        border: 1px solid #dee2e6;
        border-radius: 8px;
        background: #f8f9fa;
    }

    .pdf-fill-overlay-layer {
        position: absolute;
        top: 0;
        left: 0;
        z-index: 10;
        pointer-events: none;
    }

    .pdf-fill-field-box {
        position: absolute;
        box-sizing: border-box;
        overflow: hidden;
        pointer-events: auto;
        border: 1px dashed transparent;
        background: transparent;
        cursor: text;
    }

    .pdf-fill-field-box--active {
        border-color: rgba(13, 110, 253, 0.45);
        background: rgba(255, 255, 255, 0.15);
    }

    .pdf-fill-field-box .pdf-fill-input {
        display: block;
        width: 100%;
        height: 100%;
        margin: 0;
        padding: 0 2px;
        border: 0;
        outline: none;
        resize: none;
        overflow: hidden;
        background: transparent;
        color: #111;
        font-family: Arial, Helvetica, sans-serif;
        line-height: 1.15;
        pointer-events: auto;
        cursor: text;
    }

    .pdf-fill-field-box .pdf-fill-input:focus {
        background: rgba(255, 255, 255, 0.3);
        outline: 1px solid rgba(13, 110, 253, 0.5);
    }

    .pdf-fill-page-canvas {
        display: block;
        pointer-events: none;
    }
</style>

<div class="pdf-fill-hero">
    <div>
        <h1 class="h4 mb-1">PDF Workspace — заповнення</h1>
        <p class="text-muted mb-0">@Model.TemplateNameUk · v@(Model.VersionNumber)</p>
        <p class="small text-muted mb-0">Клікніть поле на PDF і вводьте текст прямо на бланку (без модалок).</p>
    </div>
    <div class="d-flex flex-wrap gap-2 justify-content-end">
        <a class="btn btn-outline-secondary btn-sm" asp-action="Index">Список версій</a>
        @if (!string.IsNullOrWhiteSpace(Model.PdfPreviewUrl))
        {
            <a class="btn btn-outline-secondary btn-sm" href="@Model.PdfPreviewUrl" target="_blank" rel="noopener">Оригінал PDF</a>
        }
        <button id="pdfFillSaveButton" type="button" class="btn btn-primary btn-sm">Зберегти значення</button>
        <a id="pdfFillPreviewFinalButton"
           class="btn btn-success btn-sm @(Model.OrderId.HasValue ? "" : "d-none")"
           href="@(Model.OrderId.HasValue ? Url.Action("FinalPdf", "PdfWorkspace", new { templateVersionId = Model.TemplateVersionId, orderId = Model.OrderId }) : "#")"
           target="_blank"
           rel="noopener">Переглянути фінальний PDF</a>
        <a id="pdfFillDownloadFinalButton"
           class="btn btn-outline-success btn-sm @(Model.OrderId.HasValue ? "" : "d-none")"
           href="@(Model.OrderId.HasValue ? Url.Action("FinalPdf", "PdfWorkspace", new { templateVersionId = Model.TemplateVersionId, orderId = Model.OrderId, download = true }) : "#")">Зберегти як PDF</a>
    </div>
</div>

<div id="pdfFillStatus" class="alert d-none mb-2" role="status"></div>

<form id="pdfFillAntiforgeryForm" class="d-none">
    @Html.AntiForgeryToken()
</form>

@if (TempData["TemplateWarning"] is string warning)
{
    <div class="alert alert-warning">@warning</div>
}

@if (string.IsNullOrWhiteSpace(Model.PdfPreviewUrl))
{
    <div class="alert alert-warning">Preview URL для PDF не згенеровано.</div>
}
else if (!Model.Segments.Any())
{
    <div class="alert alert-info">У цій версії ще немає розміщених полів (сегментів).</div>
}
else
{
    <div class="row g-2 align-items-center mb-2">
        <div class="col-auto">
            <label class="form-label mb-0 small" for="pdfFillZoomSlider">Масштаб</label>
        </div>
        <div class="col-md-4">
            <input id="pdfFillZoomSlider" class="form-range" type="range" min="75" max="300" step="5" value="100" />
        </div>
        <div class="col-auto small text-muted"><span id="pdfFillZoomValue">100%</span></div>
        <div class="col-auto small text-muted ms-auto">Полів: @Model.Segments.Count</div>
    </div>

    <div id="pdfFillWorkspaceRoot" class="p-2">
        <div id="pdfFillZoomContainer">
            <div id="pdfFillPagesHost"></div>
        </div>
        <div id="pdfFillPreviewError" class="alert alert-warning m-2" style="display:none;"></div>
    </div>
}

@section Scripts {
    @if (!string.IsNullOrWhiteSpace(Model.PdfPreviewUrl))
    {
        <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js" referrerpolicy="no-referrer"></script>
        <script>
            window.__pdfPreviewUrl = "@Model.PdfPreviewUrl";
            window.__templateVersionId = "@Model.TemplateVersionId";
            window.__pdfFillOrderId = @(Model.OrderId.HasValue ? $"\"{Model.OrderId}\"" : "null");
            window.__pdfFillSaveUrl = "@($"/PdfWorkspace/Fill/{Model.TemplateVersionId}/values")";
            window.__pdfFillFinalPdfUrlTemplate = "@Url.Action("FinalPdf", "PdfWorkspace", new { templateVersionId = Model.TemplateVersionId, orderId = "__ORDER_ID__" })".replace("__ORDER_ID__", "{orderId}");
            window.__pdfFillSavedValues = @Html.Raw(JsonSerializer.Serialize(Model.SavedValuesByKey));
            window.__pdfFillSegments = @Html.Raw(JsonSerializer.Serialize(
                Model.Segments.Select(segment => new
                {
                    segmentId = segment.SegmentId,
                    templateFieldId = segment.TemplateFieldId,
                    tag = segment.Tag,
                    title = segment.Title,
                    dataFieldKey = segment.DataFieldKey,
                    sequence = segment.Sequence,
                    page = segment.PageNumber,
                    x = segment.PositionX,
                    y = segment.PositionY,
                    width = segment.Width,
                    height = segment.Height,
                    allowMultiline = segment.AllowMultiline,
                    textOffsetX = segment.TextOffsetX,
                    textOffsetY = segment.TextOffsetY,
                    fontSize = segment.FontSize,
                    fontName = segment.FontName,
                    horizontalAlignment = segment.HorizontalAlignment,
                    verticalAlignment = segment.VerticalAlignment
                })));
        </script>
        <script src="~/js/pdf-workspace-fill.js" asp-append-version="true"></script>
    }
}
