@model UniversalLIMS.ViewModels.Diagnostics.TemplateConstructorStatusViewModel

@{
    Layout = "_LayoutWorkspace";
    ViewData["Title"] = "Перевірка конструктора шаблонів";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="mb-1">Перевірка конструктора шаблонів</h1>
        <p class="text-muted mb-0">Dev-only сторінка для контролю інваріантів Етапу 2.</p>
    </div>
    @if (Model.HasPendingMigrations)
    {
        <span class="badge bg-warning text-dark">Є незастосовані міграції</span>
    }
    else
    {
        <span class="badge bg-success">База актуальна</span>
    }
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted">Шаблони</div>
                <div class="display-6">@Model.TemplateCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted">Версії</div>
                <div class="display-6">@Model.TemplateVersionCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted">Опубліковані версії</div>
                <div class="display-6">@Model.PublishedTemplateVersionCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted">Анулювані версії</div>
                <div class="display-6">@Model.AnnulledTemplateVersionCount</div>
            </div>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">Інваріанти Template Constructor</div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted">Content Control fields</div>
                    <div class="fs-4">@Model.TemplateFieldCount</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted">Неприв'язані required поля</div>
                    <div class="fs-4 @(Model.UnmappedRequiredFieldCount > 0 ? "text-danger" : "text-success")">
                        @Model.UnmappedRequiredFieldCount
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted">Field permissions</div>
                    <div class="fs-4">@Model.TemplateFieldPermissionCount</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted">Шаблони без published-версії</div>
                    <div class="fs-4">@Model.TemplatesWithoutPublishedVersionCount</div>
                </div>
            </div>
        </div>
        <div class="mt-3">
            <span class="text-muted">Останній шаблон:</span>
            <code>@(Model.LatestTemplateCode ?? "немає")</code>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header">Застосовані міграції</div>
            <ul class="list-group list-group-flush">
                @foreach (var migration in Model.AppliedMigrations)
                {
                    <li class="list-group-item"><code>@migration</code></li>
                }
            </ul>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header">Очікують застосування</div>
            @if (Model.PendingMigrations.Count == 0)
            {
                <div class="card-body text-muted">Незастосованих міграцій немає.</div>
            }
            else
            {
                <ul class="list-group list-group-flush">
                    @foreach (var migration in Model.PendingMigrations)
                    {
                        <li class="list-group-item"><code>@migration</code></li>
                    }
                </ul>
            }
        </div>
    </div>
</div>
