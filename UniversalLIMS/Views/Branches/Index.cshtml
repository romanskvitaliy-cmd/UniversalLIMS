@model BranchIndexViewModel
@{
    Layout = "_LayoutWorkspace";
    ViewData["Title"] = "Філії";
}

<section class="lims-page">
    <header class="lims-page-header">
        <div class="lims-page-header__text">
            <h1 class="lims-page-header__title">Довідник філій</h1>
            <p class="lims-page-header__subtitle">
                Керування назвами та адресами лабораторних філій. Код філії не змінюється після створення
                (від нього залежить нумерація проб). Деактивація приховує філію в нових замовленнях.
                Облікові записи для входу — у колонці «Логін філії» або в розділі
                <a asp-controller="Users" asp-action="Index">Користувачі</a>.
            </p>
        </div>
        <a class="lims-btn lims-btn--primary" asp-action="Create">
            <i class="bi bi-plus-lg" aria-hidden="true"></i>
            Нова філія
        </a>
    </header>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert alert-success py-2">@successMessage</div>
    }

    <div class="lims-panel">
        <div class="lims-data-table-wrap">
            <table class="lims-data-table">
                <thead>
                    <tr>
                        <th>Код</th>
                        <th>Назва</th>
                        <th>Місто</th>
                        <th>Статус</th>
                        <th class="text-center">У workflow</th>
                        <th class="text-center">Очікує</th>
                        <th class="text-center">Користувачі</th>
                        <th>Логін філії</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var branch in Model.Branches)
                    {
                        <tr>
                            <td><code class="lims-code">@branch.Code</code></td>
                            <td class="lims-data-table__name">
                                @branch.Name
                                @if (!string.IsNullOrWhiteSpace(branch.Address))
                                {
                                    <div class="small text-muted">@branch.Address</div>
                                }
                            </td>
                            <td>@branch.City</td>
                            <td>
                                @if (branch.IsActive)
                                {
                                    <span class="badge text-bg-success">Активна</span>
                                }
                                else
                                {
                                    <span class="lims-badge lims-badge--draft">Неактивна</span>
                                }
                            </td>
                            <td class="text-center">@branch.WorkflowDocumentCount</td>
                            <td class="text-center">@branch.PendingDocumentCount</td>
                            <td class="text-center">@branch.AssignedUserCount</td>
                            <td>
                                @if (branch.PortalAccount is { } portal)
                                {
                                    <div class="lims-branch-login">
                                        <code class="lims-code lims-branch-login__email" title="@portal.Email">@portal.Email</code>
                                        @if (!portal.IsActive)
                                        {
                                            <span class="lims-badge lims-badge--draft ms-1">Неактивний</span>
                                        }
                                        <a class="lims-btn lims-btn--outline lims-btn--sm lims-branch-login__edit"
                                           asp-controller="Users"
                                           asp-action="Edit"
                                           asp-route-id="@portal.UserId">
                                            Пароль
                                        </a>
                                    </div>
                                }
                                else
                                {
                                    <a class="lims-btn lims-btn--outline lims-btn--sm"
                                       asp-controller="Users"
                                       asp-action="Create"
                                       asp-route-branchId="@branch.Id">
                                        <i class="bi bi-person-plus" aria-hidden="true"></i>
                                        Створити
                                    </a>
                                }
                            </td>
                            <td class="text-end text-nowrap">
                                <a class="lims-btn lims-btn--outline lims-btn--sm" asp-action="Edit" asp-route-id="@branch.Id">
                                    Редагувати
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
