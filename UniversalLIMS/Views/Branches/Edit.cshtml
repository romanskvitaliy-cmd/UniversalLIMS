@model BranchEditViewModel
@{
    Layout = "_LayoutWorkspace";
    ViewData["Title"] = "Редагування філії";
}

<section class="lims-page">
    <header class="lims-page-header">
        <div class="lims-page-header__text">
            <h1 class="lims-page-header__title">Редагування філії</h1>
            <p class="lims-page-header__subtitle">
                Код <code class="lims-code">@Model.Code</code> лише для перегляду.
            </p>
        </div>
    </header>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert alert-success py-2">@successMessage</div>
    }

    <div class="lims-panel">
        <form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="lims-form">
            <input asp-for="Id" type="hidden" />
            <input asp-for="Code" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label class="form-label">Код</label>
                <input class="form-control" value="@Model.Code" readonly disabled />
            </div>
            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="City" class="form-label"></label>
                <input asp-for="City" class="form-control" />
                <span asp-validation-for="City" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Address" class="form-label"></label>
                <input asp-for="Address" class="form-control" />
                <span asp-validation-for="Address" class="text-danger"></span>
            </div>
            <div class="mb-4 form-check">
                <input asp-for="IsActive" class="form-check-input" />
                <label asp-for="IsActive" class="form-check-label"></label>
            </div>

            <div class="d-flex flex-wrap gap-2">
                <button type="submit" class="lims-btn lims-btn--primary">Зберегти</button>
                <a class="lims-btn lims-btn--outline" asp-action="Index">До списку</a>
                <a class="lims-btn lims-btn--outline text-danger ms-auto" asp-action="Annul" asp-route-id="@Model.Id">
                    Анулювати філію
                </a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
