@page
@model RegisterModel
@{
    ViewData["Title"] = "Реєстрація";
}

<div class="lims-account-shell lims-account-shell--auth">
    <header class="lims-account-page-header text-center">
        <h1 class="lims-account-page-title">Реєстрація</h1>
        <p class="lims-account-page-subtitle">Створіть обліковий запис UniversalLIMS</p>
    </header>

    <div class="lims-account-panel lims-account-panel--auth">
        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>
            <div class="lims-account-field">
                <label asp-for="Input.Email" class="lims-account-field__label"></label>
                <input asp-for="Input.Email" class="lims-account-field__input" autocomplete="username" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>
            <div class="lims-account-field">
                <label asp-for="Input.Password" class="lims-account-field__label"></label>
                <input asp-for="Input.Password" class="lims-account-field__input" autocomplete="new-password" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>
            <div class="lims-account-field">
                <label asp-for="Input.ConfirmPassword" class="lims-account-field__label"></label>
                <input asp-for="Input.ConfirmPassword" class="lims-account-field__input" autocomplete="new-password" />
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>
            <button id="registerSubmit" type="submit" class="lims-account-btn">Зареєструватися</button>
        </form>

        <p class="lims-account-auth-links">
            <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl">Уже маєте обліковий запис? Увійти</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
