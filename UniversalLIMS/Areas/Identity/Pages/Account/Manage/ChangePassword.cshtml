@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Пароль";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<h2 class="lims-account-section-title">Зміна пароля</h2>
<partial name="_StatusMessage" model="Model.StatusMessage" />
<form id="change-password-form" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
    <div class="lims-account-field">
        <label asp-for="Input.OldPassword" class="lims-account-field__label"></label>
        <input asp-for="Input.OldPassword" class="lims-account-field__input" autocomplete="current-password" />
        <span asp-validation-for="Input.OldPassword" class="text-danger"></span>
    </div>
    <div class="lims-account-field">
        <label asp-for="Input.NewPassword" class="lims-account-field__label"></label>
        <input asp-for="Input.NewPassword" class="lims-account-field__input" autocomplete="new-password" />
        <span asp-validation-for="Input.NewPassword" class="text-danger"></span>
    </div>
    <div class="lims-account-field">
        <label asp-for="Input.ConfirmPassword" class="lims-account-field__label"></label>
        <input asp-for="Input.ConfirmPassword" class="lims-account-field__input" autocomplete="new-password" />
        <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
    </div>
    <button type="submit" class="lims-account-btn">Оновити пароль</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
